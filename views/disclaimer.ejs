  <style>
    :root {
      /* Strictly Monochrome Professional Palette */
      --bg-body: #ffffff;      /* Pure white background */
      --text-primary: #000000; /* Jet black for headings */
      --text-body: #1a1a1a;    /* Near black for high contrast reading */
      --text-muted: #555555;   /* Gray for metadata */
      --border-light: #e5e5e5; /* Light divider lines */
      --border-strong: #000000; /* Strong structural lines */
      --bg-box: #f9f9f9;       /* Very light gray for section boxes */
    }

    * {
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      margin: 0;
      padding: 0;
      background-color: var(--bg-body);
      color: var(--text-body);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      width: 100%;
    }

    /* --- Layout Container: Full Width --- */
    .container {
      width: 100%;
      max-width: 100%;
      margin: 0;
      padding: 40px 60px;
    }

    /* --- Typography --- */
    h1 {
      font-weight: 800;
      font-size: 3rem;
      color: var(--text-primary);
      margin: 0 0 15px 0;
      letter-spacing: -0.04em;
      line-height: 1.1;
      text-transform: uppercase;
    }

    h2 {
      font-weight: 700;
      font-size: 1.5rem;
      color: var(--text-primary);
      margin-top: 60px;
      margin-bottom: 25px;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--border-strong);
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }

    h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-top: 30px;
      margin-bottom: 10px;
      text-transform: uppercase;
      font-size: 0.95rem;
      letter-spacing: 0.05em;
    }

    p {
      margin-bottom: 1.5em;
      max-width: 100%;
      font-size: 1rem;
    }

    /* --- Header --- */
    header {
      margin-bottom: 60px;
      padding-bottom: 40px;
      border-bottom: 1px solid var(--border-light);
    }

    .back-link {
      display: inline-block;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      color: var(--text-primary);
      margin-bottom: 20px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .back-link:hover {
      text-decoration: underline;
    }

    .meta-info {
      font-size: 0.85rem;
      color: var(--text-muted);
      font-family: 'Inter', monospace;
      margin-top: 10px;
      display: block;
      border-left: 3px solid var(--border-strong);
      padding-left: 15px;
    }

    /* --- Lists --- */
    ul, ol {
      margin: 20px 0;
      padding-left: 25px;
    }

    li {
      margin-bottom: 10px;
      padding-left: 5px;
    }

    /* --- Alert/Warning Boxes (Monochrome) --- */
    .notice-box {
      width: 100%;
      margin: 30px 0;
      padding: 30px;
      background-color: var(--bg-box);
      border: 1px solid var(--border-light);
    }

    /* Important Warnings (Replaces Red) */
    .warning-box {
      border-left: 6px solid #000;
      background-color: #fff;
      border-top: 1px solid #000;
      border-right: 1px solid #000;
      border-bottom: 1px solid #000;
      padding: 25px;
      margin: 30px 0;
    }

    .warning-box strong {
      display: block;
      text-transform: uppercase;
      font-weight: 800;
      letter-spacing: 0.05em;
      margin-bottom: 10px;
      color: #000;
    }

    /* Highlight/Note Boxes (Replaces Orange) */
