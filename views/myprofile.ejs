<%-include("header")%>
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover" />
    <title>My Profile - Vidyari</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;800;900&family=Space+Grotesk:wght@700;900&family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
    /* ==========================================================================
       VIDYARI PROFILE: PROFESSIONAL DASHBOARD ARCHITECTURE
       ========================================================================== */
    .vidyari-profile-master {
        --v-bg: #fdfdfc; 
        --v-black: #09090b;
        --v-white: #ffffff;
        --v-pink: #ff66a3; 
        --v-green: #4ade80; 
        --v-yellow: #ffd60a; 
        --v-blue: #1ac2ff; 
        --v-gray-50: #fafafa;
        --v-gray-100: #f4f4f5;
        --v-gray-200: #e4e4e7;
        --v-gray-800: #27272a;
        
        --v-font-sans: 'Inter', sans-serif;
        --v-font-head: 'Montserrat', sans-serif;
        --v-font-loud: 'Space Grotesk', sans-serif;
        
        --v-radius-sm: 8px;
        --v-radius-md: 16px;
        --v-radius-lg: 24px;
        
        --v-border-thin: 2px solid var(--v-black);
        --v-border-thick: 4px solid var(--v-black);
        
        --v-shadow-sm: 4px 4px 0 var(--v-black);
        --v-shadow-md: 8px 8px 0 var(--v-black);
        --v-shadow-hover: 12px 12px 0 var(--v-black);
        
        --v-transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);

        font-family: var(--v-font-sans);
        background-color: var(--v-yellow); 
        background-image: radial-gradient(#d4b300 2px, transparent 2px);
        background-size: 24px 24px;
        color: var(--v-black);
        min-height: 100vh;
        padding-top: clamp(30px, 5vw, 60px);
        padding-bottom: clamp(60px, 8vw, 100px);
        overflow-x: hidden;
    }

    .vidyari-profile-master a { text-decoration: none; color: inherit; }
    .vidyari-profile-master * { box-sizing: border-box; }

    /* Dashboard Layout Grid */
    .v-container {
        width: 100%;
        max-width: 1200px; /* Wider to accommodate the 2-column layout */
        margin: 0 auto;
        padding: 0 clamp(16px, 4vw, 32px);
    }
    .profile-dashboard-grid {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: clamp(24px, 4vw, 40px);
        align-items: start;
    }

    /* UI Boxes */
    .v-box {
        background: var(--v-bg);
        border: var(--v-border-thick);
        border-radius: var(--v-radius-lg);
        box-shadow: var(--v-shadow-md);
        padding: clamp(24px, 4vw, 32px);
    }

    /* Buttons */
    .v-btn {
        background: var(--v-green);
        border: var(--v-border-thick);
        border-radius: var(--v-radius-sm);
        box-shadow: var(--v-shadow-sm);
        padding: 14px 24px;
        font-family: var(--v-font-loud);
        font-size: 1.1rem;
        font-weight: 900;
        text-transform: uppercase;
        color: var(--v-black);
        cursor: pointer;
        transition: all var(--v-transition);
        display: inline-flex; align-items: center; justify-content: center; gap: 10px;
        width: 100%;
    }
    .v-btn:hover { transform: translate(-2px, -2px); box-shadow: var(--v-shadow-md); background: var(--v-white); }
    .v-btn:active { transform: translate(2px, 2px); box-shadow: 2px 2px 0 var(--v-black); }

    /* Form Controls */
    .v-form-control {
        background: var(--v-white);
        border: var(--v-border-thick);
        border-radius: var(--v-radius-sm);
        padding: 14px 16px;
        font-family: var(--v-font-sans);
        font-size: 1rem;
        font-weight: 600;
        color: var(--v-black);
        box-shadow: 3px 3px 0 var(--v-gray-200);
        transition: all var(--v-transition);
    }
    .v-form-control:focus { outline: none; border-color: var(--v-blue); box-shadow: 4px 4px 0 var(--v-black); transform: translate(-1px, -1px); }
    .input-group-text { background: var(--v-gray-100); border: var(--v-border-thick); border-right: none; border-radius: var(--v-radius-sm) 0 0 var(--v-radius-sm); font-size: 1.2rem; color: var(--v-black); }
    .input-group .v-form-control { border-radius: 0 var(--v-radius-sm) var(--v-radius-sm) 0; }

    /* --- LEFT COLUMN: ID Card --- */
    .id-card-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    .profile-avatar {
        width: 160px; height: 160px;
        border-radius: 50%;
        border: var(--v-border-thick);
        box-shadow: var(--v-shadow-sm);
        object-fit: cover;
        background: var(--v-white);
        margin-bottom: 20px;
    }
    .profile-name {
        font-family: var(--v-font-loud);
        font-size: 2rem;
        text-transform: uppercase;
        line-height: 1.1;
        margin-bottom: 4px;
        text-shadow: 2px 2px 0 var(--v-pink);
    }
    .profile-username {
        font-family: var(--v-font-head);
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--v-gray-600);
        margin-bottom: 16px;
    }
    .profile-bio {
        font-size: 1.05rem;
        font-weight: 600;
        line-height: 1.6;
        color: var(--v-gray-800);
        margin-bottom: 24px;
        background: var(--v-gray-50);
        padding: 16px;
        border-radius: var(--v-radius-sm);
        border: 2px dashed var(--v-gray-300);
        width: 100%;
    }
    
    .social-links { display: flex; gap: 16px; justify-content: center; margin-bottom: 24px; }
    .social-links a {
        display: grid; place-items: center; width: 44px; height: 44px;
        border: var(--v-border-thin); border-radius: 50%;
        background: var(--v-white); font-size: 1.3rem;
        box-shadow: 2px 2px 0 var(--v-black); transition: all 0.15s;
    }
    .social-links a:hover { background: var(--v-blue); color: var(--v-white); transform: translate(-2px,-2px); box-shadow: 4px 4px 0 var(--v-black); }

    .follower-metrics {
        display: flex; justify-content: space-between; width: 100%;
        border-top: var(--v-border-thick); padding-top: 20px; margin-bottom: 24px;
    }
    .metric-item { text-align: center; cursor: pointer; transition: transform 0.15s; flex: 1; }
    .metric-item:hover { transform: translateY(-3px); color: var(--v-blue); }
    .metric-item .count { font-family: var(--v-font-loud); font-size: 1.8rem; line-height: 1; display: block; }
    .metric-item .lbl { font-weight: 800; font-size: 0.85rem; text-transform: uppercase; color: var(--v-gray-600); }
    .metric-divider { width: 4px; background: var(--v-black); border-radius: 2px; }

    /* --- RIGHT COLUMN: Workspace --- */
    .stats-grid {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 24px; margin-bottom: 32px;
    }
    .stat-card {
        background: var(--v-white); border: var(--v-border-thick); border-radius: var(--v-radius-md);
        box-shadow: var(--v-shadow-sm); padding: 24px; text-align: center; transition: transform var(--v-transition);
    }
    .stat-card:hover { transform: translateY(-4px); box-shadow: var(--v-shadow-md); }
    .stat-card:nth-child(1) { background: var(--v-pink); }
    .stat-card:nth-child(2) { background: var(--v-blue); }
    .stat-val { font-family: var(--v-font-loud); font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1; text-shadow: 3px 3px 0 var(--v-white); margin-bottom: 4px; }
    .stat-lbl { font-family: var(--v-font-head); font-weight: 900; font-size: 1rem; text-transform: uppercase; }

    /* Tabbed Interface (Physical Folders) */
    .v-nav-tabs {
        display: flex; gap: 8px; margin-bottom: 0; padding: 0 16px; border-bottom: none;
    }
    .v-nav-tabs .nav-link {
        background: var(--v-gray-200);
        border: var(--v-border-thick);
        border-bottom: none;
        border-radius: var(--v-radius-md) var(--v-radius-md) 0 0;
        padding: 12px 24px;
        font-family: var(--v-font-loud); font-size: 1.1rem; font-weight: 900; text-transform: uppercase;
        color: var(--v-gray-600);
        margin-bottom: -4px; /* Pull down to overlap the content box border */
        transition: all 0.1s;
        z-index: 1; position: relative;
    }
    .v-nav-tabs .nav-link:hover:not(.active) { background: var(--v-gray-100); color: var(--v-black); }
    .v-nav-tabs .nav-link.active {
        background: var(--v-white);
        color: var(--v-black);
        padding-bottom: 16px; /* Push through the border */
        z-index: 3;
    }

    .tab-content-box {
        background: var(--v-white);
        border: var(--v-border-thick);
        border-radius: var(--v-radius-lg);
        box-shadow: var(--v-shadow-md);
        padding: clamp(24px, 4vw, 40px);
        position: relative; z-index: 2;
    }

    /* Info Cards Grid inside Tabs */
    .details-grid {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px;
    }
    .info-card {
        background: var(--v-gray-50); border: var(--v-border-thin); border-radius: var(--v-radius-sm);
        padding: 16px; box-shadow: 2px 2px 0 var(--v-gray-300); display: flex; flex-direction: column; gap: 4px;
    }
    .info-card label { font-family: var(--v-font-head); font-size: 0.8rem; font-weight: 900; text-transform: uppercase; color: var(--v-gray-600); }
    .info-card p { font-size: 1.15rem; font-weight: 700; color: var(--v-black); margin: 0; word-break: break-all; }

    /* --- Modal Overrides --- */
    .v-modal-content { background: var(--v-bg); border: var(--v-border-heavy); border-radius: var(--v-radius-lg); box-shadow: 16px 16px 0 rgba(0,0,0,0.8); }
    .v-modal-header { border-bottom: var(--v-border-thick); padding: 24px; }
    .v-modal-title { font-family: var(--v-font-loud); font-size: 1.8rem; text-transform: uppercase; text-shadow: 2px 2px 0 var(--v-pink); }
    .v-modal-footer { border-top: var(--v-border-thick); padding: 24px; }
    .btn-close { border: var(--v-border-thin); background-color: var(--v-yellow); opacity: 1; box-shadow: 2px 2px 0 var(--v-black); border-radius: 50%; padding: 12px;}

    .image-upload-wrapper { display: flex; flex-direction: column; align-items: center; gap: 16px; }
    .image-preview { width: 140px; height: 140px; border-radius: 50%; object-fit: cover; border: var(--v-border-thick); box-shadow: var(--v-shadow-sm); }

    /* ==========================================================================
       MOBILE RESPONSIVENESS FIXES
       ========================================================================== */
    @media (max-width: 991px) {
        .profile-dashboard-grid { grid-template-columns: 1fr; } /* Stack layout on mobile/tablet */
        .id-card-wrapper { flex-direction: row; flex-wrap: wrap; text-align: left; }
        .profile-avatar { width: 100px; height: 100px; margin-bottom: 0; margin-right: 20px;}
        .profile-info-mobile { flex: 1; min-width: 200px; }
        .profile-bio { width: 100%; order: 3; margin-top: 20px; }
        .social-links { justify-content: flex-start; width: 100%; order: 4; }
        .follower-metrics { order: 5; margin-bottom: 0; border-bottom: var(--v-border-thick); padding-bottom: 20px; margin-bottom: 20px; }
        .v-btn { order: 6; }
        
        .v-nav-tabs .nav-link { padding: 12px 16px; font-size: 0.95rem; }
    }
    @media (max-width: 576px) {
        .id-card-wrapper { flex-direction: column; text-align: center; }
        .profile-avatar { margin-right: 0; margin-bottom: 16px; }
        .social-links { justify-content: center; }
    }
</style>
</head>
<body>

<div class="vidyari-profile-master">
    <div class="v-container">
        
        <div class="profile-dashboard-grid">
            
            <aside>
                <div class="v-box id-card-wrapper">
                    <img src="<%= userData.profilePicUrl %>" alt="User Avatar" class="profile-avatar" id="profileAvatar" onerror="this.onerror=null; this.src='/images/avatar.jpg';"/>
                    
                    <div class="profile-info-mobile">
                        <div class="d-flex align-items-center justify-content-lg-center justify-content-start gap-2">
                            <h1 class="profile-name" id="profileName"><%= userData.fullname || userData.username %></h1>
                            <% if (userData.ISVERIFIED) { %>
                                <span title="Verified User"><img style="width: 28px; height: 28px;" src="/images/verify.png" alt="Verified Badge"/></span>
                            <% } %>
                        </div>
                        <div class="profile-username" id="profileUsername">@<%= userData.username %></div>
                    </div>
                    
                    <div class="profile-bio" id="profileBio"><%= userData.bio || 'No bio yet. Click edit to add one!' %></div>
                    
                    <div class="social-links" id="socialLinksContainer">
                        <a title="Instagram" href="<%= userData.instagramUrl || '#' %>" id="socialInstagram" target="_blank"><i class="fa-brands fa-instagram"></i></a>
                        <a title="GitHub" href="<%= userData.githubUrl || '#' %>" id="socialGithub" target="_blank"><i class="fab fa-github"></i></a>
                    </div>
                    
                    <div class="follower-metrics">
                        <div class="metric-item" onclick="window.location.href='/followers'">
                            <span class="count"><%= userData.followers.length %></span>
                            <span class="lbl">Followers</span>
                        </div>
                        <div class="metric-divider"></div>
                        <div class="metric-item" onclick="window.location.href='/following'">
                            <span class="count"><%= userData.following.length %></span>
                            <span class="lbl">Following</span>
                        </div>
                    </div>

                    <button class="v-btn" style="background: var(--v-yellow);" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                        <i class="fas fa-pen-alt"></i> Edit Profile
                    </button>
                </div>
            </aside>

            <main>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-val" data-value="<%=numOfCourses%>">0</div>
                        <div class="stat-lbl"><i class="fas fa-video me-2"></i>Courses</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-val" data-value="<%=numsOfDocs%>">0</div>
                        <div class="stat-lbl"><i class="fas fa-file-alt me-2"></i>Files</div>
                    </div>
                </div>

                <ul class="nav nav-tabs v-nav-tabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#profile" type="button">Details</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#security" type="button"><i class="fas fa-shield-alt me-2"></i> Security</button>
                    </li>
                </ul>

                <div class="tab-content tab-content-box">
                    <div class="tab-pane fade show active" id="profile" role="tabpanel">
                        <h3 class="mb-4" style="font-family: var(--v-font-loud); text-transform: uppercase;">Account Information</h3>
                        <div class="details-grid">
                            <div class="info-card">
                                <label>Full Name</label>
                                <p id="detailsFullName"><%= userData.fullname || 'Not Set' %></p>
                            </div>
                            <div class="info-card">
                                <label>Username</label>
                                <p id="detailsUsername">@<%= userData.username %></p>
                            </div>
                            <div class="info-card" style="grid-column: 1 / -1;">
                                <label>Email Address</label>
                                <p id="detailsEmail"><%= userData.email %></p>
                            </div>
                            <div class="info-card">
                                <label>Date of Birth</label>
                                <p id="detailsDob"><%= userData.DOB || 'Not Set' %></p>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="security" role="tabpanel">
                        <% if (hasPassword) { %>
                            <div id="change-password-container">
                                <h3 class="mb-4" style="font-family: var(--v-font-loud); text-transform: uppercase;">Change Password</h3>
                                <form id="changePasswordForm" class="row g-4">
                                    <div class="col-12">
                                        <label for="currentPassword" class="form-label fw-bold">Current Password</label>
                                        <input type="password" class="form-control v-form-control" id="currentPassword" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="newPasswordChange" class="form-label fw-bold">New Password</label>
                                        <input type="password" class="form-control v-form-control" id="newPasswordChange" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="confirmNewPasswordChange" class="form-label fw-bold">Confirm Password</label>
                                        <input type="password" class="form-control v-form-control" id="confirmNewPasswordChange" required>
                                    </div>
                                    <div class="col-md-6 mt-4">
                                        <button type="submit" class="v-btn w-100">Update Password</button>
                                    </div>
                                </form>
                            </div>
                        <% } else { %>
                            <div id="set-password-container">
                                <h3 class="mb-3" style="font-family: var(--v-font-loud); text-transform: uppercase;">Set Your Password</h3>
                                <div class="alert alert-warning border border-2 border-dark fw-bold mb-4">
                                    <i class="fas fa-exclamation-triangle me-2"></i> You signed up using a social account. Set a password to enable email login.
                                </div>
                                <form id="setPasswordForm" class="row g-4">
                                    <div class="col-md-6">
                                        <label for="newPasswordSet" class="form-label fw-bold">New Password</label>
                                        <input type="password" class="form-control v-form-control" id="newPasswordSet" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="confirmNewPasswordSet" class="form-label fw-bold">Confirm Password</label>
                                        <input type="password" class="form-control v-form-control" id="confirmNewPasswordSet" required>
                                    </div>
                                    <div class="col-md-6 mt-4">
                                        <button type="submit" class="v-btn w-100" style="background: var(--v-blue);">Set Password</button>
                                    </div>
                                </form>
                            </div>
                        <% } %>
                        <div id="password-feedback" class="d-none fw-bold p-3 border border-2 border-dark rounded mt-4"></div>
                    </div>
                </div>
            </main>
            
        </div>
    </div>

    <div class="modal fade" id="editProfileModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content v-modal-content">
                <div class="modal-header v-modal-header">
                    <h5 class="modal-title v-modal-title">Edit Profile</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="editProfileForm" novalidate>
                    <div class="modal-body p-4">
                        <div class="row g-4">
                            <div class="col-md-4">
                                <div class="image-upload-wrapper">
                                    <img src="" alt="Avatar Preview" id="imagePreview" class="image-preview" />
                                    <input type="file" id="avatarUpload" class="form-control v-form-control w-100" accept="image/*" />
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="mb-4">
                                    <label for="fullNameInput" class="form-label fw-bold">Full Name</label>
                                    <input type="text" class="form-control v-form-control" id="fullNameInput" />
                                </div>
                                <div class="mb-4">
                                    <label for="bioInput" class="form-label fw-bold">Bio</label>
                                    <textarea class="form-control v-form-control" id="bioInput" rows="3"></textarea>
                                </div>
                                <div class="mb-4">
                                    <label for="dobInput" class="form-label fw-bold">Date of Birth</label>
                                    <input type="date" class="form-control v-form-control" id="dobInput" />
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-4 pt-4 border-top border-dark border-3">
                            <h6 class="fw-bold mb-3" style="font-family: var(--v-font-loud); font-size: 1.3rem;">Social Links</h6>
                            <div class="input-group mb-3">
                                <span class="input-group-text"><i class="fab fa-github fa-fw"></i></span>
                                <input type="text" class="form-control v-form-control" id="githubInput" placeholder="https://github.com/username" />
                            </div>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-brands fa-instagram"></i></span>
                                <input type="text" class="form-control v-form-control" id="instagramInput" placeholder="https://www.instagram.com/username/" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer v-modal-footer d-flex gap-3">
                        <button type="button" class="v-btn" style="background: var(--v-gray-200); flex: 1;" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="v-btn" style="flex: 2;">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%-include("footer")%>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener("DOMContentLoaded", () => {
    // Number Counter Animation
    const animateValue = (obj, start, end, duration) => {
        let startTimestamp = null;
        const step = (timestamp) => {
            if (!startTimestamp) startTimestamp = timestamp;
            const progress = Math.min((timestamp - startTimestamp) / duration, 1);
            obj.innerHTML = Math.floor(progress * (end - start) + start);
            if (progress < 1) window.requestAnimationFrame(step);
        };
        window.requestAnimationFrame(step);
    };
    
    document.querySelectorAll(".stat-val").forEach(stat => {
        const endValue = parseInt(stat.getAttribute("data-value"), 10);
        if (!isNaN(endValue)) {
            animateValue(stat, 0, endValue, 1500);
        }
    });

    // Profile Edit Modal Logic
    const editModalElement = document.getElementById("editProfileModal");
    if (editModalElement) {
        const editProfileModal = new bootstrap.Modal(editModalElement);
        const editProfileForm = document.getElementById("editProfileForm");
        const avatarUpload = document.getElementById("avatarUpload");
        const imagePreview = document.getElementById("imagePreview");
        let initialProfileData = {};

        editModalElement.addEventListener("show.bs.modal", () => {
            initialProfileData = {
                fullname: document.getElementById("profileName").textContent.trim(),
                bio: document.getElementById("profileBio").textContent.trim(),
                dob: document.getElementById("detailsDob").textContent.trim(),
                avatarSrc: document.getElementById("profileAvatar").src,
                githubUrl: document.getElementById("socialGithub").href,
                instagramUrl: document.getElementById("socialInstagram").href,
            };
            document.getElementById("fullNameInput").value = initialProfileData.fullname;
            document.getElementById("bioInput").value = initialProfileData.bio.includes('No bio yet') ? '' : initialProfileData.bio;
            document.getElementById("dobInput").value = initialProfileData.dob === 'Not Set' ? '' : initialProfileData.dob;
            document.getElementById("githubInput").value = initialProfileData.githubUrl.includes('#') ? '' : initialProfileData.githubUrl;
            document.getElementById("instagramInput").value = initialProfileData.instagramUrl.includes('#') ? '' : initialProfileData.instagramUrl;
            imagePreview.src = initialProfileData.avatarSrc;
        });

        avatarUpload.addEventListener("change", (e) => {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (e) => (imagePreview.src = e.target.result);
                reader.readAsDataURL(file);
            }
        });

        editProfileForm.addEventListener("submit", async (event) => {
            event.preventDefault();
            const saveButton = editProfileForm.querySelector('button[type="submit"]');
            saveButton.disabled = true;
            saveButton.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> Saving...`;
            
            const formData = new FormData();
            const changedData = {};
            const newValues = {
                fullname: document.getElementById("fullNameInput").value,
                bio: document.getElementById("bioInput").value,
                dob: document.getElementById("dobInput").value,
                githubUrl: document.getElementById("githubInput").value,
                instagramUrl: document.getElementById("instagramInput").value,
            };
            
            for (const key in newValues) {
                if (newValues[key] !== initialProfileData[key]) {
                    formData.append(key, newValues[key]);
                    changedData[key] = newValues[key];
                }
            }
            if (avatarUpload.files[0]) {
                formData.append('profilepic', avatarUpload.files[0]);
                changedData.profilepic = true;
            }

            try {
                if (Object.keys(changedData).length > 0) {
                    const response = await fetch("/update/user-detail", { method: "POST", body: formData });
                    if (!response.ok) throw new Error('Update failed');
                    const result = await response.json();
                    
                    if (changedData.fullname) {
                        document.getElementById("profileName").textContent = changedData.fullname;
                        document.getElementById("detailsFullName").textContent = changedData.fullname;
                    }
                    if (changedData.bio !== undefined) document.getElementById("profileBio").textContent = changedData.bio || 'No bio yet.';
                    if (changedData.dob !== undefined) document.getElementById("detailsDob").textContent = changedData.dob || 'Not Set';
                    if (changedData.githubUrl !== undefined) document.getElementById("socialGithub").href = changedData.githubUrl || '#';
                    if (changedData.instagramUrl !== undefined) document.getElementById("socialInstagram").href = changedData.instagramUrl || '#';
                    if (result.newProfilePicUrl) document.getElementById("profileAvatar").src = result.newProfilePicUrl;
                }
            } catch(error) { 
                console.error('Error:', error);
            } finally {
                saveButton.disabled = false;
                saveButton.innerHTML = 'Save Changes';
                editProfileModal.hide();

                const backdrop = document.querySelector('.modal-backdrop');
                if (backdrop) backdrop.remove();
                document.body.classList.remove('modal-open');
                document.body.style.overflow = '';
                document.body.style.paddingRight = '';
            }
        });
    }
    
    // Feedback handler
    const feedbackEl = document.getElementById("password-feedback");
    const showFeedback = (message, type) => {
        feedbackEl.innerHTML = `<i class="fas fa-info-circle me-2"></i> ${message}`;
        feedbackEl.className = `alert alert-${type} mt-3 mb-0`;
        feedbackEl.classList.remove("d-none");
    };

    // Change Password Form
    const changePasswordForm = document.getElementById("changePasswordForm");
    if (changePasswordForm) {
        changePasswordForm.addEventListener("submit", async (event) => {
            event.preventDefault();
            feedbackEl.className = "d-none";
            const submitBtn = changePasswordForm.querySelector('button[type="submit"]');
            const currentPassword = document.getElementById("currentPassword").value;
            const newPassword = document.getElementById("newPasswordChange").value;
            const confirmNewPassword = document.getElementById("confirmNewPasswordChange").value;

            if (!currentPassword || !newPassword || !confirmNewPassword) return showFeedback("Please fill in all fields.", "danger");
            if (newPassword.length < 8) return showFeedback("Password must be at least 8 characters.", "warning");
            if (newPassword !== confirmNewPassword) return showFeedback("New passwords do not match.", "danger");
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> Updating...`;
            
            try {
                const response = await fetch("/update/user-password", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ currentPassword, newPassword }),
                });
                const result = await response.json();
                if (!response.ok) throw new Error(result.message || "An error occurred.");
                showFeedback(result.message || "Password updated successfully!", "success");
                changePasswordForm.reset();
            } catch (error) {
                showFeedback(error.message, "danger");
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = "Update Password";
            }
        });
    }

    // Set Password Form
    const setPasswordForm = document.getElementById("setPasswordForm");
    if (setPasswordForm) {
        setPasswordForm.addEventListener("submit", async (event) => {
            event.preventDefault();
            feedbackEl.className = "d-none";
            const submitBtn = setPasswordForm.querySelector('button[type="submit"]');
            const newPassword = document.getElementById("newPasswordSet").value;
            const confirmNewPassword = document.getElementById("confirmNewPasswordSet").value;
            
            if (!newPassword || !confirmNewPassword) return showFeedback("Please fill in all fields.", "danger");
            if (newPassword.length < 8) return showFeedback("Password must be at least 8 characters.", "warning");
            if (newPassword !== confirmNewPassword) return showFeedback("Passwords do not match.", "danger");

            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> Setting...`;
            
            try {
                const response = await fetch("/set/user-password", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ newPassword }),
                });
                const result = await response.json();
                if (!response.ok) throw new Error(result.message || "An error occurred.");
                
                showFeedback(result.message || "Password set successfully!", "success");
                setPasswordForm.style.display = 'none';
                setTimeout(() => window.location.reload(), 1500);
            } catch (error) {
                showFeedback(error.message, "danger");
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = "Set Password";
            }
        });
    }
});
</script>
</body>
</html>