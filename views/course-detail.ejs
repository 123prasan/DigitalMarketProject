<%-include('header')%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Course Details | Vidyari</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <style>
        /* ============================================================
           VIDYARI COURSE DETAIL — LUXURY EDITORIAL WHITE THEME
           ============================================================ */
        :root {
            --ink:        #0a0a0b;
            --ink-2:      #3f424a;
            --ink-3:      #6b707d;
            --ink-4:      #a2a6b0;
            --rule:       #e2e4e9;
            --rule-light: #f1f3f7;
            --surface:    #ffffff;
            --bg:         #fcfcfd;
            
            /* Professional Trust Blue */
            --accent:     #0F4C81; 
            --accent-2:   #F0F4F8;
            --accent-ink: #0A365C;
            
            --green:      #0b7a45;
            --green-bg:   #edfaf3;
            --amber:      #e8811f;

            --serif:  'DM Serif Display', Georgia, serif;
            --sans:   'DM Sans', system-ui, sans-serif;

            --r-sm:   6px;
            --r-md:   12px;
            --r-lg:   16px;
            --r-xl:   24px;
            --r-pill: 9999px;

            --shadow-sm: 0 2px 8px rgba(10,10,11,0.04);
            --shadow-md: 0 8px 24px rgba(10,10,11,0.08);
            --shadow-card: 0 0 0 1px rgba(10,10,11,0.05), 0 4px 20px rgba(10,10,11,0.04);
            --shadow-float: 0 -4px 24px rgba(10,10,11,0.12);

            --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; min-width: 0; }
        html { -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }

        body {
            font-family: var(--sans);
            background: var(--bg);
            color: var(--ink);
            overflow-x: hidden;
            /* Padding for mobile sticky bar */
            padding-bottom: 0; 
        }

        /* ── CONTAINER ── */
        .cd-wrap {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 clamp(16px, 4vw, 40px);
        }

        /* ── BACK BUTTON ── */
        .back-btn {
            display: inline-flex; align-items: center; gap: 8px;
            font-size: 0.9rem; font-weight: 600; color: var(--ink-3);
            text-decoration: none; padding: 12px 20px;
            background: var(--surface); border: 1px solid var(--rule);
            border-radius: var(--r-pill); margin: 32px 0 24px;
            transition: all 0.2s var(--ease-out); box-shadow: var(--shadow-sm);
        }
        .back-btn:hover {
            color: var(--accent); border-color: var(--accent);
            transform: translateX(-4px); box-shadow: var(--shadow-md);
        }

        /* ── MAIN LAYOUT ── */
        .cd-layout {
            display: grid; grid-template-columns: 1fr 380px; gap: 40px;
            padding-bottom: 80px; align-items: start;
        }

        /* ── VIDEO PLAYER ── */
        .player-shell {
            background: var(--ink); border-radius: var(--r-xl); overflow: hidden;
            position: relative; margin-bottom: 32px; box-shadow: var(--shadow-md);
            aspect-ratio: 16 / 9; border: 1px solid var(--rule);
        }

        .player-thumb { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; cursor: pointer; }
        .player-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease-out); }
        .player-thumb:hover img { transform: scale(1.04); }
        .player-thumb-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,10,11,0.8) 0%, rgba(10,10,11,0.2) 60%, transparent 100%); }

        .play-ring {
            position: absolute; width: 80px; height: 80px; border-radius: 50%;
            background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3); transition: all 0.3s var(--ease-out);
        }
        .player-thumb:hover .play-ring { transform: scale(1.1); background: white; box-shadow: 0 12px 40px rgba(0,0,0,0.4); }
        .play-ring i { color: var(--accent); font-size: 1.5rem; margin-left: 4px; }

        .player-label {
            position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
            font-size: 0.85rem; font-weight: 600; color: rgba(255,255,255,0.9);
            letter-spacing: 0.08em; text-transform: uppercase;
            display: flex; align-items: center; gap: 8px;
        }
        .player-label::before, .player-label::after { content: ''; width: 40px; height: 1px; background: rgba(255,255,255,0.4); }

        .player-shell iframe, .player-shell video { position: absolute; inset: 0; width: 100%; height: 100%; border: none; border-radius: var(--r-xl); }
        .player-shell.playing .player-thumb { display: none; }

        /* ── COURSE HEADER CARD ── */
        .course-header-card {
            background: var(--surface); border: 1px solid var(--rule);
            border-radius: var(--r-xl); padding: 40px; margin-bottom: 32px;
            box-shadow: var(--shadow-card);
        }

        .course-eyebrow {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em;
            text-transform: uppercase; color: var(--accent); background: var(--accent-2);
            border: 1px solid rgba(15,76,129,0.15); padding: 6px 14px;
            border-radius: var(--r-pill); margin-bottom: 20px;
        }

        .course-title {
            font-family: var(--serif); font-size: clamp(1.8rem, 3.5vw, 2.6rem);
            font-weight: 400; line-height: 1.15; color: var(--ink); margin-bottom: 16px;
        }

        .course-desc {
            font-size: 1.05rem; font-weight: 400; color: var(--ink-2);
            line-height: 1.6; margin-bottom: 28px; max-width: 720px;
        }

        .course-meta-row {
            display: flex; flex-wrap: wrap; gap: 24px; padding: 24px 0;
            border-top: 1px solid var(--rule-light); border-bottom: 1px solid var(--rule-light);
            margin-bottom: 28px;
        }
        .meta-chip { display: inline-flex; align-items: center; gap: 8px; font-size: 0.9rem; color: var(--ink-2); }
        .meta-chip i { color: var(--accent); font-size: 1rem; }
        .meta-chip .stars { color: var(--amber); letter-spacing: -1px; font-size: 0.9rem; }
        .meta-chip strong { font-weight: 700; color: var(--ink); }

        .instructor-link {
            display: flex; align-items: center; gap: 16px; padding: 16px 24px;
            background: var(--rule-light); border: 1px solid var(--rule);
            border-radius: var(--r-lg); text-decoration: none; color: inherit;
            transition: all 0.2s var(--ease-out);
        }
        .instructor-link:hover { border-color: var(--accent); background: var(--surface); box-shadow: var(--shadow-sm); transform: translateY(-2px); }
        .instructor-avatar { width: 64px; height: 64px; border-radius: 50%; object-fit: cover; border: 2px solid var(--surface); box-shadow: 0 2px 8px rgba(0,0,0,0.1); flex-shrink: 0; }
        .instructor-name { font-family: var(--serif); font-size: 1.15rem; color: var(--ink); }
        .instructor-role { font-size: 0.85rem; color: var(--ink-3); margin-top: 2px; }

        /* ── CONTENT SECTIONS ── */
        .cd-section {
            background: var(--surface); border: 1px solid var(--rule);
            border-radius: var(--r-xl); padding: 40px; margin-bottom: 32px;
            box-shadow: var(--shadow-card);
        }

        .cd-section-title {
            font-family: var(--serif); font-size: 1.6rem; font-weight: 400;
            color: var(--ink); margin-bottom: 28px; padding-bottom: 16px;
            border-bottom: 1px solid var(--rule-light);
        }

        /* What you'll learn */
        .learn-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
        .learn-item {
            display: flex; align-items: flex-start; gap: 12px; padding: 16px;
            background: var(--bg); border: 1px solid var(--rule);
            border-radius: var(--r-md); font-size: 0.95rem; color: var(--ink-2);
            line-height: 1.5; transition: all 0.2s;
        }
        .learn-item:hover { border-color: rgba(15,76,129,0.3); background: var(--accent-2); }
        .learn-item i { color: var(--green); font-size: 1.1rem; margin-top: 2px; flex-shrink: 0; }

        /* Curriculum */
        .curriculum-summary { font-size: 0.95rem; color: var(--ink-3); margin-bottom: 24px; font-weight: 500; }
        .module-item { border: 1px solid var(--rule); border-radius: var(--r-lg); margin-bottom: 12px; overflow: hidden; transition: box-shadow 0.2s; }
        .module-item.open { box-shadow: var(--shadow-sm); border-color: var(--ink-4); }

        .module-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 20px 24px; cursor: pointer; background: var(--rule-light);
            transition: background 0.2s; user-select: none;
        }
        .module-header:hover { background: #eef0f4; }
        .module-item.open .module-header { background: var(--surface); border-bottom: 1px solid var(--rule); }

        .module-title { font-size: 1rem; font-weight: 700; color: var(--ink); display: flex; align-items: center; gap: 14px; }
        .module-num {
            width: 32px; height: 32px; border-radius: 50%; background: var(--surface);
            border: 1px solid var(--rule); font-size: 0.85rem; font-weight: 700;
            color: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .module-item.open .module-num { background: var(--accent); color: white; border-color: var(--accent); }

        .module-meta { display: flex; align-items: center; gap: 16px; font-size: 0.9rem; color: var(--ink-3); font-weight: 500; }
        .module-chevron {
            width: 32px; height: 32px; border-radius: 50%; background: var(--surface);
            border: 1px solid var(--rule); display: flex; align-items: center; justify-content: center;
            color: var(--ink-3); font-size: 0.85rem; transition: all 0.3s var(--ease-out); flex-shrink: 0;
        }
        .module-item.open .module-chevron { transform: rotate(180deg); background: var(--accent); color: white; border-color: var(--accent); }

        .module-body { max-height: 0; overflow: hidden; transition: max-height 0.4s var(--ease-out); background: var(--surface); }
        .module-item.open .module-body { max-height: 2000px; }
        
        .lesson-row {
            display: flex; align-items: center; justify-content: space-between;
            padding: 16px 24px; border-bottom: 1px solid var(--rule-light);
        }
        .lesson-row:last-child { border-bottom: none; }
        .lesson-left { display: flex; align-items: center; gap: 12px; font-size: 0.95rem; color: var(--ink-2); font-weight: 500; }
        .lesson-left i { color: var(--accent); font-size: 1rem; opacity: 0.8; }
        .lesson-dur { font-size: 0.85rem; color: var(--ink-4); font-weight: 600; }

        /* ── SIDEBAR (DESKTOP) ── */
        .cd-sidebar { position: sticky; top: 32px; }

        .price-card {
            background: var(--surface); border: 1px solid var(--rule);
            border-radius: var(--r-xl); overflow: hidden; box-shadow: var(--shadow-md);
            margin-bottom: 24px;
        }
        .price-card-thumb { width: 100%; aspect-ratio: 16/9; object-fit: cover; border-bottom: 1px solid var(--rule); display: block; }
        .price-card-body { padding: 32px; }

        .price-current { font-family: var(--serif); font-size: 2.8rem; color: var(--ink); line-height: 1; margin-bottom: 8px; }
        .price-current.free { color: var(--green); font-size: 2.2rem; }
        .price-was { font-size: 1rem; color: var(--ink-4); text-decoration: line-through; font-weight: 500; }
        .price-discount {
            display: inline-block; background: #FEF3C7; color: #92400E;
            font-size: 0.8rem; font-weight: 700; padding: 4px 12px; border-radius: var(--r-pill); margin-left: 12px; vertical-align: middle;
        }

        .enroll-btn {
            width: 100%; display: flex; align-items: center; justify-content: center; gap: 10px;
            font-family: var(--sans); font-size: 1.1rem; font-weight: 700; color: white;
            background: var(--accent); border: none; border-radius: var(--r-lg);
            padding: 18px; cursor: pointer; margin: 24px 0 16px;
            transition: all 0.2s var(--ease-out); box-shadow: 0 4px 16px rgba(15,76,129,0.3);
        }
        .enroll-btn:hover { background: var(--accent-ink); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(15,76,129,0.4); }
        .enroll-btn:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

        .guarantee-note { text-align: center; font-size: 0.85rem; color: var(--ink-3); font-weight: 500; display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 24px; }
        .guarantee-note i { color: var(--green); font-size: 1rem; }

        /* ── STICKY MOBILE ACTION BAR ── */
        .mobile-enroll-bar {
            display: none; position: fixed; bottom: 0; left: 0; right: 0;
            background: var(--surface); padding: 16px 24px;
            border-top: 1px solid var(--rule); box-shadow: var(--shadow-float);
            z-index: 100; align-items: center; justify-content: space-between;
            padding-bottom: calc(16px + env(safe-area-inset-bottom));
        }
        .mobile-enroll-price { font-family: var(--serif); font-size: 1.8rem; font-weight: 600; color: var(--ink); line-height: 1; }
        .mobile-enroll-price.free { color: var(--green); }
        .mobile-enroll-was { font-size: 0.85rem; color: var(--ink-4); text-decoration: line-through; font-family: var(--sans); font-weight: 500; display: block; }
        
        .mobile-enroll-btn {
            background: var(--accent); color: white; border: none;
            padding: 14px 32px; border-radius: var(--r-pill); font-size: 1rem;
            font-weight: 700; cursor: pointer; transition: all 0.2s;
            box-shadow: 0 4px 12px rgba(15,76,129,0.3);
        }
        .mobile-enroll-btn:active { transform: scale(0.98); }
        .mobile-enroll-btn:disabled { opacity: 0.7; pointer-events: none; }

        /* ── SUCCESS MODAL ── */
        .modal-veil {
            position: fixed; inset: 0; background: rgba(10,10,11,0.6);
            backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; z-index: 9999;
        }
        .modal-veil.show { display: flex; animation: fadeVeil 0.3s ease; }
        @keyframes fadeVeil { from { opacity: 0; } to { opacity: 1; } }

        .success-modal {
            background: var(--surface); border-radius: var(--r-xl); padding: 48px;
            text-align: center; max-width: 440px; width: 90%; box-shadow: var(--shadow-float);
            animation: modalUp 0.4s var(--ease-out);
        }
        @keyframes modalUp { from { opacity:0; transform: translateY(24px) scale(0.95); } to { opacity:1; transform: translateY(0) scale(1); } }

        .modal-icon {
            width: 80px; height: 80px; border-radius: 50%; background: var(--green-bg);
            border: 2px solid rgba(11,122,69,0.2); display: flex; align-items: center; justify-content: center;
            margin: 0 auto 24px; animation: iconPop 0.5s var(--ease-out) 0.2s both;
        }
        @keyframes iconPop { from { transform: scale(0.5); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        .modal-icon i { color: var(--green); font-size: 2.2rem; }

        .modal-title { font-family: var(--serif); font-size: 1.8rem; color: var(--ink); margin-bottom: 12px; }
        .modal-text { font-size: 1rem; color: var(--ink-2); line-height: 1.6; margin-bottom: 32px; }
        .modal-progress { height: 4px; background: var(--rule-light); border-radius: var(--r-pill); overflow: hidden; }
        .modal-progress-bar { height: 100%; background: var(--green); border-radius: var(--r-pill); animation: progress 2s linear forwards; }
        @keyframes progress { from { width: 0; } to { width: 100%; } }

        /* ── RESPONSIVE ── */
        @media (max-width: 1024px) {
            .cd-layout { grid-template-columns: 1fr; gap: 32px; padding-bottom: 120px; }
            /* Hide desktop sidebar price card, show mobile bar */
            .cd-sidebar .price-card { display: none; }
            .mobile-enroll-bar { display: flex; }
            .course-header-card, .cd-section { padding: 32px 24px; }
        }
        @media (max-width: 640px) {
            .course-meta-row { gap: 16px; flex-direction: column; }
            .instructor-link { flex-direction: column; text-align: center; align-items: center; }
            .instructor-link i { display: none; }
            .course-title { font-size: 2rem; }
            .mobile-enroll-btn { padding: 14px 24px; }
        }
    </style>
</head>
<body>

<div class="cd-wrap">
    <a href="/courses" class="back-btn">
        <i class="fa-solid fa-arrow-left"></i> Back to Catalog
    </a>

    <div class="cd-layout">

        <!-- ════════════════════════ LEFT COLUMN -->
        <div class="cd-main">

            <!-- VIDEO PLAYER -->
            <div class="player-shell" id="playerShell">
                <div class="player-thumb" id="playerThumb" onclick="startPlayer()">
                    <img src="<%= typeof course !== 'undefined' && course.thumbnailUrl ? course.thumbnailUrl : 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=1200&h=675&fit=crop' %>" alt="Course preview" id="thumbImg">
                    <div class="player-thumb-overlay"></div>
                    <div class="play-ring"><i class="fa-solid fa-play"></i></div>
                    <div class="player-label">Preview this course</div>
                </div>
            </div>

            <!-- COURSE HEADER -->
            <div class="course-header-card">
                <div class="course-eyebrow">
                    <%= typeof course !== 'undefined' && course.published ? '✦ Published' : '✦ Bestseller' %>
                </div>

                <h1 class="course-title">
                    <%= typeof course !== 'undefined' && course.title ? course.title : 'Complete Web Development Bootcamp 2025' %>
                </h1>

                <p class="course-desc">
                    <%= typeof course !== 'undefined' && course.description ? course.description : 'Become a full-stack developer with one comprehensive, expertly crafted course.' %>
                </p>

                <!-- Meta -->
                <div class="course-meta-row">
                    <div class="meta-chip">
                        <span class="stars">
                            <% if (course && course.rating) { %>
                                <%= '★'.repeat(Math.round(course.rating)) %><% if (Math.round(course.rating) < 5) { %><span style="color:var(--rule)"><%= '★'.repeat(5 - Math.round(course.rating)) %></span><% } %>
                            <% } else { %><span style="color:var(--rule)">★★★★★</span><% } %>
                        </span>
                        <strong><%= course && course.rating ? course.rating.toFixed(1) : '—' %></strong>
                        <span style="color:var(--ink-4)">(<%= course && course.enrollCount ? course.enrollCount.toLocaleString() : 0 %> ratings)</span>
                    </div>
                    <div class="meta-chip">
                        <i class="fa-solid fa-users"></i>
                        <strong><%= course && course.enrollCount ? course.enrollCount.toLocaleString() : 0 %></strong> students
                    </div>
                    <div class="meta-chip">
                        <i class="fa-regular fa-clock"></i>
                        <strong><%= course && course.duration ? (course.duration / 60).toFixed(1) : '0' %>h</strong> content
                    </div>
                    <div class="meta-chip">
                        <i class="fa-solid fa-layer-group"></i>
                        <%= course && course.category ? course.category : 'General' %>
                    </div>
                </div>

                <!-- Instructor -->
                <a href="/profile/<%= course && course.userId ? (course.userId.username || '') : '' %>" class="instructor-link">
                    <img src="<%= typeof profileUrl !== 'undefined' && profileUrl && profileUrl.trim() ? profileUrl : '/images/avatar.jpg' %>" alt="Instructor" class="instructor-avatar" onerror="this.src='/images/avatar.jpg'">
                    <div>
                        <div class="instructor-name"><%= course && course.userId ? (course.userId.fullName || 'Premium Instructor') : 'Premium Instructor' %></div>
                        <div class="instructor-role">Course Creator &amp; Subject Matter Expert</div>
                    </div>
                    <i class="fa-solid fa-arrow-right" style="margin-left:auto;color:var(--ink-4);"></i>
                </a>
            </div>

            <!-- WHAT YOU'LL LEARN -->
            <div class="cd-section">
                <h2 class="cd-section-title">What you'll learn</h2>
                <div class="learn-grid">
                    <% if (course && course.learningOutcomes && course.learningOutcomes.length > 0) { %>
                        <% course.learningOutcomes.forEach(o => { %>
                            <div class="learn-item"><i class="fa-solid fa-circle-check"></i><span><%= o %></span></div>
                        <% }); %>
                    <% } else { %>
                        <div class="learn-item"><i class="fa-solid fa-circle-check"></i><span>Complete curriculum with <%= course && course.modules ? course.modules.length : 0 %> modules</span></div>
                        <div class="learn-item"><i class="fa-solid fa-circle-check"></i><span><%= course && course.duration ? (course.duration/60).toFixed(1) + ' hours' : 'Comprehensive' %> of expert-led video</span></div>
                        <div class="learn-item"><i class="fa-solid fa-circle-check"></i><span>Professional best practices &amp; patterns</span></div>
                        <div class="learn-item"><i class="fa-solid fa-circle-check"></i><span>Real-world projects &amp; applications</span></div>
                    <% } %>
                </div>
            </div>

            <!-- CURRICULUM -->
            <div class="cd-section">
                <h2 class="cd-section-title">Course Curriculum</h2>
                <p class="curriculum-summary" id="curriculumSummary">Loading curriculum…</p>
                <div id="curriculumContainer"></div>
            </div>

        </div><!-- /cd-main -->

        <!-- ════════════════════════ RIGHT SIDEBAR -->
        <aside class="cd-sidebar">
            <div class="price-card">
                <img src="<%= typeof course !== 'undefined' && course.thumbnailUrl ? course.thumbnailUrl : 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=800' %>" alt="Course thumbnail" class="price-card-thumb" onerror="this.style.display='none'">
                
                <div class="price-card-body">
                    <% const isFree = !course || !course.price || course.price <= 0; %>
                    <% const hasDis = course && course.discountPrice && course.discountPrice > 0; %>

                    <% if (isFree) { %>
                        <div class="price-current free">Free</div>
                    <% } else { %>
                        <div style="display:flex;align-items:baseline;gap:8px;flex-wrap:wrap;">
                            <div class="price-current">₹<%= course.price.toFixed(0) %></div>
                            <% if (hasDis) { %>
                                <span class="price-was">₹<%= course.discountPrice.toFixed(0) %></span>
                                <span class="price-discount"><%= Math.round((1 - course.price / course.discountPrice) * 100) %>% OFF</span>
                            <% } else { %>
                                <span class="price-was">₹<%= (course.price * 1.3).toFixed(0) %></span>
                            <% } %>
                        </div>
                    <% } %>

                    <button class="enroll-btn" onclick="enrollNow(event, this)">
                        <i class="fa-solid fa-bolt"></i>
                        <%= isFree ? 'Enroll for Free' : 'Enroll Now' %>
                    </button>

                    <div class="guarantee-note">
                        <i class="fa-solid fa-shield-halved"></i> 30-day money-back guarantee
                    </div>

                    <ul class="includes-list" style="list-style:none;">
                        <li style="font-size:0.8rem; font-weight:700; text-transform:uppercase; color:var(--ink-3); margin-bottom:12px;">This course includes</li>
                        <li style="display:flex; gap:10px; padding:8px 0; font-size:0.9rem; color:var(--ink-2); border-bottom:1px solid var(--rule-light);"><i class="fa-solid fa-video" style="color:var(--ink-4); width:16px;"></i><span><%= course && course.duration ? (course.duration/60).toFixed(1) : 0 %>h on-demand video</span></li>
                        <li style="display:flex; gap:10px; padding:8px 0; font-size:0.9rem; color:var(--ink-2); border-bottom:1px solid var(--rule-light);"><i class="fa-solid fa-cubes" style="color:var(--ink-4); width:16px;"></i><span><%= course && course.modules ? course.modules.length : 0 %> course modules</span></li>
                        <li style="display:flex; gap:10px; padding:8px 0; font-size:0.9rem; color:var(--ink-2); border-bottom:1px solid var(--rule-light);"><i class="fa-solid fa-download" style="color:var(--ink-4); width:16px;"></i><span>Downloadable resources</span></li>
                        <li style="display:flex; gap:10px; padding:8px 0; font-size:0.9rem; color:var(--ink-2);"><i class="fa-solid fa-infinity" style="color:var(--ink-4); width:16px;"></i><span>Full lifetime access</span></li>
                    </ul>
                </div>
            </div>
        </aside>

    </div>
</div>

<!-- ── STICKY MOBILE ACTION BAR ── -->
<div class="mobile-enroll-bar">
    <div>
        <% if (isFree) { %>
            <div class="mobile-enroll-price free">Free</div>
        <% } else { %>
            <div class="mobile-enroll-price">₹<%= course.price.toFixed(0) %></div>
            <% if (hasDis) { %><span class="mobile-enroll-was">₹<%= course.discountPrice.toFixed(0) %></span><% } %>
        <% } %>
    </div>
    <button class="mobile-enroll-btn" onclick="enrollNow(event, this)">
        <%= isFree ? 'Enroll Free' : 'Enroll Now' %>
    </button>
</div>

<!-- SUCCESS MODAL -->
<div class="modal-veil" id="successModal">
    <div class="success-modal">
        <div class="modal-icon"><i class="fa-solid fa-check"></i></div>
        <div class="modal-title">You're enrolled! 🎉</div>
        <p class="modal-text">Welcome aboard. You'll be redirected to your courses in a moment.</p>
        <div class="modal-progress"><div class="modal-progress-bar"></div></div>
    </div>
</div>

<!-- Course data for JS -->
<script id="course-json" type="application/json"><%- JSON.stringify(course || {}) %></script>

<script>
const COURSE = (() => {
    try { return JSON.parse(document.getElementById('course-json').textContent); }
    catch(e) { return {}; }
})();

function getYouTubeId(url) {
    if (!url) return null;
    const patterns = [
        /youtube\.com\/watch\?(?:.*&)?v=([^&#]+)/,
        /youtube\.com\/embed\/([^/?#]+)/,
        /youtu\.be\/([^/?#]+)/,
    ];
    for (const re of patterns) {
        const m = url.match(re);
        if (m && m[1]) return m[1];
    }
    return null;
}

function startPlayer() {
    const shell = document.getElementById('playerShell');
    const url   = COURSE.introVideoUrl || '';
    if (!url) { alert('No preview video available.'); return; }
    
    const ytId = getYouTubeId(url);
    if (ytId) {
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube.com/embed/${ytId}?autoplay=1&rel=0&modestbranding=1`;
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
        iframe.allowFullscreen = true;
        shell.appendChild(iframe);
    } else {
        const video = document.createElement('video');
        video.src = url; video.controls = true; video.autoplay = true; video.style.background = '#000';
        shell.appendChild(video);
    }
    shell.classList.add('playing');
}

(function renderCurriculum() {
    const container = document.getElementById('curriculumContainer');
    const summary   = document.getElementById('curriculumSummary');
    const modules   = COURSE.modules || [];

    if (!modules.length) {
        summary.textContent = '0 modules · 0 lessons';
        container.innerHTML = `<div style="text-align:center;padding:32px;color:var(--ink-3);background:var(--rule-light);border:1px dashed var(--rule);border-radius:var(--r-lg);">No curriculum available yet.</div>`;
        return;
    }

    const totalLessons = modules.reduce((s, m) => s + (m.submodules?.length || 0), 0);
    summary.textContent = `${modules.length} section${modules.length !== 1 ? 's' : ''} · ${totalLessons} lesson${totalLessons !== 1 ? 's' : ''}`;

    function esc(t) { return (t || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c])); }

    container.innerHTML = modules.map((mod, i) => {
        const count = mod.submodules?.length || 0;
        const lessons = count === 0
            ? `<p style="color:var(--ink-4);font-size:0.875rem;padding:12px 0;">No lessons added yet.</p>`
            : mod.submodules.map(l => `
                <div class="lesson-row">
                    <div class="lesson-left">
                        <i class="fa-${l.type === 'Video' ? 'solid fa-play-circle' : 'regular fa-file-lines'}"></i>
                        <span>${esc(l.title)}</span>
                    </div>
                    ${l.duration ? `<span class="lesson-dur">${l.duration} min</span>` : ''}
                </div>`).join('');

        return `
            <div class="module-item" id="mod-${i}">
                <div class="module-header" onclick="toggleModule(${i})">
                    <div class="module-title"><span class="module-num">${i + 1}</span>${esc(mod.unit)}</div>
                    <div class="module-meta">
                        <span>${count} lesson${count !== 1 ? 's' : ''}</span>
                        <span class="module-chevron"><i class="fa-solid fa-chevron-down"></i></span>
                    </div>
                </div>
                <div class="module-body"><div class="lesson-list">${lessons}</div></div>
            </div>`;
    }).join('');

    if (modules.length > 0) toggleModule(0);
})();

function toggleModule(i) {
    document.getElementById('mod-' + i)?.classList.toggle('open');
}

/* ══════════════════════════════════════════════
   ENROLMENT (Syncs both Mobile & Desktop Buttons)
   ══════════════════════════════════════════════ */
function enrollNow(event, btnElement) {
    const courseId    = '<%= typeof course !== "undefined" ? course._id : "" %>';
    const coursePrice = <%= typeof course !== "undefined" ? (course.price || 0) : 0 %>;
    
    // Target both buttons to lock UI
    const allBtns = document.querySelectorAll('.enroll-btn, .mobile-enroll-btn');
    const originalTexts = Array.from(allBtns).map(b => b.innerHTML);
    
    allBtns.forEach(b => {
        b.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processing…';
        b.disabled = true;
    });

    const restoreBtns = () => {
        allBtns.forEach((b, i) => {
            b.innerHTML = originalTexts[i];
            b.disabled = false;
        });
    };

    if (!coursePrice || coursePrice <= 0) {
        fetch('/api/enroll/free', {
            method:'POST', headers:{'Content-Type':'application/json'},
            credentials:'include', body: JSON.stringify({ courseId })
        }).then(r => {
            if (r.status === 401) {
                return r.json().then(data => {
                    restoreBtns();
                    window.location.href = data.loginRedirectUrl;
                    throw new Error('login_required');
                });
            }
            return r.json();
        }).then(d => {
            if (d.requiresLogin) { restoreBtns(); window.location.href = d.loginRedirectUrl; return; }
            if (d.success) { showSuccessModal(() => window.location.href = '/my-courses'); } 
            else { restoreBtns(); alert(d.message || 'Enrollment failed.'); }
        }).catch(err => {
            if (err.message === 'login_required') return;
            restoreBtns(); alert('Enrollment failed: ' + (err.message || 'Unknown error'));
        });
        return;
    }

    fetch('/api/payments/initiate-payment', {
        method:'POST', headers:{'Content-Type':'application/json'},
        credentials:'include', body: JSON.stringify({ courseId })
    }).then(r => {
        if (r.status === 401) {
            return r.json().then(data => {
                restoreBtns(); window.location.href = data.loginRedirectUrl;
                throw new Error('login_required');
            });
        }
        return r.json();
    }).then(data => {
        if (data.requiresLogin) { restoreBtns(); window.location.href = data.loginRedirectUrl; return; }
        if (!data.success) { restoreBtns(); alert(data.error || 'Payment initiation failed.'); return; }

        const rzp = new Razorpay({
            key:         data.keyId,
            amount:      data.amount,
            currency:    data.currency,
            name:        'Vidyari',
            description: data.courseName,
            order_id:    data.orderId,
            prefill:     { name: data.studentName, email: data.studentEmail },
            theme:       { color: '#0F4C81' },
            handler: function(res) {
                allBtns.forEach(b => b.innerHTML = '<i class="fa-solid fa-shield-check"></i> Verifying…');
                fetch('/api/payments/verify-payment', {
                    method:'POST', headers:{'Content-Type':'application/json'}, credentials:'include',
                    body: JSON.stringify({
                        orderId: data.orderId, paymentId: res.razorpay_payment_id,
                        signature: res.razorpay_signature, paymentDocumentId: data.paymentId
                    })
                }).then(r => r.json()).then(d => {
                    if (d.success) showSuccessModal(() => window.location.href = '/my-courses');
                    else { alert('Verification failed: ' + (d.error || '')); restoreBtns(); }
                }).catch(() => { alert('Verification error.'); restoreBtns(); });
            },
            modal: { ondismiss: () => restoreBtns() }
        });
        rzp.open();
    }).catch(err => {
        if (err.message === 'login_required') return;
        restoreBtns(); alert('Error: ' + (err.message || 'Unknown error'));
    });
}

function showSuccessModal(cb) {
    const modal = document.getElementById('successModal');
    modal.classList.add('show');
    setTimeout(() => { if (cb) cb(); }, 2100);
}
</script>

<%- include('footer') %>
</body>
</html>