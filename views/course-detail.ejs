<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Course Details | Premium Learning</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <%- include('header.ejs') %>
    <style>
        :root {
            /* Clean SaaS Light Theme Palette */
            --bg:           #f8fafc;
            --surface:      #ffffff;
            --surface-hover:#f1f5f9;
            --border:       #e2e8f0;
            --text-main:    #0f172a;
            --text-muted:   #475569;
            --text-dim:     #94a3b8;
            
            --accent-blue:  #3b82f6;
            --accent-hover: #2563eb;
            --accent-light: #eff6ff;
            --warning-star: #fbbf24;
            --success:      #10b981;
            
            --radius-lg:    24px;
            --radius-md:    16px;
            --radius-sm:    12px;
            
            --shadow-sm:    0 1px 3px rgba(0, 0, 0, 0.05);
            --shadow-md:    0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --shadow-lg:    0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.02);
            --shadow-float: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--bg);
            color: var(--text-main);
            overflow-x: hidden;
            min-height: 100vh;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        /* Container */
        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 2rem;
            position: relative;
            z-index: 1;
        }

        /* Back Button */
        .back-button {
            margin: 2rem 0;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 40px;
            padding: 0.6rem 1.25rem;
            font-weight: 500;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.2s;
            color: var(--text-muted);
            box-shadow: var(--shadow-sm);
            text-decoration: none;
        }
        .back-button:hover {
            transform: translateX(-4px);
            color: var(--accent-blue);
            border-color: var(--border);
            box-shadow: var(--shadow-md);
        }

        /* Main Layout */
        .main-layout {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 2.5rem;
            padding-bottom: 4rem;
        }

        /* Hero Section */
        .hero-section {
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            background: var(--surface);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-md);
            margin-bottom: 2rem;
            border: 1px solid var(--border);
        }

        .video-container {
            position: relative;
            width: 100%;
            max-width: 800px; /* Set a maximum width for the video container */
            margin: 0 auto; /* Center the video container */
            padding-top: 56.25%; /* Maintain 16:9 aspect ratio */
            background: #000;
            cursor: pointer;
            overflow: hidden;
            border-radius: var(--radius-lg); /* Add rounded corners */
        }
        .video-preview {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            object-fit: contain; /* Ensure the video maintains its aspect ratio */
            background-color: black; /* Add black background for letterboxing */
            opacity: 1; /* Ensure full visibility */
            transition: opacity 0.3s;
        }
        .video-container:hover .video-preview { opacity: 0.7; }

        .play-button {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 72px; height: 72px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(8px);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }
        .video-container:hover .play-button { transform: translate(-50%, -50%) scale(1.1); background: #fff; }
        .play-icon {
            width: 0; height: 0;
            border-left: 22px solid var(--accent-blue);
            border-top: 14px solid transparent;
            border-bottom: 14px solid transparent;
            margin-left: 6px;
        }

        .course-header { padding: 2.5rem; }

        .course-badge {
            display: inline-block;
            background: var(--accent-light);
            color: var(--accent-blue);
            border-radius: 20px;
            padding: 0.4rem 1rem;
            font-weight: 700;
            font-size: 0.8rem;
            margin-bottom: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .course-title {
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 1rem;
            line-height: 1.2;
            color: var(--text-main);
        }

        .course-subtitle {
            font-size: 1.1rem;
            color: var(--text-muted);
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        .course-meta {
            display: flex; flex-wrap: wrap; gap: 1.5rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid var(--border);
        }
        .meta-item { display: flex; align-items: center; gap: 0.5rem; font-weight: 500; color: var(--text-muted); font-size: 0.95rem; }
        .meta-item .material-icons { color: var(--accent-blue); font-size: 20px; }
        .rating-stars { color: var(--warning-star); display: flex; gap: 0.1rem; }

        .instructor-info { display: flex; align-items: center; gap: 1rem; margin-top: 2rem; }
        .instructor-avatar { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; }
        .instructor-details h4 { font-weight: 600; color: var(--text-main); font-size: 1rem; }
        .instructor-details p { color: var(--text-muted); font-size: 0.85rem; }

        /* Content Sections */
        .content-section {
            background: var(--surface);
            border-radius: var(--radius-lg);
            padding: 2.5rem;
            box-shadow: var(--shadow-md);
            margin-bottom: 2rem;
            border: 1px solid var(--border);
        }
        .section-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--text-main); }
        .section-subtitle { font-size: 1.2rem; font-weight: 600; margin: 2rem 0 1rem; color: var(--text-main); }

        /* What You'll Learn */
        .learning-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; }
        .learning-item {
            display: flex; gap: 0.75rem; padding: 1rem;
            background: var(--bg); border-radius: var(--radius-sm);
            border: 1px solid var(--border); transition: all 0.2s;
            align-items: flex-start;
        }
        .learning-item:hover { border-color: var(--accent-blue); box-shadow: var(--shadow-sm); }
        .learning-item .material-icons { color: var(--success); font-size: 20px; flex-shrink: 0; margin-top: 2px;}
        .learning-item span { font-size: 0.95rem; color: var(--text-muted); line-height: 1.5;}

        /* Requirements */
        .requirements-list { list-style: none; }
        .requirements-list li {
            padding: 1rem 0;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 1rem;
            color: var(--text-muted); font-size: 0.95rem;
        }
        .requirements-list li:last-child { border-bottom: none; }
        .requirements-list li::before {
            content: '•'; color: var(--accent-blue); font-size: 1.5rem; font-weight: bold; line-height: 0;
        }

        /* Curriculum */
        .curriculum-item {
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            margin-bottom: 1rem;
            background: var(--surface);
            overflow: hidden;
            transition: all 0.2s;
        }
        .curriculum-header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 1.25rem 1.5rem; cursor: pointer; background: var(--bg); transition: background 0.2s;
        }
        .curriculum-header:hover { background: var(--surface-hover); }
        .curriculum-title { font-weight: 600; font-size: 1.05rem; display: flex; align-items: center; gap: 1rem; color: var(--text-main); }
        .curriculum-meta { color: var(--text-dim); font-size: 0.9rem; }
        .curriculum-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
        .curriculum-item.active .curriculum-content { max-height: 1500px; }
        .curriculum-item.active .expand-icon { transform: rotate(180deg); }
        .expand-icon { transition: transform 0.3s; color: var(--text-dim); }

        .lesson-list { padding: 0.5rem 1.5rem 1.5rem; }
        .lesson-item {
            display: flex; align-items: center; justify-content: space-between;
            padding: 0.85rem 0; border-bottom: 1px solid var(--border);
        }
        .lesson-item:last-child { border-bottom: none; padding-bottom: 0; }
        .lesson-info { display: flex; align-items: center; gap: 0.75rem; color: var(--text-muted); font-size: 0.95rem;}
        .lesson-icon { color: var(--accent-blue); font-size: 18px; }
        .lesson-duration { color: var(--text-dim); font-size: 0.85rem; }

        /* Sidebar & Pricing */
        .sidebar { position: sticky; top: 2rem; height: fit-content; }
        .price-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            padding: 2rem;
            box-shadow: var(--shadow-float);
            border: 1px solid var(--border);
            margin-bottom: 2rem;
        }
        .price-header { text-align: center; padding-bottom: 1.5rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
        .price-current { font-size: 2.8rem; font-weight: 700; color: var(--text-main); line-height: 1;}
        .price-original { font-size: 1.1rem; color: var(--text-dim); text-decoration: line-through; margin-top: 0.25rem; }
        
        .discount-badge-large {
            display: inline-block; background: #fef3c7; color: #b45309;
            border-radius: 6px; padding: 0.25rem 0.75rem; font-weight: 700; font-size: 0.85rem; margin-top: 0.75rem;
        }

        .enroll-button {
            width: 100%;
            background: var(--accent-blue);
            color: white;
            border: none;
            border-radius: var(--radius-md);
            padding: 1.1rem;
            font-weight: 600;
            font-size: 1.05rem;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25);
            margin: 0.5rem 0 1.5rem;
        }
        .enroll-button:hover { background: var(--accent-hover); transform: translateY(-2px); box-shadow: 0 6px 15px rgba(59, 130, 246, 0.35); }

        .guarantee-text { text-align: center; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.5rem; }
        .includes-list { list-style: none; }
        .includes-list li { display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 0; color: var(--text-muted); font-size: 0.9rem;}
        .includes-list .material-icons { color: var(--text-dim); font-size: 18px; }

        /* Reviews Section */
        .reviews-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 2rem; }
        .rating-summary { display: flex; align-items: center; gap: 1.5rem; }
        .rating-number { font-size: 4rem; font-weight: 700; color: var(--text-main); line-height: 1;}
        .rating-details { display: flex; flex-direction: column; gap: 0.25rem; }
        
        .review-card {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 1.5rem;
            margin-bottom: 1rem;
            transition: all 0.2s;
        }
        .review-card:hover { border-color: var(--border-hover); box-shadow: var(--shadow-sm); }
        .review-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
        .reviewer-avatar { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; }
        .reviewer-info h4 { font-weight: 600; font-size: 1rem; color: var(--text-main);}
        .review-rating { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.15rem; }
        .review-date { color: var(--text-dim); font-size: 0.85rem; margin-left: auto; }
        .review-text { color: var(--text-muted); line-height: 1.6; margin-bottom: 1rem; font-size: 0.95rem;}
        
        .review-helpful {
            display: inline-flex; align-items: center; gap: 0.5rem; color: var(--text-muted);
            font-size: 0.85rem; cursor: pointer; padding: 0.4rem 0.75rem; border-radius: 40px;
            background: var(--surface); border: 1px solid var(--border); transition: all 0.2s; user-select: none;
        }
        .review-helpful:hover { background: var(--surface-hover); color: var(--text-main); }
        .review-helpful.liked { color: var(--accent-blue); background: var(--accent-light); border-color: var(--accent-light); }
        .like-icon { font-size: 16px; }

        /* Comment Form */
        .comment-form {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 2rem;
            margin-top: 2rem;
        }
        .form-group { margin-bottom: 1.25rem; }
        .form-group label { display: block; font-weight: 500; margin-bottom: 0.5rem; color: var(--text-main); font-size: 0.95rem;}
        .form-control {
            width: 100%; padding: 0.85rem 1rem; border: 1px solid var(--border);
            border-radius: var(--radius-sm); font-family: 'Outfit', sans-serif; font-size: 0.95rem; transition: all 0.2s;
        }
        .form-control:focus { outline: none; border-color: var(--accent-blue); box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1); }
        textarea.form-control { min-height: 100px; resize: vertical; }

        .rating-input { display: flex; gap: 0.25rem; font-size: 1.8rem; }
        .star-rating { cursor: pointer; color: var(--border-hover); transition: all 0.2s; }
        .star-rating:hover, .star-rating.active { color: var(--warning-star); transform: scale(1.1); }

        .submit-button {
            background: var(--text-main); color: white; border: none; border-radius: var(--radius-sm);
            padding: 0.85rem 2rem; font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: all 0.2s;
        }
        .submit-button:hover { background: #000; transform: translateY(-1px); box-shadow: var(--shadow-sm); }

        /* Custom Success Modal */
        .success-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            animation: fadeIn 0.3s ease;
        }
        .success-modal-overlay.show {
            display: flex;
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .success-modal {
            background: var(--surface);
            border-radius: var(--radius-lg);
            padding: 3rem 2rem;
            text-align: center;
            max-width: 420px;
            box-shadow: var(--shadow-float);
            animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        @keyframes slideUp {
            from { 
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .success-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 1.5rem;
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 2.5rem;
            animation: scaleIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        @keyframes scaleIn {
            from { transform: scale(0.5); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
        .success-modal h2 {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }
        .success-modal p {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 2rem;
            line-height: 1.6;
        }
        .success-progress {
            width: 100%;
            height: 3px;
            background: var(--border);
            border-radius: 2px;
            overflow: hidden;
        }
        .success-progress-bar {
            height: 100%;
            background: linear-gradient(90deg, #10b981 0%, #059669 100%);
            animation: progressBounce 2s ease-in-out forwards;
        }
        @keyframes progressBounce {
            0% { width: 0%; }
            100% { width: 100%; }
        }

        @media (max-width: 1024px) {
            .main-layout { grid-template-columns: 1fr; }
            .sidebar { position: static; }
        }
        @media (max-width: 768px) {
            .container { padding: 0 1rem; }
            .course-header, .content-section, .price-card, .comment-form { padding: 1.5rem; }
            .course-title { font-size: 1.8rem; }
            .rating-summary { flex-direction: column; align-items: flex-start; gap: 1rem;}
            .success-modal {
                padding: 2rem 1.5rem;
                margin: 0 1rem;
            }
        }
    </style>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
</head>

<body>
    <div class="container">
        <a href="/courses" class="back-button">
            <span class="material-icons" style="font-size: 18px;">arrow_back</span>
            Back to Catalog
        </a>

        <div class="main-layout">
            <div class="main-content">
                
                <div class="hero-section">
                    <div class="video-container" onclick="playVideo()">
                        <video id="intro-video" class="video-preview" poster="<%= typeof course !== 'undefined' && course.thumbnailUrl ? course.thumbnailUrl : 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=1200&h=675&fit=crop' %>"></video>
                        <div class="play-button"><div class="play-icon"></div></div>
                    </div>

                    <div class="course-header">
                        <span class="course-badge"><%= typeof course !=='undefined' && course.published ? 'Published' : 'Bestseller' %></span>
                        <h1 class="course-title">
                            <%= typeof course !=='undefined' && course.title ? course.title : 'Complete Web Development Bootcamp 2025' %>
                        </h1>
                        <p class="course-subtitle">
                            <%= typeof course !=='undefined' && course.description ? course.description : 'Become a Full-Stack Web Developer with just ONE course. HTML, CSS, JavaScript, React, Node.js, MongoDB and More!' %>
                        </p>

                        <div class="course-meta">
                            <div class="meta-item">
                                <div class="rating-stars">
                                    <% if (course.rating) { %>
                                        <%- Array(Math.round(course.rating)).fill('★').join('') %><% if (course.rating < 5) { %><span style="color:#e2e8f0;">☆</span><% } %>
                                    <% } else { %>
                                        <span style="color:#e2e8f0;">☆☆☆☆☆</span>
                                    <% } %>
                                </div>
                                <span><%= course.rating ? course.rating.toFixed(1) : '0' %> (<%= course.enrollCount || 0 %> ratings)</span>
                            </div>
                            <div class="meta-item"><span class="material-icons">people</span> <%= course.enrollCount || 0 %> students</div>
                            <div class="meta-item"><span class="material-icons">schedule</span> <%= course.duration ? (course.duration / 60).toFixed(1) : '0' %> hours</div>
                            <div class="meta-item"><span class="material-icons">category</span> <%= course.category || 'General' %></div>
                            <div class="meta-item"><span class="material-icons">school</span> <%= course.level || 'All Levels' %></div>
                        </div>

                       <a href="/profile/<%= course.userId?.username || '' %>" 
   style="
     display: flex;
     align-items: center;
     gap: 16px;
     padding: 14px;
     border-radius: 12px;
     background: #ffffff;
     text-decoration: none;
     color: inherit;
     transition: all 0.3s ease;
     box-shadow: 0 2px 8px rgba(0,0,0,0.06);
   "
   onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 6px 18px rgba(0,0,0,0.12)'"
   onmouseout="this.style.transform='translateY(0px)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'"
>

  <img 
    src="<%= profileUrl && profileUrl.trim() ? profileUrl : '/images/avatar.jpg' %>" 
    alt="<%= course.userId?.fullName || 'Instructor' %>" 
    style="
      width: 70px;
      height: 70px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid #f0f0f0;
      flex-shrink: 0;
    "
    onerror="this.src='/images/avatar.jpg'"
  >

  <div style="display: flex; flex-direction: column; justify-content: center;">
    
    <h4 style="
      margin: 0;
      font-size: 16px;
      font-weight: 600;
      color: #333;
    ">
      Created by <%= course.userId?.fullName || 'Premium Instructor' %>
    </h4>
    
    <p style="
      margin: 4px 0 0;
      font-size: 18px;
      font-weight: 500;
      color: #0073e6;
    ">
      <%= course.userId?.username || 'Instructor' %>
      <span style="color:#777; font-size:14px;"> • Course Creator</span>
    </p>

  </div>

</a>
                    </div>
                </div>

                <div class="content-section">
                    <h2 class="section-title">What you'll learn</h2>
                    <div class="learning-grid">
                        <% if (course && course.learningOutcomes && course.learningOutcomes.length > 0) { %>
                            <% course.learningOutcomes.forEach((outcome) => { %>
                                <div class="learning-item"><span class="material-icons">check_circle</span><span><%= outcome %></span></div>
                            <% }); %>
                        <% } else { %>
                            <div class="learning-item"><span class="material-icons">check_circle</span><span>Complete curriculum with <%= course.modules ? course.modules.length : '0' %> modules</span></div>
                            <div class="learning-item"><span class="material-icons">check_circle</span><span><%= course.duration ? 'Learn in ' + (course.duration / 60).toFixed(1) + ' hours' : 'Comprehensive training' %></span></div>
                            <% if (course.tags && course.tags.length > 0) { %>
                                <% course.tags.slice(0, 4).forEach((tag) => { %>
                                    <div class="learning-item"><span class="material-icons">check_circle</span><span>Master <%= tag %></span></div>
                                <% }); %>
                            <% } else { %>
                                <div class="learning-item"><span class="material-icons">check_circle</span><span>Professional-grade content and best practices</span></div>
                                <div class="learning-item"><span class="material-icons">check_circle</span><span>Real-world projects and practical applications</span></div>
                            <% } %>
                        <% } %>
                    </div>
                </div>

                <div class="content-section">
                    <h2 class="section-title">Requirements</h2>
                    <ul class="requirements-list">
                        <% if (course && course.requirements && course.requirements.length > 0) { %>
                            <% course.requirements.forEach((req) => { %> <li><%= req %></li> <% }); %>
                        <% } else { %>
                            <li>Basic computer knowledge and internet connection</li>
                            <li>Willingness to learn and practice</li>
                        <% } %>
                    </ul>
                </div>

                <div class="content-section">
                    <h2 class="section-title">Course Curriculum</h2>
                    <p id="curriculum-summary" style="margin-bottom:1.5rem; color: var(--text-muted); font-size:0.95rem;">Loading curriculum...</p>
                    <div id="curriculum-container"></div>
                </div>

                <div class="content-section">
                    <h2 class="section-title">Student Reviews</h2>

                    <div class="reviews-header">
                        <div class="rating-summary">
                            <div class="rating-number"><%= (course && course.rating) ? course.rating.toFixed(1) : 'N/A' %></div>
                            <div class="rating-details">
                                <div class="rating-stars" style="font-size:1.2rem;">
                                    <% 
                                        const stars = (course && course.rating) ? Math.round(course.rating) : 0;
                                        for (let i = 0; i < 5; i++) {
                                            if (i < stars) { %>★<% } else { %><span style="color:#e2e8f0;">☆</span><% }
                                        }
                                    %>
                                </div>
                                <p style="color:var(--text-muted); font-size: 0.85rem;"><%= (course && course.enrollCount) ? course.enrollCount + ' ratings' : 'No ratings yet' %></p>
                            </div>
                        </div>
                    </div>

                    <div class="reviews-container">
                        <% if (!course || !course.rating || course.rating === 0) { %>
                            <div style="padding: 2rem; text-align: center; color: var(--text-muted); background: var(--bg); border-radius: 12px; border: 1px solid var(--border);">
                                <p style="font-size: 1.05rem; margin-bottom: 0.5rem; font-weight:500;">No reviews yet</p>
                                <p style="font-size: 0.9rem;">Be the first to review this course!</p>
                            </div>
                        <% } %>
                    </div>

                    <div class="comment-form">
                        <h3 class="section-subtitle" style="margin-top:0;">Leave a Review</h3>
                        <form onsubmit="submitReview(event)">
                            <div class="form-group">
                                <label>Your Rating</label>
                                <div class="rating-input" id="ratingInput">
                                    <span class="star-rating" data-rating="1">☆</span>
                                    <span class="star-rating" data-rating="2">☆</span>
                                    <span class="star-rating" data-rating="3">☆</span>
                                    <span class="star-rating" data-rating="4">☆</span>
                                    <span class="star-rating" data-rating="5">☆</span>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="reviewTitle">Review Title</label>
                                <input type="text" id="reviewTitle" class="form-control" placeholder="Summarize your experience" required>
                            </div>
                            <div class="form-group">
                                <label for="reviewText">Your Review</label>
                                <textarea id="reviewText" class="form-control" placeholder="Share your thoughts about this course..." required></textarea>
                            </div>
                            <button type="submit" class="submit-button">Submit Review</button>
                        </form>
                    </div>
                </div>
            </div>

            <aside class="sidebar">
                <div class="price-card">
                    <div class="price-header">
                        <div class="price-current">₹<%= course && course.price ? course.price.toFixed(2) : '0.00' %></div>
                        <% if (course && course.discountPrice && course.discountPrice > 0) { %>
                            <div class="price-original">$<%= course.discountPrice.toFixed(2) %></div>
                            <div class="discount-badge-large"><%= Math.round((1 - course.price / course.discountPrice) * 100) %>% OFF</div>
                        <% } else if (course && course.price > 0) { %>
                            <div class="price-original">₹<%= (course.price * 1.3).toFixed(2) %></div>
                            <div class="discount-badge-large">Special Offer</div>
                        <% } else { %>
                            <div class="price-original" style="font-size: 1.1rem; color: var(--success); font-weight: 600; text-decoration:none;">FREE COURSE</div>
                        <% } %>
                    </div>

                    <button class="enroll-button" onclick="enrollNow()">Enroll Now</button>
                    <p class="guarantee-text">30-Day Money-Back Guarantee</p>

                    <h3 style="font-weight:600; margin-bottom: 1rem; font-size:1rem;">This course includes:</h3>
                    <ul class="includes-list">
                        <li><span class="material-icons">ondemand_video</span><span><%= course && course.duration ? (course.duration / 60).toFixed(1) : '0' %> hours on-demand video</span></li>
                        <li><span class="material-icons">article</span><span><%= course && course.modules ? course.modules.length : '0' %> modules</span></li>
                        <li><span class="material-icons">file_download</span><span>Downloadable resources</span></li>
                        <li><span class="material-icons">code</span><span>Practical projects & exercises</span></li>
                        <li><span class="material-icons">all_inclusive</span><span>Full lifetime access</span></li>
                        <!-- <li><span class="material-icons">workspace_premium</span><span>Certificate of completion</span></li> -->
                    </ul>
                </div>
            </aside>
        </div>
    </div>

    <script id="course-data" type="application/json">
        <%-JSON.stringify(course || {})%>
    </script>

    <script>
        // Make course data available to JavaScript
        const course = <%- JSON.stringify(course || {}) %>;
        
        // Star rating
        let selectedRating = 0;
        const stars = document.querySelectorAll('.star-rating');

        stars.forEach(star => {
            star.addEventListener('click', function () {
                selectedRating = parseInt(this.dataset.rating);
                updateStarDisplay();
            });
            star.addEventListener('mouseenter', function () {
                highlightStars(parseInt(this.dataset.rating));
            });
        });

        document.getElementById('ratingInput').addEventListener('mouseleave', updateStarDisplay);

        function highlightStars(rating) {
            stars.forEach((star, index) => {
                if (index < rating) {
                    star.textContent = '★'; star.style.color = '#fbbf24';
                } else {
                    star.textContent = '☆'; star.style.color = '#cbd5e1';
                }
            });
        }
        function updateStarDisplay() { highlightStars(selectedRating); }

        // Reviews Loader
        function loadReviews() {
            const courseId = new URLSearchParams(window.location.search).get('courseId');
            if (!courseId) return;

            fetch(`/api/reviews/course/${courseId}`)
                .then(res => res.ok ? res.json() : Promise.reject('Failed to load reviews'))
                .then(data => {
                    const container = document.querySelector('.reviews-container');
                    if (!container) return;

                    container.querySelectorAll('.review-card').forEach(r => r.remove());

                    if (data.reviews && data.reviews.length > 0) {
                        const noMsg = container.querySelector('div[style*="text-align: center"]');
                        if (noMsg) noMsg.remove();

                        data.reviews.forEach(review => {
                            const isLiked = review.isLikedByCurrentUser || false;
                            const html = `
                                <div class="review-card">
                                    <div class="review-header">
<img 
  src="${review.userId?.profilePicUrl && review.userId.profilePicUrl.trim() 
        ? review.userId.profilePicUrl 
        : '/images/avatar.jpg'}" 
  class="reviewer-avatar"
  onerror="this.src='/images/avatar.jpg'"
>                                        <div class="reviewer-info">
                                            <h4>${review.userId ? (review.userId.fullName || review.userId.username || 'Anonymous') : 'Anonymous'}</h4>
                                            <div class="review-rating">
                                                <div class="rating-stars" style="font-size:0.9rem;">
                                                    ${'★'.repeat(review.rating)}<span style="color:#e2e8f0;">${'☆'.repeat(5 - review.rating)}</span>
                                                </div>
                                            </div>
                                        </div>
                                        <span class="review-date">${new Date(review.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                                    </div>
                                    <h5 style="font-weight: 600; margin-bottom: 0.5rem;">${review.title}</h5>
                                    <p class="review-text">${review.reviewText}</p>
                                    <div class="review-helpful ${isLiked ? 'liked' : ''}" onclick="toggleHelpful('${review._id}', this)">
                                        <span class="material-icons like-icon">thumb_up</span>
                                        <span class="helpful-count">${review.helpful}</span>
                                        <span style="margin-left:2px;">helpful</span>
                                    </div>
                                </div>
                            `;
                            container.insertAdjacentHTML('afterbegin', html);
                        });
                    }
                }).catch(console.error);
        }

        function submitReview(event) {
            event.preventDefault();
            if (selectedRating === 0) return alert('Please select a rating!');
            const title = document.getElementById('reviewTitle').value.trim();
            const text = document.getElementById('reviewText').value.trim();
            const courseId = new URLSearchParams(window.location.search).get('courseId');

            if (!title || !text || !courseId) return alert('Missing fields');

            fetch('/api/reviews/submit', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ courseId, rating: selectedRating, title, reviewText: text })
            }).then(res => res.json().then(data => ({ isOk: res.ok, data })))
              .then(result => {
                  if (!result.isOk) return alert(result.data.message || 'Failed to submit review');
                  alert('Review submitted successfully!');
                  loadReviews();
                  event.target.reset();
                  selectedRating = 0; updateStarDisplay();
              }).catch(err => alert('Error submitting review.'));
        }

        function toggleHelpful(reviewId, element) {
            if (element.style.pointerEvents === 'none') return;
            element.style.pointerEvents = 'none';

            fetch(`/api/reviews/${reviewId}/helpful`, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
                .then(res => res.ok ? res.json() : Promise.reject('Failed to update'))
                .then(data => {
                    element.querySelector('.helpful-count').textContent = data.helpfulCount;
                    if (data.isLiked) { element.classList.add('liked'); } 
                    else { element.classList.remove('liked'); }
                })
                .catch(() => alert('Failed to update. Please try again.'))
                .finally(() => element.style.pointerEvents = 'auto');
        }

        function playVideo() { 
            console.log("playing video");
            const video = document.getElementById('intro-video');
            const playButton = document.querySelector('.play-button');
            const videoContainer = document.querySelector('.video-container');
            
            if (!course || !course.introVideoUrl) {
                console.warn('No intro video URL available');
                alert('No preview video available for this course.');
                return;
            }

            const videoUrl = course.introVideoUrl;
            
            // Check if it's a YouTube URL
            const youtubeId = getYouTubeVideoId(videoUrl);
            
            if (youtubeId) {
                // Handle YouTube video
                const youtubeEmbedUrl = `https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0`;
                const iframe = document.createElement('iframe');
                iframe.src = youtubeEmbedUrl;
                iframe.width = '100%';
                iframe.height = '100%';
                iframe.frameBorder = '0';
                iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
                iframe.allowFullscreen = true;
                
                // Replace the video element with iframe
                videoContainer.innerHTML = '';
                videoContainer.appendChild(iframe);
                if (playButton) playButton.style.display = 'none';
                
                console.log('Playing YouTube video:', youtubeEmbedUrl);
            } else {
                // Handle direct video file
                video.src = videoUrl;
                video.style.display = 'block';
                video.play().catch(err => {
                    console.error('Video play failed:', err);
                    
                    // If direct video fails, try to treat it as an embed URL
                    if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
                        const youtubeId = getYouTubeVideoId(videoUrl);
                        if (youtubeId) {
                            const youtubeEmbedUrl = `https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0`;
                            const iframe = document.createElement('iframe');
                            iframe.src = youtubeEmbedUrl;
                            iframe.width = '100%';
                            iframe.height = '100%';
                            iframe.frameBorder = '0';
                            iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
                            iframe.allowFullscreen = true;
                            
                            videoContainer.innerHTML = '';
                            videoContainer.appendChild(iframe);
                            if (playButton) playButton.style.display = 'none';
                            return;
                        }
                    }
                    
                    alert('Unable to play video. The video format may not be supported or the URL may be invalid.');
                });
                if (playButton) playButton.style.display = 'none';
            }
        }

        // Helper function to extract YouTube video ID from various URL formats
        function getYouTubeVideoId(url) {
            if (!url) return null;
            
            // Handle youtube.com URLs
            const youtubeRegex = /(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/;
            const match = url.match(youtubeRegex);
            
            if (match && match[1]) {
                return match[1];
            }
            
            // Handle direct video IDs (11 characters)
            if (/^[a-zA-Z0-9_-]{11}$/.test(url)) {
                return url;
            }
            
            return null;
        }

        // Curriculum Loader
        class CurriculumLoader {
            constructor() {
                this.containerEl = document.getElementById('curriculum-container');
                this.summaryEl = document.getElementById('curriculum-summary');
                this.courseData = this.extractCourseData();
            }
            extractCourseData() {
                try { return JSON.parse(document.getElementById('course-data').textContent); } 
                catch (e) { return null; }
            }
            render() {
                if (!this.courseData || !this.courseData.modules || this.courseData.modules.length === 0) {
                    this.summaryEl.textContent = '0 modules • 0 lessons';
                    this.containerEl.innerHTML = `<div style="padding: 2rem; text-align: center; color: var(--text-muted); background: var(--bg); border-radius: 12px; border: 1px dashed var(--border);">No curriculum available for this course yet.</div>`;
                    return;
                }
                const modules = this.courseData.modules;
                const totalResources = modules.reduce((sum, mod) => sum + (mod.submodules?.length || 0), 0);
                this.summaryEl.textContent = `${modules.length} sections • ${totalResources} lectures`;
                this.containerEl.innerHTML = modules.map((m, i) => this.createModuleElement(m, i)).join('');
                
                this.containerEl.addEventListener('click', e => {
                    const header = e.target.closest('.curriculum-header');
                    if (header) header.closest('.curriculum-item').classList.toggle('active');
                });
            }
            createModuleElement(module, i) {
                const count = module.submodules?.length || 0;
                return `
                    <div class="curriculum-item">
                        <div class="curriculum-header">
                            <div class="curriculum-title">Section ${i + 1}: ${this.escapeHtml(module.unit)}</div>
                            <div style="display:flex; align-items:center; gap:1rem;">
                                <span class="curriculum-meta">${count} lecture${count !== 1 ? 's' : ''}</span>
                                <span class="material-icons expand-icon">expand_more</span>
                            </div>
                        </div>
                        <div class="curriculum-content">
                            <div class="lesson-list">
                                ${count === 0 ? '<p style="color:var(--text-muted); font-size:0.9rem;">No lectures yet.</p>' : 
                                    module.submodules.map(l => `
                                    <div class="lesson-item">
                                        <div class="lesson-info">
                                            <span class="material-icons lesson-icon">${l.type === 'Video' ? 'play_circle' : 'description'}</span>
                                            <span>${this.escapeHtml(l.title)}</span>
                                        </div>
                                        <span class="lesson-duration">${l.duration ? l.duration + ' min' : ''}</span>
                                    </div>`).join('')}
                            </div>
                        </div>
                    </div>`;
            }
            escapeHtml(t) { return (t || '').replace(/[&<>"']/g, m => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;' })[m]); }
        }

        document.addEventListener('DOMContentLoaded', () => {
            new CurriculumLoader().render();
            loadReviews();
            const firstHeader = document.querySelector('.curriculum-item .curriculum-header');
            if (firstHeader) firstHeader.click();
        });

        // Razorpay Enrollment
        function enrollNow() {
            const courseId = '<%= typeof course !== "undefined" ? course._id : "" %>';
            const coursePrice = <%= typeof course !== "undefined" ? (course.price || 0) : 0 %>;
            if (!coursePrice || coursePrice <= 0) {
                alert('This course is not available for purchase');
                return;
            }

            const btn = event.target; const origText = btn.innerHTML;
            btn.innerHTML = 'Processing...'; btn.disabled = true;

            fetch('/api/payments/initiate-payment', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ courseId })
            }).then(res => res.json()).then(data => {
                if (!data.success) throw new Error(data.error || 'Failed to initiate payment');
                const options = {
                    key: data.keyId, amount: data.amount, currency: data.currency,
                    name: 'Premium Learning', description: data.courseName, order_id: data.orderId,
                    prefill: { name: data.studentName, email: data.studentEmail },
                    handler: function(res) {
                        fetch('/api/payments/verify-payment', {
                            method: 'POST', headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ orderId: data.orderId, paymentId: res.razorpay_payment_id, signature: res.razorpay_signature, paymentDocumentId: data.paymentId })
                        }).then(r => r.json()).then(d => {
                            if (d.success) { 
                                showSuccessModal(() => window.location.href = '/my-courses');
                            } 
                            else throw new Error(d.error || 'Verification failed');
                        }).catch(e => { 
                            alert('Verification failed: ' + e.message); 
                            btn.innerHTML = origText; 
                            btn.disabled = false; 
                        });
                    },
                    modal: { ondismiss: function() { btn.innerHTML = origText; btn.disabled = false; } }
                };
                new Razorpay(options).open();
            }).catch(e => { alert('Error: ' + e.message); btn.innerHTML = origText; btn.disabled = false; });
        }
    </script>

    <!-- Custom Success Modal -->
    <div class="success-modal-overlay" id="successModal">
        <div class="success-modal">
            <div class="success-icon">
                <i class="fa-solid fa-check"></i>
            </div>
            <h2>Enrollment Successful! 🎉</h2>
            <p>You have successfully enrolled in this course. Redirecting to your courses...</p>
            <div class="success-progress">
                <div class="success-progress-bar"></div>
            </div>
        </div>
    </div>

    <script>
        function showSuccessModal(callback) {
            const modal = document.getElementById('successModal');
            modal.classList.add('show');
            setTimeout(() => {
                if (callback) callback();
            }, 2000);
        }
    </script>
</body>
</html>
<%-include('footer')%>