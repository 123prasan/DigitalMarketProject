<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
    /* ==========================================================================
       VIDYARI REVIEWS SYSTEM: MATERIAL 3 THEME
       ========================================================================== */
    .v-reviews-master {
        --v-bg: #f0f4f9;
        --v-surface: #ffffff;
        --v-text-main: #202124;
        --v-text-muted: #5f6368;
        
        --v-primary: #0b57d0;
        --v-primary-hover: #0842a0;
        --v-primary-bg: #e8f0fe;
        
        --v-warning: #fbbc04; /* Star Yellow */
        --v-border: #dadce0;
        
        --v-font-display: 'Outfit', sans-serif;
        --v-font-sans: 'Inter', sans-serif;
        
        --v-radius-sm: 8px;
        --v-radius-md: 12px;
        --v-radius-lg: 24px;
        --v-radius-pill: 9999px;
        
        --v-shadow-sm: 0 1px 3px rgba(60,64,67,0.1);
        --v-shadow-card: 0 4px 12px rgba(60,64,67,0.05);
        --v-transition: all 0.2s cubic-bezier(0.2, 0, 0, 1);

        font-family: var(--v-font-sans);
        color: var(--v-text-main);
        max-width: 1000px;
        margin: 0 auto;
        padding: 24px 0;
    }

    .v-reviews-master * { box-sizing: border-box; }

    /* --- Section Header --- */
    .v-reviews-header {
        font-family: var(--v-font-display);
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .v-reviews-header i { color: var(--v-warning); }

    /* --- Dashboard Grid --- */
    .v-reviews-dashboard {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 40px;
        background: var(--v-surface);
        border: 1px solid var(--v-border);
        border-radius: var(--v-radius-lg);
        padding: 32px;
        box-shadow: var(--v-shadow-card);
        margin-bottom: 40px;
    }

    /* Left: Aggregate Score */
    .v-aggregate-score {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
    .v-avg-number {
        font-family: var(--v-font-display);
        font-size: 4rem;
        font-weight: 700;
        line-height: 1;
        color: var(--v-text-main);
        margin-bottom: 8px;
    }
    .v-stars-display {
        color: var(--v-warning);
        font-size: 1.25rem;
        margin-bottom: 8px;
        display: flex;
        gap: 4px;
    }
    .v-total-count {
        color: var(--v-text-muted);
        font-size: 0.95rem;
        margin-bottom: 24px;
    }
    .v-btn-review {
        background: var(--v-primary);
        color: white;
        border: none;
        border-radius: var(--v-radius-pill);
        padding: 12px 24px;
        font-family: var(--v-font-sans);
        font-weight: 500;
        font-size: 1rem;
        cursor: pointer;
        transition: var(--v-transition);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: 100%;
    }
    .v-btn-review:hover { background: var(--v-primary-hover); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(11,87,208,0.2); }

    /* Right: Distribution Bars */
    .v-distribution {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 12px;
    }
    .v-dist-row {
        display: flex;
        align-items: center;
        gap: 16px;
        font-size: 0.9rem;
        color: var(--v-text-muted);
    }
    .v-dist-stars { width: 50px; text-align: right; font-weight: 500;}
    .v-dist-bar-bg {
        flex: 1;
        height: 8px;
        background: var(--v-bg);
        border-radius: 4px;
        overflow: hidden;
    }
    .v-dist-bar-fill {
        height: 100%;
        background: var(--v-warning);
        border-radius: 4px;
    }
    .v-dist-percent { width: 40px; text-align: right; }

    /* --- Reviews List --- */
    .v-reviews-list {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }
    .v-review-card {
        background: var(--v-surface);
        border: 1px solid var(--v-border);
        border-radius: var(--v-radius-md);
        padding: 24px;
        transition: var(--v-transition);
    }
    .v-review-card:hover { border-color: #d2e3fc; box-shadow: var(--v-shadow-sm); }
    
    .v-review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
    }
    .v-reviewer-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .v-reviewer-avatar {
        width: 40px; height: 40px;
        border-radius: 50%;
        background: var(--v-primary-bg);
        color: var(--v-primary);
        display: flex; align-items: center; justify-content: center;
        font-weight: 600; font-size: 1.1rem;
    }
    .v-reviewer-name { font-weight: 600; font-size: 1.05rem; color: var(--v-text-main); margin-bottom: 2px;}
    .v-review-date { font-size: 0.85rem; color: var(--v-text-muted); }
    
    .v-review-stars { color: var(--v-warning); font-size: 0.95rem; display: flex; gap: 2px;}
    .v-review-stars i.empty { color: var(--v-border); }
    
    .v-review-body {
        font-size: 1rem;
        line-height: 1.6;
        color: var(--v-text-main);
        margin-bottom: 16px;
    }

    .v-review-actions {
        display: flex;
        align-items: center;
        gap: 16px;
        border-top: 1px solid var(--v-border);
        padding-top: 16px;
    }
    .v-helpful-btn {
        background: transparent;
        border: 1px solid var(--v-border);
        color: var(--v-text-muted);
        border-radius: var(--v-radius-pill);
        padding: 6px 16px;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: var(--v-transition);
        display: flex; align-items: center; gap: 6px;
    }
    .v-helpful-btn:hover, .v-helpful-btn.active {
        background: var(--v-primary-bg);
        color: var(--v-primary);
        border-color: transparent;
    }

    /* --- Interactive Rating Modal --- */
    .v-modal-overlay {
        position: fixed; inset: 0; background: rgba(32, 33, 36, 0.6); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center; z-index: 1000;
        opacity: 0; visibility: hidden; transition: opacity 0.2s ease;
    }
    .v-modal-overlay.active { opacity: 1; visibility: visible; }
    
    .v-review-modal {
        background: var(--v-surface); border-radius: var(--v-radius-lg); width: 90%; max-width: 500px;
        padding: 32px; box-shadow: 0 24px 38px rgba(0,0,0,0.14);
        transform: scale(0.95) translateY(10px); transition: transform 0.3s cubic-bezier(0.2, 0, 0, 1);
    }
    .v-modal-overlay.active .v-review-modal { transform: scale(1) translateY(0); }

    .v-modal-title { font-family: var(--v-font-display); font-size: 1.5rem; font-weight: 600; margin-bottom: 8px; text-align: center;}
    .v-modal-subtitle { text-align: center; color: var(--v-text-muted); font-size: 0.95rem; margin-bottom: 24px; }

    /* Interactive Stars */
    .v-interactive-stars {
        display: flex; justify-content: center; gap: 12px; margin-bottom: 24px; flex-direction: row-reverse;
        position: relative;
    }
    .v-interactive-stars input { display: none; }
    .v-interactive-stars label {
        font-size: 3rem; color: #e0e0e0; cursor: pointer;
        transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        position: relative;
        filter: drop-shadow(0 0 0 rgba(251, 191, 36, 0));
        transform: scale(1) rotate(0deg);
    }
    .v-interactive-stars label::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        background: radial-gradient(circle, rgba(251, 191, 36, 0.6) 0%, transparent 70%);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        transition: all 0.6s ease-out;
        z-index: -1;
    }
    .v-interactive-stars label:hover {
        color: #fbbf24 !important;
        transform: scale(1.2) rotate(5deg);
        filter: drop-shadow(0 0 8px rgba(251, 191, 36, 0.8));
        animation: starBounce 0.6s ease-in-out;
    }
    .v-interactive-stars label:hover::before {
        width: 60px;
        height: 60px;
    }
    .v-interactive-stars label:hover ~ label {
        color: #fbbf24 !important;
        transform: scale(1.1) rotate(-2deg);
        filter: drop-shadow(0 0 6px rgba(251, 191, 36, 0.6));
        animation: starPulse 0.8s ease-in-out infinite;
    }
    .v-interactive-stars input:checked ~ label {
        color: #f59e0b !important;
        transform: scale(1.15) rotate(0deg);
        filter: drop-shadow(0 0 12px rgba(245, 158, 11, 1));
        animation: starSelected 0.5s ease-out;
    }
    .v-interactive-stars input:checked ~ label::before {
        width: 50px;
        height: 50px;
        background: radial-gradient(circle, rgba(245, 158, 11, 0.8) 0%, transparent 70%);
    }

    /* Force gold color for Font Awesome stars */
    .v-interactive-stars label i.fa-star,
    .v-interactive-stars label i.fas.fa-star,
    .v-interactive-stars label i.far.fa-star {
        color: inherit !important;
    }
    .v-interactive-stars input:checked ~ label i.fa-star,
    .v-interactive-stars input:checked ~ label i.fas.fa-star,
    .v-interactive-stars input:checked ~ label i.far.fa-star {
        color: #f59e0b !important;
    }
    .v-interactive-stars label:hover i.fa-star,
    .v-interactive-stars label:hover i.fas.fa-star,
    .v-interactive-stars label:hover i.far.fa-star {
        color: #fbbf24 !important;
    }

    /* Star Animation Keyframes */
    @keyframes starBounce {
        0%, 20%, 50%, 80%, 100% { transform: scale(1) rotate(0deg) translateY(0); }
        40% { transform: scale(1.3) rotate(10deg) translateY(-8px); }
        60% { transform: scale(1.1) rotate(-5deg) translateY(-4px); }
    }

    @keyframes starPulse {
        0%, 100% { transform: scale(1) rotate(0deg); opacity: 1; }
        50% { transform: scale(1.05) rotate(2deg); opacity: 0.8; }
    }

    @keyframes starSelected {
        0% { transform: scale(1) rotate(0deg); }
        25% { transform: scale(1.4) rotate(15deg); }
        50% { transform: scale(1.2) rotate(-10deg); }
        75% { transform: scale(1.3) rotate(5deg); }
        100% { transform: scale(1.15) rotate(0deg); }
    }

    /* Add sparkle effect */
    .v-interactive-stars label::after {
        content: '✨';
        position: absolute;
        top: -10px;
        right: -10px;
        font-size: 12px;
        opacity: 0;
        transform: scale(0) rotate(0deg);
        transition: all 0.4s ease-out;
        pointer-events: none;
    }
    .v-interactive-stars input:checked ~ label::after {
        opacity: 1;
        transform: scale(1) rotate(360deg);
        animation: sparkle 1s ease-out infinite;
    }

    @keyframes sparkle {
        0%, 100% { transform: scale(1) rotate(0deg); opacity: 1; }
        50% { transform: scale(1.2) rotate(180deg); opacity: 0.7; }
    }

    /* Enhanced Modal Animations */
    .v-modal-overlay {
        position: fixed; inset: 0; background: rgba(32, 33, 36, 0.6); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center; z-index: 1000;
        opacity: 0; visibility: hidden; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .v-modal-overlay.active {
        opacity: 1; visibility: visible;
        animation: modalBackdrop 0.4s ease-out;
    }

    .v-review-modal {
        background: var(--v-surface); border-radius: var(--v-radius-lg); width: 90%; max-width: 500px;
        padding: 32px; box-shadow: 0 24px 38px rgba(0,0,0,0.14);
        transform: scale(0.7) translateY(50px) rotate(-5deg);
        transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        opacity: 0;
    }
    .v-modal-overlay.active .v-review-modal {
        transform: scale(1) translateY(0) rotate(0deg);
        opacity: 1;
        animation: modalEntrance 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @keyframes modalBackdrop {
        0% { backdrop-filter: blur(0px); background: rgba(32, 33, 36, 0); }
        100% { backdrop-filter: blur(4px); background: rgba(32, 33, 36, 0.6); }
    }

    @keyframes modalEntrance {
        0% { transform: scale(0.7) translateY(50px) rotate(-5deg); opacity: 0; }
        50% { transform: scale(1.05) translateY(-10px) rotate(2deg); opacity: 0.8; }
        100% { transform: scale(1) translateY(0) rotate(0deg); opacity: 1; }
    }

    /* Enhanced Button Animations */
    .v-btn-review {
        background: linear-gradient(135deg, var(--v-primary) 0%, var(--v-primary-hover) 100%);
        color: white;
        border: none;
        border-radius: var(--v-radius-pill);
        padding: 14px 28px;
        font-family: var(--v-font-sans);
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(11, 87, 208, 0.3);
    }
    .v-btn-review::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.5s ease;
    }
    .v-btn-review:hover::before {
        left: 100%;
    }
    .v-btn-review:hover {
        transform: translateY(-2px) scale(1.05);
        box-shadow: 0 8px 25px rgba(11, 87, 208, 0.4);
        animation: buttonGlow 1.5s ease-in-out infinite;
    }
    .v-btn-review:active {
        transform: translateY(0) scale(0.98);
    }

    @keyframes buttonGlow {
        0%, 100% { box-shadow: 0 8px 25px rgba(11, 87, 208, 0.4); }
        50% { box-shadow: 0 8px 25px rgba(11, 87, 208, 0.6), 0 0 30px rgba(11, 87, 208, 0.3); }
    }

    /* Shake Animation for Validation */
    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
        20%, 40%, 60%, 80% { transform: translateX(5px); }
    }

    /* Success Pulse Animation */
    @keyframes successPulse {
        0% { transform: scale(1); box-shadow: 0 4px 15px rgba(11, 87, 208, 0.3); }
        50% { transform: scale(1.05); box-shadow: 0 8px 25px rgba(20, 115, 51, 0.5); }
        100% { transform: scale(1); box-shadow: 0 4px 15px rgba(11, 87, 208, 0.3); }
    }

    /* Confetti Animation */
    .confetti-piece {
        position: fixed;
        top: -10px;
        width: 8px;
        height: 8px;
        z-index: 9999;
        animation: confettiFall linear infinite;
        pointer-events: none;
    }

    @keyframes confettiFall {
        0% {
            transform: translateY(-10px) rotate(0deg);
            opacity: 1;
        }
        100% {
            transform: translateY(100vh) rotate(720deg);
            opacity: 0;
        }
    }

    .v-textarea {
        width: 100%; padding: 16px; border: 1px solid var(--v-border); border-radius: var(--v-radius-md);
        font-family: var(--v-font-sans); font-size: 1rem; color: var(--v-text-main); resize: vertical; min-height: 120px;
        margin-bottom: 24px; transition: var(--v-transition);
    }
    .v-textarea:focus { outline: none; border-color: var(--v-primary); box-shadow: 0 0 0 3px var(--v-primary-bg); }

    .v-modal-actions { display: flex; gap: 12px; }
    .v-modal-btn { flex: 1; padding: 14px; border-radius: var(--v-radius-pill); font-weight: 500; font-size: 1rem; cursor: pointer; border: none; transition: var(--v-transition); }
    .v-btn-cancel { background: var(--v-bg); color: var(--v-text-main); }
    .v-btn-cancel:hover { background: #e4e8ee; }
    .v-btn-submit { background: var(--v-primary); color: white; }
    .v-btn-submit:hover:not(:disabled) { background: var(--v-primary-hover); box-shadow: 0 4px 12px rgba(11,87,208,0.2); }
    .v-btn-submit:disabled { background: var(--v-border); color: white; cursor: not-allowed; }

    /* Mobile Adjustments */
    @media (max-width: 768px) {
        .v-reviews-dashboard { grid-template-columns: 1fr; gap: 24px; padding: 24px; }
        .v-aggregate-score { border-bottom: 1px solid var(--v-border); padding-bottom: 24px; }
    }
</style>

<div class="v-reviews-master">
    
    <h2 class="v-reviews-header"><i class="fa-solid fa-star"></i> Student Reviews</h2>

    <div id="reviewsContainer">
        <p class="text-muted" style="text-align: center; padding: 40px;">Loading reviews...</p>
