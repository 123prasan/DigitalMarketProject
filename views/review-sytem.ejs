<script>
    // Get file ID from URL or pass it as a parameter
    const urlParams = new URLSearchParams(window.location.search);
    const fileId = urlParams.get('fileId') || 'YOUR_DEFAULT_FILE_ID'; // Replace with actual file ID

    const reviewModal = document.getElementById('reviewModal');
    const reviewForm = document.getElementById('reviewForm');
    const submitBtn = document.getElementById('submitReviewBtn');
    const reviewsContainer = document.getElementById('reviewsContainer');

    // Load reviews on page load
    document.addEventListener('DOMContentLoaded', function() {
        loadReviews();
    });

    async function loadReviews() {
        try {
            const response = await fetch(`/api/file-reviews/file/${fileId}`);
            if (!response.ok) throw new Error('Failed to load reviews');
            
            const data = await response.json();
            
            if (data.count === 0) {
                reviewsContainer.innerHTML = `
                    <div style="text-align: center; padding: 40px 20px;">
                        <i class="fa-solid fa-star text-muted" style="font-size: 3rem; margin-bottom: 16px;"></i>
                        <h4 style="color: var(--v-text-muted); margin-bottom: 8px;">No reviews yet</h4>
                        <p style="color: var(--v-text-muted); margin-bottom: 24px;">Be the first to review this document!</p>
                        <button class="v-btn-review" onclick="document.getElementById('reviewModal').classList.add('active')" style="width: auto; padding: 12px 24px;">
                            <i class="fa-regular fa-pen-to-square"></i> Write a Review
                        </button>
                    </div>
                `;
                return;
            }

            // Generate stars HTML
            const generateStars = (rating) => {
                let stars = '';
                for (let i = 1; i <= 5; i++) {
                    stars += `<i class="fa-solid fa-star ${i <= rating ? '' : 'empty'}"></i>`;
                }
                return stars;
            };

            // Generate distribution bars
            const maxCount = Math.max(...Object.values(data.ratingDistribution));
            const distributionHTML = Object.entries(data.ratingDistribution)
                .reverse()
                .map(([stars, count]) => {
                    const percentage = maxCount > 0 ? (count / maxCount) * 100 : 0;
                    return `
                        <div class="v-dist-row">
                            <div class="v-dist-stars">${stars} star</div>
                            <div class="v-dist-bar-bg"><div class="v-dist-bar-fill" style="width: ${percentage}%;"></div></div>
                            <div class="v-dist-percent">${count}</div>
                        </div>
                    `;
                }).join('');

            // Generate reviews list
            const reviewsHTML = data.reviews.map(review => `
                <div class="v-review-card">
                    <div class="v-review-header">
                        <div class="v-reviewer-info">
                            <div class="v-reviewer-avatar">${(review.userId?.fullName || review.userId?.username || 'User').substring(0, 2).toUpperCase()}</div>
                            <div>
                                <div class="v-reviewer-name">${review.userId?.fullName || review.userId?.username || 'Anonymous'}</div>
                                <div class="v-review-date">${new Date(review.createdAt).toLocaleDateString()}</div>
                            </div>
                        </div>
                        <div class="v-review-stars">
                            ${generateStars(review.rating)}
                        </div>
                    </div>
                    <div class="v-review-body">
                        <strong>${review.title}</strong><br>
                        ${review.reviewText}
                    </div>
                    <div class="v-review-actions">
                        <span style="font-size: 0.85rem; color: var(--v-text-muted); margin-right: auto;">Was this helpful?</span>
                        <button class="v-helpful-btn" onclick="markHelpful('${review._id}')">
                            <i class="fa-regular fa-thumbs-up"></i> Yes (${review.helpful || 0})
                        </button>
                        <button class="v-helpful-btn">
                            <i class="fa-regular fa-thumbs-down"></i> No
                        </button>
                    </div>
                </div>
            `).join('');

            reviewsContainer.innerHTML = `
                <div class="v-reviews-dashboard">
                    <div class="v-aggregate-score">
                        <div class="v-avg-number">${data.averageRating.toFixed(1)}</div>
                        <div class="v-stars-display">
                            ${generateStars(Math.round(data.averageRating))}
                        </div>
                        <div class="v-total-count">Based on ${data.count} reviews</div>
                        <button class="v-btn-review" onclick="document.getElementById('reviewModal').classList.add('active')">
                            <i class="fa-regular fa-pen-to-square"></i> Write a Review
                        </button>
                    </div>
                    <div class="v-distribution">
                        ${distributionHTML}
                    </div>
                </div>
                
                <div class="v-reviews-list">
                    ${reviewsHTML}
                </div>
            `;
        } catch (error) {
            console.error('Error loading reviews:', error);
            reviewsContainer.innerHTML = '<p class="text-danger" style="text-align: center;">Error loading reviews. Please try again later.</p>';
        }
    }

    function closeReviewModal() {
        reviewModal.classList.remove('active');
        setTimeout(() => reviewForm.reset(), 300);
    }

    // Close modal on outside click
    reviewModal.addEventListener('click', (e) => {
        if (e.target === reviewModal) closeReviewModal();
    });

    reviewForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const rating = document.querySelector('input[name="rating"]:checked')?.value;
        const title = document.getElementById('reviewTitle').value.trim();
        const text = document.getElementById('reviewText').value;

        if (!rating) {
            alert('Please select a star rating.');
            // Shake animation for stars
            const starsContainer = document.querySelector('.v-interactive-stars');
            starsContainer.style.animation = 'shake 0.5s ease-in-out';
            setTimeout(() => starsContainer.style.animation = '', 500);
            return;
        }

        if (!title || !text) {
            alert('Please fill in all fields.');
            return;
        }

        submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Submitting...';
        submitBtn.disabled = true;

        try {
            const response = await fetch('/api/file-reviews/submit', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    fileId: fileId,
                    rating: parseInt(rating),
                    title,
                    reviewText: text
                })
            });

            const data = await response.json();

            if (response.ok) {
                // Success animation
                submitBtn.innerHTML = '<i class="fa-solid fa-check"></i> Success!';
                submitBtn.style.background = '#137333';
                submitBtn.style.animation = 'successPulse 0.6s ease-out';
                
                // Trigger confetti effect
                createConfetti();
                
                alert('Review submitted successfully!');
                
                setTimeout(() => {
                    closeReviewModal();
                    loadReviews(); // Reload reviews
                }, 2000);
            } else {
                alert(data.message || 'Failed to submit review.');
            }
        } catch (error) {
            console.error('Error submitting review:', error);
            alert('Failed to submit review. Please try again.');
        } finally {
            if (!response?.ok) {
                submitBtn.innerHTML = 'Submit Review';
                submitBtn.disabled = false;
                submitBtn.style.background = '';
                submitBtn.style.animation = '';
            }
        }
    });

    // Mark review as helpful
    async function markHelpful(reviewId) {
        try {
            const response = await fetch(`/api/file-reviews/${reviewId}/helpful`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            });
            if (response.ok) {
                loadReviews(); // Reload reviews to update counts
            }
        } catch (error) {
            console.error('Error marking review helpful:', error);
        }
    }

    // World's Best Confetti Effect Function
    function createConfetti() {
        const colors = ['#fbbf24', '#f59e0b', '#d97706', '#b45309', '#92400e', '#78350f', '#f97316', '#ea580c', '#dc2626', '#b91c1c', '#0b57d0', '#0842a0', '#137333', '#0f5132', '#7c3aed', '#6d28d9'];
        const confettiCount = 150;
        const container = document.body;
        
        for (let i = 0; i < confettiCount; i++) {
            const confetti = document.createElement('div');
            confetti.className = 'confetti-piece';
            confetti.style.left = Math.random() * 100 + 'vw';
            confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
            confetti.style.animationDelay = Math.random() * 3 + 's';
            confetti.style.animationDuration = (Math.random() * 3 + 2) + 's';
            
            // Random shapes for premium effect
            const shapes = ['circle', 'square', 'triangle'];
            const shape = shapes[Math.floor(Math.random() * shapes.length)];
            
            if (shape === 'circle') {
                confetti.style.borderRadius = '50%';
                confetti.style.width = confetti.style.height = Math.random() * 12 + 4 + 'px';
            } else if (shape === 'square') {
                confetti.style.width = confetti.style.height = Math.random() * 10 + 4 + 'px';
            } else {
                confetti.style.width = '0';
                confetti.style.height = '0';
                confetti.style.borderLeft = Math.random() * 8 + 4 + 'px solid transparent';
                confetti.style.borderRight = Math.random() * 8 + 4 + 'px solid transparent';
                confetti.style.borderBottom = Math.random() * 12 + 6 + 'px solid ' + confetti.style.backgroundColor;
                confetti.style.backgroundColor = 'transparent';
            }
            
            container.appendChild(confetti);
            
            setTimeout(() => {
                if (confetti.parentNode) {
                    confetti.parentNode.removeChild(confetti);
                }
            }, 5000);
        }
    }
</script>