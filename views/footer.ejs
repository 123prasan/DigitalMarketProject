<!-- ═══════════════════════════════════════════════════════════
     VIDYARI FOOTER — LUXURY EDITORIAL WHITE THEME
     Drop the <style> + <footer> block into your EJS template.
     Replace <%= new Date().getFullYear() %> with your EJS tag.
     ═══════════════════════════════════════════════════════════ -->

<style>
/* ── FOOTER DESIGN TOKENS (inherits from page if already set) ── */
.vf {
    --ink:        #0e0f11;
    --ink-2:      #3a3d44;
    --ink-3:      #7a7e8a;
    --ink-4:      #b4b8c4;
    --rule:       #e8eaee;
    --rule-light: #f4f5f7;
    --surface:    #ffffff;
    --bg:         #f9fafb;
    --accent:     #1a56f0;
    --accent-2:   #f0f4ff;
    --green:      #0b7a45;
    --serif:      'DM Serif Display', Georgia, serif;
    --sans:       'DM Sans', system-ui, sans-serif;
    --ease-out:   cubic-bezier(0.22, 1, 0.36, 1);
}

/* ── FOOTER SHELL ── */
.vf {
    font-family: var(--sans);
    background: var(--surface);
    border-top: 1px solid var(--rule);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
}

.vf-inner {
    max-width: 1380px;
    margin: 0 auto;
    padding: 0 clamp(16px, 3vw, 40px);
}

/* ── TOP BAND ── */
.vf-top {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 48px;
    padding: 56px 0 48px;
    border-bottom: 1px solid var(--rule-light);
}

/* ── BRAND COLUMN ── */
.vf-brand {}
.vf-logo-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 18px;
}
.vf-logo-img { height: 36px; width: auto; }
.vf-brand-name {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -0.02em;
}

.vf-tagline {
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--ink-2);
    line-height: 1.65;
    max-width: 240px;
    margin-bottom: 24px;
}

.vf-email-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    padding: 8px 14px;
    background: var(--accent-2);
    border: 1px solid rgba(26,86,240,0.15);
    border-radius: 8px;
    transition: all 0.2s var(--ease-out);
}
.vf-email-link:hover {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(26,86,240,0.25);
}
.vf-email-link i { font-size: 0.8rem; }

/* ── LINKS COLUMN ── */
.vf-links-col {}
.vf-col-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 20px;
}

.vf-nav-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px 16px;
    list-style: none;
    padding: 0;
    margin: 0;
}

.vf-nav-link {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--ink-2);
    text-decoration: none;
    padding: 5px 0;
    transition: color 0.15s;
    position: relative;
}
.vf-nav-link::after {
    content: '';
    position: absolute;
    left: 0; bottom: 3px;
    width: 0; height: 1px;
    background: var(--accent);
    transition: width 0.2s var(--ease-out);
}
.vf-nav-link:hover { color: var(--accent); }
.vf-nav-link:hover::after { width: 100%; }

/* ── CONNECT COLUMN ── */
.vf-connect {}

.vf-location {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--ink-3);
    margin-bottom: 24px;
}
.vf-location i { color: var(--accent); }

.vf-socials-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 14px;
}

.vf-socials {
    display: flex;
    gap: 8px;
    list-style: none;
    padding: 0; margin: 0 0 28px;
}

.vf-social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px; height: 38px;
    border-radius: 10px;
    color: var(--ink-2);
    background: var(--rule-light);
    border: 1px solid var(--rule);
    text-decoration: none;
    font-size: 0.95rem;
    transition: all 0.2s var(--ease-out);
}
.vf-social-btn:hover {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 6px 16px rgba(26,86,240,0.2);
}

/* Individual brand colors on hover */
.vf-social-btn.x:hover      { background: #000; border-color: #000; }
.vf-social-btn.li:hover     { background: #0a66c2; border-color: #0a66c2; }
.vf-social-btn.ig:hover     { background: linear-gradient(135deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888); border-color: #dc2743; }
.vf-social-btn.yt:hover     { background: #ff0000; border-color: #ff0000; }

/* ── TRUST BADGES ── */
.vf-badges {
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.vf-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--ink-3);
    background: var(--rule-light);
    border: 1px solid var(--rule);
    padding: 6px 12px;
    border-radius: 8px;
    width: fit-content;
}
.vf-badge i { color: var(--green); font-size: 0.8rem; }

/* ── BOTTOM BAR ── */
.vf-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 0;
    gap: 16px;
    flex-wrap: wrap;
}

.vf-copyright {
    font-size: 0.82rem;
    color: var(--ink-4);
}
.vf-copyright strong { color: var(--ink-3); font-weight: 500; }

.vf-bottom-links {
    display: flex;
    gap: 20px;
    list-style: none;
    padding: 0; margin: 0;
}
.vf-bottom-link {
    font-size: 0.78rem;
    color: var(--ink-4);
    text-decoration: none;
    transition: color 0.15s;
}
.vf-bottom-link:hover { color: var(--accent); }

.vf-made-in {
    font-size: 0.78rem;
    color: var(--ink-4);
    display: flex;
    align-items: center;
    gap: 5px;
}
.vf-made-in .flag { font-size: 1rem; }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
    .vf-top { grid-template-columns: 1fr 1fr; }
    .vf-connect { grid-column: 1 / -1; border-top: 1px solid var(--rule-light); padding-top: 32px; }
    .vf-socials { }
    .vf-badges { flex-direction: row; flex-wrap: wrap; }
}

@media (max-width: 640px) {
    .vf-top { grid-template-columns: 1fr; gap: 36px; }
    .vf-connect { grid-column: auto; border-top: 1px solid var(--rule-light); padding-top: 32px; }
    .vf-bottom { flex-direction: column; align-items: flex-start; gap: 12px; }
    .vf-bottom-links { flex-wrap: wrap; gap: 12px; }
    .vf-tagline { max-width: none; }
}
</style>

