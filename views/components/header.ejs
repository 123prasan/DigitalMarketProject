<!DOCTYPE html>
<html lang="en" data-user-id="<%= typeof uId !== 'undefined' && uId ? uId : '' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= seo && seo.metaTags && seo.metaTags.title ? seo.metaTags.title : 'Vidyari - Learn Online' %></title>
    <meta name="description" content="<%= seo && seo.metaTags && seo.metaTags.description ? seo.metaTags.description : 'Online courses and digital resources for learners' %>">
    <meta name="keywords" content="<%= seo && seo.metaTags && seo.metaTags.keywords ? seo.metaTags.keywords : 'online courses, learning, education' %>">
    <meta name="author" content="<%= seo && seo.metaTags && seo.metaTags.author ? seo.metaTags.author : 'Vidyari Team' %>">
    <meta name="robots" content="<%= seo && seo.metaTags && seo.metaTags.robots ? seo.metaTags.robots : 'index, follow' %>">
    
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3321203820490717" crossorigin="anonymous"></script>
    <meta name="google-site-verification" content="Hcnu9BHn9udbxOrSebP2NCm4kTf0IwYg9mStgcwI0BU" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <link rel="icon" type="image/svg+xml" href="/images/logo.svg">
    <link rel="alternate icon" type="image/png" href="/images/logo.png">
    <link rel="manifest" href="/manifest.json">
    
    <meta property="og:title" content="<%= seo && seo.metaTags && seo.metaTags.ogTitle ? seo.metaTags.ogTitle : 'Vidyari' %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.vidyari.com/">
    <meta property="og:image" content="<%= seo && seo.metaTags && seo.metaTags.ogImage ? seo.metaTags.ogImage : 'https://www.vidyari.com/images/logo.svg' %>">
    <meta property="og:description" content="<%= seo && seo.metaTags && seo.metaTags.ogDescription ? seo.metaTags.ogDescription : 'Vidyari - Learn online' %>">
    <meta property="og:site_name" content="Vidyari">
    
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= seo && seo.metaTags && seo.metaTags.ogTitle ? seo.metaTags.ogTitle : 'Vidyari' %>">
    <meta name="twitter:description" content="<%= seo && seo.metaTags && seo.metaTags.ogDescription ? seo.metaTags.ogDescription : 'Learn from experts' %>">
    <meta name="twitter:image" content="<%= seo && seo.metaTags && seo.metaTags.ogImage ? seo.metaTags.ogImage : 'https://www.vidyari.com/images/logo.svg' %>">
    
    <% if (seo && seo.schemas && seo.schemas.length > 0) { %>
      <% seo.schemas.forEach(schema => { %>
        <script type="application/ld+json">
          <%- JSON.stringify(schema, null, 2) %>
        </script>
      <% }); %>
    <% } %>

    <style>
        /* ------------------------------------------------------------------- */
        /* ---------------- SOLID & ANIMATED THEME VARIABLES ----------------- */
        /* ------------------------------------------------------------------- */

        :root {
            --font-main: 'Outfit', 'Inter', sans-serif;
            --bg-main: #f4f7f9;        
            --bg-surface: #ffffff;     
            
            --primary: #0b57d0;        
            --primary-bg: #e8f0fe;     
            --primary-hover: #1a73e8;
            --primary-glow: rgba(11, 87, 208, 0.15);
            
            --text-main: #0f172a; /* Slate 900 */
            --text-muted: #475569; /* Slate 600 */
            --border: #e2e8f0;
            --border-strong: #cbd5e1;
            
            --radius-pill: 9999px;
            --radius-card: 24px;
            --radius-sm: 12px;
            
            /* Enhanced Solid Shadows */
            --shadow-solid: 0 4px 6px -1px rgba(15, 23, 42, 0.05), 0 2px 4px -2px rgba(15, 23, 42, 0.05);
            --shadow-float: 0 10px 25px -5px rgba(15, 23, 42, 0.1), 0 8px 10px -6px rgba(15, 23, 42, 0.05);
            
            /* Cinematic Transitions */
            --timing-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
            --transition-smooth: 0.3s cubic-bezier(0.2, 0, 0, 1);
        }

        body {
            background-color: var(--bg-main);
            font-family: var(--font-main);
            color: var(--text-main);
            line-height: 1.6;
            margin: 0;
            padding: 0;
            padding-top: 92px;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* ========================================================= */
        /* ANIMATIONS                                                */
        /* ========================================================= */
        @keyframes popIn {
            0% { opacity: 0; transform: scale(0.92) translateY(-10px); }
            100% { opacity: 1; transform: scale(1) translateY(0); }
        }

        @keyframes slideInRight {
            0% { opacity: 0; transform: translateX(-30px); }
            100% { opacity: 1; transform: translateX(0); }
        }

        @keyframes bounceIcon {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-4px); }
        }

        @keyframes heartPulse {
            0% { transform: scale(1); }
            20% { transform: scale(1.35) rotate(-10deg); }
            40% { transform: scale(1); }
            60% { transform: scale(1.35) rotate(10deg); }
            100% { transform: scale(1); }
        }

        /* ========================================================= */
        /* HEADER STYLES                                             */
        /* ========================================================= */
        .site-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            width: 100%;
            background-color: var(--bg-surface);
            z-index: 1020;
            padding: 16px 32px;
            border-bottom: 1px solid var(--border);
            transition: box-shadow var(--transition-smooth), background-color var(--transition-smooth);
        }
        
        .site-header.scrolled {
            box-shadow: var(--shadow-solid);
            background-color: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(12px);
        }
        
        /* Logo */
        .brand-name { 
            font-family: var(--font-main); 
            font-size: 1.8rem; 
            font-weight: 700; 
            color: var(--text-main); 
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
            letter-spacing: -0.5px;
            flex-shrink: 0;
            transition: transform var(--transition-smooth);
        }
        .brand-name:hover { 
            color: var(--primary); 
            transform: scale(1.02);
        }

        /* ========================================================= */
        /* ANIMATED SEARCH BAR                                       */
        /* ========================================================= */
        .header-search-container {
            flex: 1;
            max-width: 480px;
            margin: 0 24px;
            display: flex;
            justify-content: flex-start;
        }
        .header-search-form {
            display: flex;
            align-items: center;
            background-color: var(--bg-main);
            border-radius: var(--radius-pill);
            padding: 12px 24px;
            border: 2px solid transparent;
            transition: width 0.5s var(--timing-bounce), background-color 0.3s, box-shadow 0.3s, border-color 0.3s;
            width: 80%; /* Starts compact */
        }
        .header-search-form:hover {
            background-color: #e2e8f0;
        }
        .header-search-form:focus-within {
            width: 100%; /* Expands with bounce */
            background-color: var(--bg-surface);
            border-color: var(--primary);
            box-shadow: 0 0 0 4px var(--primary-glow), var(--shadow-solid);
            transform: translateY(-1px);
        }
        .search-icon {
            color: var(--text-muted);
            margin-right: 12px;
            font-size: 16px;
            transition: transform 0.4s var(--timing-bounce), color 0.3s;
        }
        .header-search-form:focus-within .search-icon {
            color: var(--primary);
            transform: scale(1.15) rotate(5deg);
        }
        .header-search-input {
            border: none;
            background: transparent;
            outline: none;
            width: 100%;
            font-size: 15px;
            color: var(--text-main);
            font-weight: 500;
        }
        .header-search-input::placeholder {
            color: var(--text-muted);
            font-weight: 400;
        }
        
        /* Mobile Search */
        .mobile-search-container {
            padding: 0 16px;
            margin-bottom: 16px;
        }
        .mobile-search-container .header-search-form {
            width: 100%;
            padding: 14px 20px;
            border: 1px solid var(--border);
            background: var(--bg-surface);
        }

        /* ========================================================= */
        /* ANIMATED MAIN NAVIGATION                                  */
        /* ========================================================= */
        .main-nav {
            display: flex;
            gap: 8px;
            align-items: center;
        }
        .main-nav a {
            color: var(--text-muted); 
            font-weight: 600; 
            font-size: 15px; 
            text-decoration: none;
            padding: 8px 16px;
            position: relative;
            transition: color var(--transition-smooth);
        }
        
        /* Sliding Underline Animation */
        .main-nav a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 3px;
            background: var(--primary);
            border-radius: 4px;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s;
            transform: translateX(-50%);
        }
        
        .main-nav a:hover {
            color: var(--text-main);
        }
        .main-nav a:hover::after {
            width: 80%;
        }
        .main-nav a.active {
            color: var(--primary);
        }
        .main-nav a.active::after {
            width: 100%;
        }
        
        /* ========================================================= */
        /* ACTION ICONS & AVATAR                                     */
        /* ========================================================= */
        .header-actions-group { 
            display: flex;
            align-items: center;
            gap: 12px; 
            flex-shrink: 0;
        }
        
        .icon-btn {
            width: 44px;
            height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: none;
            background: transparent;
            border-radius: 50%; 
            font-size: 20px;
            color: var(--text-muted);
            transition: background 0.3s, color 0.3s;
            cursor: pointer;
            text-decoration: none;
            position: relative;
        }
        .icon-btn:hover {
            background-color: var(--bg-main);
            color: var(--primary);
        }
        /* Icon Bounce on Hover */
        .icon-btn:hover i {
            animation: bounceIcon 0.4s ease;
        }
        
        .icon-btn.active-state {
            background-color: var(--primary-bg);
            color: var(--primary);
        }

        /* Avatar Container */
        .header-avatar-container {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3px; 
            border-radius: 50%;
            border: 2px solid transparent; 
            margin-left: 8px;
            cursor: pointer;
            transition: var(--transition-smooth);
        }
        .header-avatar-container:hover {
            border-color: var(--primary);
            transform: scale(1.05);
            box-shadow: 0 4px 12px var(--primary-glow);
        }
        .user-avatar { 
            width: 40px; 
            height: 40px; 
            border-radius: 50%; 
            object-fit: cover;
        }
        
        /* Wishlist Heart Button */
        .header-icon-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: transparent;
            color: var(--text-main);
            font-size: 20px;
            transition: all var(--transition-smooth);
            cursor: pointer;
            text-decoration: none;
            position: relative;
        }
        
        .header-icon-btn:hover {
            background-color: #fee2e2;
            color: #ef4444;
            transform: scale(1.1);
        }
        
        .header-icon-btn.is-wishlisted {
            color: #ef4444;
        }
        
        .header-icon-btn.is-wishlisted i {
            animation: heartPulse 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        .header-badge {
            background-color: #ef4444 !important;
            color: white;
            border-radius: 50%;
            width: 22px;
            height: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 800;
            position: absolute;
            top: -4px;
            right: -4px;
            box-shadow: 0 4px 8px rgba(239, 68, 68, 0.4);
            border: 2px solid var(--bg-surface);
        }

        /* ========================================================= */
        /* DROPDOWNS & MENUS                                         */
        /* ========================================================= */
        .dropdown-menu {
            border: 1px solid var(--border) !important;
            box-shadow: var(--shadow-float) !important;
            border-radius: var(--radius-card) !important;
            padding: 12px 0 !important;
            margin-top: 16px !important;
            background: var(--bg-surface) !important;
            animation: popIn 0.3s var(--timing-bounce) forwards;
            transform-origin: top right;
            min-width: 260px;
        }

        .dropdown-item {
            font-family: var(--font-main);
            font-weight: 600 !important;
            font-size: 15px !important;
            padding: 14px 24px !important;
            color: var(--text-muted) !important;
            transition: var(--transition-smooth);
            display: flex;
            align-items: center;
        }
        .dropdown-item:hover {
            background-color: var(--bg-main) !important;
            color: var(--primary) !important;
            padding-left: 30px !important; /* Slide right slightly */
        }
        .dropdown-item i { margin-right: 14px; font-size: 18px; transition: transform 0.3s; }
        .dropdown-item:hover i { transform: scale(1.1); }

        /* Apps Grid Dropdown */
        .apps-dropdown { 
            width: 340px; 
            background: var(--bg-surface); 
            border: 1px solid var(--border); 
            border-radius: var(--radius-card); 
            padding: 24px; 
            box-shadow: var(--shadow-float); 
            display: none; 
            position: absolute; 
            top: calc(100% + 16px); 
            right: 0; 
            z-index: 1021; 
            transform-origin: top right;
        }
        .apps-dropdown.is-open { 
            display: block; 
            animation: popIn 0.3s var(--timing-bounce) forwards; 
        }

        .apps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
        .app-item { 
            text-decoration: none; 
            color: var(--text-main); 
            border-radius: var(--radius-sm); 
            padding: 14px 8px; 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            gap: 10px; 
            transition: var(--transition-smooth); 
            border: 1px solid transparent;
        }
        .app-item:hover { 
            background: var(--bg-main); 
            border-color: var(--border);
            transform: translateY(-2px);
            box-shadow: var(--shadow-solid);
        }
        .app-icon { 
            width: 52px; height: 52px; border-radius: 50%;
            display: grid; place-items: center; font-size: 22px; 
            background: var(--bg-surface); color: var(--primary);
            box-shadow: 0 2px 6px rgba(0,0,0,0.06);
            transition: transform 0.3s var(--timing-bounce);
        }
        .app-item:hover .app-icon { 
            background: var(--primary); 
            color: white; 
            transform: scale(1.1); 
            box-shadow: 0 6px 12px var(--primary-glow);
        }
        .app-label { font-size: 13px; font-weight: 600; text-align: center; }

        /* Standard Buttons */
        .btn-custom {
            padding: 12px 28px; 
            border-radius: var(--radius-pill); 
            font-weight: 600; 
            font-size: 15px;
            transition: all 0.3s var(--timing-bounce); 
            cursor: pointer; 
            text-decoration: none; 
            display: inline-flex; 
            align-items: center; 
            justify-content: center;
            border: 2px solid transparent;
        }
        .btn-primary-custom { 
            background-color: var(--primary); 
            color: white; 
            box-shadow: 0 4px 12px var(--primary-glow);
        }
        .btn-primary-custom:hover { 
            background-color: var(--primary-hover); 
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 16px var(--primary-glow);
        }
        .btn-secondary-custom { 
            background-color: white; 
            color: var(--text-main); 
            border-color: var(--border-strong);
        }
        .btn-secondary-custom:hover { 
            background-color: var(--bg-main); 
            border-color: var(--text-main);
            transform: translateY(-2px);
        }

        /* Mobile Hamburger */
        .hamburger-btn { 
            width: 48px; height: 48px; font-size: 24px; border: none; background: transparent; cursor: pointer; color: var(--text-main); border-radius: 50%;
            transition: background 0.3s;
        }
        .hamburger-btn:hover { background-color: var(--bg-main); }
        .hamburger-btn i { transition: transform 0.4s var(--timing-bounce), opacity 0.2s ease; position: relative; }
        .hamburger-btn.is-open .fa-bars { transform: rotate(180deg) scale(0); opacity: 0; }
        .hamburger-btn.is-open .fa-xmark { transform: rotate(0deg) scale(1); opacity: 1; }
        .hamburger-btn .fa-xmark { position: absolute; transform: rotate(-180deg) scale(0); opacity: 0; left: 12px;}

        /* ========================================================= */
        /* STAGGERED MOBILE NAV PANEL                                */
        /* ========================================================= */
        .mobile-nav-panel { 
            width: 320px; background-color: var(--bg-surface); 
            z-index: 1045; transform: translateX(-100%); transition: transform 0.4s var(--timing-bounce); 
            display: flex; flex-direction: column; position: fixed; top: 0; bottom: 0; left: 0; height: 100vh; 
        }
        .mobile-nav-panel.is-open { 
            transform: translateX(0); 
            box-shadow: var(--shadow-float); 
        }
        
        .nav-overlay { background-color: rgba(15, 23, 42, 0.6); transition: opacity 0.4s ease; position: fixed; inset: 0; opacity: 0; pointer-events: none; z-index: 1040; backdrop-filter: blur(4px); }
        .nav-overlay.is-open { opacity: 1; pointer-events: auto; }

        .panel-header { padding: 24px; border-bottom: 1px solid var(--border); flex-shrink: 0; background: var(--bg-surface); }
        .panel-body { padding: 24px 0; flex-grow: 1; overflow-y: auto; background: var(--bg-surface); }
        .panel-footer { padding: 24px; border-top: 1px solid var(--border); flex-shrink: 0; background: var(--bg-main); }
        
        .panel-section { padding: 0 16px; }
        .panel-link { 
            display: flex; align-items: center; gap: 16px; padding: 14px 20px; margin-bottom: 8px; border-radius: var(--radius-sm); 
            color: var(--text-muted); text-decoration: none; font-weight: 600; font-size: 16px; transition: all var(--transition-smooth);
            opacity: 0; /* Starts hidden for stagger animation */
            border: 1px solid transparent;
        }
        
        /* Staggered Animation Trigger */
        .mobile-nav-panel.is-open .panel-link {
            animation: slideInRight 0.4s var(--timing-bounce) forwards;
        }
        .mobile-nav-panel.is-open .panel-section:nth-child(2) .panel-link:nth-child(1) { animation-delay: 0.1s; }
        .mobile-nav-panel.is-open .panel-section:nth-child(2) .panel-link:nth-child(2) { animation-delay: 0.15s; }
        .mobile-nav-panel.is-open .panel-section:nth-child(2) .panel-link:nth-child(3) { animation-delay: 0.2s; }
        .mobile-nav-panel.is-open .panel-section:nth-child(2) .panel-link:nth-child(4) { animation-delay: 0.25s; }
        
        .mobile-nav-panel.is-open .panel-section:nth-child(4) .panel-link:nth-child(1) { animation-delay: 0.3s; }
        .mobile-nav-panel.is-open .panel-section:nth-child(4) .panel-link:nth-child(2) { animation-delay: 0.35s; }
        .mobile-nav-panel.is-open .panel-section:nth-child(4) .panel-link:nth-child(3) { animation-delay: 0.4s; }
        .mobile-nav-panel.is-open .panel-section:nth-child(4) .panel-link:nth-child(4) { animation-delay: 0.45s; }
        .mobile-nav-panel.is-open .panel-section:nth-child(4) .panel-link:nth-child(5) { animation-delay: 0.5s; }
        .mobile-nav-panel.is-open .panel-section:nth-child(4) .panel-link:nth-child(6) { animation-delay: 0.55s; }

        .panel-link:hover, .panel-link.active { 
            background-color: var(--bg-main); 
            color: var(--primary); 
            border-color: var(--border);
            transform: translateX(5px);
        }
        .panel-link i { font-size: 20px; width: 24px; text-align: center; transition: transform 0.3s; }
        .panel-link:hover i { transform: scale(1.1); }

    </style>
</head>

<body>
    <header class="site-header" id="siteHeader">
        <div class="container-fluid d-flex align-items-center justify-content-between">
            
            <a href="/" class="brand-name">
                <img src="/images/logo.svg" alt="Vidyari Logo" height="36" onerror="this.style.display='none'">
                Vidyari
            </a>

            <div class="header-search-container d-none d-md-flex">
                <form action="/search" method="GET" class="header-search-form">
                    <i class="fa-solid fa-magnifying-glass search-icon"></i>
                    <input type="text" name="query" class="header-search-input" placeholder="Search courses, documents..." aria-label="Search">
                    <button type="submit" class="d-none" aria-hidden="true">Search</button>
                </form>
            </div>

            <div class="d-none d-lg-flex align-items-center justify-content-center">
                <nav class="main-nav"> 
                    <a href="/documents">Documents</a>
                    <a href="/courses">Courses</a>
                    <a href="/pricing">Pricing</a>
                    <a href="/about">About Us</a>
                </nav>
            </div>

            <div class="d-flex align-items-center header-actions-group">
                
                <% if(isLoggedin) { %>
                    <button onclick="window.location.href='/user-notifications'" type="button" class="icon-btn d-none d-md-flex" aria-label="Notifications">
                        <i class="fa-regular fa-bell"></i>
                    </button>
                    
                    <div class="chat-popup-wrapper">
                        <a href="/chats" id="chat-icon-btn" class="icon-btn d-none d-md-flex" aria-label="Chats">
                            <i class="fa-regular fa-comments"></i>
                        </a>
                    </div>

                    <div class="position-relative d-none d-md-block" id="grip-container">
                        <button id="grip-button" type="button" class="icon-btn" aria-label="Quick Links">
                            <i class="fa-solid fa-shapes"></i>
                        </button>
                        <div class="apps-dropdown" id="grip-menu">
                          <div class="apps-grid">
                            <a href="/dashboard" class="app-item">
                              <span class="app-icon"><i class="fa-solid fa-store"></i></span>
                              <span class="app-label">Dashboard</span>
                            </a>
                            <a href="/my-courses" class="app-item">
                              <span class="app-icon"><i class="fa-solid fa-book"></i></span>
                              <span class="app-label">My Courses</span>
                            </a>
                            <a href="/downloads" class="app-item">
                              <span class="app-icon"><i class="fa-solid fa-cloud-arrow-down"></i></span>
                              <span class="app-label">Downloads</span>
                            </a>
                            <a href="/transactions" class="app-item">
                              <span class="app-icon"><i class="fa-solid fa-receipt"></i></span>
                              <span class="app-label">Receipts</span>
