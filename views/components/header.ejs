    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>
    <script defer>
    document.addEventListener('DOMContentLoaded', () => {
        
        // Dynamic Header Shadow with blur
        const siteHeader = document.getElementById('siteHeader');
        if (siteHeader) {
            window.addEventListener('scroll', () => {
                if (window.scrollY > 10) siteHeader.classList.add('scrolled');
                else siteHeader.classList.remove('scrolled');
            });
        }

        // Dropdown Toggle Logic
        const gripButton = document.getElementById('grip-button');
        const gripMenu = document.getElementById('grip-menu');
        const gripContainer = document.getElementById('grip-container');
        
        if (gripButton) {
            gripButton.addEventListener('click', (e) => {
                e.stopPropagation();
                gripMenu.classList.toggle('is-open');
                gripButton.classList.toggle('active-state');
            });
            document.addEventListener('click', (e) => {
                if (gripContainer && !gripContainer.contains(e.target)) {
                    gripMenu.classList.remove('is-open');
                    gripButton.classList.remove('active-state');
                }
            });
        }

        // Mobile Nav Logic (Triggers staggered animations)
        const mobileNavPanel = document.getElementById('mobileNavPanel');
        const navOverlay = document.getElementById('navOverlay');
        const hamburgerBtn = document.getElementById('hamburgerBtn');

        const toggleMobileNav = () => {
            const isOpen = mobileNavPanel.classList.toggle('is-open');
            navOverlay.classList.toggle('is-open');
            hamburgerBtn.classList.toggle('is-open'); 
            document.body.style.overflow = isOpen ? 'hidden' : ''; 
        };

        if (hamburgerBtn) hamburgerBtn.addEventListener('click', toggleMobileNav);
        if (navOverlay) navOverlay.addEventListener('click', toggleMobileNav);

        // Avatar Image Caching Logic (Preserved)
        (() => {
            const img = document.getElementById('userAvatar');
            if (!img) return;
            const { userId, profileUrl, avatarVersion } = img.dataset;
            const DEFAULT_AVATAR = '/images/avatar.jpg';
            if (!userId || !profileUrl) { img.src = DEFAULT_AVATAR; return; }
            const CACHE_KEY = `avatar:${userId}`;
            let cached;
            try { cached = JSON.parse(localStorage.getItem(CACHE_KEY)); } catch { localStorage.removeItem(CACHE_KEY); }
            if (cached && cached.url === profileUrl && cached.version === avatarVersion && Date.now() - cached.time < 86400000) {
                img.src = cached.url; return;
            }
            img.src = DEFAULT_AVATAR;
            const testImg = new Image(); testImg.src = profileUrl;
            testImg.onload = () => { img.src = profileUrl; try { localStorage.setItem(CACHE_KEY, JSON.stringify({ url: profileUrl, version: avatarVersion, time: Date.now() })); } catch {} };
            testImg.onerror = () => { img.src = DEFAULT_AVATAR; localStorage.removeItem(CACHE_KEY); };
        })();
    });
    </script>
    
    <% if(isLoggedin) { %>
    <div id="notifyModal" class="modal fade" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content notification-modal-content">
                <div class="modal-header border-0 text-center justify-content-center p-4 pb-0">
                    <div style="width: 64px; height: 64px; background-color: var(--primary-bg); color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28px;">
                        <i class="fa-regular fa-bell"></i>
                    </div>
                </div>
                <div class="modal-body text-center p-4">
                    <h5 class="mb-2" style="font-weight: 700; color: var(--text-main);">Stay Updated!</h5>
                    <p class="mb-0 text-muted" style="font-size: 15px;">
                        Enable notifications to be the first to know about new content, exclusive offers, and important updates.
                    </p>
                </div>
                <div class="modal-footer justify-content-center border-top-0 pt-0 pb-4 px-4 flex-column gap-2">
                    <button type="button" id="allowNotifications" class="btn-custom btn-primary-custom w-100 m-0">Enable Notifications</button>
                    <button type="button" class="btn-custom btn-secondary-custom w-100 m-0 border-0" data-bs-dismiss="modal">Not right now</button>
                </div>
            </div>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/12.4.0/firebase-app.js";
        import { getMessaging, getToken, onMessage } from "https://www.gstatic.com/firebasejs/12.4.0/firebase-messaging.js";
        const firebaseConfig = { apiKey: "AIzaSyCewKKaSGXDAiBPQRYqOtFJ_DV6A-OborA", authDomain: "vidyari-notification.firebaseapp.com", projectId: "vidyari-notification", storageBucket: "vidyari-notification.appspot.com", messagingSenderId: "1061582963767", appId: "1:1061582963767:web:f97da1a865022e6d172bb2" };
        try {
            const app = initializeApp(firebaseConfig);
            const messaging = getMessaging(app);
            if ('serviceWorker' in navigator) { navigator.serviceWorker.register('/firebase-messaging-sw.js').catch(err => console.error(err)); }
            const modalElement = document.getElementById('notifyModal');
            const allowBtn = document.getElementById('allowNotifications');
            let notifyModal; 
            if (!modalElement || !allowBtn) return;
            try { notifyModal = new bootstrap.Modal(modalElement, {backdrop: 'static', keyboard: false}); } catch (e) { return; }
            if (Notification.permission === 'default') { try { notifyModal.show(); } catch(e) {} }
            allowBtn.addEventListener('click', async () => {
                const hideModal = () => { if (notifyModal) { try { notifyModal.hide(); } catch (e) {} } };
                try {
                    const permission = await Notification.requestPermission();
                    if (permission !== 'granted') { hideModal(); return; }
                    const token = await getToken(messaging, { vapidKey: "BHsfuRpT67uCNIc_2p6h5cj0Ze6y09HsR0ZTZsvHaWDz9OjFLC6k2LlVWW7nWZuuBX90IAjwTMSFgQ5Mz2V_pt8" });
                    if (!token) throw new Error('No token.');
                    const response = await fetch('/register-token', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ userId: '<%=uId%>', token }) });
                    if (!response.ok) throw new Error(`Server failed: ${response.status}`);
                    hideModal(); 
                } catch (err) { hideModal(); }
            });
            onMessage(messaging, payload => { if (payload.notification) alert(`Notification: ${payload.notification.title}\n${payload.notification.body}`); });
        } catch (e) {}
    </script>
    <% } %>

    <script src="/js/activity-tracker.js" defer></script>
    <script src="/js/wishlist-manager.js" defer></script>
    <script defer>
        document.addEventListener('DOMContentLoaded', function() {
            const token = localStorage.getItem('token');
            const isLoggedinServer = <%= isLoggedin ? 'true' : 'false' %>;
            const reloadAttempt = sessionStorage.getItem('authReloadAttempt') || '0';
            
            if (parseInt(reloadAttempt) > 2) {
                sessionStorage.removeItem('authReloadAttempt');
                localStorage.removeItem('token'); 
                return;
            }
            
            if (token && !isLoggedinServer && parseInt(reloadAttempt) === 0) {
                fetch('/api/validate-token', {
                    method: 'POST',
                    headers: { 
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => {
                    if (response.ok) {
                        sessionStorage.setItem('authReloadAttempt', '1');
                        window.location.reload();
                    } else {
                        localStorage.removeItem('token');
                        sessionStorage.removeItem('authReloadAttempt');
                    }
                })
                .catch(error => {
                    console.error('Token validation error:', error);
                    localStorage.removeItem('token');
                    sessionStorage.removeItem('authReloadAttempt');
                });
            } else if (parseInt(reloadAttempt) > 0) {
                sessionStorage.removeItem('authReloadAttempt');
            }
            
            if (!token && isLoggedinServer) {
                const userAvatar = document.querySelector('[data-user-id]');
                if (userAvatar?.dataset.userId) {
                    return;
                }
            }
        });
        
        document.addEventListener('DOMContentLoaded', function() {
            try {
                if (typeof ActivityTracker !== 'undefined') {
                    window.ActivityTracker_Instance = new ActivityTracker();
                    window.ActivityTracker_Instance.init({ autoTrack: true });
                }
            } catch (error) {}
        });
    </script>
