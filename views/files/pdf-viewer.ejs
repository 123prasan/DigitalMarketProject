<amp-auto-ads type="adsense"
        data-ad-client="ca-pub-3321203820490717">
</amp-auto-ads>
  <script>
    pdfjsLib.GlobalWorkerOptions.workerSrc =
      'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    /* ═══════════════════════════════════════
       WEB AUDIO ENGINE
    ═══════════════════════════════════════ */
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

    function playPageTurn(dir) {
      try {
        const now = audioCtx.currentTime;
        const sr = audioCtx.sampleRate;
        // ── Layered paper rustle ──
        const bufLen = sr * 0.22;
        const buf = audioCtx.createBuffer(2, bufLen, sr);
        for (let ch = 0; ch < 2; ch++) {
          const d = buf.getChannelData(ch);
          let b0 = 0, b1 = 0, b2 = 0, b3 = 0, b4 = 0, b5 = 0, b6 = 0; // pink noise state
          for (let i = 0; i < bufLen; i++) {
            const wh = Math.random() * 2 - 1;
            b0 = 0.99886 * b0 + wh * 0.0555179; b1 = 0.99332 * b1 + wh * 0.0750759;
            b2 = 0.96900 * b2 + wh * 0.1538520; b3 = 0.86650 * b3 + wh * 0.3104856;
            b4 = 0.55000 * b4 + wh * 0.5329522; b5 = -0.7616 * b5 - wh * 0.0168980;
            const pink = (b0 + b1 + b2 + b3 + b4 + b5 + b6 + wh * 0.5362) / 7;
            b6 = wh * 0.115926;
            const env = Math.pow(1 - i / bufLen, 0.7) * Math.pow(i / bufLen + 0.01, 0.15);
            d[i] = pink * env * (ch === 0 ? 1 : 0.7);
          }
        }
        const src = audioCtx.createBufferSource();
        src.buffer = buf;
        const bp = audioCtx.createBiquadFilter();
        bp.type = 'bandpass';
        bp.frequency.setValueAtTime(dir === 'next' ? 2200 : 1800, now);
        bp.frequency.exponentialRampToValueAtTime(dir === 'next' ? 900 : 1100, now + 0.18);
        bp.Q.value = 0.5;
        const hs = audioCtx.createBiquadFilter();
        hs.type = 'highshelf'; hs.frequency.value = 4000; hs.gain.value = 8;
        const g = audioCtx.createGain();
        g.gain.setValueAtTime(0, now);
        g.gain.linearRampToValueAtTime(0.6, now + 0.008);
        g.gain.exponentialRampToValueAtTime(0.001, now + 0.22);
        // Thud
        const o = audioCtx.createOscillator();
        o.type = 'sine';
        o.frequency.setValueAtTime(220, now + 0.06);
        o.frequency.exponentialRampToValueAtTime(55, now + 0.2);
        const og = audioCtx.createGain();
        og.gain.setValueAtTime(0.2, now + 0.06);
        og.gain.exponentialRampToValueAtTime(0.001, now + 0.25);
        src.connect(bp); bp.connect(hs); hs.connect(g); g.connect(audioCtx.destination);
        o.connect(og); og.connect(audioCtx.destination);
        src.start(now); src.stop(now + 0.24);
        o.start(now + 0.06); o.stop(now + 0.26);
      } catch (e) { }
    }

    function playTap() {
      try {
        const now = audioCtx.currentTime;
        const o = audioCtx.createOscillator();
        o.type = 'sine'; o.frequency.setValueAtTime(900, now);
        o.frequency.exponentialRampToValueAtTime(400, now + 0.06);
        const g = audioCtx.createGain();
        g.gain.setValueAtTime(0.08, now);
        g.gain.exponentialRampToValueAtTime(0.001, now + 0.07);
        o.connect(g); g.connect(audioCtx.destination);
        o.start(now); o.stop(now + 0.08);
      } catch (e) { }
    }

    function playBookmark(on) {
      try {
        const now = audioCtx.currentTime;
        const freqs = on ? [880, 1320] : [660, 440];
        freqs.forEach((f, i) => {
          const o = audioCtx.createOscillator();
          o.type = 'sine'; o.frequency.value = f;
          const g = audioCtx.createGain();
          g.gain.setValueAtTime(0, now + i * 0.06);
          g.gain.linearRampToValueAtTime(0.12, now + i * 0.06 + 0.01);
          g.gain.exponentialRampToValueAtTime(0.001, now + i * 0.06 + 0.12);
          o.connect(g); g.connect(audioCtx.destination);
          o.start(now + i * 0.06); o.stop(now + i * 0.06 + 0.14);
        });
      } catch (e) { }
    }

    function playOpen() {
      try {
        const now = audioCtx.currentTime;
        const sr = audioCtx.sampleRate;
        const bufLen = sr * 0.45;
        const buf = audioCtx.createBuffer(1, bufLen, sr);
        const d = buf.getChannelData(0);
        for (let i = 0; i < bufLen; i++) {
          d[i] = (Math.random() * 2 - 1) * Math.pow(i / bufLen, 0.25) * Math.pow(1 - i / bufLen, 0.6);
        }
        const src = audioCtx.createBufferSource(); src.buffer = buf;
        const lp = audioCtx.createBiquadFilter();
        lp.type = 'lowpass';
        lp.frequency.setValueAtTime(200, now);
        lp.frequency.exponentialRampToValueAtTime(5000, now + 0.35);
        const g = audioCtx.createGain();
        g.gain.setValueAtTime(0.35, now);
        g.gain.exponentialRampToValueAtTime(0.001, now + 0.46);
        // Chime chord
        [523, 659, 784].forEach((f, i) => {
          const o = audioCtx.createOscillator();
          o.type = 'triangle'; o.frequency.value = f;
          const og = audioCtx.createGain();
          og.gain.setValueAtTime(0, now + i * 0.04);
          og.gain.linearRampToValueAtTime(0.06, now + i * 0.04 + 0.02);
          og.gain.exponentialRampToValueAtTime(0.001, now + i * 0.04 + 0.6);
          o.connect(og); og.connect(audioCtx.destination);
          o.start(now + i * 0.04); o.stop(now + i * 0.04 + 0.65);
        });
        src.connect(lp); lp.connect(g); g.connect(audioCtx.destination);
        src.start(now); src.stop(now + 0.48);
      } catch (e) { }
    }

    function resumeAudio() { if (audioCtx.state === 'suspended') audioCtx.resume(); }
    document.addEventListener('touchstart', resumeAudio, { once: true });
    document.addEventListener('click', resumeAudio, { once: true });

    /* ═══════════════════════════════════════
       BIG PICTURE ANIMATION
    ═══════════════════════════════════════ */
    function triggerBigPicture() {
      playOpen();
      const flash = document.getElementById('bp-flash');
      flash.classList.remove('flash'); void flash.offsetWidth;
      flash.classList.add('flash');
      const canvas = document.getElementById('rc');
      canvas.classList.remove('bp-opening'); void canvas.offsetWidth;
      canvas.classList.add('bp-opening');
      canvas.addEventListener('animationend', () => canvas.classList.remove('bp-opening'), { once: true });
    }

    /* ═══════════════════════════════════════
       CANVAS & STATE
    ═══════════════════════════════════════ */
    const rc = document.getElementById('rc');
    const ctx = rc.getContext('2d', { alpha: false, willReadFrequently: false });
    ctx.imageSmoothingEnabled = true; ctx.imageSmoothingQuality = 'high';
    const DPR = window.devicePixelRatio || 1;

    let W = 0, H = 0;
    let pdf = null, total = 0, cur = 1;
    let pageCache = {}, thumbCache = {}, pageTexts = {};
    let theme = 'white', brightness = 1;
    let bookmarks = new Set();
    let pagesRead = new Set();
    let autoReadTimer = null, autoReadOn = false;
    let sessionStart = Date.now();

    function resize() {
      W = window.innerWidth; H = window.innerHeight;
      rc.width = W * DPR; rc.height = H * DPR;
      rc.style.width = W + 'px'; rc.style.height = H + 'px';
    }
    resize();

    function pageBG() {
      return theme === 'sepia' ? '#F0E6C8' : theme === 'night' ? '#161618' : '#F8F3EA';
    }
    function updateAmbient() {
      const colors = {
        white: 'rgba(200,190,255,0.08)',
        sepia: 'rgba(200,160,80,0.08)',
        night: 'rgba(108,99,255,0.15)'
      };
      document.getElementById('amb').style.background =
        `radial-gradient(ellipse 80% 60% at 50% 110%, ${colors[theme]}, transparent 70%)`;
    }
    updateAmbient();

    /* ── Render page ── */
    async function renderPage(n) {
      if (pageCache[n]) return pageCache[n];
      const page = await pdf.getPage(n);
      const vp1 = page.getViewport({ scale: 1 });
      const scale = Math.min((W * DPR) / vp1.width, (H * DPR) / vp1.height);
      const vp = page.getViewport({ scale });
      const oc = document.createElement('canvas');
      oc.width = Math.ceil(vp.width); oc.height = Math.ceil(vp.height);
      const octx = oc.getContext('2d');
      octx.imageSmoothingEnabled = false;
      octx.fillStyle = pageBG();
      octx.fillRect(0, 0, oc.width, oc.height);
      if (brightness < 1) octx.filter = `brightness(${brightness})`;
      await page.render({ canvasContext: octx, viewport: vp }).promise;
      octx.filter = 'none';
      pageCache[n] = { canvas: oc, w: oc.width, h: oc.height };
      return pageCache[n];
    }

    /* ── Page shadow on canvas bg ── */
    function clearBg() {
      ctx.fillStyle = theme === 'night' ? '#0d0d0f' : '#1a1a1e';
      ctx.fillRect(0, 0, W * DPR, H * DPR);
    }

    async function showPage(n) {
      const pc = await renderPage(n);
      clearBg();
      const x = Math.round((W * DPR - pc.w) / 2);
      const y = Math.round((H * DPR - pc.h) / 2);
      // Subtle drop shadow under page
      ctx.shadowColor = 'rgba(0,0,0,0.55)';
      ctx.shadowBlur = 40 * DPR;
      ctx.shadowOffsetY = 8 * DPR;
      ctx.drawImage(pc.canvas, x, y);
      ctx.shadowColor = 'transparent'; ctx.shadowBlur = 0; ctx.shadowOffsetY = 0;
      pagesRead.add(n);
      updateUI();
      preload(n);
      updateBookmarkBtn(n);
    }

    function preload(n) {
      if (n > 1) renderPage(n - 1).catch(() => { });
      if (n < total) renderPage(n + 1).catch(() => { });
    }

    /* ═══════════════════════════════════════
       PAGE-TURN FOLD RENDERER
    ═══════════════════════════════════════ */
    let animRaf = null, swipeDir = null, swipeProg = 0;

    function drawFold(foldXpx, dir) {
      const A = pageCache[cur];
      const B = dir === 'next' ? pageCache[cur + 1] : pageCache[cur - 1];
      if (!A) return;
      const CW = W * DPR, CH = H * DPR;
      const iw = A.w, ih = A.h;
      const cx = (CW - iw) >> 1, cy = (CH - ih) >> 1;
      const creaseL = Math.max(0, Math.min(iw, (foldXpx | 0) - cx));
      clearBg();

      // Drop shadow helper
      function drawShadowedPage(canvas, dx, dy) {
        ctx.shadowColor = 'rgba(0,0,0,0.5)'; ctx.shadowBlur = 30 * DPR; ctx.shadowOffsetY = 6 * DPR;
        ctx.drawImage(canvas, dx, dy);
        ctx.shadowColor = 'transparent'; ctx.shadowBlur = 0; ctx.shadowOffsetY = 0;
      }

      if (dir === 'next') {
        const peeledW = iw - creaseL;
        const t = peeledW / iw;
        if (creaseL > 0) ctx.drawImage(A.canvas, 0, 0, creaseL, ih, cx, cy, creaseL, ih);
        if (peeledW > 0 && B) {
          const bx = (CW - B.w) >> 1, by = (CH - B.h) >> 1;
          ctx.drawImage(B.canvas, creaseL, 0, peeledW, ih, bx + creaseL, by, peeledW, ih);
        }
        if (peeledW > 0) {
          const angle = t * (Math.PI / 2);
          const proj = Math.max(1, (peeledW * Math.cos(angle)) | 0);
          ctx.drawImage(A.canvas, creaseL, 0, peeledW, ih, cx + creaseL - proj, cy, proj, ih);
          // Curl shade
          const shade = ctx.createLinearGradient(cx + creaseL - proj, 0, cx + creaseL, 0);
          shade.addColorStop(0, `rgba(255,255,255,${0.08 * t})`);
          shade.addColorStop(0.5, `rgba(0,0,0,${0.3 * t})`);
          shade.addColorStop(1, `rgba(0,0,0,${0.72 * t})`);
          ctx.fillStyle = shade; ctx.fillRect(cx + creaseL - proj, cy, proj, ih);
          // Specular highlight at curl edge
          const spec = ctx.createLinearGradient(cx + creaseL - proj, 0, cx + creaseL - proj + Math.max(1, proj * 0.15), 0);
          spec.addColorStop(0, `rgba(255,255,255,${0.18 * t})`);
          spec.addColorStop(1, 'rgba(255,255,255,0)');
          ctx.fillStyle = spec; ctx.fillRect(cx + creaseL - proj, cy, proj * 0.15, ih);
          // Shadow on B
          const sw = Math.min(iw * 0.12, peeledW) | 0;
          if (sw > 0) {
            const shadow = ctx.createLinearGradient(cx + creaseL, 0, cx + creaseL + sw, 0);
            shadow.addColorStop(0, `rgba(0,0,0,${0.5 * Math.min(t * 2, 1)})`);
            shadow.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.fillStyle = shadow; ctx.fillRect(cx + creaseL, cy, sw, ih);
          }
        }
      } else {
        const t = creaseL / iw;
        ctx.drawImage(A.canvas, cx, cy);
        if (creaseL > 0 && B) {
          const bx = (CW - B.w) >> 1, by = (CH - B.h) >> 1;
          ctx.drawImage(B.canvas, 0, 0, creaseL, ih, bx, by, creaseL, ih);
          const angle = (1 - t) * (Math.PI / 2);
          const proj = Math.max(1, (creaseL * Math.cos(angle)) | 0);
          ctx.drawImage(B.canvas, B.w - creaseL, 0, creaseL, ih, cx + creaseL, cy, proj, ih);
          // Curl shade
          const shade = ctx.createLinearGradient(cx + creaseL, 0, cx + creaseL + proj, 0);
          shade.addColorStop(0, `rgba(0,0,0,${0.68 * t})`);
          shade.addColorStop(0.5, `rgba(0,0,0,${0.22 * t})`);
          shade.addColorStop(1, `rgba(255,255,255,${0.14 * t})`);
          ctx.fillStyle = shade; ctx.fillRect(cx + creaseL, cy, proj, ih);
          // Specular
          const spec = ctx.createLinearGradient(cx + creaseL + proj - proj * 0.12, 0, cx + creaseL + proj, 0);
          spec.addColorStop(0, 'rgba(255,255,255,0)');
          spec.addColorStop(1, `rgba(255,255,255,${0.2 * t})`);
          ctx.fillStyle = spec; ctx.fillRect(cx + creaseL + proj - proj * 0.12, cy, proj * 0.12, ih);
          // Shadow leftward
          const sw = Math.min(iw * 0.12, creaseL) | 0;
          if (sw > 0) {
            const shadow = ctx.createLinearGradient(cx + creaseL - sw, 0, cx + creaseL, 0);
            shadow.addColorStop(0, 'rgba(0,0,0,0)');
            shadow.addColorStop(1, `rgba(0,0,0,${0.5 * Math.min(t * 2, 1)})`);
            ctx.fillStyle = shadow; ctx.fillRect(cx + creaseL - sw, cy, sw, ih);
          }
        }
      }
    }

    function progToFoldX(p, dir) {
      const A = pageCache[cur];
      if (!A) return (W * DPR) >> 1;
      const cx = ((W * DPR - A.w) >> 1);
      return dir === 'next' ? cx + A.w - (A.w * p) | 0 : cx + (A.w * p) | 0;
    }

    function animateFold(fromP, toP, onDone) {
      if (animRaf) { cancelAnimationFrame(animRaf); animRaf = null; }
      const dir = swipeDir;
      const dist = Math.abs(toP - fromP);
      const ms = Math.max(90, Math.min(dist * 300, 340));
      const t0 = performance.now();
      function frame(ts) {
        const t = Math.min((ts - t0) / ms, 1);
        // Spring-like: ease out with slight bounce feel
        const p = fromP + (toP - fromP) * (1 - Math.pow(1 - t, 3));
        drawFold(progToFoldX(p, dir), dir);
        if (t < 1) { animRaf = requestAnimationFrame(frame); }
        else { animRaf = null; onDone(); }
      }
      animRaf = requestAnimationFrame(frame);
    }

    /* ═══════════════════════════════════════
       TOUCH HANDLING
    ═══════════════════════════════════════ */
    let tStartX = 0, tStartY = 0, tDir = null, tActive = false, tDragging = false, tCurX = 0;
    let edgeTimeout = null;

    document.addEventListener('touchstart', onTS, { passive: true });
    document.addEventListener('touchmove', onTM, { passive: false });
    document.addEventListener('touchend', onTE, { passive: true });

    function onTS(e) {
      if (e.target.closest('#ts,#so,#set,#om,#ls,#ghint')) return;
      if (e.touches.length !== 1 || !pdf) return;
      tStartX = e.touches[0].clientX; tStartY = e.touches[0].clientY; tCurX = tStartX;
      tDir = null; tActive = true; tDragging = false;
      if (animRaf) { cancelAnimationFrame(animRaf); animRaf = null; }
    }

    function onTM(e) {
      if (!tActive || e.touches.length !== 1 || !pdf) return;
      const dx = e.touches[0].clientX - tStartX;
      const dy = e.touches[0].clientY - tStartY;
      tCurX = e.touches[0].clientX;
      if (!tDragging) {
        if (Math.abs(dx) < 6 && Math.abs(dy) < 6) return;
        if (Math.abs(dy) > Math.abs(dx) * 1.3) { tActive = false; return; }
        tDragging = true;
        tDir = dx < 0 ? 'next' : 'prev';
        swipeDir = tDir; swipeProg = 0;
        if (tDir === 'next' && cur >= total) { tActive = false; tDragging = false; showEdgeBounce('right'); return; }
        if (tDir === 'prev' && cur <= 1) { tActive = false; tDragging = false; showEdgeBounce('left'); return; }
        renderPage(tDir === 'next' ? cur + 1 : cur - 1).catch(() => { });
      }
      if (!tDragging) return;
      e.preventDefault();
      const cur_pc = pageCache[cur];
      const pageW = cur_pc ? cur_pc.w / DPR : W;
      const absDx = Math.abs(tCurX - tStartX);
      swipeProg = Math.min(absDx / pageW, 0.98);
      const CW = W * DPR, iw = cur_pc ? cur_pc.w : CW, cx = Math.round((CW - iw) / 2);
      let foldXpx;
      if (tDir === 'next') foldXpx = Math.max(cx, (cx + iw) - absDx * DPR);
      else foldXpx = Math.min(cx + iw, cx + absDx * DPR);
      drawFold(foldXpx, swipeDir);
      // Edge glow
      const el = document.getElementById('edge-l'), er = document.getElementById('edge-r');
      if (tDir === 'prev') { el.style.opacity = Math.min(swipeProg * 2, 0.8) + ''; er.style.opacity = '0'; }
      else { er.style.opacity = Math.min(swipeProg * 2, 0.8) + ''; el.style.opacity = '0'; }
    }

    function onTE(e) {
      document.getElementById('edge-l').style.opacity = '0';
      document.getElementById('edge-r').style.opacity = '0';
      if (!tDragging || !pdf) { tActive = false; return; }
      tActive = false; tDragging = false;
      const threshold = 0.26;
      const startP = swipeProg, dir = swipeDir;
      if (startP >= threshold) {
        playPageTurn(dir);
        animateFold(startP, 1, () => {
          cur = dir === 'next' ? cur + 1 : cur - 1;
          swipeProg = 0; swipeDir = null;
          showPage(cur);
        });
      } else {
        animateFold(startP, 0, () => { swipeProg = 0; swipeDir = null; showPage(cur); });
      }
    }

    function showEdgeBounce(side) {
      const el = document.getElementById(side === 'left' ? 'edge-l' : 'edge-r');
      el.style.transition = 'none'; el.style.opacity = '0.5';
      setTimeout(() => { el.style.transition = 'opacity .4s'; el.style.opacity = '0'; }, 200);
    }

    /* ═══════════════════════════════════════
       CHROME & UI
    ═══════════════════════════════════════ */
    let chromeOn = true, hideT = null;
    function showChrome() {
      clearTimeout(hideT); chromeOn = true;
      document.getElementById('ct').classList.remove('off');
      document.getElementById('cb').classList.remove('off');
      document.getElementById('bm-btn').classList.add('vis');
      document.getElementById('prog-ring').classList.add('vis');
    }
    function hideChrome() {
      chromeOn = false;
      document.getElementById('ct').classList.add('off');
      document.getElementById('cb').classList.add('off');
      document.getElementById('bm-btn').classList.remove('vis');
      // Keep ring visible
    }
    function scheduleHide() { clearTimeout(hideT); hideT = setTimeout(hideChrome, 3500); }

    function ripple(x, y, color = 'rgba(108,99,255,.25)') {
      const d = document.createElement('div');
      d.className = 'ripple';
      d.style.cssText = `left:${x}px;top:${y}px;width:70px;height:70px;background:${color}`;
      document.body.appendChild(d);
      setTimeout(() => d.remove(), 600);
    }

    /* Page number toast */
    let toastT = null;
    function showToast(msg) {
      const t = document.getElementById('pgtoast');
      t.textContent = msg; t.classList.add('show');
      clearTimeout(toastT); toastT = setTimeout(() => t.classList.remove('show'), 1200);
    }

    /* Tap zones */
    document.getElementById('tz-l').addEventListener('click', e => {
      if (!pdf) return;
      ripple(e.clientX, e.clientY);
      playTap();
      if (cur > 1) {
        swipeDir = 'prev';
        renderPage(cur - 1).then(() => {
          playPageTurn('prev');
          animateFold(0, 1, () => { cur--; swipeProg = 0; swipeDir = null; showPage(cur); });
        });
      } else { showEdgeBounce('left'); }
      showChrome(); scheduleHide();
    });
    document.getElementById('tz-r').addEventListener('click', e => {
      if (!pdf) return;
      ripple(e.clientX, e.clientY);
      playTap();
      if (cur < total) {
        swipeDir = 'next';
        renderPage(cur + 1).then(() => {
          playPageTurn('next');
          animateFold(0, 1, () => { cur++; swipeProg = 0; swipeDir = null; showPage(cur); });
        });
      } else { showEdgeBounce('right'); }
      showChrome(); scheduleHide();
    });
    document.getElementById('tz-c').addEventListener('click', () => {
      if (chromeOn) hideChrome(); else { showChrome(); scheduleHide(); }
    });

    /* Button nav */
    document.getElementById('btn-prev').addEventListener('click', () => {
      if (!pdf || cur <= 1) return;
      swipeDir = 'prev';
      renderPage(cur - 1).then(() => { playPageTurn('prev'); animateFold(0, 1, () => { cur--; swipeProg = 0; swipeDir = null; showPage(cur); }); });
      scheduleHide();
    });
    document.getElementById('btn-next').addEventListener('click', () => {
      if (!pdf || cur >= total) return;
      swipeDir = 'next';
      renderPage(cur + 1).then(() => { playPageTurn('next'); animateFold(0, 1, () => { cur++; swipeProg = 0; swipeDir = null; showPage(cur); }); });
      scheduleHide();
    });

    /* Slider with live preview toast */
    const pgSl = document.getElementById('pg-sl');
    pgSl.addEventListener('input', e => {
      const n = parseInt(e.target.value);
      showToast(`${n} / ${total}`);
      // update gradient fill
      const pct = ((n - 1) / (total - 1 || 1)) * 100;
      pgSl.style.backgroundSize = pct + '% 100%';
    });
    pgSl.addEventListener('change', e => {
      const n = parseInt(e.target.value);
      if (n !== cur) { cur = n; showPage(cur); }
      scheduleHide();
    });

    function updateUI() {
      document.getElementById('pg-lbl').textContent = `${cur} / ${total}`;
      pgSl.value = cur;
      const pct = total > 1 ? ((cur - 1) / (total - 1)) * 100 : 0;
      pgSl.style.backgroundSize = pct + '% 100%';
      document.getElementById('mpf').style.width = pct + '%';
      // Progress ring
      const circ = 113; // 2π*18
      const offset = circ - (pct / 100) * circ;
      document.getElementById('pr-fill').style.strokeDashoffset = offset;
      document.getElementById('pr-pct').textContent = Math.round(pct) + '%';
      // Thumbs
      document.querySelectorAll('.tc').forEach(c => c.classList.toggle('cur', parseInt(c.dataset.n) === cur));
      const tc = document.querySelector(`.tc[data-n="${cur}"]`);
      if (tc) tc.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      // Stats
      document.getElementById('st-pages').textContent = pagesRead.size;
      document.getElementById('st-pct').textContent = Math.round(pct) + '%';
      document.getElementById('st-bm').textContent = bookmarks.size;
      // Thumbnail count
      document.getElementById('ts-cnt').textContent = total ? `${total} pages` : '';
    }

    /* ═══════════════════════════════════════
       BOOKMARKS
    ═══════════════════════════════════════ */
    function updateBookmarkBtn(n) {
      const btn = document.getElementById('bm-btn');
      const tgl = document.getElementById('btn-bm-tgl');
      const on = bookmarks.has(n);
      btn.classList.toggle('bm-on', on);
      tgl.querySelector('svg').style.fill = on ? 'var(--accent2)' : 'none';
      tgl.style.color = on ? 'var(--accent2)' : '';
    }

    document.getElementById('bm-btn').addEventListener('click', () => {
      if (!pdf) return;
      const on = bookmarks.has(cur);
      if (on) bookmarks.delete(cur); else bookmarks.add(cur);
      playBookmark(!on);
      updateBookmarkBtn(cur);
      updateUI();
      // Micro-animation: scale pulse
      const btn = document.getElementById('bm-btn');
      btn.style.transform = 'scale(1.35)';
      setTimeout(() => btn.style.transform = '', 200);
    });
    document.getElementById('btn-bm-tgl').addEventListener('click', () => {
      document.getElementById('bm-btn').click();
    });

    /* ═══════════════════════════════════════
       AUTO-READ
    ═══════════════════════════════════════ */
    document.getElementById('btn-auto').addEventListener('click', () => {
      autoReadOn = !autoReadOn;
      const btn = document.getElementById('btn-auto');
      btn.style.color = autoReadOn ? 'var(--accent)' : '';
      btn.querySelector('svg').style.fill = autoReadOn ? 'var(--accent)' : 'none';
      if (autoReadOn) {
        playTap();
        scheduleAutoRead();
      } else {
        clearTimeout(autoReadTimer); autoReadTimer = null;
      }
      scheduleHide();
    });
    function scheduleAutoRead() {
      if (!autoReadOn) return;
      autoReadTimer = setTimeout(() => {
        if (!autoReadOn || !pdf) return;
        if (cur < total) {
          swipeDir = 'next';
          renderPage(cur + 1).then(() => {
            playPageTurn('next');
            animateFold(0, 1, () => { cur++; swipeProg = 0; swipeDir = null; showPage(cur); scheduleAutoRead(); });
          });
        } else {
          autoReadOn = false;
          document.getElementById('btn-auto').style.color = '';
          document.getElementById('btn-auto').querySelector('svg').style.fill = 'none';
        }
      }, 5000);
    }

    /* ═══════════════════════════════════════
       THUMBNAIL STRIP
    ═══════════════════════════════════════ */
    async function renderThumb(n) {
      if (thumbCache[n]) return thumbCache[n];
      const page = await pdf.getPage(n);
      const vp1 = page.getViewport({ scale: 1 });
      const targetH = Math.round(window.innerHeight * 0.52);
      const scale = (targetH / vp1.height) * DPR;
      const vp = page.getViewport({ scale });
      const c = document.createElement('canvas');
      c.width = Math.ceil(vp.width); c.height = Math.ceil(vp.height);
      const tc = c.getContext('2d');
      tc.fillStyle = pageBG(); tc.fillRect(0, 0, c.width, c.height);
      await page.render({ canvasContext: tc, viewport: vp }).promise;
      thumbCache[n] = { canvas: c, w: vp.width / DPR, h: vp.height / DPR };
      return thumbCache[n];
    }

    async function openThumbStrip() {
      document.getElementById('ts').classList.add('open');
      const scroll = document.getElementById('ts-scroll');
      if (scroll.children.length > 0) { updateUI(); return; }
      scroll.innerHTML = '<div class="ts-loading">Generating previews…</div>';
      const frag = document.createDocumentFragment();
      for (let i = 1; i <= total; i++) {
        const card = document.createElement('div');
        card.className = 'tc' + (i === cur ? ' cur' : '');
        card.dataset.n = i;
        card.style.cssText = 'width:110px;height:165px';
        // Bookmark badge
        const nbadge = document.createElement('div');
        nbadge.className = 'tc-n'; nbadge.textContent = i;
        card.appendChild(nbadge);
        card.addEventListener('click', () => {
          playTap();
          document.getElementById('ts').classList.remove('open');
          if (i !== cur) {
            const dir = i > cur ? 'next' : 'prev';
            cur = i; swipeDir = dir;
            renderPage(i).then(() => { playPageTurn(dir); animateFold(0, 1, () => { swipeProg = 0; swipeDir = null; showPage(cur); }); });
          }
        });
        frag.appendChild(card);
      }
      scroll.innerHTML = ''; scroll.appendChild(frag);
      const cards = scroll.querySelectorAll('.tc');
      for (let i = 0; i < cards.length; i++) {
        const n = i + 1;
        const th = await renderThumb(n);
        const card = cards[i];
        const cssW = Math.round(th.w), cssH = Math.round(th.h);
        th.canvas.style.width = cssW + 'px'; th.canvas.style.height = cssH + 'px';
        card.style.width = cssW + 'px'; card.style.height = (cssH + 22) + 'px';
        card.insertBefore(th.canvas, card.querySelector('.tc-n'));
        // Animate in
        card.style.opacity = '0'; card.style.transform = 'scale(0.9) translateY(10px)';
        requestAnimationFrame(() => {
          card.style.transition = `opacity .25s ${i * 0.03}s, transform .25s ${i * 0.03}s cubic-bezier(.34,1.2,.64,1)`;
          card.style.opacity = ''; card.style.transform = '';
        });
      }
      const curCard = scroll.querySelector(`.tc[data-n="${cur}"]`);
      if (curCard) curCard.scrollIntoView({ inline: 'center', block: 'nearest' });
    }

    document.getElementById('btn-pages').addEventListener('click', () => { playTap(); openThumbStrip(); showChrome(); });
    document.getElementById('ts-x').addEventListener('click', () => { playTap(); document.getElementById('ts').classList.remove('open'); });

    /* ═══════════════════════════════════════
       SEARCH
    ═══════════════════════════════════════ */
    let sMatches = [], sIdx = -1;
    document.getElementById('btn-search').addEventListener('click', () => {
      playTap();
      document.getElementById('so').classList.add('open');
      document.getElementById('si').focus();
      showChrome();
    });
    document.getElementById('sc-x').addEventListener('click', closeSearch);
    document.getElementById('so').addEventListener('click', e => { if (e.target === document.getElementById('so')) closeSearch(); });
    document.getElementById('sn-p').addEventListener('click', () => navS(-1));
    document.getElementById('sn-n').addEventListener('click', () => navS(1));

    function closeSearch() {
      document.getElementById('so').classList.remove('open');
      document.getElementById('si').value = '';
      sMatches = []; sIdx = -1; updateSUI();
    }
    let sdt;
    document.getElementById('si').addEventListener('input', e => {
      clearTimeout(sdt); sdt = setTimeout(() => doSearch(e.target.value.trim()), 320);
    });

    async function doSearch(q) {
      sMatches = []; sIdx = -1;
      const sr = document.getElementById('sr');
      if (!q || !pdf) { updateSUI(); sr.innerHTML = ''; return; }
      sr.innerHTML = '<div class="sc-empty">Searching…</div>';
      const lq = q.toLowerCase();
      for (let p = 1; p <= total; p++) {
        if (!pageTexts[p]) {
          const page = await pdf.getPage(p);
          const tc = await page.getTextContent();
          pageTexts[p] = tc.items.map(i => i.str).join(' ');
        }
        const txt = pageTexts[p]; let i = 0;
        while ((i = txt.toLowerCase().indexOf(lq, i)) !== -1) {
          sMatches.push({ page: p, snip: txt.substring(Math.max(0, i - 40), i + q.length + 60), q });
          i += q.length;
        }
      }
      if (sMatches.length) sIdx = 0;
      updateSUI(); renderSResults();
    }

    function renderSResults() {
      const sr = document.getElementById('sr');
      if (!sMatches.length) { sr.innerHTML = '<div class="sc-empty">No results found</div>'; return; }
      sr.innerHTML = sMatches.map((m, i) => {
        const hi = m.snip.replace(new RegExp(m.q, 'gi'), s => `<mark>${s}</mark>`);
        return `<div class="sri" data-i="${i}"><div class="sri-p">Page ${m.page}</div><div class="sri-s">…${hi}…</div></div>`;
      }).join('');
      sr.querySelectorAll('.sri').forEach(el => {
        el.addEventListener('click', () => {
          const m = sMatches[parseInt(el.dataset.i)];
          closeSearch();
          if (m.page !== cur) { const d = m.page > cur ? 'next' : 'prev'; cur = m.page; swipeDir = d; renderPage(cur).then(() => { playPageTurn(d); animateFold(0, 1, () => { swipeProg = 0; swipeDir = null; showPage(cur); }); }); }
        });
      });
    }
    function navS(d) { if (!sMatches.length) return; sIdx = (sIdx + d + sMatches.length) % sMatches.length; updateSUI(); }
    function updateSUI() {
      const ct = document.getElementById('sc-ct'), p = document.getElementById('sn-p'), n = document.getElementById('sn-n');
      if (!sMatches.length) { ct.textContent = sIdx === -1 ? 'Type to search' : 'No results'; p.disabled = n.disabled = true; }
      else { ct.textContent = `${sIdx + 1} of ${sMatches.length}`; p.disabled = n.disabled = false; }
    }

    /* ═══════════════════════════════════════
       SETTINGS
    ═══════════════════════════════════════ */
    document.getElementById('btn-set').addEventListener('click', () => { playTap(); document.getElementById('set').classList.add('open'); showChrome(); });
    document.getElementById('set').addEventListener('click', e => { if (e.target === document.getElementById('set')) { playTap(); document.getElementById('set').classList.remove('open'); } });

    document.querySelectorAll('.th-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        document.querySelectorAll('.th-chip').forEach(c => c.classList.remove('on'));
        chip.classList.add('on');
        theme = chip.dataset.t;
        playTap();
        pageCache = {}; thumbCache = {};
        document.getElementById('ts-scroll').innerHTML = '';
        updateAmbient();
        if (pdf) showPage(cur);
      });
    });

    document.getElementById('br').addEventListener('input', e => {
      brightness = parseInt(e.target.value) / 100;
      pageCache = {};
      if (pdf) showPage(cur);
    });

    /* ═══════════════════════════════════════
       OPEN MODAL
    ═══════════════════════════════════════ */
    async function loadRemoteUrl(url, name) {
      resumeAudio();
      if (!url) throw new Error('Missing remote PDF URL');
      showLoad('Opening PDF…');
      pageCache = {}; thumbCache = {}; pageTexts = {};
      bookmarks = new Set(); pagesRead = new Set();
      document.getElementById('ts-scroll').innerHTML = '';
      pdf = await pdfjsLib.getDocument({ url, withCredentials: false }).promise;
      total = pdf.numPages; cur = 1;
      pgSl.max = total;
      document.getElementById('doc-t').textContent = name || 'Document';
      document.getElementById('doc-s').textContent = total + ' pages';
      document.getElementById('empty').classList.add('gone');
      hideLoad();
      await showPage(1);
      triggerBigPicture();
      showChrome(); scheduleHide();
      if (!localStorage.getItem('pf-hint-seen')) {
        setTimeout(() => { document.getElementById('ghint').classList.add('show'); }, 800);
      }
    }

    async function loadBuf(buf, name) {
      pageCache = {}; thumbCache = {}; pageTexts = {};
      bookmarks = new Set(); pagesRead = new Set();
      document.getElementById('ts-scroll').innerHTML = '';
      pdf = await pdfjsLib.getDocument({ data: buf }).promise;
      total = pdf.numPages; cur = 1;
      pgSl.max = total;
      document.getElementById('doc-t').textContent = name;
      document.getElementById('doc-s').textContent = total + ' pages';
      document.getElementById('empty').classList.add('gone');
      hideLoad();
      await showPage(1);
      triggerBigPicture();
      showChrome(); scheduleHide();
      // Show gesture hint first time
      if (!localStorage.getItem('pf-hint-seen')) {
        setTimeout(() => { document.getElementById('ghint').classList.add('show'); }, 800);
      }
    }

    function showLoad(msg) { document.getElementById('ls').classList.add('on'); document.getElementById('lm').textContent = msg || '…'; }
    function hideLoad() { document.getElementById('ls').classList.remove('on'); }

    const viewerFileUrl = <%- JSON.stringify(pdfDataUrl) %>;
    const viewerFileName = <%- JSON.stringify(fileName) %> || 'Document';

    async function initializeViewer() {
      if (!viewerFileUrl) return;
      document.getElementById('empty').classList.add('gone');
      try {
        await loadRemoteUrl(viewerFileUrl, viewerFileName);
      } catch (err) {
        console.error('Failed to load PDF from viewer:', err);
        hideLoad();
        document.getElementById('empty').classList.remove('gone');
        const docS = document.getElementById('doc-s');
        if (docS) docS.textContent = 'Unable to open document.';
      }
    }

    initializeViewer().catch(err => {
      console.error('PDF viewer init error:', err);
    });

    /* ═══════════════════════════════════════
       GESTURE HINT
    ═══════════════════════════════════════ */
    document.getElementById('ghint-dismiss').addEventListener('click', () => {
      playTap();
      document.getElementById('ghint').classList.remove('show');
      try { localStorage.setItem('pf-hint-seen', '1'); } catch (e) { }
    });

    /* ═══════════════════════════════════════
       KEYBOARD
    ═══════════════════════════════════════ */
    document.addEventListener('keydown', e => {
      if (!pdf) return;
      if (document.activeElement === document.getElementById('si')) return;
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') document.getElementById('btn-next').click();
      if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') document.getElementById('btn-prev').click();
      if (e.key === 'b') document.getElementById('bm-btn').click();
      if ((e.ctrlKey || e.metaKey) && e.key === 'f') { e.preventDefault(); document.getElementById('btn-search').click(); }
    });

    /* ═══════════════════════════════════════
       RESIZE
    ═══════════════════════════════════════ */
    let lastW = window.innerWidth;
    window.addEventListener('resize', () => {
      if (window.innerWidth === lastW) return;
      lastW = window.innerWidth; resize(); pageCache = {}; thumbCache = {};
      if (pdf) showPage(cur);
    });
  </script>
</body>

</html>