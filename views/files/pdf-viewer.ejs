<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no" />
  <title>PageFlow Reader</title>
  <link rel="icon" type="image/png" href="./images/logo.svg" />
      <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3321203820490717" crossorigin="anonymous"></script>
<script async custom-element="amp-auto-ads"
        src="https://cdn.ampproject.org/v0/amp-auto-ads-0.1.js">
</script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    :root {
      --accent: #6C63FF;
      --accent2: #FF6584;
      --chrome: rgba(10, 10, 15, 0.92);
      --glass: rgba(255, 255, 255, 0.06);
      --border: rgba(255, 255, 255, 0.08);
      --txt: rgba(255, 255, 255, 0.9);
      --txt2: rgba(255, 255, 255, 0.45);
      --r: 16px;
    }

    html,
    body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #0d0d0f;
      font-family: 'Inter', sans-serif;
      -webkit-font-smoothing: antialiased;
      touch-action: none;
      color: #fff
    }

    /* ── GRAIN TEXTURE ── */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      opacity: .025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    }

    /* ── CANVAS ── */
    #rc {
      position: fixed;
      top: 0;
      left: 0;
      touch-action: none;
      display: block;
      will-change: transform;
      transform: translateZ(0);
      z-index: 2
    }

    /* ── AMBIENT GLOW (behind canvas, theme-reactive) ── */
    #amb {
      position: fixed;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      transition: background 1.2s ease;
      background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(108, 99, 255, 0.12) 0%, transparent 70%);
    }

    /* ── TAP ZONES ── */
    .tz {
      position: fixed;
      top: 0;
      bottom: 0;
      z-index: 40;
      pointer-events: all;
      -webkit-tap-highlight-color: transparent
    }

    #tz-l {
      left: 0;
      width: 25%
    }

    #tz-c {
      left: 25%;
      right: 25%
    }

    #tz-r {
      right: 0;
      width: 25%
    }

    /* ══════════════════════════ CHROME ══════════════════════════ */
    #ct,
    #cb {
      position: fixed;
      left: 0;
      right: 0;
      z-index: 100;
      background: var(--chrome);
      backdrop-filter: blur(28px) saturate(180%);
      -webkit-backdrop-filter: blur(28px) saturate(180%);
      will-change: transform, opacity;
      transition: transform .38s cubic-bezier(.4, 0, .2, 1), opacity .38s;
    }

    #ct {
      top: 0;
      height: 60px;
      display: flex;
      align-items: center;
      padding: 0 8px;
      gap: 4px;
      border-bottom: 1px solid var(--border);
    }

    #cb {
      bottom: 0;
      display: flex;
      flex-direction: column;
      border-top: 1px solid var(--border);
    }

    #ct.off {
      transform: translateY(-100%);
      opacity: 0;
      pointer-events: none
    }

    #cb.off {
      transform: translateY(100%);
      opacity: 0;
      pointer-events: none
    }

    .ib {
      width: 44px;
      height: 44px;
      border: none;
      background: transparent;
      color: var(--txt);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      flex-shrink: 0;
      -webkit-tap-highlight-color: transparent;
      transition: background .12s, transform .1s, color .2s;
      position: relative;
      overflow: hidden;
    }

    .ib:active {
      background: var(--glass);
      transform: scale(0.9)
    }

    .ib svg {
      transition: transform .2s cubic-bezier(.34, 1.5, .64, 1)
    }

    .ib:active svg {
      transform: scale(0.85)
    }

    .doc-wrap {
      flex: 1;
      min-width: 0;
      padding: 0 8px
    }

    .doc-t {
      font-size: 14px;
      font-weight: 600;
      color: var(--txt);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      letter-spacing: -.01em
    }

    .doc-s {
      font-size: 11px;
      color: var(--txt2);
      letter-spacing: .01em;
      margin-top: 1px
    }

    /* ── SLIDER ROW ── */
    .sl-row {
      display: flex;
      align-items: center;
      padding: 10px 16px;
      gap: 14px
    }

    .pg-lbl {
      font-size: 11px;
      color: var(--txt2);
      white-space: nowrap;
      min-width: 52px;
      text-align: center;
      font-variant-numeric: tabular-nums;
      font-weight: 500
    }

    input.pg-sl {
      flex: 1;
      height: 4px;
      -webkit-appearance: none;
      appearance: none;
      background: rgba(255, 255, 255, 0.12);
      border-radius: 4px;
      outline: none;
      cursor: pointer;
      background-image: linear-gradient(var(--accent), var(--accent));
      background-size: 0% 100%;
      background-repeat: no-repeat;
    }

    input.pg-sl::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: #fff;
      box-shadow: 0 2px 8px rgba(0, 0, 0, .5), 0 0 0 3px rgba(108, 99, 255, .3);
      transition: box-shadow .15s, transform .15s;
    }

    input.pg-sl:active::-webkit-slider-thumb {
      transform: scale(1.25);
      box-shadow: 0 2px 12px rgba(0, 0, 0, .6), 0 0 0 5px rgba(108, 99, 255, .25)
    }

    .act-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 12px 10px;
      gap: 4px
    }

    .act-center {
      display: flex;
      gap: 4px
    }

    /* ── MINI PROGRESS ── */
    #mp {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      z-index: 99;
      pointer-events: none;
      background: rgba(255, 255, 255, 0.06)
    }

    #mpf {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      transition: width .3s cubic-bezier(.4, 0, .2, 1);
      border-radius: 0 2px 2px 0
    }

    /* ── RIPPLE ── */
    .ripple {
      position: fixed;
      border-radius: 50%;
      background: rgba(108, 99, 255, .25);
      pointer-events: none;
      z-index: 50;
      transform: translate(-50%, -50%) scale(0);
      animation: rip .55s cubic-bezier(.4, 0, .2, 1) forwards
    }

    @keyframes rip {
      0% {
        transform: translate(-50%, -50%) scale(0);
        opacity: 1
      }

      100% {
        transform: translate(-50%, -50%) scale(3.5);
        opacity: 0
      }
    }

    /* ── PAGE NUMBER TOAST ── */
    #pgtoast {
      position: fixed;
      left: 50%;
      bottom: 90px;
      transform: translateX(-50%) translateY(10px);
      background: rgba(10, 10, 15, 0.88);
      backdrop-filter: blur(16px);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 8px 18px;
      font-size: 13px;
      font-weight: 600;
      color: #fff;
      pointer-events: none;
      z-index: 150;
      opacity: 0;
      transition: opacity .2s, transform .2s cubic-bezier(.34, 1.3, .64, 1);
      white-space: nowrap;
    }

    #pgtoast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0)
    }

    /* ══════════════════════════ THUMBNAIL STRIP ══════════════════════════ */
    #ts {
      position: fixed;
      inset: 0;
      z-index: 200;
      background: rgba(5, 5, 8, 0.96);
      backdrop-filter: blur(28px);
      -webkit-backdrop-filter: blur(28px);
      display: flex;
      flex-direction: column;
      opacity: 0;
      pointer-events: none;
      transition: opacity .3s cubic-bezier(.4, 0, .2, 1);
      touch-action: none;
      overflow: hidden;
    }

    #ts.open {
      opacity: 1;
      pointer-events: all;
      touch-action: pan-x
    }

    .ts-hdr {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 20px 12px;
      flex-shrink: 0;
      border-bottom: 1px solid var(--border);
    }

    .ts-title {
      font-size: 17px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -.02em
    }

    .ts-cnt {
      font-size: 12px;
      color: var(--txt2);
      margin-top: 2px
    }

    .ts-x {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: none;
      background: var(--glass);
      color: #fff;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      -webkit-tap-highlight-color: transparent;
      transition: background .15s, transform .1s;
      border: 1px solid var(--border);
    }

    .ts-x:active {
      transform: scale(0.88)
    }

    #ts-scroll {
      flex: 1;
      overflow-x: auto;
      overflow-y: hidden;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 20px 24px env(safe-area-inset-bottom, 20px);
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      touch-action: pan-x;
    }

    #ts-scroll::-webkit-scrollbar {
      display: none
    }

    .tc {
      flex-shrink: 0;
      border-radius: 12px;
      overflow: hidden;
      border: 2.5px solid rgba(255, 255, 255, 0.08);
      scroll-snap-align: center;
      cursor: pointer;
      transition: border-color .2s, transform .25s cubic-bezier(.34, 1.3, .64, 1), box-shadow .2s, opacity .2s;
      position: relative;
      background: #111;
      box-shadow: 0 8px 32px rgba(0, 0, 0, .6);
      -webkit-tap-highlight-color: transparent;
      opacity: 0.7;
    }

    .tc.cur {
      border-color: var(--accent);
      box-shadow: 0 8px 32px rgba(108, 99, 255, .4);
      opacity: 1;
      transform: scale(1.06) translateY(-4px)
    }

    .tc:active {
      transform: scale(0.93)
    }

    .tc:not(.cur):hover {
      opacity: 0.9;
      transform: scale(1.03) translateY(-2px)
    }

    .tc canvas {
      display: block
    }

    .tc-n {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(transparent, rgba(0, 0, 0, .85));
      color: #fff;
      font-size: 10px;
      font-weight: 600;
      text-align: center;
      padding: 14px 2px 6px;
      font-variant-numeric: tabular-nums;
      letter-spacing: .02em;
    }

    .ts-loading {
      color: var(--txt2);
      font-size: 13px;
      text-align: center;
      padding: 40px;
      width: 100%;
      font-weight: 500
    }

    /* ══════════════════════════ SEARCH ══════════════════════════ */
    #so {
      position: fixed;
      inset: 0;
      z-index: 200;
      background: rgba(0, 0, 0, .65);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      display: none;
      flex-direction: column;
      align-items: center;
      padding-top: 16px;
    }

    #so.open {
      display: flex
    }

    .sc {
      background: #131318;
      border-radius: 20px;
      width: calc(100% - 32px);
      max-width: 440px;
      overflow: hidden;
      border: 1px solid var(--border);
      animation: popIn .24s cubic-bezier(.34, 1.2, .64, 1);
      box-shadow: 0 24px 80px rgba(0, 0, 0, .6);
    }

    @keyframes popIn {
      from {
        transform: scale(.88) translateY(-12px);
        opacity: 0
      }

      to {
        transform: none;
        opacity: 1
      }
    }

    .sc-top {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 12px 14px 18px;
      border-bottom: 1px solid var(--border)
    }

    .sc-top svg {
      color: var(--txt2);
      flex-shrink: 0
    }

    #si {
      flex: 1;
      border: none;
      background: transparent;
      outline: none;
      font-size: 16px;
      color: #fff;
      font-family: 'Inter', sans-serif;
      padding: 2px 0;
      font-weight: 400
    }

    #si::placeholder {
      color: rgba(255, 255, 255, .2)
    }

    .sc-nav {
      display: flex;
      align-items: center;
      padding: 8px 12px;
      gap: 6px;
      background: rgba(255, 255, 255, .02)
    }

    .sc-ct {
      flex: 1;
      font-size: 12px;
      color: var(--txt2);
      padding-left: 4px;
      font-weight: 500
    }

    .snb {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--glass);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: background .12s, transform .1s;
    }

    .snb:disabled {
      opacity: .2
    }

    .snb:active {
      background: rgba(255, 255, 255, .15);
      transform: scale(0.9)
    }

    #sr {
      max-height: 52vh;
      overflow-y: auto
    }

    #sr::-webkit-scrollbar {
      width: 3px
    }

    #sr::-webkit-scrollbar-track {
      background: transparent
    }

    #sr::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, .1);
      border-radius: 2px
    }

    .sri {
      padding: 12px 18px;
      border-bottom: 1px solid rgba(255, 255, 255, .04);
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: background .1s
    }

    .sri:active {
      background: rgba(255, 255, 255, .05)
    }

    .sri-p {
      font-size: 10px;
      color: var(--accent);
      font-weight: 700;
      margin-bottom: 4px;
      letter-spacing: .06em;
      text-transform: uppercase
    }

    .sri-s {
      font-size: 12px;
      color: rgba(255, 255, 255, .55);
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden
    }

    .sri-s mark {
      background: rgba(108, 99, 255, .3);
      color: #fff;
      border-radius: 3px;
      font-style: normal;
      padding: 0 2px
    }

    .sc-empty {
      padding: 28px;
      text-align: center;
      font-size: 13px;
      color: rgba(255, 255, 255, .2);
      font-weight: 500
    }

    /* ══════════════════════════ SETTINGS ══════════════════════════ */
    #set {
      position: fixed;
      inset: 0;
      z-index: 200;
      background: rgba(0, 0, 0, .55);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      display: none;
      align-items: flex-end;
      justify-content: center
    }

    #set.open {
      display: flex
    }

    .set-sh {
      background: #131318;
      border-radius: 24px 24px 0 0;
      width: 100%;
      max-width: 480px;
      padding-bottom: env(safe-area-inset-bottom, 12px);
      animation: sUp .3s cubic-bezier(.34, 1.1, .64, 1);
      border: 1px solid var(--border);
      border-bottom: none;
    }

    @keyframes sUp {
      from {
        transform: translateY(60px);
        opacity: 0
      }

      to {
        transform: none;
        opacity: 1
      }
    }

    .sh-pill {
      width: 40px;
      height: 4px;
      border-radius: 2px;
      background: rgba(255, 255, 255, .15);
      margin: 14px auto 0
    }

    .sh-lb {
      font-size: 11px;
      font-weight: 700;
      color: var(--txt2);
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 18px 20px 10px
    }

    .th-row {
      display: flex;
      gap: 8px;
      padding: 0 20px 20px
    }

    .th-chip {
      flex: 1;
      height: 52px;
      border-radius: 14px;
      border: 2px solid transparent;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-size: 13px;
      font-weight: 600;
      transition: border-color .2s, transform .15s, box-shadow .2s;
      -webkit-tap-highlight-color: transparent;
    }

    .th-chip:active {
      transform: scale(0.94)
    }

    .th-chip.on {
      border-color: var(--accent);
      box-shadow: 0 4px 20px rgba(108, 99, 255, .25)
    }

    .th-chip[data-t=white] {
      background: #F8F3EA;
      color: #2c2c2c
    }

    .th-chip[data-t=sepia] {
      background: #F0E6C8;
      color: #5A3E1B
    }

    .th-chip[data-t=night] {
      background: #141414;
      color: #888;
      border-color: rgba(255, 255, 255, .1)
    }

    .th-chip[data-t=night].on {
      border-color: var(--accent)
    }

    .sh-div {
      height: 1px;
      background: var(--border);
      margin: 0 20px
    }

    /* Font size row */
    .fs-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 20px 20px
    }

    .fs-btn {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--glass);
      color: #fff;
      font-size: 18px;
      font-weight: 300;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background .12s, transform .1s;
      -webkit-tap-highlight-color: transparent;
      flex-shrink: 0;
    }

    .fs-btn:active {
      transform: scale(0.9);
      background: rgba(255, 255, 255, .12)
    }

    .fs-val {
      flex: 1;
      text-align: center;
      font-size: 15px;
      font-weight: 600;
      color: #fff
    }

    .fs-sub {
      font-size: 11px;
      color: var(--txt2);
      font-weight: 400
    }

    /* brightness row */
    .br-row {
      padding: 0 20px 20px;
      display: flex;
      align-items: center;
      gap: 12px
    }

    .br-icon {
      color: var(--txt2);
      flex-shrink: 0
    }

    input[type=range].br-sl {
      flex: 1;
      height: 4px;
      -webkit-appearance: none;
      appearance: none;
      background: rgba(255, 255, 255, .12);
      border-radius: 4px;
      outline: none;
      cursor: pointer;
      accent-color: var(--accent);
    }

    input[type=range].br-sl::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: #fff;
      box-shadow: 0 2px 6px rgba(0, 0, 0, .4)
    }

    /* reading stats row */
    .stat-row {
      display: flex;
      gap: 0;
      padding: 0 20px 20px
    }

    .stat-box {
      flex: 1;
      background: rgba(255, 255, 255, .04);
      border-radius: 12px;
      padding: 10px 8px;
      text-align: center;
      border: 1px solid var(--border)
    }

    .stat-box+.stat-box {
      margin-left: 8px
    }

    .stat-val {
      font-size: 18px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -.02em
    }

    .stat-lbl {
      font-size: 10px;
      color: var(--txt2);
      font-weight: 600;
      letter-spacing: .05em;
      text-transform: uppercase;
      margin-top: 2px
    }

    /* ══════════════════════════ OPEN MODAL ══════════════════════════ */
    #om {
      position: fixed;
      inset: 0;
      z-index: 300;
      background: rgba(0, 0, 0, .75);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      display: flex;
      align-items: flex-end;
      justify-content: center
    }

    #om.hidden {
      display: none
    }

    .om-sh {
      background: #131318;
      border-radius: 24px 24px 0 0;
      width: 100%;
      max-width: 480px;
      padding-bottom: env(safe-area-inset-bottom, 20px);
      animation: sUp .3s cubic-bezier(.34, 1.1, .64, 1);
      border: 1px solid var(--border);
      border-bottom: none;
    }

    .om-h {
      width: 40px;
      height: 4px;
      border-radius: 2px;
      background: rgba(255, 255, 255, .15);
      margin: 14px auto 0
    }

    .om-hdr {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 20px 0
    }

    .om-ti {
      font-size: 19px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -.02em
    }

    .om-x {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      border: 1px solid var(--border);
      background: var(--glass);
      color: #fff;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background .12s, transform .1s
    }

    .om-x:active {
      transform: scale(0.88)
    }

    .om-tabs {
      display: flex;
      margin: 16px 20px 0;
      background: rgba(255, 255, 255, .05);
      border-radius: 14px;
      padding: 4px;
      gap: 3px
    }

    .om-tab {
      flex: 1;
      padding: 9px;
      border: none;
      background: transparent;
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: rgba(255, 255, 255, .35);
      border-radius: 10px;
      cursor: pointer;
      transition: background .18s, color .18s;
      -webkit-tap-highlight-color: transparent;
      letter-spacing: -.01em
    }

    .om-tab.on {
      background: rgba(255, 255, 255, .12);
      color: #fff
    }

    .om-pn {
      display: none;
      padding: 16px 20px 20px
    }

    .om-pn.on {
      display: block
    }

    /* drop zone */
    .dz {
      border: 2px dashed rgba(255, 255, 255, .1);
      border-radius: 16px;
      padding: 32px 16px;
      text-align: center;
      cursor: pointer;
      transition: border-color .2s, background .2s, transform .15s;
      -webkit-tap-highlight-color: transparent;
      position: relative;
      overflow: hidden;
    }

    .dz::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 14px;
      background: radial-gradient(circle at 50% 0%, rgba(108, 99, 255, .08), transparent 70%);
      opacity: 0;
      transition: opacity .2s;
    }

    .dz:active,
    .dz.ov {
      border-color: var(--accent);
      transform: scale(0.99)
    }

    .dz:active::before,
    .dz.ov::before {
      opacity: 1
    }

    .dz-icon {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: rgba(108, 99, 255, .12);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 14px;
      border: 1px solid rgba(108, 99, 255, .2);
    }

    .dz h3 {
      font-size: 15px;
      color: #fff;
      margin-bottom: 6px;
      font-weight: 600;
      letter-spacing: -.01em
    }

    .dz p {
      font-size: 12px;
      color: rgba(255, 255, 255, .35);
      line-height: 1.5
    }

    .om-or {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 14px 0;
      font-size: 12px;
      color: rgba(255, 255, 255, .2);
      font-weight: 500
    }

    .om-or::before,
    .om-or::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(255, 255, 255, .06)
    }

    .fbtn {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, var(--accent), #8b84ff);
      color: #fff;
      border: none;
      border-radius: 14px;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      -webkit-tap-highlight-color: transparent;
      letter-spacing: -.01em;
      transition: transform .15s, box-shadow .15s;
      box-shadow: 0 4px 20px rgba(108, 99, 255, .35);
    }

    .fbtn:active {
      transform: scale(0.97);
      box-shadow: 0 2px 8px rgba(108, 99, 255, .25)
    }

    .ur {
      display: flex;
      border: 1.5px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      transition: border-color .18s
    }

    .ur:focus-within {
      border-color: var(--accent)
    }

    #ui {
      flex: 1;
      border: none;
      background: transparent;
      outline: none;
      font-size: 13px;
      color: #fff;
      padding: 13px 16px;
      font-family: monospace
    }

    #ui::placeholder {
      color: rgba(255, 255, 255, .18);
      font-family: 'Inter', sans-serif
    }

    #ug {
      padding: 0 18px;
      background: var(--accent);
      color: #fff;
      border: none;
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      letter-spacing: -.01em
    }

    .uerr {
      display: none;
      margin-top: 10px;
      padding: 11px 14px;
      background: rgba(234, 67, 53, .1);
      border: 1px solid rgba(234, 67, 53, .2);
      border-radius: 10px;
      font-size: 12px;
      color: #f28b82;
      line-height: 1.5
    }

    .un {
      margin-top: 10px;
      font-size: 11px;
      color: rgba(255, 255, 255, .18);
      line-height: 1.5
    }

    /* ══════════════════════════ LOADING ══════════════════════════ */
    #ls {
      position: fixed;
      inset: 0;
      z-index: 250;
      background: rgba(5, 5, 8, .92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
    }

    #ls.on {
      display: flex
    }

    .lr-wrap {
      position: relative;
      width: 56px;
      height: 56px
    }

    .lr {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      border: 3px solid rgba(255, 255, 255, .06);
      border-top-color: var(--accent);
      animation: spin .75s cubic-bezier(.5, 0, .5, 1) infinite
    }

    .lr2 {
      position: absolute;
      inset: 8px;
      border-radius: 50%;
      border: 2px solid rgba(255, 255, 255, .04);
      border-bottom-color: var(--accent2);
      animation: spin .5s cubic-bezier(.5, 0, .5, 1) infinite reverse
    }

    @keyframes spin {
      to {
        transform: rotate(360deg)
      }
    }

    #lm {
      font-size: 14px;
      color: var(--txt2);
      font-weight: 500;
      letter-spacing: -.01em
    }

    .lp {
      width: 160px;
      height: 2px;
      background: rgba(255, 255, 255, .08);
      border-radius: 2px;
      overflow: hidden
    }

    .lp-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      border-radius: 2px;
      width: 0%;
      transition: width .3s;
      animation: lpPulse 1.5s ease-in-out infinite
    }

    @keyframes lpPulse {

      0%,
      100% {
        opacity: 1
      }

      50% {
        opacity: .5
      }
    }

    /* ══════════════════════════ EMPTY STATE ══════════════════════════ */
    #empty {
      position: fixed;
      inset: 0;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0;
      pointer-events: none;
      padding: 32px
    }

    #empty.gone {
      display: none
    }

    .empty-bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 60% 50% at 50% 60%, rgba(108, 99, 255, .07) 0%, transparent 70%)
    }

    .ei-wrap {
      position: relative;
      margin-bottom: 24px
    }

    .ei {
      width: 88px;
      height: 88px;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(108, 99, 255, .15), rgba(255, 101, 132, .08));
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(108, 99, 255, .2);
      box-shadow: 0 8px 40px rgba(108, 99, 255, .15);
      animation: float 3s ease-in-out infinite;
    }

    @keyframes float {

      0%,
      100% {
        transform: translateY(0)
      }

      50% {
        transform: translateY(-8px)
      }
    }

    .ei-ring {
      position: absolute;
      inset: -8px;
      border-radius: 32px;
      border: 1px solid rgba(108, 99, 255, .12);
      animation: float 3s ease-in-out infinite .3s
    }

    .ei-ring2 {
      position: absolute;
      inset: -18px;
      border-radius: 40px;
      border: 1px solid rgba(108, 99, 255, .06);
      animation: float 3s ease-in-out infinite .6s
    }

    .eh {
      font-size: 22px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -.03em;
      margin-bottom: 8px
    }

    .ep {
      font-size: 14px;
      color: var(--txt2);
      text-align: center;
      max-width: 260px;
      line-height: 1.65;
      margin-bottom: 28px;
      font-weight: 400
    }

    .ebtn {
      pointer-events: all;
      padding: 14px 36px;
      background: linear-gradient(135deg, var(--accent), #8b84ff);
      color: #fff;
      border: none;
      border-radius: 16px;
      font-family: 'Inter', sans-serif;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 8px 32px rgba(108, 99, 255, .4);
      -webkit-tap-highlight-color: transparent;
      letter-spacing: -.01em;
      transition: transform .15s, box-shadow .15s;
    }

    .ebtn:active {
      transform: scale(0.96);
      box-shadow: 0 4px 16px rgba(108, 99, 255, .3)
    }

    .empty-hint {
      pointer-events: none;
      margin-top: 20px;
      font-size: 12px;
      color: rgba(255, 255, 255, .15);
      display: flex;
      align-items: center;
      gap: 6px;
      font-weight: 500
    }

    /* ══════════════════════════ BIG PICTURE OPEN ══════════════════════════ */
    @keyframes bigPictureIn {
      0% {
        transform: scale(0.06) translateZ(0);
        opacity: 0;
        filter: brightness(2) blur(4px)
      }

      35% {
        opacity: 1;
        filter: brightness(1.2) blur(0px)
      }

      70% {
        transform: scale(1.035) translateZ(0)
      }

      85% {
        transform: scale(0.988) translateZ(0)
      }

      100% {
        transform: scale(1) translateZ(0);
        opacity: 1;
        filter: none
      }
    }

    @keyframes bigPictureFlash {
      0% {
        opacity: 0
      }

      12% {
        opacity: .22
      }

      100% {
        opacity: 0
      }
    }

    #bp-flash {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: #fff;
      pointer-events: none;
      opacity: 0
    }

    #bp-flash.flash {
      animation: bigPictureFlash .6s cubic-bezier(.4, 0, .2, 1) forwards
    }

    #rc.bp-opening {
      animation: bigPictureIn .7s cubic-bezier(.22, 1, .36, 1) forwards;
      transform-origin: center center
    }

    /* ══════════════════════════ BOOKMARK BUTTON ══════════════════════════ */
    #bm-btn {
      position: fixed;
      top: 70px;
      right: 12px;
      z-index: 90;
      width: 40px;
      height: 40px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--chrome);
      backdrop-filter: blur(20px);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: opacity .3s, transform .3s cubic-bezier(.34, 1.3, .64, 1), background .2s;
      opacity: 0;
      pointer-events: none;
    }

    #bm-btn.vis {
      opacity: 1;
      pointer-events: all
    }

    #bm-btn.bm-on {
      background: rgba(255, 101, 132, .15);
      border-color: rgba(255, 101, 132, .35);
      color: var(--accent2)
    }

    #bm-btn:active {
      transform: scale(0.88)
    }

    /* ══════════════════════════ GESTURE HINT ══════════════════════════ */
    #ghint {
      position: fixed;
      inset: 0;
      z-index: 300;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      background: rgba(0, 0, 0, .7);
      backdrop-filter: blur(8px);
      pointer-events: none;
      opacity: 0;
      transition: opacity .4s;
    }

    #ghint.show {
      opacity: 1;
      pointer-events: all
    }

    .gh-hand {
      font-size: 48px;
      animation: swipeHint 1.6s ease-in-out infinite
    }

    @keyframes swipeHint {

      0%,
      100% {
        transform: translateX(0)
      }

      40% {
        transform: translateX(-30px)
      }

      60% {
        transform: translateX(20px)
      }
    }

    .gh-txt {
      font-size: 16px;
      font-weight: 600;
      color: #fff;
      text-align: center;
      letter-spacing: -.01em
    }

    .gh-sub {
      font-size: 13px;
      color: var(--txt2);
      text-align: center
    }

    .gh-dismiss {
      margin-top: 8px;
      padding: 10px 28px;
      background: rgba(255, 255, 255, .1);
      border: 1px solid var(--border);
      border-radius: 12px;
      color: #fff;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: background .15s;
      pointer-events: all
    }

    .gh-dismiss:active {
      background: rgba(255, 255, 255, .2)
    }

    /* ══════════════════════════ READING PROGRESS RING ══════════════════════════ */
    #prog-ring {
      position: fixed;
      bottom: 90px;
      right: 14px;
      z-index: 90;
      width: 42px;
      height: 42px;
      opacity: 0;
      transition: opacity .3s;
      pointer-events: none;
    }

    #prog-ring.vis {
      opacity: 1
    }

    #prog-ring svg {
      transform: rotate(-90deg)
    }

    #pr-track {
      fill: none;
      stroke: rgba(255, 255, 255, .08);
      stroke-width: 3
    }

    #pr-fill {
      fill: none;
      stroke: url(#pr-grad);
      stroke-width: 3;
      stroke-linecap: round;
      transition: stroke-dashoffset .5s cubic-bezier(.4, 0, .2, 1)
    }

    #pr-pct {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 8px;
      font-weight: 700;
      color: var(--txt2);
      letter-spacing: -.02em
    }

    /* ══════════════════════════ SWIPE EDGE GLOW ══════════════════════════ */
    #edge-l,
    #edge-r {
      position: fixed;
      top: 0;
      bottom: 0;
      width: 60px;
      z-index: 45;
      pointer-events: none;
      opacity: 0;
      transition: opacity .2s;
    }

    #edge-l {
      left: 0;
      background: linear-gradient(to right, rgba(108, 99, 255, .2), transparent)
    }

    #edge-r {
      right: 0;
      background: linear-gradient(to left, rgba(108, 99, 255, .2), transparent)
    }

    /* ══════════════════════════ FILE-INPUT ══════════════════════════ */
    #file-input {
      display: none
    }
  </style>
</head>

<body>

  <!-- Ambient glow -->
  <div id="amb"></div>
  <!-- Big-picture flash -->
  <div id="bp-flash"></div>
  <!-- Reader canvas -->
  <canvas id="rc"></canvas>
  <!-- Swipe edge glows -->
  <div id="edge-l"></div>
  <div id="edge-r"></div>

  <!-- Tap zones -->
  <div class="tz" id="tz-l"></div>
  <div class="tz" id="tz-c"></div>
  <div class="tz" id="tz-r"></div>

  <!-- Mini progress -->
  <div id="mp">
    <div id="mpf" style="width:0%"></div>
  </div>

  <!-- Page number toast -->
  <div id="pgtoast">1 / 1</div>

  <!-- Progress ring -->
  <div id="prog-ring">
    <svg width="42" height="42" viewBox="0 0 42 42">
      <defs>
        <linearGradient id="pr-grad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#6C63FF" />
          <stop offset="100%" stop-color="#FF6584" />
        </linearGradient>
      </defs>
      <circle id="pr-track" cx="21" cy="21" r="18" />
      <circle id="pr-fill" cx="21" cy="21" r="18" stroke-dasharray="113" stroke-dashoffset="113" />
    </svg>
    <div id="pr-pct">0%</div>
  </div>

  <!-- Bookmark button -->
  <button id="bm-btn" title="Bookmark">
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
      <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
    </svg>
  </button>

  <!-- TOP CHROME -->
  <div id="ct">
    <div class="doc-wrap">
      <div class="doc-t" id="doc-t">PageFlow Reader</div>
      <div class="doc-s" id="doc-s">Open a PDF to begin</div>
    </div>
    <button class="ib" id="btn-search" title="Search">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
    </button>
    <button class="ib" id="btn-set" title="Settings">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="3" />
        <path
          d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
      </svg>
    </button>
  </div>

  <!-- BOTTOM CHROME -->
  <div id="cb">
    <div class="sl-row">
      <button class="ib" id="btn-prev" style="width:40px;height:40px">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <polyline points="15 18 9 12 15 6" />
        </svg>
      </button>
      <input type="range" class="pg-sl" id="pg-sl" min="1" value="1" step="1" />
      <button class="ib" id="btn-next" style="width:40px;height:40px">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </button>
    </div>
    <div class="act-row">
      <button class="ib" id="btn-bm-tgl" title="Bookmarks" style="width:40px;height:40px">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
        </svg>
      </button>
      <div class="act-center">
        <div class="pg-lbl" id="pg-lbl">—</div>
        <button class="ib" id="btn-pages" title="All pages" style="width:40px;height:40px">
          <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="2" y="3" width="20" height="14" rx="2" />
            <line x1="8" y1="21" x2="16" y2="21" />
            <line x1="12" y1="17" x2="12" y2="21" />
          </svg>
        </button>
      </div>
      <button class="ib" id="btn-auto" title="Auto-read" style="width:40px;height:40px">
        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <polygon points="5 3 19 12 5 21 5 3" />
        </svg>
      </button>
    </div>
  </div>

  <!-- THUMBNAIL STRIP -->
  <div id="ts">
    <div class="ts-hdr">
      <div>
        <div class="ts-title">All Pages</div>
        <div class="ts-cnt" id="ts-cnt"></div>
      </div>
      <button class="ts-x" id="ts-x">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
    <div id="ts-scroll"></div>
  </div>

  <!-- SEARCH -->
  <div id="so">
    <div class="sc">
      <div class="sc-top">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input id="si" type="search" placeholder="Search in document…" autocomplete="off" autocorrect="off" />
        <button class="ib" id="sc-x" style="color:var(--txt2);width:36px;height:36px">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
      <div class="sc-nav">
        <span class="sc-ct" id="sc-ct">Type to search</span>
        <button class="snb" id="sn-p" disabled><svg width="13" height="13" fill="none" stroke="currentColor"
            stroke-width="2.5" viewBox="0 0 24 24">
            <polyline points="15 18 9 12 15 6" />
          </svg></button>
        <button class="snb" id="sn-n" disabled><svg width="13" height="13" fill="none" stroke="currentColor"
            stroke-width="2.5" viewBox="0 0 24 24">
            <polyline points="9 18 15 12 9 6" />
          </svg></button>
      </div>
      <div id="sr"></div>
    </div>
  </div>

  <!-- SETTINGS -->
  <div id="set">
    <div class="set-sh">
      <div class="sh-pill"></div>
      <div class="sh-lb">Reading Theme</div>
      <div class="th-row">
        <div class="th-chip on" data-t="white">☀️ Light</div>
        <div class="th-chip" data-t="sepia">☕ Sepia</div>
