<script>
/* ════════════════════════════════════════════════════
   VIDYARI · FILE PAGE SCRIPT — ENHANCED EDITION
════════════════════════════════════════════════════ */
const FILE_ID   = "<%= String(file._id) %>";
const FILE_NAME = "<%- (file.filename || 'Resource').replace(/"/g,'&quot;') %>";
let   activeTotal = <%= priceDetails.total %>;

console.log('✅ File-details loaded:', { FILE_ID, FILE_NAME, activeTotal });

/* ── Activity Tracker ── */
if(typeof window.ActivityTracker_Instance !== 'undefined') {
    window.ActivityTracker_Instance.init({ autoTrack:true });
} else {
    setTimeout(() => window.ActivityTracker_Instance?.init({ autoTrack:true }), 500);
}

/* ══════════════════════════════════════════
   SCROLL REVEAL — IntersectionObserver
══════════════════════════════════════════ */
const revealObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
        if(e.isIntersecting) {
            e.target.classList.add('in');
            revealObs.unobserve(e.target);
        }
    });
}, { threshold:0.08, rootMargin:'0px 0px -36px 0px' });
document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

/* ══════════════════════════════════════════
   TOAST
══════════════════════════════════════════ */
function showToast(msg, type='success') {
    const el   = document.getElementById('vToast');
    const icon = el.querySelector('.toast-icon');
    icon.className = 'toast-icon ' + type + ' ' + {
        success:'fa-solid fa-circle-check',
        error:  'fa-solid fa-circle-exclamation',
        info:   'fa-solid fa-circle-info'
    }[type];
    document.getElementById('vToastText').textContent = msg;
    el.classList.add('show');
    clearTimeout(el._t);
    el._t = setTimeout(() => el.classList.remove('show'), 4000);
}

/* ══════════════════════════════════════════
   FAQ ACCORDION
══════════════════════════════════════════ */
function toggleFaq(btn) {
    const item   = btn.closest('.faq-item');
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
    if(!isOpen) item.classList.add('open');
}

/* ══════════════════════════════════════════
   IMAGE MODAL
══════════════════════════════════════════ */
function openImgModal(src) {
    document.getElementById('imgModalSrc').src = src;
    document.getElementById('imgModalVeil').classList.add('open');
}
function closeImgModal() { document.getElementById('imgModalVeil').classList.remove('open'); }

/* ══════════════════════════════════════════
   REVIEW MODAL
══════════════════════════════════════════ */
function openReviewModal() { document.getElementById('reviewModalVeil').classList.add('open'); }
function closeReviewModal() {
    document.getElementById('reviewModalVeil').classList.remove('open');
    document.getElementById('reviewForm').reset();
}
document.getElementById('reviewModalVeil').addEventListener('click', e => {
    if(e.target === e.currentTarget) closeReviewModal();
});

/* ══════════════════════════════════════════
   LIKE BUTTON
══════════════════════════════════════════ */
(function() {
    const btn    = document.getElementById('likeBtn');
    if(!btn) return;
    const fileId = btn.dataset.id;
    let   count  = parseInt(btn.dataset.count) || 0;
    const stored = JSON.parse(localStorage.getItem('vidyari_likes') || '{}');
    let   liked  = !!stored[fileId];

    const render = () => {
        btn.classList.toggle('liked', liked);
        btn.innerHTML = `<i class="${liked?'fa-solid':'fa-regular'} fa-heart"></i><span>${count}</span>`;
    };
    render();

    btn.addEventListener('click', () => {
        liked = !liked; count += liked ? 1 : -1;
        if(!liked) delete stored[fileId]; else stored[fileId] = true;
        localStorage.setItem('vidyari_likes', JSON.stringify(stored));
        render();
        fetch(`/files/impression/${fileId}/${liked?'like':'dislike'}`).catch(()=>{});
        window.ActivityTracker_Instance?.trackActivity({ activityType:'click', pageType:'file', fileId:FILE_ID, elementClicked:'like-btn' });
    });
})();

/* ══════════════════════════════════════════
   SHARE / COPY
══════════════════════════════════════════ */
function copyPageLink(e) {
    navigator.clipboard.writeText(location.href).then(() => {
        const btn  = e.currentTarget, orig = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
        setTimeout(() => btn.innerHTML = orig, 2400);
        showToast('Link copied to clipboard', 'success');
    });
}

/* ══════════════════════════════════════════
   COUPON — Enhanced feedback states
══════════════════════════════════════════ */
document.getElementById('couponApplyBtn')?.addEventListener('click', async () => {
    const input = document.getElementById('couponInput');
    const code  = input.value.trim();
    if(!code) { showToast('Enter a promo code first.', 'info'); return; }

    const btn  = document.getElementById('couponApplyBtn');
    const wrap = document.getElementById('couponWrap');
    const msg  = document.getElementById('couponMsg');

    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
    btn.disabled  = true;
    wrap.classList.remove('valid','invalid');
    msg.className  = 'coupon-msg';
    msg.textContent = '';

    try {
        const res  = await fetch(`/check/coupon?fileId=${FILE_ID}&couponCode=${code}&quantity=1`);
        const data = await res.json();

        if(data.valid) {
            const p       = data.priceDetails;
            const saving  = p.originalPrice - p.discountedPrice;
            activeTotal   = p.total;

            /* Update totals */
            document.getElementById('finalTotal').textContent = `₹${p.total.toFixed(2)}`;
            const mobPrice = document.getElementById('mobileFinalPrice');
            if(mobPrice) mobPrice.textContent = p.total.toFixed(0);

            /* Discount row */
            document.getElementById('discountRow').innerHTML = `
                <div class="invoice-discount">
                    <span><i class="fa-solid fa-tag" style="margin-right:6px"></i>Promo "<strong>${code}</strong>" applied</span>
                    <span>−₹${saving.toFixed(2)}</span>
                </div>`;

            /* Coupon wrap state */
            wrap.classList.add('valid');
            input.disabled = true;
            btn.innerHTML  = '<i class="fa-solid fa-check"></i>';
            btn.style.color = 'var(--green)';

            /* Message */
            msg.textContent = `✓ You saved ₹${saving.toFixed(2)}!`;
            msg.className   = 'coupon-msg success show';

            showToast(`Saved ₹${saving.toFixed(2)} with code "${code}"`, 'success');
        } else {
            wrap.classList.add('invalid');
            msg.textContent = data.message || 'Invalid promo code.';
            msg.className   = 'coupon-msg error show';
            showToast(data.message || 'Invalid promo code.', 'error');
            btn.innerHTML   = 'Apply';
            btn.disabled    = false;

            /* Shake input */
            input.style.animation = 'none';
            setTimeout(() => { input.style.animation = 'shake .4s'; }, 10);
            setTimeout(() => { wrap.classList.remove('invalid'); input.style.animation = ''; }, 1200);
        }
    } catch {
        showToast('Server error. Try again.', 'error');
        btn.innerHTML = 'Apply';
        btn.disabled  = false;
    }
});

/* ══════════════════════════════════════════
   BUTTON RIPPLE EFFECT
══════════════════════════════════════════ */
document.querySelectorAll('.cta-btn, .mobile-enroll-btn').forEach(btn => {
    btn.addEventListener('click', function(e) {
        const rect   = this.getBoundingClientRect();
        const size   = Math.max(rect.width, rect.height);
        const x      = e.clientX - rect.left - size / 2;
        const y      = e.clientY - rect.top  - size / 2;
        const ripple = document.createElement('span');
        ripple.className = 'ripple';
        ripple.style.cssText = `width:${size}px;height:${size}px;left:${x}px;top:${y}px`;
        this.appendChild(ripple);
        setTimeout(() => ripple.remove(), 600);
    });
});

/* ══════════════════════════════════════════
   CONFETTI ENGINE
══════════════════════════════════════════ */
function launchConfetti() {
    const canvas = document.getElementById('confettiCanvas');
    canvas.classList.add('show');
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    const ctx    = canvas.getContext('2d');
    const colors = ['#1a56f0','#0b7a45','#e8811f','#e53e3e','#6ee7b7','#fbbf24','#a78bfa','#f9fafb'];

    const pieces = Array.from({ length:130 }, () => ({
        x:    Math.random() * canvas.width,
        y:   -10 - Math.random() * 140,
        r:    4 + Math.random() * 9,
        c:    colors[Math.floor(Math.random() * colors.length)],
        vx:   (Math.random() - 0.5) * 5,
        vy:   2 + Math.random() * 4.5,
        rot:  Math.random() * Math.PI * 2,
        vr:   (Math.random() - 0.5) * 0.22,
        alpha:1,
        shape:Math.random() > 0.5 ? 'rect' : 'circle'
    }));

    let frame = 0, raf;
    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        let alive = 0;
        pieces.forEach(p => {
            p.x += p.vx; p.y += p.vy; p.rot += p.vr;
            p.vy += 0.07; p.alpha -= 0.009;
            if(p.y < canvas.height + 20 && p.alpha > 0) alive++;
            ctx.save();
            ctx.globalAlpha = Math.max(0, p.alpha);
            ctx.translate(p.x, p.y); ctx.rotate(p.rot);
            ctx.fillStyle = p.c;
            if(p.shape === 'circle') {
                ctx.beginPath(); ctx.arc(0, 0, p.r, 0, Math.PI * 2); ctx.fill();
            } else {
                ctx.fillRect(-p.r, -p.r * 0.45, p.r * 2, p.r * 0.9);
            }
            ctx.restore();
        });
        frame++;
        if(alive > 0 && frame < 300) raf = requestAnimationFrame(draw);
        else { canvas.classList.remove('show'); ctx.clearRect(0, 0, canvas.width, canvas.height); }
    }
    draw();
    setTimeout(() => { cancelAnimationFrame(raf); canvas.classList.remove('show'); }, 5500);
}

/* ══════════════════════════════════════════
   CTA STATE HELPER
══════════════════════════════════════════ */
function setCTAState(btn, state, html) {
    btn.className = 'cta-btn state-' + state;
    btn.innerHTML = html;
    btn.disabled  = (state !== 'idle');
}

/* ══════════════════════════════════════════
   PAYMENT FLOW — Enhanced states
══════════════════════════════════════════ */
async function initiatePayment(btn) {
    if(typeof Razorpay === 'undefined') { showToast('Payment system not loaded. Please refresh the page.', 'error'); return; }

    setCTAState(btn, 'loading', '<i class="fa-solid fa-spinner fa-spin"></i>&nbsp; Creating order…');
    window.ActivityTracker_Instance?.trackCartInteraction('checkout_start', { fileId:FILE_ID, fileName:FILE_NAME, amount:activeTotal });

    try {
        const res = await fetch('/create-order', {
            method:'POST', headers:{'Content-Type':'application/json'}, credentials:'include',
            body:JSON.stringify({ fileId:FILE_ID, price:activeTotal, filename:FILE_NAME, couponCode:document.getElementById('couponInput')?.value.trim() || '' })
        });
        const order = await res.json();

        if(res.status === 401 || order.requiresLogin) { window.location.href = order.loginRedirectUrl || '/login'; return; }

        if(!res.ok || !order.success) {
            setCTAState(btn, 'error', '<i class="fa-solid fa-circle-exclamation"></i>&nbsp; Order failed');
            showToast(order.error || 'Order creation failed.', 'error');
            setTimeout(() => { btn.className='cta-btn'; btn.innerHTML='<i class="fa-solid fa-lock"></i> Secure Checkout'; btn.disabled=false; }, 2200);
            return;
        }

        /* Reset button for Razorpay modal */
        btn.className = 'cta-btn'; btn.innerHTML = '<i class="fa-solid fa-lock"></i> Secure Checkout'; btn.disabled = false;

        const rzp = new Razorpay({
            key:order.key, amount:order.amount, currency:'INR',
            name:'Vidyari', image:'https://vidyari.com/images/logo.svg',
            description:FILE_NAME, order_id:order.order_id,
            theme:{ color:'#1a56f0' },
            handler: async function(resp) {
                setCTAState(btn, 'verifying', '<i class="fa-solid fa-shield-halved fa-fade"></i>&nbsp; Verifying payment…');
                try {
                    const vRes  = await fetch('/verify-payment', {
                        method:'POST', headers:{'Content-Type':'application/json'}, credentials:'include',
                        body:JSON.stringify({ razorpay_order_id:resp.razorpay_order_id, razorpay_payment_id:resp.razorpay_payment_id, razorpay_signature:resp.razorpay_signature, fileId:FILE_ID, totalprice:activeTotal })
                    });
                    const vData = await vRes.json();
                    if(vRes.status === 401 || vData.requiresLogin) { window.location.href = vData.loginRedirectUrl || '/login'; return; }

                    if(vData.success) {
                        setCTAState(btn, 'success', '<i class="fa-solid fa-check"></i>&nbsp; Payment Successful!');
                        launchConfetti();
                        setTimeout(() => {
                            document.getElementById('successDownloadLink').href = vData.downloadUrl;
                            document.getElementById('successOverlay').classList.add('show');
                            setTimeout(() => window.location.href = vData.downloadUrl, 4800);
                        }, 700);
                        window.ActivityTracker_Instance?.trackCartInteraction('add', { fileId:FILE_ID, fileName:FILE_NAME, price:activeTotal });
                    } else throw new Error(vData.message || 'Verification failed.');
                } catch(e) {
                    setCTAState(btn, 'error', '<i class="fa-solid fa-circle-exclamation"></i>&nbsp; Verification failed');
                    showToast(e.message, 'error');
                    setTimeout(() => { btn.className='cta-btn'; btn.innerHTML='<i class="fa-solid fa-lock"></i> Retry Checkout'; btn.disabled=false; }, 2500);
                }
            },
            modal:{ ondismiss:() => {
                btn.className='cta-btn'; btn.innerHTML='<i class="fa-solid fa-lock"></i> Secure Checkout'; btn.disabled=false;
            }}
        });
        rzp.open();
    } catch(e) {
        setCTAState(btn, 'error', '<i class="fa-solid fa-circle-exclamation"></i>&nbsp; Connection error');
        showToast('Connection error. Please retry.', 'error');
        setTimeout(() => { btn.className='cta-btn'; btn.innerHTML='<i class="fa-solid fa-lock"></i> Secure Checkout'; btn.disabled=false; }, 2500);
    }
}

document.getElementById('payBtn')?.addEventListener('click', e => initiatePayment(e.currentTarget));
document.getElementById('payBtnMobile')?.addEventListener('click', () => {
    const main = document.getElementById('payBtn');
    if(main) initiatePayment(main);
});

/* ══════════════════════════════════════════
   REVIEWS
══════════════════════════════════════════ */
async function loadReviews() {
    const area = document.getElementById('reviewsArea');
    try {
        const fileId = FILE_ID || document.documentElement.dataset.fileId;
        console.log('📝 loadReviews called with fileId:', fileId);
        
        if (!fileId || fileId.trim() === '') {
            console.error('❌ FILE_ID is empty or not found');
            area.innerHTML = '<p style="color:var(--ink-3);font-size:.875rem;padding:8px 0;">File ID not available. Please refresh the page.</p>';
            return;
        }

        console.log('🔍 Fetching reviews from:', `/api/file-reviews/file/${fileId}`);
        const res = await fetch(`/api/file-reviews/file/${fileId}`);
        
        console.log('📊 API response status:', res.status, res.statusText);
        
        if (!res.ok) {
            throw new Error(`API error: ${res.status} ${res.statusText}`);
        }
        
        const data = await res.json();
        console.log('✅ Reviews loaded:', data);
        
        // Debug: Log first review's user data
        if(data.reviews && data.reviews.length > 0) {
            console.log('📸 First review user data:', {
                userId: data.reviews[0].userId?._id,
                username: data.reviews[0].userId?.username,
                fullName: data.reviews[0].userId?.fullName,
                profilePicUrl: data.reviews[0].userId?.profilePicUrl,
                isCloudFront: data.reviews[0].userId?.profilePicUrl?.includes('cloudfront')
            });
            
            // Log all reviews profile URLs
            console.log('📸 All reviewer profile URLs:');
            data.reviews.forEach((rv, idx) => {
                console.log(`  ${idx + 1}. ${rv.userId?.username}: ${rv.userId?.profilePicUrl}`);
            });
        }

        if(!data) {
            throw new Error('No data returned from API');
        }

        if(data.averageRating) {
            document.getElementById('avgRatingDisplay').textContent = `${data.averageRating.toFixed(1)} / 5.0`;
        }

        const genStars = n => '★'.repeat(n) + `<span class="empty">${'★'.repeat(5-n)}</span>`;

        if(data.count === 0) {
            area.innerHTML = `
                <div class="no-reviews-box">
                    <i class="fa-regular fa-star"></i>
                    <p style="font-weight:600;color:var(--ink);margin-bottom:8px;">No reviews yet</p>
                    <p style="color:var(--ink-3);font-size:.88rem;">Be the first to share your experience!</p>
                    <button class="write-review-btn" style="margin:20px auto 0;display:inline-flex;" onclick="openReviewModal()">
                        <i class="fa-regular fa-pen-to-square"></i> Write a Review
                    </button>
                </div>`;
            return;
        }

        const maxC     = Math.max(...Object.values(data.ratingDistribution), 1);
        const distHTML = [5,4,3,2,1].map(s => `
            <div class="dist-row">
                <span class="dist-label">${s} ★</span>
                <div class="dist-track">
                    <div class="dist-fill" data-pct="${((data.ratingDistribution[s]||0)/maxC*100).toFixed(0)}"></div>
                </div>
                <span class="dist-count">${data.ratingDistribution[s]||0}</span>
            </div>`).join('');

        const reviewsHTML = data.reviews.map((rv,i) => {
            const initials = (rv.userId?.fullName||rv.userId?.username||'U').substring(0,2).toUpperCase();
            const profileImg = rv.userId?.profilePicUrl;
            
            const isCloudFront = profileImg?.includes('cloudfront');
            const isS3 = profileImg?.includes('s3');
            console.log(`📸 Review ${i + 1} (${rv.userId?.username}):`, {
                profileImg: profileImg,
                isCloudFront: isCloudFront,
                isS3: isS3,
                initials: initials
            });
            
            if (profileImg) {
                // Show image with fallback to initials
                return `
                <div class="review-item" style="animation-delay:${i*0.07}s">
                    <div class="review-head">
                        <div class="review-initials">
                            <img src="${profileImg}" alt="${rv.userId?.username}" style="width:100%; height:100%; object-fit:cover;" onerror="console.warn('Image failed to load:', this.src); this.parentElement.innerHTML='${initials}'" />
                        </div>
                        <div>
                            <div class="review-user-name">${rv.userId?.fullName||rv.userId?.username||'Anonymous'}</div>
                            <div class="review-user-date">${new Date(rv.createdAt).toLocaleDateString('en-IN',{year:'numeric',month:'short',day:'numeric'})}</div>
                        </div>
                        <div class="review-stars">${genStars(rv.rating)}</div>
                    </div>
                    ${rv.title ? `<div class="review-title">${rv.title}</div>` : ''}
                    <div class="review-body">${rv.reviewText||''}</div>
                    <div class="helpful-row">
                        <span class="helpful-label">Was this helpful?</span>
                        <button class="helpful-btn" onclick="markHelpful('${rv._id}',this)">
                            <i class="fa-regular fa-thumbs-up"></i> ${rv.helpful||0}
                        </button>
                    </div>
                </div>`;
            } else {
                // No image, just show initials
                return `
                <div class="review-item" style="animation-delay:${i*0.07}s">
                    <div class="review-head">
                        <div class="review-initials">${initials}</div>
                        <div>
                            <div class="review-user-name">${rv.userId?.fullName||rv.userId?.username||'Anonymous'}</div>
                            <div class="review-user-date">${new Date(rv.createdAt).toLocaleDateString('en-IN',{year:'numeric',month:'short',day:'numeric'})}</div>
                        </div>
                        <div class="review-stars">${genStars(rv.rating)}</div>
                    </div>
                    ${rv.title ? `<div class="review-title">${rv.title}</div>` : ''}
                    <div class="review-body">${rv.reviewText||''}</div>
                    <div class="helpful-row">
                        <span class="helpful-label">Was this helpful?</span>
                        <button class="helpful-btn" onclick="markHelpful('${rv._id}',this)">
                            <i class="fa-regular fa-thumbs-up"></i> ${rv.helpful||0}
                        </button>
                    </div>
                </div>`;
            }
        }).join('');

        area.innerHTML = `
            <div class="rating-block">
                <div class="rating-score">
                    <div class="rating-num">${data.averageRating.toFixed(1)}</div>
                    <div class="rating-stars">${genStars(Math.round(data.averageRating))}</div>
                    <div class="rating-count">${data.count} review${data.count!==1?'s':''}</div>
                </div>
                <div class="dist-bars">${distHTML}</div>
            </div>
            <button class="write-review-btn" onclick="openReviewModal()">
                <i class="fa-regular fa-pen-to-square"></i> Write a Review
            </button>
            <div class="review-list">${reviewsHTML}</div>`;

        /* Animate dist bars after paint */
        requestAnimationFrame(() => {
            setTimeout(() => {
                area.querySelectorAll('.dist-fill').forEach(el => {
                    el.style.width = el.dataset.pct + '%';
                });
            }, 100);
        });

    } catch (error) {
        console.error('❌ Error loading reviews:', error);
        console.error('Error details:', {
            message: error.message,
            stack: error.stack,
            name: error.name
        });
        area.innerHTML = `<p style="color:var(--ink-3);font-size:.875rem;padding:8px 0;">⚠️ Unable to load reviews. Error: ${error.message}. Check console for details.</p>`;
    }
}

async function markHelpful(id, btn) {
    try {
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
        const res = await fetch(`/api/file-reviews/${id}/helpful`, { method:'POST', headers:{'Content-Type':'application/json'} });
        if(res.ok) {
            btn.classList.add('active');
            showToast('Marked as helpful!', 'success');
            loadReviews();
        }
    } catch {}
}

document.getElementById('reviewForm').addEventListener('submit', async e => {
    e.preventDefault();
    const rating = document.querySelector('input[name="rating"]:checked')?.value;
    if(!rating) { showToast('Please select a star rating.', 'error'); return; }
    const btn = document.getElementById('rvSubmitBtn');
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Submitting…';
    btn.disabled  = true;
    try {
        const res  = await fetch('/api/file-reviews/submit', {
            method:'POST', headers:{'Content-Type':'application/json'},
            body:JSON.stringify({ fileId:FILE_ID, rating:+rating, title:document.getElementById('rvTitle').value.trim(), reviewText:document.getElementById('rvText').value.trim() })
        });
        const data = await res.json();
        if(res.ok) {
            console.log('✅ Review submitted successfully:', data);
            btn.innerHTML = '<i class="fa-solid fa-check"></i> Thank you!';
            btn.style.background = 'var(--green)';
            showToast('Review submitted! Thank you 🎉');
            setTimeout(() => { closeReviewModal(); loadReviews(); }, 1600);
        } else {
            console.error('❌ Review submission failed:', data);
            showToast(data.message || 'Submission failed.', 'error');
            btn.innerHTML = 'Submit Review'; btn.disabled = false; btn.style.background = '';
        }
    } catch (error) {
        console.error('❌ Review submission error:', error);
        showToast('Error. Please try again.', 'error');
        btn.innerHTML = 'Submit Review'; btn.disabled = false;
    }
});

/* ══════════════════════════════════════════
   RELATED FILES
══════════════════════════════════════════ */
async function loadRelated() {
    const area = document.getElementById('relatedArea');
    if(!area) return;
    try {
        const res  = await fetch(`/products/related?fileId=${FILE_ID}`);
        if(!res.ok) throw new Error();
        const docs = await res.json();

        if(!docs?.length) {
            area.innerHTML = `
                <div style="text-align:center;padding:44px 20px;">
                    <i class="fa-solid fa-layer-group" style="font-size:2.5rem;color:var(--rule);margin-bottom:14px;display:block;"></i>
                    <p style="color:var(--ink-3);font-size:.9rem;">No similar resources found yet.</p>
                </div>`;
            return;
        }

        const groups = {};
        docs.forEach(d => {
            const a = d.user || 'Vidyari Creator';
            if(!groups[a]) groups[a] = [];
            groups[a].push(d);
        });

        area.innerHTML = Object.entries(groups).map(([author, files]) => `
            <div class="related-group">
                <h3 class="related-group-label">Created by ${author}</h3>
                <div class="related-grid">
                    ${files.map((f,i) => {
                        const free    = f.price===0||f.price==='0';
                        const rating  = (f.rating||4.8).toFixed(1);
                        const dl      = f.downloadCount||0;
                        const dlDisp  = dl > 999 ? (dl/1000).toFixed(1)+'k' : dl;
                        return `
                        <a href="/file/${f.slug||f._id}/${f._id}" class="rel-card" style="animation-delay:${i*.08}s">
                            <div class="rel-thumb">
                                <img src="${f.previewUrl||'/images/File_Demo.svg'}" alt="${f.filename}" loading="lazy" onerror="this.src='/images/File_Demo.svg'">
                                <span class="rel-badge ${free?'free':''}">${free?'Free':'Premium'}</span>
                            </div>
                            <div class="rel-body">
                                <div class="rel-name">${f.filename}</div>
                                <div class="rel-author"><i class="fa-solid fa-circle-user"></i> ${author}</div>
                                <div class="rel-footer">
                                    <div class="rel-price ${free?'free':''}">${free?'Free':'₹'+f.price}</div>
                                    <div class="rel-meta">
                                        <span><i class="fa-solid fa-star"></i> ${rating}</span>
                                        <span><i class="fa-solid fa-cloud-arrow-down"></i> ${dlDisp}</span>
                                    </div>
                                </div>
                            </div>
                        </a>`;
                    }).join('')}
                </div>
            </div>`).join('');

    } catch {
        area.innerHTML = `
            <div style="text-align:center;padding:32px 20px;color:var(--ink-3);">
                <i class="fa-solid fa-triangle-exclamation" style="font-size:2rem;margin-bottom:12px;display:block;color:var(--rule);"></i>
                <p style="font-size:.88rem;">Unable to load suggestions right now.</p>
            </div>`;
    }
}

/* ── Adsense ── */
try { (adsbygoogle = window.adsbygoogle || []).push({}); } catch {}

/* ── Activity: downloads & reviews ── */
document.addEventListener('click', e => {
    if(!window.ActivityTracker_Instance) return;
    if(e.target.closest('a[href*="/download"]'))
        window.ActivityTracker_Instance.trackActivity({ activityType:'file_download', pageType:'file', fileId:FILE_ID, elementClicked:'download-btn', metadata:{fileName:FILE_NAME} });
    if(e.target.closest('.helpful-btn'))
        window.ActivityTracker_Instance.trackReviewInteraction(FILE_ID, 'helpful');
});

/* ── Init ── */
document.addEventListener('DOMContentLoaded', () => {
    loadReviews();
    loadRelated();
});
</script>
