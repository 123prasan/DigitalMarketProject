<%- include("../components/header") %>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Courses</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary-blue: #0b57d0;
            --light-bg: #f0f4f9;
            --card-bg: #ffffff;
            --text-main: #1f1f1f;
            --text-muted: #5f6368;
            --border-color: #e8e8e8;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            --shadow-hover: 0 8px 16px rgba(0, 0, 0, 0.12);
        }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: linear-gradient(135deg, #f0f4f9 0%, #e8eef5 100%);
            min-height: 100vh;
            color: var(--text-main);
        }

        .courses-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .page-header {
            text-align: center;
            margin-bottom: 50px;
        }

        .page-header h1 {
            font-size: 42px;
            font-weight: 700;
            margin-bottom: 10px;
            color: var(--text-main);
        }

        .page-header p {
            font-size: 16px;
            color: var(--text-muted);
        }

        .courses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 24px;
            margin-top: 30px;
        }

        .course-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s ease;
            cursor: pointer;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
        }

        .course-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-hover);
            border-color: var(--primary-blue);
        }

        .course-image {
            width: 100%;
            height: 180px;
            object-fit: cover;
            background: linear-gradient(135deg, var(--primary-blue), #1e88e5);
            position: relative;
            overflow: hidden;
        }

        .course-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .play-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
            cursor: pointer;
        }

        .course-card:hover .play-overlay {
            opacity: 1;
        }

        .play-button {
            width: 60px;
            height: 60px;
            background: var(--primary-blue);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
            transition: all 0.3s ease;
        }

        .course-card:hover .play-button {
            transform: scale(1.1);
            background: #1a73e8;
        }

        .course-content {
            padding: 20px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .course-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 8px;
            color: var(--text-main);
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .course-description {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 12px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            flex-grow: 1;
        }

        .course-meta {
            display: flex;
            gap: 16px;
            font-size: 13px;
            color: var(--text-muted);
            padding-top: 12px;
            border-top: 1px solid var(--border-color);
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .meta-item i {
            color: var(--primary-blue);
            font-size: 14px;
        }

        .progress-bar-container {
            width: 100%;
            height: 4px;
            background: #e8e8e8;
            border-radius: 2px;
            margin-bottom: 8px;
            overflow: hidden;
        }

        .progress-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary-blue), #1e88e5);
            transition: width 0.3s ease;
        }

        .price-badge {
            background: var(--primary-blue);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .empty-state {
            text-align: center;
            padding: 80px 20px;
        }

        .empty-icon {
            font-size: 64px;
            color: #d0d0d0;
            margin-bottom: 20px;
        }

        .empty-title {
            font-size: 24px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 10px;
        }

        .empty-description {
            font-size: 16px;
            color: var(--text-muted);
            margin-bottom: 30px;
        }

        .browse-button {
            display: inline-block;
            background: var(--primary-blue);
            color: white;
            padding: 12px 32px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .browse-button:hover {
            background: #1a73e8;
            transform: translateY(-2px);
            box-shadow: var(--shadow-hover);
            text-decoration: none;
            color: white;
        }

        @media (max-width: 768px) {
            .courses-grid {
                grid-template-columns: 1fr;
            }

            .page-header h1 {
                font-size: 28px;
            }

            .courses-container {
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="courses-container">
        <div class="page-header">
            <h1>My Courses</h1>
            <p>Continue learning where you left off</p>
        </div>

        <% if (courses && courses.length > 0) { %>
            <div class="courses-grid">
                <% courses.forEach(course => { %>
                    <div class="course-card" onclick="playCourse('<%= course._id %>')">
                        <div class="course-image">
                            <img src="<%= course.thumbnailUrl || '/images/course-placeholder.jpg' %>" alt="<%= course.title %>" onerror="this.src='/images/course-placeholder.jpg'">
                            <div class="play-overlay">
                                <div class="play-button">
                                    <i class="fas fa-play"></i>
                                </div>
                            </div>
                        </div>

                        <div class="course-content">
                            <h3 class="course-title"><%= course.title %></h3>
                            <p class="course-description"><%= course.description || 'No description available' %></p>

                            <% 
                                const progressData = courseProgress.find(p => p.courseId === course._id.toString());
                                const progressPercentage = progressData ? progressData.percentage : 0;
                            %>

                            <div class="progress-bar-container">
                                <div class="progress-bar-fill" style="width: <%= progressPercentage %>%"></div>
                            </div>

                            <div class="course-meta">
                                <div class="meta-item">
                                    <i class="fas fa-graduation-cap"></i>
                                    <span><%= course.enrollCount || 0 %> students</span>
                                </div>
                                <div class="meta-item">
                                    <i class="fas fa-clock"></i>
                                    <span><%= course.duration || '?' %> hours</span>
                                </div>
                                <div class="meta-item">
                                    <i class="fas fa-star"></i>
                                    <span><%= course.rating ? course.rating.toFixed(1) : '0' %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-book"></i>
                </div>
                <h2 class="empty-title">No Courses Yet</h2>
                <p class="empty-description">You haven't enrolled in any courses yet. Start learning today!</p>
                <a href="/courses" class="browse-button">Browse Courses</a>
            </div>
        <% } %>
    </div>

    <script>
        function playCourse(courseId) {
            window.location.href = `/api/courses/${courseId}`;
        }
    </script>

    <%- include("../components/footer") %>
</body>
</html>
