<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3321203820490717" crossorigin="anonymous"></script>

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover">
    <title><%= userData.fullname || userData.username %> - Vidyari Profile</title>

    <meta name="description" content="View <%= userData.fullname || userData.username %>'s profile on Vidyari. Access shared docs, courses, followers, and explore their content.">
    <meta name="author" content="Vidyari">
    <link rel="canonical" href="https://vidyari.com/profile/<%= userData.username %>">
    <meta name="robots" content="index, follow">
    <meta property="og:title" content="<%= userData.fullname || userData.username %> on Vidyari">
    <meta property="og:description" content="<%- userData.bio || 'View ' + (userData.fullname || userData.username) + '\'s profile on Vidyari.' %>">
    <meta property="og:url" content="https://vidyari.com/profile/<%= userData.username %>">
    <meta property="og:image" content="<%= userData.profilePicUrl %>">
    <meta property="og:type" content="profile">
    <meta property="og:site_name" content="Vidyari">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= userData.fullname || userData.username %> on Vidyari">
    <meta name="twitter:description" content="<%- userData.bio || 'View ' + (userData.fullname || userData.username) + '\'s profile on Vidyari.' %>">
    <meta name="twitter:image" content="<%= userData.profilePicUrl %>">
    
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "<%= userData.fullname || userData.username %>",
      "alternateName": "<%= userData.username %>",
      "url": "https://vidyari.com/profile/<%= userData.username %>",
      "image": "<%= userData.profilePicUrl %>",
      "description": "<%- JSON.stringify(userData.bio || 'Digital explorer navigating the vast realms of code and creativity.').slice(1, -1) %>",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://vidyari.com/profile/<%= userData.username %>"
      }
    }
    </script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;800;900&family=Space+Grotesk:wght@700;900&family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        /* ==========================================================================
           VIDYARI PUBLIC PROFILE: NEO-BRUTALIST ARCHITECTURE
           ========================================================================== */
        .vidyari-public-profile-master {
            --v-bg: #fdfdfc; 
            --v-black: #09090b;
            --v-white: #ffffff;
            --v-pink: #ff66a3; 
            --v-green: #4ade80; 
            --v-yellow: #ffd60a; 
            --v-blue: #1ac2ff; 
            --v-gray-50: #fafafa;
            --v-gray-100: #f4f4f5;
            --v-gray-200: #e4e4e7;
            --v-gray-800: #27272a;
            
            --v-font-sans: 'Inter', sans-serif;
            --v-font-head: 'Montserrat', sans-serif;
            --v-font-loud: 'Space Grotesk', sans-serif;
            
            --v-radius-sm: 8px;
            --v-radius-md: 16px;
            --v-radius-lg: 24px;
            
            --v-border-thin: 2px solid var(--v-black);
            --v-border-thick: 4px solid var(--v-black);
            
            --v-shadow-sm: 4px 4px 0 var(--v-black);
            --v-shadow-md: 8px 8px 0 var(--v-black);
            --v-shadow-hover: 12px 12px 0 var(--v-black);
            
            --v-transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);

            font-family: var(--v-font-sans);
            background-color: var(--v-gray-50);
            background-image: radial-gradient(var(--v-gray-200) 2px, transparent 2px);
            background-size: 24px 24px;
            color: var(--v-black);
            min-height: 100vh;
            padding-top: clamp(30px, 5vw, 60px);
            padding-bottom: clamp(60px, 8vw, 100px);
            overflow-x: hidden;
        }

        .vidyari-public-profile-master a { text-decoration: none; color: inherit; }
        .vidyari-public-profile-master * { box-sizing: border-box; }

        /* Dashboard Layout Grid */
        .v-container {
            width: 100%;
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 clamp(16px, 4vw, 32px);
        }
        .profile-dashboard-grid {
            display: grid;
            grid-template-columns: 360px 1fr;
            gap: clamp(24px, 4vw, 40px);
            align-items: start;
        }

        /* UI Boxes */
        .v-box {
            background: var(--v-white);
            border: var(--v-border-thick);
            border-radius: var(--v-radius-lg);
            box-shadow: var(--v-shadow-md);
            padding: clamp(24px, 4vw, 32px);
            margin-bottom: clamp(24px, 4vw, 32px);
        }

        /* Buttons */
        .v-btn {
            background: var(--v-green);
            border: var(--v-border-thick);
            border-radius: var(--v-radius-sm);
            box-shadow: var(--v-shadow-sm);
            padding: 14px 24px;
            font-family: var(--v-font-loud);
            font-size: 1.1rem;
            font-weight: 900;
            text-transform: uppercase;
            color: var(--v-black);
            cursor: pointer;
            transition: all var(--v-transition);
            display: inline-flex; align-items: center; justify-content: center; gap: 10px;
            width: 100%;
        }
        .v-btn:hover { transform: translate(-2px, -2px); box-shadow: var(--v-shadow-md); background: var(--v-yellow); }
        .v-btn:active { transform: translate(2px, 2px); box-shadow: 2px 2px 0 var(--v-black); }
        
        .v-btn.btn-chat { background: var(--v-blue); }
        .v-btn.btn-chat:hover { background: var(--v-pink); color: var(--v-white); }
        
        .v-btn.is-following { background: var(--v-black); color: var(--v-white); }
        .v-btn.is-following:hover { background: var(--v-gray-800); box-shadow: var(--v-shadow-sm); transform: none; }

        /* --- LEFT COLUMN: Public ID Card --- */
        .sidebar-sticky {
            position: sticky;
            top: 100px;
        }
        .id-card-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .profile-avatar {
            width: 180px; height: 180px;
            border-radius: 50%;
            border: var(--v-border-thick);
            box-shadow: var(--v-shadow-sm);
            object-fit: cover;
            background: var(--v-white);
            margin-bottom: 20px;
        }
        .profile-name {
            font-family: var(--v-font-loud);
            font-size: 2.2rem;
            text-transform: uppercase;
            line-height: 1.1;
            margin-bottom: 4px;
            text-shadow: 2px 2px 0 var(--v-pink);
        }
        .profile-username {
            font-family: var(--v-font-head);
            font-size: 1.2rem;
            font-weight: 900;
            color: var(--v-gray-600);
            margin-bottom: 20px;
            background: var(--v-gray-100);
            padding: 4px 12px;
            border-radius: var(--v-radius-pill);
            border: var(--v-border-thin);
        }
        .profile-bio {
            font-size: 1.05rem;
            font-weight: 600;
            line-height: 1.6;
            color: var(--v-gray-800);
            margin-bottom: 24px;
            background: var(--v-yellow);
            padding: 16px;
            border-radius: var(--v-radius-sm);
            border: var(--v-border-thick);
            box-shadow: inset 4px 4px 0 rgba(0,0,0,0.05);
            width: 100%;
        }

        .user-meta-info {
            width: 100%;
            text-align: left;
            border-top: var(--v-border-thick);
            padding-top: 20px;
            margin-bottom: 24px;
        }
        .meta-row { display: flex; justify-content: space-between; font-weight: 700; margin-bottom: 8px; font-size: 0.95rem; }
        .meta-row .lbl { color: var(--v-gray-600); text-transform: uppercase; font-weight: 900; font-family: var(--v-font-head); }
        .meta-row .val { color: var(--v-black); }

        /* Public Stats Mini-Grid */
        .public-stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            width: 100%;
            margin-bottom: 24px;
        }
        .stat-pill {
            background: var(--v-white);
            border: var(--v-border-thin);
            border-radius: var(--v-radius-sm);
            padding: 12px;
            box-shadow: 2px 2px 0 var(--v-black);
            display: flex; flex-direction: column; align-items: center;
        }
        .stat-pill .count { font-family: var(--v-font-loud); font-size: 1.8rem; line-height: 1; margin-bottom: 4px;}
        .stat-pill .lbl { font-family: var(--v-font-head); font-size: 0.8rem; font-weight: 900; text-transform: uppercase; color: var(--v-gray-600); }

        .action-group {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* --- RIGHT COLUMN: Content --- */
        .content-heading {
            font-family: var(--v-font-loud);
            font-size: clamp(2.5rem, 5vw, 4rem);
            text-transform: uppercase;
            color: var(--v-black);
            margin-bottom: 24px;
            text-shadow: 3px 3px 0 var(--v-blue);
            display: flex; align-items: center; gap: 16px;
        }
        .content-heading i { font-size: 0.8em; color: var(--v-pink); }
        
        .content-section { margin-bottom: 48px; }

        /* Cards Grid */
        .v-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 24px; }
        .v-card { 
            background: var(--v-white); border: var(--v-border-thick); border-radius: var(--v-radius-lg); 
            box-shadow: var(--v-shadow-md); display: flex; flex-direction: column; overflow: hidden; 
            transition: all var(--v-transition); text-decoration: none; color: inherit;
        }
        .v-card:hover { transform: translate(-6px, -6px); box-shadow: var(--v-shadow-hover); }
        
        .v-card-img-box { aspect-ratio: 4/3; border-bottom: var(--v-border-thick); overflow: hidden; position: relative; background: var(--v-gray-100); }
        .v-card-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
        .v-card:hover .v-card-img { transform: scale(1.05); }
        
        .v-badge-card { position: absolute; top: 12px; left: 12px; background: var(--v-yellow); border: var(--v-border-thin); border-radius: var(--v-radius-sm); padding: 4px 10px; font-size: 0.8rem; font-weight: 900; text-transform: uppercase; }
        
        .v-card-content { padding: 20px; flex: 1; display: flex; flex-direction: column; justify-content: center;}
        .v-card-title { font-size: 1.25rem; font-weight: 800; margin-bottom: 8px; line-height: 1.3; }
        
        .v-card-footer { padding: 16px 20px; border-top: var(--v-border-thick); background: var(--v-gray-50); display: flex; justify-content: space-between; align-items: center; }
        .v-card-action { width: 36px; height: 36px; border: var(--v-border-thin); border-radius: 50%; display: grid; place-items: center; background: var(--v-white); box-shadow: 2px 2px 0 var(--v-black); transition: all 0.2s; }
        .v-card:hover .v-card-action { background: var(--v-black); color: var(--v-white); }

        /* Empty States */
        .empty-state {
            border: 4px dashed var(--v-gray-300);
            border-radius: var(--v-radius-lg);
            padding: 60px 20px;
            text-align: center;
            background: var(--v-white);
        }
        .empty-icon { font-size: 4rem; color: var(--v-gray-300); margin-bottom: 16px; }
        .empty-state h3 { font-family: var(--v-font-loud); font-size: 2rem; color: var(--v-gray-600); margin: 0; text-transform: uppercase; }

        /* ==========================================================================
           MOBILE RESPONSIVENESS FIXES
           ========================================================================== */
        @media (max-width: 991px) {
            .profile-dashboard-grid { grid-template-columns: 1fr; } /* Stack on mobile/tablet */
            .sidebar-sticky { position: relative; top: 0; }
            
            .id-card-wrapper { flex-direction: row; flex-wrap: wrap; text-align: left; align-items: flex-start; }
            .profile-avatar { width: 120px; height: 120px; margin-bottom: 0; margin-right: 24px;}
            .profile-info-mobile { flex: 1; min-width: 200px; display: flex; flex-direction: column; justify-content: center; }
            
            .profile-bio { order: 3; margin-top: 24px; }
            .public-stats-grid { order: 4; }
            .user-meta-info { order: 5; }
            .action-group { order: 6; flex-direction: row; }
        }
        @media (max-width: 576px) {
            .id-card-wrapper { flex-direction: column; text-align: center; align-items: center; }
            .profile-avatar { margin-right: 0; margin-bottom: 16px; }
            .profile-info-mobile { align-items: center; }
            .action-group { flex-direction: column; }
            .public-stats-grid { grid-template-columns: 1fr 1fr; } /* Keep 2 cols for stats */
        }
    </style>
</head>

<body>
    <div class="vidyari-public-profile-master">
        <div class="v-container">
            
            <div class="profile-dashboard-grid">
                
                <aside>
                    <div class="v-box id-card-wrapper sidebar-sticky">
                        <img src="<%= userData.profilePicUrl %>" alt="<%= userData.fullname || userData.username %>'s Avatar" class="profile-avatar" onerror="this.onerror=null; this.src='/images/avatar.jpg';"/>
                        
                        <div class="profile-info-mobile">
                            <div class="d-flex align-items-center justify-content-lg-center justify-content-start gap-2">
                                <h1 class="profile-name"><%= userData.fullname || userData.username %></h1>
                                <% if (userData.ISVERIFIED) { %>
                                    <span title="Verified Creator"><img style="width: 28px; height: 28px;" src="/images/verify.png" alt="Verified Badge"/></span>
                                <% } %>
                            </div>
                            <div class="profile-username">@<%= userData.username %></div>
                        </div>
                        
                        <div class="profile-bio"><%= userData.bio || 'Digital explorer navigating the vast realms of code and creativity.' %></div>
                        
                        <div class="public-stats-grid">
                            <div class="stat-pill">
                                <span class="count"><%= userData.followers.length || 0 %></span>
                                <span class="lbl">Followers</span>
                            </div>
                            <div class="stat-pill">
                                <span class="count"><%= userData.following.length || 0 %></span>
                                <span class="lbl">Following</span>
                            </div>
                            <div class="stat-pill">
                                <span class="count"><%= numsOfDocs %></span>
                                <span class="lbl">Docs</span>
                            </div>
                            <div class="stat-pill">
                                <span class="count"><%= numOfCourses %></span>
                                <span class="lbl">Courses</span>
                            </div>
                        </div>

                        <div class="user-meta-info">
                            <div class="meta-row">
                                <span class="lbl">Status</span>
                                <span class="val" style="color: var(--v-green);"><i class="fas fa-circle text-success me-1" style="font-size: 0.6rem;"></i> Online</span>
                            </div>
                            <% if (userData.createdAt) { %>
                                <div class="meta-row">
                                    <span class="lbl">Joined</span>
                                    <span class="val"><%= new Date(userData.createdAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %></span>
                                </div>
                            <% } %>
                        </div>
                        
                        <div class="action-group">
                            <button class="v-btn" id="followBtn" data-user-id="<%= userData._id %>">
                                </button>
                            <a href="/user/chat/<%=userData._id%>" class="v-btn btn-chat">
                                <i class="fas fa-comment-dots"></i> Message
                            </a>
                        </div>
                    </div>
                </aside>

                <main>
                    
                    <section class="content-section" id="docs-section">
                        <h2 class="content-heading"><i class="fas fa-file-alt"></i> Documents</h2>
                        
                        <% if (files && files.length > 0) { %>
                            <div class="v-grid">
                                <% files.forEach((file) => { %>
                                    <a href="/file/<%= file.slug %>/<%= file._id %>" class="v-card">
                                        <div class="v-card-img-box">
                                            <div class="v-badge-card"><%= file.category || 'Resource' %></div>
                                            <img class="v-card-img" src="<%= file.previewUrl || '/images/File_Demo.svg' %>" alt="Preview" onerror="this.onerror=null;this.src='/images/File_Demo.svg';">
                                        </div>
                                        <div class="v-card-content">
                                            <h3 class="v-card-title"><%= file.filename || 'Untitled Document' %></h3>
                                        </div>
                                        <div class="v-card-footer">
                                            <div class="fw-bold text-muted small"><%= file.fileType || 'PDF' %></div>
                                            <div class="v-card-action"><i class="fas fa-arrow-right"></i></div>
                                        </div>
                                    </a>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div class="empty-state">
                                <i class="fas fa-folder-open empty-icon"></i>
                                <h3>No Documents Published</h3>
                            </div>
                        <% } %>
                    </section>
                    
                    <section class="content-section" id="courses-section">
                        <h2 class="content-heading" style="text-shadow: 3px 3px 0 var(--v-yellow);"><i class="fas fa-video" style="color: var(--v-blue);"></i> Courses</h2>
                        
                        <div class="empty-state">
                            <i class="fas fa-video-slash empty-icon"></i>
                            <h3>No Courses Available</h3>
                        </div>
                    </section>

                </main>
            </div>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            
            // --- Follow Button Logic ---
            const followBtn = document.getElementById('followBtn');
            let isFollowed = <%= isFollowed %>; 
            const userIdToFollow = followBtn.dataset.userId;

            function updateFollowButtonState() {
                if (isFollowed) {
                    followBtn.innerHTML = '<i class="fas fa-check"></i> Following';
                    followBtn.classList.add('is-following');
                } else {
                    followBtn.innerHTML = '<i class="fas fa-user-plus"></i> Follow';
                    followBtn.classList.remove('is-following');
                }
            }

            if (followBtn) {
                followBtn.addEventListener('click', () => {
                    const url = isFollowed ? `/user/unfollow` : `/user/follow`;
                    
                    // Optimistic UI update
                    const previousState = isFollowed;
                    isFollowed = !isFollowed;
                    updateFollowButtonState();
                    followBtn.disabled = true;

                    fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ userId: userIdToFollow })
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            // Only reload if successful to update true backend state
                            window.location.reload(); 
                        } else {
                            // Revert on failure
                            isFollowed = previousState;
                            updateFollowButtonState();
                            alert(data.message || 'An error occurred.');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        // Revert on failure
                        isFollowed = previousState;
                        updateFollowButtonState();
                        alert('An error occurred.');
                    })
                    .finally(() => {
                        followBtn.disabled = false;
                    });
                });

                // Initial State Setup
                updateFollowButtonState();
            }
        });
    </script>
</body>
</html>