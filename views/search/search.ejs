<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    
    <title><%= seo && seo.metaTags && seo.metaTags.title ? seo.metaTags.title : 'Search Courses & Resources - Vidyari' %></title>
    <meta name="title" content="<%= seo && seo.metaTags && seo.metaTags.title ? seo.metaTags.title : 'Search Courses & Resources - Vidyari' %>">
