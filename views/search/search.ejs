    <meta name="author" content="Vidyari Inc.">
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <meta name="theme-color" content="#ffffff">

    <link rel="canonical" href="https://www.vidyari.com/search?<%= query ? 'query=' + encodeURIComponent(query) : '' %>">

    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.vidyari.com/search?<%= query ? 'query=' + encodeURIComponent(query) : '' %>">
