<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<div class="v-share-widget">
    <button class="share-button" id="mainShareButton" aria-label="Share this page" aria-expanded="false">
        <i class="fa-solid fa-share-nodes"></i> <span>Share</span>
    </button>
    
    <div class="share-options" id="shareOptionsContainer" role="menu">
        <a href="#" id="shareFacebook" title="Share on Facebook" role="menuitem"><i class="fa-brands fa-facebook-f"></i></a>
        <a href="#" id="shareTwitter" title="Share on X (Twitter)" role="menuitem"><i class="fa-brands fa-x-twitter"></i></a>
        <a href="#" id="shareWhatsapp" title="Share on WhatsApp" role="menuitem"><i class="fa-brands fa-whatsapp"></i></a>
        <a href="#" id="shareEmail" title="Share via Email" role="menuitem"><i class="fa-regular fa-envelope"></i></a>
        <button id="copyLinkButton" title="Copy Link" role="menuitem"><i class="fa-solid fa-link"></i></button>
    </div>
    
    <div id="copyFeedback" role="status">Link copied to clipboard</div>
</div>

<style>
    /* --- Styles scoped under .v-share-widget (Material 3 Theme) --- */
    .v-share-widget {
        --v-font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        
        --v-bg-surface: #ffffff;
        --v-bg-soft: #f0f4f9;
        --v-text-main: #1f1f1f;
        --v-text-muted: #444746;
        
        --v-primary: #0b57d0;
        --v-primary-bg: #e8f0fe;
        
        --v-border: #dadce0;
        
        --v-shadow-popover: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        --v-shadow-hover: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        
        --v-radius-pill: 9999px;
        --v-radius-card: 16px;
        
        --v-transition: all 0.2s cubic-bezier(0.2, 0, 0, 1);

        font-family: var(--v-font-sans);
        position: relative;
        display: inline-block;
    }

    .v-share-widget *,
    .v-share-widget *::before,
    .v-share-widget *::after {
        box-sizing: border-box;
    }

    /* --- Main Share Button --- */
    .v-share-widget .share-button {
        background-color: var(--v-bg-surface);
        color: var(--v-text-muted);
        border: 1px solid var(--v-border);
        border-radius: var(--v-radius-pill);
        padding: 10px 20px;
        font-family: var(--v-font-sans);
        font-size: 0.95rem;
        font-weight: 500;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: var(--v-transition);
        line-height: 1;
    }

    .v-share-widget .share-button i {
        font-size: 1.1rem;
    }

    .v-share-widget .share-button:hover {
        background-color: var(--v-bg-soft);
        color: var(--v-text-main);
    }

    .v-share-widget .share-button:active {
        background-color: #e4e8ee;
        transform: scale(0.98);
    }

    /* --- Share Options Panel --- */
    .v-share-widget .share-options {
        display: flex;
        flex-wrap: nowrap;
        position: absolute;
        bottom: calc(100% + 12px);
        left: 50%;
        transform: translateX(-50%) scale(0.95) translateY(10px);
        transform-origin: bottom center;
        background-color: var(--v-bg-surface);
        border: 1px solid var(--v-border);
        border-radius: var(--v-radius-card);
        box-shadow: var(--v-shadow-popover);
        padding: 12px;
        gap: 8px;
        z-index: 999;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.2, 0, 0, 1), visibility 0s 0.2s;
    }

    .v-share-widget .share-options.active {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) scale(1) translateY(0);
        box-shadow: var(--v-shadow-hover);
        transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.2, 0, 0, 1), visibility 0s;
    }

    /* --- Individual Share Icons/Buttons --- */
    .v-share-widget .share-options a,
    .v-share-widget .share-options button {
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--v-bg-soft);
        border: none;
        border-radius: 50%;
        color: var(--v-text-muted);
        font-size: 1.1rem;
        width: 44px;
        height: 44px;
        cursor: pointer;
        transition: var(--v-transition);
        text-decoration: none;
        padding: 0;
    }

    .v-share-widget .share-options a:hover,
    .v-share-widget .share-options button:hover {
        background-color: var(--v-primary-bg);
        color: var(--v-primary);
        transform: translateY(-2px);
    }

    .v-share-widget .share-options a:active,
    .v-share-widget .share-options button:active {
        transform: translateY(0) scale(0.95);
    }

    /* --- Copy Feedback Toast --- */
    .v-share-widget #copyFeedback {
        position: fixed;
        bottom: 32px;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background-color: #202124; /* Material Dark Gray */
        color: #ffffff;
        padding: 12px 24px;
        border-radius: 8px;
        font-family: var(--v-font-sans);
        font-size: 0.95rem;
        font-weight: 500;
        white-space: nowrap;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.2, 0, 0, 1), visibility 0s 0.3s;
        pointer-events: none;
        z-index: 1001;
        box-shadow: 0 4px 6px rgba(0,0,0,0.2);
    }

    .v-share-widget #copyFeedback.show {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
        transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.2, 0, 0, 1), visibility 0s;
    }

    /* --- Responsive adjustments --- */
    @media (max-width: 480px) {
        .v-share-widget .share-options {
            /* Keep it centered but prevent overflow on tiny screens */
            width: max-content;
            max-width: 90vw;
        }
    }
</style>

<script>
    function initializeVShareWidget(widgetElement) {
        if (!widgetElement) return;

        const mainShareButton = widgetElement.querySelector('.share-button');
        const shareOptionsContainer = widgetElement.querySelector('.share-options');
        const copyLinkButton = widgetElement.querySelector('#copyLinkButton');
        const copyFeedback = widgetElement.querySelector('#copyFeedback');

        if (!mainShareButton || !shareOptionsContainer || !copyLinkButton || !copyFeedback) {
            console.error("Incomplete share widget structure.", widgetElement);
            return;
        }

        // Toggle share options visibility
        mainShareButton.addEventListener('click', (event) => {
            event.stopPropagation();
            const isActive = shareOptionsContainer.classList.toggle('active');
            mainShareButton.setAttribute('aria-expanded', isActive);
            
            if (!isActive) {
                copyFeedback.classList.remove('show');
            }
        });

        // Close options if clicked outside
        document.addEventListener('click', (event) => {
            if (!widgetElement.contains(event.target)) {
                shareOptionsContainer.classList.remove('active');
                mainShareButton.setAttribute('aria-expanded', 'false');
            }
        });

        // Dynamic URL/Title Fetching
        const getCurrentShareUrl = () => encodeURIComponent(window.location.href);
        const getCurrentShareTitle = () => encodeURIComponent(document.title);

        const fbLink = shareOptionsContainer.querySelector('#shareFacebook');
        const twLink = shareOptionsContainer.querySelector('#shareTwitter');
        const waLink = shareOptionsContainer.querySelector('#shareWhatsapp');
        const emLink = shareOptionsContainer.querySelector('#shareEmail');

        // Update links dynamically when opening the menu
        mainShareButton.addEventListener('mouseenter', () => {
            const shareUrl = getCurrentShareUrl();
            const shareTitle = getCurrentShareTitle();
            if(fbLink) fbLink.href = `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`;
            if(twLink) twLink.href = `https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareTitle}`;
            if(waLink) waLink.href = `https://api.whatsapp.com/send?text=${shareTitle}%20${shareUrl}`;
            if(emLink) emLink.href = `mailto:?subject=${shareTitle}&body=Check this out:%0A${shareUrl}`;
        });

        // Copy Link Functionality
        copyLinkButton.addEventListener('click', () => {
            const urlToCopy = decodeURIComponent(getCurrentShareUrl());
            navigator.clipboard.writeText(urlToCopy).then(() => {
                copyFeedback.classList.add('show');
                setTimeout(() => {
                    copyFeedback.classList.remove('show');
                }, 2500); // Slightly longer reading time for the toast
                shareOptionsContainer.classList.remove('active');
                mainShareButton.setAttribute('aria-expanded', 'false');
            }).catch(err => {
                console.error('Failed to copy link: ', err);
            });
        });

        shareOptionsContainer.addEventListener('click', (event) => {
            event.stopPropagation();
        });

        // External link behavior
        shareOptionsContainer.querySelectorAll('a').forEach(link => {
            if (!link.href.startsWith('mailto:')) {
                 link.target = '_blank';
                 link.rel = 'noopener noreferrer';
            }
            link.addEventListener('click', () => {
                setTimeout(() => {
                     shareOptionsContainer.classList.remove('active');
                     mainShareButton.setAttribute('aria-expanded', 'false');
                }, 150);
            });
        });
    }

    // Initialize all share widgets on the page
    document.querySelectorAll('.v-share-widget').forEach(widget => {
        initializeVShareWidget(widget);
    });
</script>