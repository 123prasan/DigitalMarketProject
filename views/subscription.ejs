
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upgrade to Vidyari Pro</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;800;900&family=Space+Grotesk:wght@700;900&family=Inter:wght@500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        :root {
            --color-bg: #f4f4f0;
            --color-black: #0a0a0a;
            --color-pink: #ff66a3;
            --color-green: #4ade80;
            --color-yellow: #ffd60a;
            --color-blue: #1ac2ff;
        }

        body {
            background-color: var(--color-bg);
            color: var(--color-black);
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            background-image: radial-gradient(#d1d1cc 2px, transparent 2px);
            background-size: 30px 30px;
            position: relative;
        }

        h1, h2, h3, h4, h5 { font-family: 'Montserrat', sans-serif; }
        .font-extreme { font-family: 'Space Grotesk', sans-serif; }

        /* Typography Effects */
        .text-outline {
            color: transparent;
            -webkit-text-stroke: 2px var(--color-black);
            text-shadow: 5px 5px 0 var(--color-yellow);
            transition: all 0.3s ease;
        }
        .text-outline:hover {
            color: var(--color-black);
            -webkit-text-stroke: 0px;
            text-shadow: 6px 6px 0 var(--color-pink);
        }

        /* Brutalist Utilities */
        .chunky-card {
            border: 6px solid var(--color-black);
            border-radius: 24px;
            transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s ease;
            position: relative;
            z-index: 20;
        }
        .card-free {
            background-color: #fff;
            box-shadow: 12px 12px 0 var(--color-black);
        }
        .card-free:hover {
            transform: translate(-4px, -4px);
            box-shadow: 16px 16px 0 var(--color-black);
        }
        .card-pro {
            background-color: var(--color-black);
            color: white;
            box-shadow: 16px 16px 0 var(--color-pink);
            z-index: 30;
        }
        .card-pro:hover {
            transform: translate(-4px, -4px) scale(1.02);
            box-shadow: 20px 20px 0 var(--color-green);
        }

        /* 3D Button System */
        .chunky-btn-wrapper { position: relative; display: block; width: 100%; }
        .chunky-btn-bg {
            position: absolute; inset: 0; background: var(--color-black); border-radius: 14px;
            transform: translate(6px, 6px); transition: transform 0.2s ease;
        }
        .chunky-btn {
            position: relative; z-index: 10; display: flex; align-items: center; justify-content: center;
            border: 5px solid var(--color-black); border-radius: 14px; padding: 16px 24px;
            font-size: 1.15rem; font-weight: 900; font-family: 'Montserrat', sans-serif; text-transform: uppercase;
            cursor: pointer; transition: transform 0.2s ease; text-decoration: none; width: 100%; text-align: center;
        }

        /* Button Colors */
        .btn-primary { background-color: var(--color-pink); color: white; border-color: white; }
        .chunky-btn-wrapper:hover .btn-primary { background-color: #ff4d94; }
        .btn-wallet { background-color: var(--color-yellow); color: var(--color-black); }
        .chunky-btn-wrapper:hover .btn-wallet { background-color: #facc15; }

        /* Interaction States */
        .chunky-btn-wrapper:hover .chunky-btn { transform: translate(-2px, -2px); }
        .chunky-btn-wrapper:hover .chunky-btn-bg { transform: translate(8px, 8px); }
        .chunky-btn-wrapper:active .chunky-btn { transform: translate(4px, 4px); }
        .chunky-btn-wrapper:active .chunky-btn-bg { transform: translate(4px, 4px); }

        /* Scroll Animations */
        .reveal-up { opacity: 0; transform: translateY(40px); transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
        .is-revealed { opacity: 1; transform: translateY(0); }

        /* Sticker Badge */
        .sticker {
            position: absolute; background: var(--color-yellow); color: var(--color-black);
            border: 4px solid var(--color-black); box-shadow: 4px 4px 0 var(--color-black);
            font-weight: 900; padding: 8px 24px; border-radius: 50px; text-transform: uppercase;
            letter-spacing: 1px; z-index: 40;
        }

        /* Background SVG Animations */
        .float-slow { animation: float 6s ease-in-out infinite; }
        .float-fast { animation: float 4s ease-in-out infinite reverse; }
        .spin-slow { animation: spin 12s linear infinite; }
        
        @keyframes float {
            0% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(5deg); }
            100% { transform: translateY(0px) rotate(0deg); }
        }
        @keyframes spin { 100% { transform: rotate(360deg); } }
    </style>
</head>

<body>

    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <svg class="absolute top-10 left-10 md:left-24 w-24 h-24 spin-slow" viewBox="0 0 100 100" fill="none">
            <path d="M50 0L56 38L93 25L65 50L93 75L56 62L50 100L44 62L7 75L35 50L7 25L44 38L50 0Z" fill="#ff66a3" stroke="#0a0a0a" stroke-width="4"/>
        </svg>

        <svg class="absolute top-1/3 right-5 md:right-20 w-32 h-16 float-slow" style="transform: rotate(-15deg);" viewBox="0 0 200 100" fill="none">
            <rect x="5" y="5" width="190" height="90" rx="45" fill="#1ac2ff" stroke="#0a0a0a" stroke-width="6"/>
            <rect x="5" y="5" width="190" height="90" rx="45" fill="url(#stripes)" opacity="0.3"/>
        </svg>

        <svg class="absolute bottom-20 left-5 md:left-32 w-28 h-28 float-fast" viewBox="0 0 100 100" fill="none">
            <polygon points="50,5 61,35 95,35 68,57 79,90 50,70 21,90 32,57 5,35 39,35" fill="#ffd60a" stroke="#0a0a0a" stroke-width="4" stroke-linejoin="round"/>
        </svg>

        <svg class="absolute bottom-10 right-10 md:right-40 w-32 h-32 spin-slow" viewBox="0 0 100 100" fill="none">
            <circle cx="50" cy="50" r="45" fill="#4ade80" stroke="#0a0a0a" stroke-width="5"/>
            <circle cx="50" cy="50" r="20" fill="#0a0a0a"/>
        </svg>

        <svg style="width:0;height:0;position:absolute;" aria-hidden="true">
            <defs>
                <pattern id="stripes" width="10" height="10" patternTransform="rotate(45 0 0)" patternUnits="userSpaceOnUse">
                    <line x1="0" y1="0" x2="0" y2="10" stroke="#0a0a0a" stroke-width="3" />
                </pattern>
            </defs>
        </svg>
    </div>

    <section class="pt-24 pb-16 px-6 relative z-10 text-center reveal-up">
        <div class="inline-block bg-[#1ac2ff] text-black font-black px-6 py-2 border-[4px] border-black rounded-full mb-6 shadow-[4px_4px_0_#000] rotate-[-3deg] uppercase tracking-widest text-sm relative z-20">
            For Serious Creators
        </div>

        <h1 class="text-6xl md:text-[5.5rem] font-extreme leading-[0.9] tracking-tighter mb-6 uppercase text-balance relative z-20">
            Unleash Your <br><span class="text-outline cursor-crosshair">Revenue</span>
        </h1>

        <p class="text-xl md:text-2xl font-bold max-w-2xl mx-auto text-gray-800 bg-white/70 backdrop-blur-md p-4 rounded-xl border-4 border-black shadow-[6px_6px_0_#0a0a0a] relative z-20">
            Stop giving away 30% of your hard work. Keep 90% of your earnings and rank higher in search.
        </p>
    </section>

    <section class="pb-32 px-6 max-w-6xl mx-auto relative z-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">

            <div class="chunky-card card-free p-10 flex flex-col justify-between reveal-up order-2 lg:order-1 mt-0 lg:mt-8">
                <div>
                    <h5 class="text-2xl font-black text-gray-400 uppercase mb-2 tracking-tight">Basic Creator</h5>
                    <div class="flex items-baseline mb-8">
                        <h2 class="text-6xl font-extreme text-black">₹0</h2>
                        <span class="text-xl font-bold text-gray-400 ml-2">/ month</span>
                    </div>

                    <div class="h-1 w-full bg-gray-200 rounded-full mb-8"></div>

                    <ul class="space-y-6 text-lg font-bold text-gray-700 mb-10">
                        <li class="flex items-start">
                            <i class="fa-solid fa-check text-2xl text-[#4ade80] w-10 mt-1"></i>
                            <span>Keep 70% of sales</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fa-solid fa-check text-2xl text-[#4ade80] w-10 mt-1"></i>
                            <span>Standard Visibility</span>
                        </li>
                        <li class="flex items-start opacity-40 grayscale">
                            <i class="fa-solid fa-xmark text-2xl w-10 mt-1"></i>
                            <span class="line-through">Featured Badge Placements</span>
                        </li>
                        <li class="flex items-start opacity-40 grayscale">
                            <i class="fa-solid fa-xmark text-2xl w-10 mt-1"></i>
                            <span class="line-through">Advanced Sales Analytics</span>
                        </li>
                    </ul>
                </div>

                <div class="chunky-btn-wrapper opacity-50 cursor-not-allowed">
                    <div class="chunky-btn-bg bg-gray-300"></div>
                    <div class="chunky-btn bg-gray-100 border-gray-400 text-gray-500 py-5">
                        Your Current Plan
                    </div>
                </div>
            </div>

            <div class="chunky-card card-pro p-10 flex flex-col justify-between relative reveal-up order-1 lg:order-2 transform lg:-translate-y-4" style="transition-delay: 0.1s;">

                <div class="sticker -top-6 -right-4 rotate-6 md:-right-8 md:-top-8 md:rotate-12 bg-[#4ade80]">
                    <i class="fas fa-fire me-1"></i> Best Value
                </div>

                <div>
                    <h5 class="text-2xl font-black text-[#1ac2ff] uppercase mb-2 tracking-tight">Vidyari Pro</h5>
                    <div class="flex items-baseline mb-6">
                        <h2 class="text-7xl font-extreme text-[#ffd60a]">₹499</h2>
                        <span class="text-xl font-bold text-gray-400 ml-2">/ month</span>
                    </div>

                    <div class="bg-white text-black font-black p-4 rounded-xl border-4 border-[#ff66a3] mb-8 transform -rotate-1 shadow-[4px_4px_0_#ff66a3]">
                        <i class="fa-solid fa-sack-dollar text-[#ff66a3] me-2 text-xl"></i> Perfect for ambitious creators. Cancel anytime.
                    </div>

                    <ul class="space-y-6 text-xl font-bold text-white mb-10">
                        <li class="flex items-start">
                            <div class="bg-[#ff66a3] rounded-full w-8 h-8 flex items-center justify-center border-2 border-white me-4 mt-1 shrink-0">
                                <i class="fas fa-arrow-up text-white text-sm"></i>
                            </div>
                            <span>Keep <span class="text-[#ff66a3] font-extreme text-2xl">90%</span> of all revenue</span>
                        </li>
                        <li class="flex items-start">
                            <div class="bg-[#1ac2ff] rounded-full w-8 h-8 flex items-center justify-center border-2 border-white me-4 mt-1 shrink-0">
                                <i class="fas fa-star text-white text-sm"></i>
                            </div>
                            <span>Instant "Featured" Badge</span>
                        </li>
                        <li class="flex items-start">
                            <div class="bg-[#4ade80] rounded-full w-8 h-8 flex items-center justify-center border-2 border-white me-4 mt-1 shrink-0">
                                <i class="fas fa-chart-pie text-white text-sm"></i>
                            </div>
                            <span>Advanced Sales Analytics</span>
                        </li>
                    </ul>
                </div>

                <div class="mt-auto">
                    <% if (user && user.isPro) { %>
                        <div class="bg-[#4ade80] border-[4px] border-white rounded-xl p-6 shadow-[6px_6px_0_#fff] text-center transform rotate-1 text-black">
                            <i class="fas fa-circle-check text-5xl mb-3"></i>
                            <h4 class="text-3xl font-black uppercase mb-1">Pro Active!</h4>
                            <p class="font-bold">Next billing: <%= user.proBillingCycleEnd ? user.proBillingCycleEnd.toDateString() : 'Next Month' %></p>
                        </div>
                        <% if (user && user.isPro) { %>
    <div class="mt-8 text-center">
        <form action="/subscription/cancel" method="POST" onsubmit="return confirmCancel()">
            <button type="submit" class="text-gray-500 hover:text-red-500 font-bold text-sm uppercase tracking-widest transition-colors">
                <i class="fa-solid fa-circle-xmark mr-2"></i> Cancel Pro Subscription
            </button>
        </form>
    </div>
<% } %>

<script>
    function confirmCancel() {
        return confirm("Are you sure? \n\nYou will immediately lose your 90% revenue share and 'Featured' status. You will revert to the standard 70% share.");
    }
</script>
                    <% } else { %>
                        <div class="space-y-5">
                            
                            <div class="chunky-btn-wrapper">
                                <div class="chunky-btn-bg bg-white"></div>
                                <button id="payNowBtn" type="button" class="chunky-btn btn-primary py-5">
                                    Subscribe Now <span class="ml-2 bg-white text-[#ff66a3] px-2 py-1 rounded text-sm hidden sm:inline-block border-2 border-[#ff66a3]">Pay ₹499</span>
                                </button>
                            </div>

                            <div class="flex items-center justify-center space-x-4 opacity-50 my-2">
                                <div class="h-[2px] w-full bg-white rounded"></div>
                                <span class="font-black uppercase tracking-widest text-sm text-white">OR</span>
                                <div class="h-[2px] w-full bg-white rounded"></div>
                            </div>

                            <form action="/subscription/pay-later" method="POST" class="mb-0" onsubmit="return confirmWalletSub()">
                                <div class="chunky-btn-wrapper">
                                    <div class="chunky-btn-bg bg-[#ff66a3]"></div>
                                    <button type="submit" class="chunky-btn btn-wallet py-4 flex flex-col gap-1 border-white">
                                        <span class="flex items-center text-xl"><i class="fas fa-wallet me-3 text-black"></i> Subscribe via Wallet</span>
                                        <span class="text-xs tracking-normal normal-case font-bold opacity-80 text-black">Deduct ₹499 from your next sales</span>
                                    </button>
                                </div>
                            </form>
                        </div>
                    <% } %>
                </div>
            </div>

        </div>
    </section>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <script>
        // 1. Subscription Confirmation
        function confirmWalletSub() {
            return confirm("CONFIRM UPGRADE\n\nBy clicking OK, your account will immediately upgrade to Vidyari Pro. The ₹499 fee will be automatically deducted from your upcoming sales earnings. No upfront payment required today.");
        }

        // 2. Intersection Observer for Scroll Reveals
        document.addEventListener('DOMContentLoaded', () => {
            const revealElements = document.querySelectorAll('.reveal-up');
            const revealOptions = { threshold: 0.1, rootMargin: "0px 0px -50px 0px" };

            const revealOnScroll = new IntersectionObserver(function (entries, observer) {
                entries.forEach(entry => {
                    if (!entry.isIntersecting) return;
                    entry.target.classList.add('is-revealed');
                    observer.unobserve(entry.target);
                });
            }, revealOptions);

            revealElements.forEach(el => revealOnScroll.observe(el));
            
            // 3. Razorpay Logic (Only if user is not Pro)
            const payNowBtn = document.getElementById('payNowBtn');
            if (payNowBtn) {
                payNowBtn.onclick = async function (e) {
                    try {
                        const response = await fetch('/subscription/pay-now', { method: 'POST' });
                        const data = await response.json();

                        if (!data.success) {
                            alert("Failed to initialize payment. Please try again.");
                            return;
                        }

                        const options = {
                            "key": data.key_id,
                            "amount": data.amount,
                            "currency": "INR",
                            "image": "http://www.vidyari.com/images/logo.svg",
                            "name": "Vidyari Pro",
                            "description": "Monthly Creator Subscription",
                            "order_id": data.order_id,
                            "handler": async function (response) {
                                // Send to server for verification
                                const verifyRes = await fetch('/subscription/verify-payment', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify(response)
                                });
                                const result = await verifyRes.json();
                                if (result.success) {
                                    window.location.href = "/dashboard?status=pro_active";
                                } else {
                                    alert("Payment verification failed. Please contact support.");
                                }
                            },
                            "prefill": {
                                "name": data.user.name,
                                "email": data.user.email,
                                "contact": data.user.contact
                            },
                            "theme": { "color": "#ff66a3" } // Vidyari Pink
                        };
                        const rzp = new Razorpay(options);
                        rzp.open();
                    } catch (error) {
                        console.error("Error initiating payment:", error);
                        alert("An error occurred. Please try again later.");
                    }
                };
            }
        });
    </script>
</body>

</html>
<%- include("footer") %>