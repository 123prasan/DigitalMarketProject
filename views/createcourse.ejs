										<% if (typeof user !=='undefined' && user.isPro) { %>
											<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6 border-b-4 border-black pb-6">
												<div>
													<h4 class="text-3xl font-extreme text-[#1ac2ff] uppercase drop-shadow-[2px_2px_0_#000]">
                                                        Vidyari Pro</h4>
													<p class="font-bold text-gray-600 mt-1">You are keeping <strong class="text-[#ff66a3]">90%</strong> of your revenue.</p>
												</div> <span class="bg-[#4ade80] border-4 border-black px-4 py-2 font-black uppercase shadow-[4px_4px_0_#000] rotate-2">Active</span> </div>
											<div class="mb-8">
												<p class="text-sm font-bold text-gray-500 uppercase">Next Billing Date </p>
												<p class="text-2xl font-black mt-1">
													<%= user.proBillingCycleEnd ? new
                                                        Date(user.proBillingCycleEnd).toLocaleDateString('en-GB', {
                                                        day: 'numeric' , month: 'short' , year: 'numeric' }) : 'N/A' %>
												</p>
											</div>
											<div class="flex flex-wrap justify-between items-center gap-4 bg-gray-100 p-4 border-2 border-black">
												<p class="text-sm font-bold text-gray-600 max-w-sm">Need to cancel? You will revert to the 70% basic share at the end of your billing cycle. </p>
												<form action="/subscription/cancel" method="POST" class="m-0" onsubmit="return confirm('WARNING: Are you sure you want to cancel? You will lose your 90% revenue share and Featured status.');">
													<button type="submit" class="chunky-btn bg-[#ff66a3] !text-white text-sm">Cancel Pro</button>
												</form>
											</div>
											<% } else { %>
												<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6 border-b-4 border-black pb-6">
													<div>
														<h4 class="text-3xl font-extreme text-gray-400 uppercase drop-shadow-[2px_2px_0_#000]">
                                                            Basic Creator</h4>
														<p class="font-bold text-gray-600 mt-1">You are keeping <strong>70%</strong> of your revenue.</p>
													</div> <span class="bg-gray-200 border-4 border-black px-4 py-2 font-black uppercase shadow-[4px_4px_0_#000] -rotate-2 text-gray-500">Free</span> </div>
												<div class="flex flex-col sm:flex-row justify-between items-center gap-4 mt-8">
													<p class="font-bold text-gray-700">Stop giving away your hard work. Keep 90% with Pro.</p> <a href="/subscription" class="chunky-btn bg-[#ffd60a] !px-8 text-center w-full sm:w-auto">Upgrade
                                                        to Pro</a> </div>
												<% } %>
