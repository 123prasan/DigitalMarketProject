														<td class="p-3">
															<%= transaction.transactionId %>
														</td>
														<td class="p-3">
															<%= new
                                                                Date(transaction.createdAt).toLocaleDateString('en-GB',
                                                                { day: 'numeric' , month: 'short' , year: 'numeric' })
                                                                %>
														</td>
														<td class="p-3 font-bold">₹
															<%=
                                                                transaction.totalAmount.toFixed(2) %>
														</td>
