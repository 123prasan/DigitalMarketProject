								<nav id="settings-tabs" class="-mb-px flex space-x-6">
									<button data-target="billings-settings" class="settings-tab-btn whitespace-nowrap py-4 px-1 border-b-4 border-black font-black text-sm uppercase">Billings</button>
									<button data-target="subscription-settings" class="settings-tab-btn whitespace-nowrap py-4 px-1 border-b-4 border-transparent text-gray-500 hover:text-black font-bold text-sm uppercase transition-colors">Subscription</button>
