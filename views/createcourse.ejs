								<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
									<div class="md:col-span-1">
										<h3 class="text-lg font-bold uppercase">Payment Method</h3>
										<p class="mt-1 text-sm font-semibold text-gray-500">Where we send your money. </p>
									</div>
									<div class="md:col-span-2 p-6 border-4 border-black bg-white shadow-[6px_6px_0_#000]">
										<div>
											<label class="block text-sm font-bold uppercase">UPI ID</label>
											<div class="mt-2 space-y-4">
												<input type="text" id="upi-id" placeholder="your-upi-id@okhdfcbank" value="<%= typeof upiId !== 'undefined' ? upiId : ''%>" class="filter-input-unique block w-full py-3 px-4 sm:text-sm">
												<div class="flex justify-end">
