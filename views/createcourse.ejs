						<div class="space-y-6">
							<div class="data-card-unique flex flex-wrap items-center justify-between gap-4">
								<div class="flex items-center gap-3">
									<div class="w-12 h-12 rounded-lg flex items-center justify-center" style="background-color: var(--color-focus);"><i class="fa-solid fa-indian-rupee-sign text-2xl text-black"></i></div>
									<div>
