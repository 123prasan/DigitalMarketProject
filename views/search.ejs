        async function loadExploreCategories() {
            try {
                const response = await fetch(`${apiBaseUrl}/explore?sortBy=trending&limit=12`);
                const data = await response.json();
                if (data.success && data.explore && data.explore.length > 0) {
                    let html = `
                        <div class="section-header-block">
