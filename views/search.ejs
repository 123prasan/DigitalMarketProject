        // ============ PRICE PRESETS ============
        function setPricePreset(min, max) {
            const minPriceEl = document.getElementById('minPrice');
            const maxPriceEl = document.getElementById('maxPrice');
            const displayEl = document.getElementById('priceRangeDisplay');
            const sliderEl = document.getElementById('priceRangeSlider');
            
            if (minPriceEl) minPriceEl.value = min;
            if (maxPriceEl) maxPriceEl.value = max;
            if (sliderEl) sliderEl.value = max;
            if (displayEl) displayEl.textContent = `₹${min} - ₹${max}`;
            
            applyFilters();
        }

        function updatePriceDisplay() {
            const minPriceEl = document.getElementById('minPrice');
            const maxPriceEl = document.getElementById('maxPrice');
            const displayEl = document.getElementById('priceRangeDisplay');
            const sliderEl = document.getElementById('priceRangeSlider');
            
            if (displayEl && sliderEl) {
                const maxPrice = sliderEl.value;
                if (maxPriceEl) maxPriceEl.value = maxPrice;
                const minPrice = minPriceEl ? minPriceEl.value || 0 : 0;
                displayEl.textContent = `₹${minPrice} - ₹${maxPrice}`;
            }
        }

        // ============ DURATION PRESETS ============
        function setDurationPreset(preset) {
            document.querySelectorAll('input[value="short"], input[value="medium"], input[value="long"]').forEach(cb => cb.checked = false);
            
            if (preset === 'short') {
                const el = document.getElementById('durShort');
                if (el) el.checked = true;
            } else if (preset === 'medium') {
                const el = document.getElementById('durMed');
                if (el) el.checked = true;
            } else if (preset === 'long') {
                const el = document.getElementById('durLong');
                if (el) el.checked = true;
            }
            
            applyFilters();
        }

        // ============ TRACK SEARCHES FOR ANALYTICS ============
        function trackSearch(query) {
            fetch(`${apiBaseUrl}/track-search`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    query: query,
                    resultCount: parseInt(document.querySelector('.results-count')?.textContent || 0),
                    timeSpent: Date.now()
                })
            }).catch(err => console.error('Telemetry error:', err));
        }
    </script>
    </main>

    <!-- SEO: Add structured data for Product/Course schema in results -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Monitor results container for dynamic content changes
            const resultsContainer = document.getElementById('resultsContainer');
            if (resultsContainer) {
                // Observer to track when results are added
                const observer = new MutationObserver(() => {
                    updateProductSchemas();
                });
                
                observer.observe(resultsContainer, {
                    childList: true,
                    subtree: true
                });
            }
        });

        function updateProductSchemas() {
            // Add JSON-LD for each product in the results
            const results = document.querySelectorAll('.result-item');
            const products = [];
            
            results.forEach((item, index) => {
                const title = item.querySelector('.result-title')?.textContent || '';
                const price = item.querySelector('.result-price')?.textContent || '0';
                const rating = item.querySelector('.result-rating')?.getAttribute('data-rating') || '0';
                const image = item.querySelector('.result-image')?.src || '';
                
                if (title) {
                    products.push({
                        '@type': 'Product',
                        'position': index + 1,
                        'name': title.trim(),
                        'image': image,
                        'description': title.trim(),
                        'offers': {
                            '@type': 'Offer',
                            'price': price.replace(/[^0-9.]/g, '') || '0',
                            'priceCurrency': 'USD',
                            'availability': 'https://schema.org/InStock'
                        },
                        'aggregateRating': {
                            '@type': 'AggregateRating',
                            'ratingValue': rating,
                            'bestRating': '5',
                            'worstRating': '1'
                        }
                    });
                }
            });

            // Update or create schema for search results
            if (products.length > 0) {
                let existingScript = document.getElementById('searchProductSchema');
                if (existingScript) {
                    existingScript.remove();
                }

                const script = document.createElement('script');
                script.id = 'searchProductSchema';
                script.type = 'application/ld+json';
                script.textContent = JSON.stringify({
                    '@context': 'https://schema.org',
                    '@type': 'ItemList',
                    'itemListElement': products
                });
                document.head.appendChild(script);
            }
        }
    </script>

    <!-- SEO: Performance & Core Web Vitals Optimization -->
    <script>
        // Log Core Web Vitals for SEO optimization
        if ('web-vital' in window) {
            const vitals = window['web-vital'];
            if (vitals && vitals.getCLS) {
                vitals.getCLS(metric => console.log('CLS:', metric.value));
                vitals.getFID(metric => console.log('FID:', metric.value));
                vitals.getFCP(metric => console.log('FCP:', metric.value));
                vitals.getLCP(metric => console.log('LCP:', metric.value));
            }
        }
    </script>

