                                        ${escapeHtml(item.query)} <span style="color: var(--text-light); font-size: 0.8em; margin-left: 6px;">[${item.searches}]</span>
                                    </button>
                                `).join('')}
                            </div>
                        </div>
                    `;
                    document.getElementById('resultsContainer').insertAdjacentHTML('afterend', html);
                }
            } catch (error) { console.error('Popular searches error:', error); }
