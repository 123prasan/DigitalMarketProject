                const data = await response.json();
                
                if (!data.success || !data.dynamicFilters) return;
                
                let html = '';
                const df = data.dynamicFilters;
                
                if (df.difficulties && Object.keys(df.difficulties).length > 1) {
                    html += `
                        <div class="filter-panel" style="margin-top:16px;">
                            <div class="filter-panel-header" onclick="togglePanel(this)">
                                <span class="filter-panel-title"><i class="fas fa-layer-group"></i> Extracted Levels</span>
