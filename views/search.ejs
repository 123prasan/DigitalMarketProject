                                <i class="fas fa-chevron-down filter-panel-toggle"></i>
                            </div>
                            <div class="filter-options">
                                ${df.formats.slice(0, 6).map((f, i) => `
                                    <div class="filter-option">
                                        <input type="checkbox" id="dyn_form_${i}" value="${f.format}" onchange="applyFilters()">
                                        <label for="dyn_form_${i}">${f.format} <span style="color: var(--text-light); margin-left: auto;">${f.count}</span></label>
