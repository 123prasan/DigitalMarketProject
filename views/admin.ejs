  <!-- MODALS -->
  <div id="confirmModal" class="modal">
    <div class="modal-content" style="max-width: 400px;">
      <div class="modal-header">
        <h2 id="confirmTitle">Confirm Action</h2>
        <button class="modal-close" onclick="closeModal('confirmModal')">&times;</button>
      </div>
      <div class="modal-body">
        <p id="confirmMessage" style="color: var(--text-light);"></p>
      </div>
      <div class="modal-footer">
        <button class="btn" style="background: var(--text-light); color: white; border: none;" onclick="closeModal('confirmModal')">Cancel</button>
        <button class="btn btn-primary" id="confirmBtn" onclick="executeConfirmAction()">Confirm</button>
      </div>
    </div>
  </div>

  <script>
    const API_BASE = '/api/admin';
    let currentView = 'dashboard';
    let currentOrderId = null;
    let currentUserId = null;
    let pendingAction = null;
    let charts = {};

    function showModal(modalId) {
      document.getElementById(modalId).classList.add('active');
    }

    function closeModal(modalId) {
      document.getElementById(modalId).classList.remove('active');
    }

    function showConfirm(title, message, action) {
      document.getElementById('confirmTitle').textContent = title;
      document.getElementById('confirmMessage').textContent = message;
      pendingAction = action;
      showModal('confirmModal');
    }

    function executeConfirmAction() {
      if (pendingAction && typeof pendingAction === 'function') {
        pendingAction();
      }
      closeModal('confirmModal');
    }

    function formatCurrency(value) {
      return '₹' + (value || 0).toLocaleString('en-IN', { maximumFractionDigits: 0 });
    }

    function formatDate(date) {
      return new Date(date).toLocaleDateString('en-IN');
    }

    function getStatusBadge(status) {
      if (status && status.toLowerCase().includes('successfull')) {
        return '<span class="badge badge-success">Successful</span>';
      } else if (status && status.toLowerCase().includes('unsuccessfull')) {
        return '<span class="badge badge-danger">Failed</span>';
      }
      return '<span class="badge badge-warning">Pending</span>';
    }

    function switchView(viewName) {
      console.log('switchView to', viewName);
      document.querySelectorAll('.view-container').forEach(v => v.style.display = 'none');
      document.querySelectorAll('.menu-item').forEach(m => m.classList.remove('active'));
      
      document.getElementById(viewName + 'View').style.display = 'block';
      if (event && event.target) {
        event.target.closest('.menu-item').classList.add('active');
      }
      
      const titles = {
        dashboard: 'Dashboard', orders: 'Orders', users: 'Users', files: 'Files',
        communications: 'Email & Notifications', analytics: 'Analytics', revenue: 'Revenue', sellers: 'Sellers'
      };
      document.getElementById('topBarTitle').textContent = titles[viewName] || 'Dashboard';
      
      currentView = viewName;
      loadViewData(viewName);
    }

    async function loadViewData(viewName) {
      try {
        if (viewName === 'dashboard') loadDashboardData();
        else if (viewName === 'orders') loadOrdersData();
        else if (viewName === 'users') loadUsersData();
        else if (viewName === 'files') loadFilesData();
        else if (viewName === 'communications') loadCommunicationsData();
        else if (viewName === 'analytics') loadAnalyticsData();
        else if (viewName === 'revenue') loadRevenueData();
        else if (viewName === 'sellers') loadSellersData();
      } catch (error) {
        console.error('Error loading view:', error);
      }
    }

    async function loadDashboardData() {
      try {
        const response = await axios.get(`${API_BASE}/stats`);
        if (response.data && response.data.success === false) {
          console.error('Dashboard API responded with failure', response.data);
          if (response.data.message === 'Unauthorized') {
            window.location.href = '/admin-login';
          }
          return;
        }
        const stats = response.data && response.data.stats;
        if (!stats) {
          console.error('Dashboard error: stats object missing', response.data);
          return;
        }

        document.getElementById('totalRevenue').textContent = formatCurrency(stats.totalAmount);
        document.getElementById('totalOrders').textContent = stats.totalOrders || 0;
        document.getElementById('successOrders').textContent = stats.successfulOrders || 0;
        document.getElementById('failOrders').textContent = stats.failedOrders || 0;

        initRevenueChart();
        initStatusChart();
        await loadRecentOrders();
      } catch (error) {
        console.error('Dashboard error:', error);
      }
    }

    async function loadRecentOrders() {
      try {
        const response = await axios.get(`${API_BASE}/orders`, { params: { limit: 5 }, timeout: 10000 });
        const orders = response.data.orders || [];
        const tbody = document.getElementById('recentOrdersBody');
        tbody.innerHTML = '';

        if (orders.length === 0) {
          tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; padding: 20px;">No orders found</td></tr>';
          return;
        }

        orders.forEach(order => {
          tbody.innerHTML += `<tr>
            <td><strong>${order.orderId || order._id}</strong></td>
            <td>${order.customer || 'N/A'}</td>
            <td>${formatCurrency(order.total)}</td>
            <td>${getStatusBadge(order.status)}</td>
            <td>${formatDate(order.dateTime)}</td>
            <td><button class="btn btn-primary btn-small" onclick="viewOrderDetail('${order._id}')"><i class="fas fa-eye"></i></button></td>
          </tr>`;
        });
      } catch (error) {
        console.error('Error loading recent orders:', error);
      }
    }

    async function loadOrdersData() {
      console.log('loadOrdersData: starting request');
      const tbody = document.getElementById('ordersTableBody');
      
      try {
        tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:20px;"><span>Loading orders...</span></td></tr>';
        
        console.log('loadOrdersData: fetching from', `${API_BASE}/orders`);
        const response = await axios.get(`${API_BASE}/orders`, { timeout: 10000 });
        console.log('loadOrdersData: response status', response.status, 'data keys:', Object.keys(response.data));
        
        if (!response.data) {
          throw new Error('No response data');
        }
        
        if (response.data.success === false) {
          console.error('API returned success:false', response.data);
          if (response.data.message === 'Unauthorized') {
            window.location.href = '/admin-login';
            return;
          }
          throw new Error(response.data.message || 'API error');
        }
        
        const orders = response.data.orders || [];
        console.log('loadOrdersData: got', orders.length, 'orders');
        
        // Use DocumentFragment for efficient DOM building
        const fragment = document.createDocumentFragment();
        
        if (orders.length === 0) {
          const tr = document.createElement('tr');
          tr.innerHTML = '<td colspan="7" style="padding: 20px; text-align: center;">No orders found</td>';
          fragment.appendChild(tr);
        } else {
          orders.forEach((order, idx) => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td><strong>${String(order.orderId || order._id || '').substring(0, 12)}</strong></td>
              <td>${formatDate(order.dateTime)}</td>
              <td>${String(order.customer || 'N/A').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</td>
              <td>${formatCurrency(order.total)}</td>
              <td>${order.items ? order.items.length : 0}</td>
              <td>${getStatusBadge(order.status)}</td>
              <td>
                <button class="btn btn-primary btn-small" onclick="viewOrderDetail('${order._id}')"><i class="fas fa-eye"></i></button>
                <button class="btn btn-danger btn-small" onclick="deleteOrder('${order._id}')"><i class="fas fa-trash"></i></button>
              </td>
            `;
            fragment.appendChild(tr);
            
            if (idx % 50 === 0) console.log('loadOrdersData: processed', idx, 'rows');
          });
        }
        
        tbody.innerHTML = '';
        tbody.appendChild(fragment);
        allOrders = orders;
        setupFilterListeners();
        console.log('loadOrdersData: table populated successfully');
        
      } catch (error) {
        console.error('loadOrdersData error:', error.message, error);
        
        if (error.response?.status === 401) {
          console.log('loadOrdersData: 401 detected, redirecting to login');
          window.location.href = '/admin-login';
          return;
        }
        
        tbody.innerHTML = `
          <tr>
            <td colspan="7" style="padding: 20px; text-align: center; color: var(--danger);">
              <strong>Error loading orders</strong><br/>
              <small>${String(error.message).replace(/</g, '&lt;').replace(/>/g, '&gt;')}</small>
            </td>
          </tr>
        `;
