<script>
// --- AJAX Dashboard Loader ---
async function loadDashboardData() {
  document.getElementById('dashboardContentLoading').style.display = '';
  document.getElementById('dashboardContent').style.display = 'none';
  try {
    const statsRes = await fetch('/api/admin/stats');
    const stats = (await statsRes.json()).stats;
    // Render KPI cards and charts (stub, expand as needed)
    let html = `<div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:20px; margin-bottom:32px;">
      <div style='background:#fff; padding:24px; border-radius:12px; border:1px solid #e5e7eb;'><p style='font-size:12px; color:#6b7280; margin:0; font-weight:600;'>Total Revenue</p><h2 style='font-size:32px; font-weight:800; color:#1f2937; margin:8px 0 0 0;'>₹${(stats.totalAmount||0).toLocaleString('en-IN')}</h2></div>
      <div style='background:#fff; padding:24px; border-radius:12px; border:1px solid #e5e7eb;'><p style='font-size:12px; color:#6b7280; margin:0; font-weight:600;'>Total Orders</p><h2 style='font-size:32px; font-weight:800; color:#1f2937; margin:8px 0 0 0;'>${stats.totalOrders||0}</h2></div>
      <div style='background:#fff; padding:24px; border-radius:12px; border:1px solid #e5e7eb;'><p style='font-size:12px; color:#6b7280; margin:0; font-weight:600;'>Failed Orders</p><h2 style='font-size:32px; font-weight:800; color:#f87171; margin:8px 0 0 0;'>${stats.failedOrders||0}</h2></div>
      <div style='background:#fff; padding:24px; border-radius:12px; border:1px solid #e5e7eb;'><p style='font-size:12px; color:#6b7280; margin:0; font-weight:600;'>Successful Orders</p><h2 style='font-size:32px; font-weight:800; color:#10b981; margin:8px 0 0 0;'>${stats.successfulOrders||0}</h2></div>
      <div style='background:#fff; padding:24px; border-radius:12px; border:1px solid #e5e7eb;'><p style='font-size:12px; color:#6b7280; margin:0; font-weight:600;'>Customers</p><h2 style='font-size:32px; font-weight:800; color:#1f2937; margin:8px 0 0 0;'>${stats.uniqueCustomers||0}</h2></div>
    </div>`;
    document.getElementById('dashboardContent').innerHTML = html;
    document.getElementById('dashboardContentLoading').style.display = 'none';
    document.getElementById('dashboardContent').style.display = '';
  } catch (e) {
    document.getElementById('dashboardContentLoading').innerText = 'Failed to load dashboard data.';
  }
}

// Section loader stubs for all features (expand as needed)
async function loadOrdersView() {/* ... */}
async function loadFilesView() {/* ... */}
async function loadUsersView() {/* ... */}
async function loadTransactionsView() {/* ... */}
async function loadAnalyticsView() {/* ... */}
async function loadRevenueView() {/* ... */}
async function loadSellersView() {/* ... */}
async function loadNotificationsView() {/* ... */}


// Hook into view switching
function switchView(view) {
  // Hide all views
  document.getElementById('dashboardView').style.display = 'none';
  document.getElementById('insightsView').style.display = 'none';
  document.getElementById('ordersView').style.display = 'none';
  document.getElementById('filesView').style.display = 'none';
  document.getElementById('usersView').style.display = 'none';
  document.getElementById('transactionsView').style.display = 'none';
  document.getElementById('analyticsView').style.display = 'none';
  document.getElementById('revenueView').style.display = 'none';
  document.getElementById('sellersView').style.display = 'none';
  document.getElementById('notificationsView').style.display = 'none';

  // Show the selected view and load data if needed
  if (view === 'dashboard') {
    document.getElementById('dashboardView').style.display = 'block';
    loadDashboardData();
  } else if (view === 'orders') {
    document.getElementById('ordersView').style.display = 'block';
    loadOrdersView();
  } else if (view === 'files') {
    document.getElementById('filesView').style.display = 'block';
    loadFilesView();
  } else if (view === 'users') {
    document.getElementById('usersView').style.display = 'block';
    loadUsersView();
  } else if (view === 'transactions') {
    document.getElementById('transactionsView').style.display = 'block';
    loadTransactionsView();
  } else if (view === 'analytics') {
    document.getElementById('analyticsView').style.display = 'block';
    loadAnalyticsView();
  } else if (view === 'revenue') {
    document.getElementById('revenueView').style.display = 'block';
    loadRevenueView();
  } else if (view === 'sellers') {
    document.getElementById('sellersView').style.display = 'block';
    loadSellersView();
  } else if (view === 'notifications') {
    document.getElementById('notificationsView').style.display = 'block';
    loadNotificationsView();
  }
}

// Initial load
window.addEventListener('DOMContentLoaded', () => {
  loadDashboardData();
});
</script>

      <!-- INSIGHTS VIEW -->
      <div id="insightsView" style="display:none;">
