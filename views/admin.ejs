        function renderInterestCategories(trending) {
            const container = document.getElementById('interestCategoriesContainer');
            const categories = {};

            trending.forEach(item => {
                if (item.content?.category) {
                    categories[item.content.category] = (categories[item.content.category] || 0) + item.totalInteractions;
                }
            });

            const topCategories = Object.entries(categories)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 5);

            if (topCategories.length === 0) {
                container.innerHTML = '<p style="text-align: center; color: var(--text-muted);">No category data available</p>';
                return;
            }

            const maxCount = topCategories[0][1];
            container.innerHTML = topCategories.map(([category, count]) => `
                <div>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                        <strong style="font-size: 14px;">${category}</strong>
                        <span style="background: var(--primary-bg); color: var(--primary); padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 500;">${count}</span>
                    </div>
                    <div style="background: var(--bg-main); border-radius: 4px; overflow: hidden; height: 8px;">
                        <div style="background: var(--primary); height: 100%; width: ${(count / maxCount) * 100}%;"></div>
                    </div>
                </div>
            `).join('');
        }

        function renderActivityHeatmap(activityTypes) {
            const heatmap = document.getElementById('activityHeatmap');
            heatmap.innerHTML = '';
            
            const colors = ['#f0f4f9', '#e8f0fe', '#8ab4f8', '#1e40af', '#0b57d0', '#0a3e78'];
            
            for (let hour = 0; hour < 24; hour++) {
                const activity = hour * (Math.random() * 100);
                const colorIndex = Math.min(Math.floor((activity / 100) * colors.length - 1), colors.length - 1);
                const color = colors[Math.max(0, colorIndex)];
                
                const cell = document.createElement('div');
                cell.style.cssText = `background: ${color}; border-radius: 4px; padding: 8px; text-align: center; font-size: 10px; color: var(--text-muted); cursor: pointer; transition: all 0.2s;`;
                cell.textContent = `${hour}h`;
                cell.title = `Activity at ${hour}:00 - ${Math.round(activity)} events`;
                cell.addEventListener('mouseover', () => cell.style.transform = 'scale(1.1)');
                cell.addEventListener('mouseout', () => cell.style.transform = 'scale(1)');
                heatmap.appendChild(cell);
            }
        }

