    // ORDERS FILTERS
    function filterAndRenderOrders() {
      const searchTerm = (document.getElementById('orderSearch')?.value || '').toLowerCase();
      const statusFilter = document.getElementById('orderStatusFilter')?.value || '';

      const filtered = allOrders.filter(order => {
        const matchesSearch = !searchTerm || 
          String(order.orderId || order._id || '').toLowerCase().includes(searchTerm) ||
          String(order.customer || '').toLowerCase().includes(searchTerm);
        
        const matchesStatus = !statusFilter || 
          String(order.status || '').toLowerCase().includes(statusFilter.toLowerCase());
        
        return matchesSearch && matchesStatus;
      });

      renderOrdersTable(filtered);
    }

    function renderOrdersTable(orders) {
      const tbody = document.getElementById('ordersTableBody');
      const fragment = document.createDocumentFragment();

      if (orders.length === 0) {
        const tr = document.createElement('tr');
        tr.innerHTML = '<td colspan="7" style="padding: 20px; text-align: center;">No orders found</td>';
        fragment.appendChild(tr);
      } else {
        orders.forEach(order => {
          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td><strong>${String(order.orderId || order._id || '').substring(0, 12)}</strong></td>
            <td>${formatDate(order.dateTime)}</td>
            <td>${String(order.customer || 'N/A').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</td>
            <td>${formatCurrency(order.total)}</td>
            <td>${order.items ? order.items.length : 0}</td>
            <td>${getStatusBadge(order.status)}</td>
            <td>
              <button class="btn btn-primary btn-small" onclick="viewOrderDetail('${order._id}')"><i class="fas fa-eye"></i></button>
              <button class="btn btn-danger btn-small" onclick="deleteOrder('${order._id}')"><i class="fas fa-trash"></i></button>
            </td>
          `;
          fragment.appendChild(tr);
        });
      }

      tbody.innerHTML = '';
      tbody.appendChild(fragment);
    }

    // USERS FILTERS
    function filterAndRenderUsers() {
      const searchTerm = (document.getElementById('userSearch')?.value || '').toLowerCase();
      const roleFilter = document.getElementById('userRoleFilter')?.value || '';
      const statusFilter = document.getElementById('userStatusFilter')?.value || '';

      const filtered = allUsers.filter(user => {
        const matchesSearch = !searchTerm || 
          String(user.username || '').toLowerCase().includes(searchTerm) ||
          String(user.email || '').toLowerCase().includes(searchTerm);
        
        const matchesRole = !roleFilter || 
          String(user.role || '').toLowerCase() === roleFilter.toLowerCase();
        
        let matchesStatus = true;
        if (statusFilter) {
          if (statusFilter === 'active') {
            matchesStatus = !user.isBanned && !user.isSuspended;
          } else if (statusFilter === 'verified') {
            matchesStatus = user.ISVERIFIED || user.isVerified;
          } else if (statusFilter === 'suspended') {
            matchesStatus = user.isSuspended;
          } else if (statusFilter === 'banned') {
            matchesStatus = user.isBanned;
          }
        }
        
        return matchesSearch && matchesRole && matchesStatus;
      });

      renderUsersTable(filtered);
    }

    function renderUsersTable(users) {
      const tbody = document.getElementById('usersTableBody');
      const fragment = document.createDocumentFragment();

      if (users.length === 0) {
        const tr = document.createElement('tr');
        tr.innerHTML = '<td colspan="6" style="padding: 20px; text-align: center;">No users found</td>';
        fragment.appendChild(tr);
      } else {
        users.forEach(user => {
          let statusBadge = 'badge-info', statusText = 'Active';
          if (user.isBanned) {
            statusBadge = 'badge-danger';
            statusText = 'Banned';
          } else if (user.isSuspended) {
            statusBadge = 'badge-warning';
            statusText = 'Suspended';
          } else if (user.ISVERIFIED || user.isVerified) {
            statusBadge = 'badge-success';
            statusText = 'Verified';
          }

          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td><strong>${String(user.username || '').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</strong></td>
            <td>${String(user.email || '').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</td>
            <td><span class="badge badge-primary">${user.role || 'User'}</span></td>
            <td>${user.followers ? user.followers.length : 0}</td>
            <td><span class="badge ${statusBadge}">${statusText}</span></td>
            <td>
              <button class="btn btn-primary btn-small" onclick="viewUserDetail('${user._id}')"><i class="fas fa-eye"></i></button>
              <button class="btn btn-warning btn-small" onclick="toggleUserSuspend('${user._id}', ${user.isSuspended})">
                ${user.isSuspended ? '<i class="fas fa-check"></i>' : '<i class="fas fa-ban"></i>'}
              </button>
            </td>
          `;
          fragment.appendChild(tr);
        });
      }

      tbody.innerHTML = '';
      tbody.appendChild(fragment);
    }

    // FILES FILTERS
    function filterAndRenderFiles() {
      const searchTerm = (document.getElementById('fileSearch')?.value || '').toLowerCase();

      const filtered = allFiles.filter(file => {
        return !searchTerm || String(file.filename || '').toLowerCase().includes(searchTerm);
      });

      renderFilesGrid(filtered);
    }

    function renderFilesGrid(files) {
      const grid = document.getElementById('filesGrid');
      grid.innerHTML = '';

      if (files.length === 0) {
        grid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; padding: 40px;">No files found</div>';
        return;
      }

      files.forEach(file => {
        grid.innerHTML += `<div class="card card-small">
          <div style="margin-bottom: 12px;">
            <strong style="word-break: break-word;">${file.filename}</strong>
            <p style="font-size: 12px; color: var(--text-light); margin: 4px 0;">${file.filedescription || 'No description'}</p>
          </div>
          <div style="font-size: 11px; color: var(--text-light); margin-bottom: 12px;">
            <p style="margin: 4px 0;"><strong>Price:</strong> ${formatCurrency(file.price)}</p>
            <p style="margin: 4px 0;"><strong>Uploaded:</strong> ${formatDate(file.uploadedAt)}</p>
          </div>
          <button class="btn btn-danger btn-small" style="width: 100%;" onclick="deleteFile('${file._id}')">
            <i class="fas fa-trash"></i> Delete
          </button>
        </div>`;
      });
    }

    // SELLERS FILTERS
    function filterAndRenderSellers() {
      const searchTerm = (document.getElementById('sellerSearch')?.value || '').toLowerCase();
      const statusFilter = document.getElementById('sellerStatusFilter')?.value || '';

      const filtered = allSellers.filter(seller => {
        const matchesSearch = !searchTerm || 
          String(seller.name || seller.username || '').toLowerCase().includes(searchTerm) ||
          String(seller.email || '').toLowerCase().includes(searchTerm);
        
        const matchesStatus = !statusFilter || String(seller.status || 'active').toLowerCase() === statusFilter.toLowerCase();
        
        return matchesSearch && matchesStatus;
      });

      renderSellersTable(filtered);
    }

    function renderSellersTable(sellers) {
      const tbody = document.getElementById('sellersTableBody');
      const fragment = document.createDocumentFragment();

      if (sellers.length === 0) {
        const tr = document.createElement('tr');
        tr.innerHTML = '<td colspan="7" style="padding: 20px; text-align: center;">No sellers found</td>';
        fragment.appendChild(tr);
      } else {
        sellers.forEach(seller => {
          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td><strong>${seller.name || seller.username}</strong></td>
            <td>${seller.email}</td>
            <td>${seller.productCount || 0}</td>
            <td>${formatCurrency(seller.revenue || 0)}</td>
            <td>${seller.rating ? seller.rating.toFixed(1) : 'N/A'} ⭐</td>
            <td><span class="badge badge-success">${seller.status || 'Active'}</span></td>
            <td><button class="btn btn-primary btn-small"><i class="fas fa-eye"></i></button></td>
          `;
          fragment.appendChild(tr);
        });
      }

      tbody.innerHTML = '';
      tbody.appendChild(fragment);
    }

    // INIT EVENT LISTENERS
    function setupFilterListeners() {
      // Orders filters
      document.getElementById('orderSearch')?.addEventListener('input', filterAndRenderOrders);
      document.getElementById('orderStatusFilter')?.addEventListener('change', filterAndRenderOrders);

      // Users filters
      document.getElementById('userSearch')?.addEventListener('input', filterAndRenderUsers);
      document.getElementById('userRoleFilter')?.addEventListener('change', filterAndRenderUsers);
      document.getElementById('userStatusFilter')?.addEventListener('change', filterAndRenderUsers);

      // Files filters
      document.getElementById('fileSearch')?.addEventListener('input', filterAndRenderFiles);

      // Sellers filters
      document.getElementById('sellerSearch')?.addEventListener('input', filterAndRenderSellers);
      document.getElementById('sellerStatusFilter')?.addEventListener('change', filterAndRenderSellers);
    }

    // INIT
    window.addEventListener('DOMContentLoaded', () => {
      loadDashboardData();
      setupFilterListeners();
      document.querySelectorAll('.modal').forEach(modal => {
        modal.addEventListener('click', (e) => {
          if (e.target === modal) modal.classList.remove('active');
        });
      });
    });
  </script>
</body>
</html>
