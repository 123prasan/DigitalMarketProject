    async function loadRevenueData() {
      try {
        const response = await axios.get(`${API_BASE}/stats`);
        if (response.data && response.data.success === false) {
          console.error('Revenue API responded with failure', response.data);
          if (response.data.message === 'Unauthorized') {
            window.location.href = '/admin-login';
          }
          return;
        }
        const stats = response.data && response.data.stats;
        if (!stats) {
          console.error('Revenue error: stats object missing', response.data);
          return;
        }

        const monthRevenue = Math.floor(stats.totalAmount / 30);
        const yearRevenue = stats.totalAmount * 12;
        const avgOrder = stats.totalOrders > 0 ? stats.totalAmount / stats.totalOrders : 0;
        const conversionRate = stats.totalOrders > 0 ? ((stats.successfulOrders / stats.totalOrders) * 100).toFixed(1) : 0;

        document.getElementById('monthRevenue').textContent = formatCurrency(monthRevenue);
        document.getElementById('yearRevenue').textContent = formatCurrency(yearRevenue);
        document.getElementById('avgOrderValue').textContent = formatCurrency(avgOrder);
        document.getElementById('conversionRate').textContent = conversionRate + '%';

        initRevenueBreakdownChart();
      } catch (error) {
        console.error('Revenue error:', error);
      }
    }

