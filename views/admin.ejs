    async function loadUsersData() {
      console.log('loadUsersData: starting request');
      const tbody = document.getElementById('usersTableBody');
      
      try {
        // Show loading state
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:20px;"><span>Loading users...</span></td></tr>';
        
        console.log('loadUsersData: fetching from', `${API_BASE}/users`);
        const response = await axios.get(`${API_BASE}/users`, { timeout: 10000 });
        console.log('loadUsersData: response status', response.status, 'data:', response.data);
        
        if (!response.data) {
          throw new Error('No response data');
        }
        
        if (response.data.success === false) {
          console.error('API returned success:false', response.data);
          if (response.data.message === 'Unauthorized') {
            window.location.href = '/admin-login';
            return;
          }
          throw new Error(response.data.message || 'API error');
        }

        const users = response.data.allUsers || [];
        console.log('loadUsersData: got', users.length, 'users');

        // Update counters
        document.getElementById('totalUsersCount').textContent = users.length;
        let verifiedCount = 0, suspendedCount = 0, bannedCount = 0;
        
        users.forEach(user => {
          if (user.ISVERIFIED || user.isVerified) verifiedCount++;
          if (user.isSuspended) suspendedCount++;
          if (user.isBanned) bannedCount++;
        });

        document.getElementById('verifiedCount').textContent = verifiedCount;
        document.getElementById('suspendedCount').textContent = suspendedCount;
        document.getElementById('bannedCount').textContent = bannedCount;

        // Use DocumentFragment for efficient DOM building
        const fragment = document.createDocumentFragment();

        if (users.length === 0) {
          const tr = document.createElement('tr');
          tr.innerHTML = '<td colspan="6" style="padding: 20px; text-align: center;">No users found</td>';
          fragment.appendChild(tr);
        } else {
          users.forEach((user, idx) => {
            let statusBadge = 'badge-info', statusText = 'Active';
            if (user.isBanned) {
              statusBadge = 'badge-danger';
              statusText = 'Banned';
            } else if (user.isSuspended) {
              statusBadge = 'badge-warning';
              statusText = 'Suspended';
            } else if (user.ISVERIFIED || user.isVerified) {
              statusBadge = 'badge-success';
              statusText = 'Verified';
            }

            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td><strong>${String(user.username || '').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</strong></td>
              <td>${String(user.email || '').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</td>
              <td><span class="badge badge-primary">${user.role || 'User'}</span></td>
              <td>${user.followers ? user.followers.length : 0}</td>
              <td><span class="badge ${statusBadge}">${statusText}</span></td>
              <td>
                <button class="btn btn-primary btn-small" onclick="viewUserDetail('${user._id}')"><i class="fas fa-eye"></i></button>
                <button class="btn btn-warning btn-small" onclick="toggleUserSuspend('${user._id}', ${user.isSuspended})">
                  ${user.isSuspended ? '<i class="fas fa-check"></i>' : '<i class="fas fa-ban"></i>'}
                </button>
              </td>
            `;
            fragment.appendChild(tr);
            
            if (idx % 50 === 0) console.log('loadUsersData: processed', idx, 'rows');
          });
        }
        
        // Clear and append all at once
        tbody.innerHTML = '';
        tbody.appendChild(fragment);
        allUsers = users;
        setupFilterListeners();
        console.log('loadUsersData: table populated successfully');
        
      } catch (error) {
        console.error('loadUsersData error:', error.message, error);
        
        if (error.response?.status === 401) {
          console.log('loadUsersData: 401 detected, redirecting to login');
          window.location.href = '/admin-login';
          return;
        }
        
        // Show error in table
        tbody.innerHTML = `
          <tr>
            <td colspan="6" style="padding: 20px; text-align: center; color: var(--danger);">
              <strong>Error loading users</strong><br/>
              <small>${String(error.message).replace(/</g, '&lt;').replace(/>/g, '&gt;')}</small>
            </td>
          </tr>
        `;
        console.log('loadUsersData: error display updated');
      }
    }

