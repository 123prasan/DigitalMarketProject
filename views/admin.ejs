        async function loadBehaviorData() {
            try {
                // Load activity data
                const activityResponse = await axios.get('/api/activity-summary?days=30');
                const activities = activityResponse.data || [];

                // Calculate total activities
                let totalActivities = 0;
                const activityTypes = {};
                activities.forEach(act => {
                    totalActivities += act.count || 0;
                    activityTypes[act._id] = act.count || 0;
                });

                document.getElementById('totalActivities').textContent = totalActivities;

                // Load trending content
                const trendingResponse = await axios.get('/api/trending-content?days=7&limit=10');
                const trending = trendingResponse.data || [];
                document.getElementById('trendingCount').textContent = trending.length;

                // Calculate stats
                let totalUsers = trending.length > 0 ? trending.reduce((sum, t) => sum + (t.uniqueUserCount || 0), 0) : 0;
                let totalTimeSpent = trending.length > 0 ? trending.reduce((sum, t) => sum + (t.avgTimeSpent || 0), 0) : 0;

                document.getElementById('activeUsers').textContent = totalUsers;
                document.getElementById('avgTimeSpent').textContent = Math.round(totalTimeSpent / 60) + 'm';

                // Render tables
                renderSearchQueriesTable(activityResponse.data);
                renderEngagedUsersTable(trending);
                renderTrendingContentTable(trending);
                initActivityTrendsChart(activityTypes);
                initActivityTypeChart(activityTypes);
                renderInterestCategories(trending);
                renderActivityHeatmap(activityTypes);

            } catch (error) {
                console.error('Behavior data error:', error);
            }
        }

