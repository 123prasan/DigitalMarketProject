    async function sendEmails() {
      const subject = document.getElementById('emailSubject').value;
      const content = document.getElementById('emailContent').value;
      const recipientType = document.querySelector('input[name="recipientType"]:checked').value;
      const individualEmail = document.getElementById('individualEmail').value;
      const scheduleEmail = document.getElementById('scheduleEmail')?.checked;
      const trackOpens = document.getElementById('trackOpens')?.checked;
      const abTest = document.getElementById('abTest')?.checked;

      if (!subject || !content) {
        alert('❌ Please enter subject and content');
        return;
      }

      let recipients = [];

      if (recipientType === 'individual') {
        if (!individualEmail) {
          alert('❌ Please enter an email address');
          return;
        }
        recipients = [{ email: individualEmail, username: 'User' }];
      } else if (recipientType === 'all') {
        recipients = allUsers;
      } else if (recipientType === 'verified') {
        recipients = allUsers.filter(u => u.ISVERIFIED || u.isVerified);
      } else if (recipientType === 'sellers') {
        recipients = allUsers.filter(u => u.role === 'seller');
      }

      if (recipients.length === 0) {
        alert('❌ No recipients found for the selected criteria');
        return;
      }

      showConfirm(
        '📧 Send Email Campaign',
        `Send to ${recipients.length} recipient(s)?\n\n${scheduleEmail ? '⏰ Scheduled' : ''}\n${trackOpens ? '📊 Track Opens: Enabled' : ''}\n${abTest ? '🧪 A/B Testing: Enabled' : ''}`,
        async () => {
          try {
            const response = await axios.post('/api/admin/send-email', {
              subject: subject,
              content: content,
              recipients: recipients.map(r => ({ 
                email: r.email, 
                username: r.username 
              })),
              options: {
                scheduled: scheduleEmail,
                trackOpens: trackOpens,
                abTest: abTest
              }
            }, { timeout: 30000 });

            if (response.data.success) {
              const entry = {
                date: new Date().toLocaleString(),
                subject: subject,
                recipientType: recipientType,
                recipientCount: recipients.length,
                status: scheduleEmail ? '⏳ Scheduled' : '✅ Sent',
                openRate: '0%',
                clickRate: trackOpens ? 'tracking...' : '-'
              };
              emailHistory.unshift(entry);
              loadEmailHistory();
              
              document.getElementById('emailSubject').value = '';
              document.getElementById('emailContent').value = '';
              document.getElementById('emailPreview').innerHTML = '<div style="text-align: center; color: var(--text-light); padding: 100px 20px;"><p>Preview will appear here</p></div>';
              
              document.getElementById('emailsSent').textContent = parseInt(document.getElementById('emailsSent').textContent || 0) + recipients.length;
              
              alert(`✅ Email campaign sent successfully to ${recipients.length} recipient(s)!${scheduleEmail ? '\n\n⏰ Scheduled for delivery' : ''}`);
            } else {
              alert('❌ Error: ' + (response.data.message || 'Unknown error'));
            }
          } catch (error) {
            console.error('Email send error:', error);
            alert('❌ Error: ' + error.message);
          }
        }
      );
    }

