<script>
        const API_BASE = '/api/admin';
        let currentView = 'dashboard';
        let currentOrderId = null;
        let currentUserId = null;
        let pendingAction = null;
        let charts = {};

        // ============= UI & UTILITY FUNCTIONS =============
        
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('show');
        }

        document.addEventListener('click', function(event) {
            const sidebar = document.getElementById('sidebar');
            const toggleBtn = document.querySelector('.menu-toggle');
            if (window.innerWidth <= 768) {
                if (!sidebar.contains(event.target) && !toggleBtn.contains(event.target) && sidebar.classList.contains('show')) {
                    sidebar.classList.remove('show');
                }
            }
        });

        function showModal(modalId) { document.getElementById(modalId).classList.add('active'); }
        function closeModal(modalId) { document.getElementById(modalId).classList.remove('active'); }

        function showConfirm(title, message, action) {
            document.getElementById('confirmTitle').textContent = title;
            document.getElementById('confirmMessage').textContent = message;
            pendingAction = action;
            showModal('confirmModal');
        }

        function executeConfirmAction() {
            if (pendingAction && typeof pendingAction === 'function') pendingAction();
            closeModal('confirmModal');
        }

        function formatCurrency(value) {
            return '₹' + (value || 0).toLocaleString('en-IN', { maximumFractionDigits: 0 });
        }

        function formatDate(date) {
            return new Date(date).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' });
        }

        function getStatusBadge(status) {
            if (status && status.toLowerCase().includes('successfull')) return '<span class="badge badge-success">Successful</span>';
            if (status && status.toLowerCase().includes('unsuccessfull')) return '<span class="badge badge-danger">Failed</span>';
            return '<span class="badge badge-warning">Pending</span>';
        }

        // ============= VIEW SWITCHING =============

        function switchView(viewName) {
            document.querySelectorAll('.view-container').forEach(v => v.style.display = 'none');
            document.querySelectorAll('.menu-item').forEach(m => m.classList.remove('active'));

            document.getElementById(viewName + 'View').style.display = 'block';
            if (event && event.currentTarget) {
                event.currentTarget.classList.add('active');
            }

            const titles = {
                dashboard: 'Dashboard', orders: 'Orders Management', users: 'Users Management', files: 'Files Management',
                communications: 'Campaigns', analytics: 'Analytics', revenue: 'Revenue Management', sellers: 'Sellers Management',
                behavior: 'User Behavior Analytics'
            };
            document.getElementById('topBarTitle').innerHTML = `<button class="menu-toggle" onclick="toggleSidebar()"><i class="fas fa-bars"></i></button> <span>${titles[viewName] || 'Dashboard'}</span>`;

            if (window.innerWidth <= 768) {
                document.getElementById('sidebar').classList.remove('show');
            }

            currentView = viewName;
            loadViewData(viewName);
        }

        async function loadViewData(viewName) {
            try {
                if (viewName === 'dashboard') loadDashboardData();
                else if (viewName === 'orders') loadOrdersData();
                else if (viewName === 'users') loadUsersData();
                else if (viewName === 'files') loadFilesData();
                else if (viewName === 'communications') loadCommunicationsData();
                else if (viewName === 'analytics') loadAnalyticsData();
                else if (viewName === 'revenue') loadRevenueData();
                else if (viewName === 'sellers') loadSellersData();
                else if (viewName === 'behavior') loadBehaviorData();
            } catch (error) {
                console.error('Error loading view:', error);
            }
        }

        // ============= DATA LOADING FUNCTIONS =============

async function loadDashboardData() {
            try {
                // Fetching dashboard stats
                const response = await axios.get(`${API_BASE}/stats`);
                
                // 1. Log exactly what the backend sent back
                // Backend response logged for debugging

                if (response.data && response.data.success === false) {
                    if (response.data.message === 'Unauthorized') window.location.href = '/admin-login';
                    return;
                }

                // 2. Safely handle the data whether it's nested in 'stats' or not
                const stats = response.data.stats || response.data; 

                if (!stats || Object.keys(stats).length === 0) {
                    console.warn("No stats data found in the response!");
                    return; 
                }

                // 3. Update the UI
                document.getElementById('totalRevenue').textContent = formatCurrency(stats.totalAmount || stats.revenue || 0);
                // prefer lifetime totals when available, but fall back to weekly numbers for backwards compatibility
                document.getElementById('totalOrders').textContent =
                    stats.totalOrders || stats.weeklyTotalOrders || stats.orders || 0;
                document.getElementById('successOrders').textContent =
                    stats.successfulOrders || stats.weeklySuccessfulOrders || stats.success || 0;
                document.getElementById('failOrders').textContent =
                    stats.failedOrders || stats.weeklyFailedOrders || stats.failed || 0;

                initRevenueChart();
                initStatusChart();
                await loadRecentOrders();
                
            } catch (error) {
                console.error('Dashboard error details:', error.response?.data || error.message);
            }
        }

        async function loadRecentOrders() {
            try {
                const response = await axios.get(`${API_BASE}/orders`, { params: { limit: 5 }, timeout: 10000 });
                const orders = response.data.orders || [];
                const tbody = document.getElementById('recentOrdersBody');
                tbody.innerHTML = '';

                if (orders.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; padding: 20px;">No orders found</td></tr>';
                    return;
                }

                orders.forEach(order => {
                    tbody.innerHTML += `<tr>
                        <td><strong>${order.orderId || order._id}</strong></td>
                        <td>${order.customer || 'N/A'}</td>
                        <td>${formatCurrency(order.total)}</td>
                        <td>${getStatusBadge(order.status)}</td>
                        <td>${formatDate(order.dateTime)}</td>
                        <td><button class="btn btn-primary btn-small" onclick="viewOrderDetail('${order._id}')"><i class="fas fa-eye"></i></button></td>
                    </tr>`;
                });
            } catch (error) {
                console.error('Error loading recent orders:', error);
            }
        }

