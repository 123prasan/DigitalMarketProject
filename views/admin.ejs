    // Render template buttons dynamically
    function renderTemplateButtons() {
      const container = document.getElementById('templateButtonsContainer');
      if (!container) return;

      let html = '';
      for (const [category, templates] of Object.entries(availableTemplates)) {
        if (templates.length > 0) {
          html += `<optgroup label="${category.toUpperCase()}">`;
          templates.forEach(template => {
            html += `<option value="${category}/${template.name}" title="${template.name}">
              ${category} - ${template.name}
            </option>`;
          });
          html += `</optgroup>`;
        }
      }
      
      if (container.tagName === 'SELECT') {
        container.innerHTML = '<option value="">-- Select Template --</option>' + html;
      }
    }

    // Select and load template content
    function selectTemplate(templatePath) {
      if (!templatePath) {
        document.getElementById('emailSubject').value = '';
        document.getElementById('emailContent').value = '';
        updateLivePreview();
        return;
      }

      const [category, templateName] = templatePath.split('/');
      const templates = availableTemplates[category];
      if (templates) {
        const template = templates.find(t => t.name === templateName);
        if (template) {
          // Extract subject from HTML if possible, otherwise use template name
          let subject = templateName.replace(/([A-Z])/g, ' $1').trim();
          document.getElementById('emailSubject').value = subject;
          // Use raw HTML content from template
          document.getElementById('emailContent').value = template.content;
          updateLivePreview();
        }
      }
    }

    // Update from dropdown select
    function onTemplateSelect(selectElement) {
      selectTemplate(selectElement.value);
    }

