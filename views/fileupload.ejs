<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

<div class="v-upload-master">

  <div id="upload-form-app-container"></div>

  <template id="template-upload-form">
    <main class="upload-form__main">
      <div class="upload-form__card">
        <h1 class="upload-form__main-title">Upload Study Material</h1>
        <p class="upload-form__subtitle">Share your knowledge and start earning.</p>
        
        <form class="upload-form__form" id="upload-form-main" aria-label="Upload Form">
          
          <div class="upload-form__input-group">
            <div class="upload-form__label-wrapper">
                <label for="uploadFormTitle" class="upload-form__label">Title <span class="required">*</span></label>
                <span id="titleWordCounter" class="upload-form__word-counter">0 / 5 min words</span>
            </div>
            <input id="uploadFormTitle" required placeholder="e.g., Complete Guide to Advanced JavaScript Patterns" class="upload-form__input" />
          </div>

          <div class="upload-form__input-group">
            <div class="upload-form__label-wrapper">
                <label class="upload-form__label">Description <span class="required">*</span></label>
                <span id="descriptionWordCounter" class="upload-form__word-counter">0 / 20 min words</span>
            </div>
            <div id="descriptionEditorContainer" class="upload-form__editor-container"></div>
          </div>

          <div class="upload-form__grid-container">
            <div class="upload-form__input-group">
              <label for="uploadFormPrice" class="upload-form__label">Price (₹) <span class="required">*</span> <span class="upload-form__label-muted">(Set 0 for Free)</span></label>
              <input id="uploadFormPrice" required type="number" placeholder="e.g., 199" class="upload-form__input" min="0" max="100000" />
            </div>
            <div class="upload-form__input-group">
              <label for="uploadFormCategory" class="upload-form__label">Category <span class="required">*</span></label>
              <input id="uploadFormCategory" placeholder="e.g., Computer Science" required class="upload-form__input">
            </div>
          </div>

          <div class="upload-form__coupon-section">
            <div class="upload-form__checkbox-group">
              <input type="checkbox" id="couponToggleCheckbox" class="upload-form__checkbox-input" />
              <label for="couponToggleCheckbox" class="upload-form__checkbox-label">Offer a discount coupon</label>
            </div>
            
            <div id="couponDetailsContainer" class="upload-form__coupon-details">
              <div class="upload-form__grid-container">
                <div class="upload-form__input-group">
                  <label for="couponCode" class="upload-form__label">Coupon Code</label>
                  <input id="couponCode" placeholder="e.g., LAUNCH50" class="upload-form__input" />
                </div>
                <div class="upload-form__input-group">
                  <label for="couponPercentage" class="upload-form__label">Discount (%)</label>
                  <input id="couponPercentage" type="number" placeholder="e.g., 50" class="upload-form__input" min="1" max="100" />
                </div>
              </div>
              <div class="upload-form__input-group" style="margin-top: 1rem;">
                <label for="couponExpiry" class="upload-form__label">Expiration Date</label>
                <input id="couponExpiry" type="date" class="upload-form__input" />
              </div>
            </div>
          </div>

          <div class="upload-form__grid-container">
            <div class="upload-form__input-group">
              <label class="upload-form__label">Cover Image <span class="required">*</span></label>
              <div id="imageUploadArea" class="upload-form__drop-area" role="button" tabindex="0">
                <div class="upload-form__drop-area-content">
                  <i class="fa-regular fa-image upload-form__drop-area-icon"></i>
                  <p id="imageUploadText" class="upload-form__drop-area-text">Click or drag image here</p>
                </div>
              </div>
              <input type="file" id="imageUploadInput" hidden accept="image/*" required />
            </div>
            <div class="upload-form__input-group">
              <label class="upload-form__label">Main File <span class="required">*</span></label>
              <div id="fileUploadArea" class="upload-form__drop-area" role="button" tabindex="0">
                <div class="upload-form__drop-area-content">
                  <i class="fa-solid fa-cloud-arrow-up upload-form__drop-area-icon"></i>
                  <p id="fileUploadText" class="upload-form__drop-area-text">PDF, ZIP, PPT, DOCS</p>
                </div>
              </div>
              <input type="file" id="fileUploadInput" hidden accept=".pdf,.mp4,.ppt,.docs,.zip" required />
            </div>
          </div>

          <div class="upload-form__checkbox-group upload-form__checkbox-group--agreement">
            <input type="checkbox" id="copyrightCheck" required class="upload-form__checkbox-input" />
            <label for="copyrightCheck" class="upload-form__checkbox-label upload-form__checkbox-label--small">I confirm I own the rights to this content and it does not violate copyright laws.</label>
          </div>
          
          <button id="reviewUploadBtn" disabled class="v-btn-primary">
            Review Details <i class="fa-solid fa-arrow-right ms-2"></i>
          </button>
        </form>
      </div>
    </main>
  </template>

  <template id="template-preview">
    <main class="upload-form__main">
      <div class="upload-form__card">
        <div class="upload-form__preview-header">
          <button id="backToFormBtn" class="upload-form__back-btn" aria-label="Go back">
            <i class="fa-solid fa-arrow-left"></i>
          </button>
          <h2 class="upload-form__main-title upload-form__main-title--preview">Review & Publish</h2>
        </div>

        <section class="upload-form__section">
          <div class="upload-form__preview-box">
            <div id="previewImage" class="upload-form__preview-image"></div>
            <div class="upload-form__preview-file-info">
              <p class="upload-form__preview-file-title">Target File</p>
              <p id="previewFileName" class="upload-form__preview-file-name"></p>
            </div>
          </div>
        </section>

        <section class="upload-form__section">
          <h3 class="upload-form__section-title">Listing Details</h3>
          <div class="upload-form__metadata-grid">
            <p class="upload-form__metadata-key">Title</p>
            <p id="previewTitle" class="upload-form__metadata-value"></p>
            
            <p class="upload-form__metadata-key">Description</p>
            <div id="previewDescription" class="upload-form__metadata-value upload-form__metadata-value--description ql-snow">
              <div class="ql-editor"></div>
            </div>
            
            <p class="upload-form__metadata-key">Price</p>
            <p id="previewPrice" class="upload-form__metadata-value font-weight-bold text-success"></p>
            
            <p class="upload-form__metadata-key">Category</p>
            <p id="previewCategory" class="upload-form__metadata-value"></p>
            
            <div id="previewCouponSection" class="upload-form__metadata-coupon-row">
              <p class="upload-form__metadata-key">Coupon</p>
              <p id="previewCoupon" class="upload-form__metadata-value"></p>
              <p class="upload-form__metadata-key">Expiry</p>
              <p id="previewCouponExpiry" class="upload-form__metadata-value"></p>
            </div>
          </div>
        </section>

        <button id="publishBtn" class="v-btn-primary w-100">
          <i class="fa-solid fa-cloud-arrow-up me-2"></i> Publish Resource
        </button>
      </div>
    </main>
  </template>

  <template id="template-upload-progress">
    <main class="upload-form__main upload-form__main--centered">
      <div class="upload-form__card upload-form__card--progress">
        <div class="upload-form__progress-loader">
          <svg class="upload-form__progress-spinner" viewBox="25 25 50 50">
            <circle class="upload-form__progress-spinner-circle" r="20" cy="50" cx="50"></circle>
          </svg>
        </div>
        <h2 id="uploadHeading" class="upload-form__main-title" style="margin-bottom: 8px;">Uploading...</h2>
        <p id="uploadStatusMessage" class="upload-form__progress-status">Initializing secure connection...</p>
        
        <div class="upload-form__progress-bar-wrapper">
          <div class="upload-form__progress-bar-info">
            <span id="uploadProgressText" class="upload-form__progress-bar-text">0%</span>
            <span id="uploadBytesText" class="upload-form__progress-bar-bytes">0 B / 0 B</span>
          </div>
          <progress id="uploadProgressBar" value="0" max="100" class="upload-form__progress-bar"></progress>
        </div>
        
        <div class="upload-form__progress-stats-grid">
          <p>Speed: <span id="uploadSpeed" class="fw-bold">0 B/s</span></p>
          <p>Time Left: <span id="uploadTime" class="fw-bold">--:--</span></p>
        </div>
        
        <div class="upload-form__progress-controls" style="color: black;">
          <button id="pauseResumeBtn" class="v-btn-secondary">Pause</button>
          <button id="cancelBtn" class="v-btn-danger">Cancel</button>
        </div>
      </div>
    </main>
  </template>
  
  <template id="template-modal">
    <div id="successModalContainer" class="upload-form__modal-container">
      <div id="successModalContent" class="upload-form__modal-content">
        <div class="upload-form__modal-icon-wrapper">
            <i class="fa-regular fa-circle-check text-success" style="font-size: 5rem;"></i>
        </div>
        <h2 class="upload-form__modal-title">Upload Complete!</h2>
        <p class="upload-form__modal-text">Your resource has been securely processed and is now live on Vidyari.</p>
        <button id="dismissModalBtn" class="v-btn-primary w-100">Go to Dashboard</button>
      </div>
    </div>
  </template>
</div>

<style>
  /* ==========================================================================
     UPLOAD FORM: GEMINI / MATERIAL 3 THEME
     ========================================================================== */
  .v-upload-master {
    --v-bg: #f0f4f9;           
    --v-surface: #ffffff;      
    --v-text-main: #1f1f1f;
    --v-text-muted: #444746;
    
    --v-primary: #0b57d0;      
    --v-primary-hover: #1a73e8;
    --v-primary-bg: #e8f0fe;
    
    --v-success: #146c2e;
    --v-danger: #b3261e;
    --v-danger-bg: #fce8e6;
    
    --v-border: #dadce0;
    
    --v-font-display: 'Outfit', sans-serif;
    --v-font-sans: 'Inter', sans-serif;
    
    --v-radius-sm: 8px;
    --v-radius-md: 12px;
    --v-radius-lg: 24px;
    --v-radius-pill: 9999px;
    
    --v-shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05);
    --v-shadow-md: 0 4px 12px rgba(0, 0, 0, 0.05);
    
    --v-transition: all 0.2s cubic-bezier(0.2, 0, 0, 1);
    
    font-family: var(--v-font-sans); 
    background: transparent; 
    color: var(--v-text-main);
  }
  
  .v-upload-master *, .v-upload-master *::before, .v-upload-master *::after { 
      margin: 0; padding: 0; box-sizing: border-box; 
  }
  
  .upload-form__main { 
      width: 100%; display: flex; justify-content: center; 
  }
  .upload-form__main--centered { align-items: center; min-height: 60vh;}
  
  .upload-form__card { 
      width: 100%; max-width: 800px;
      background: var(--v-surface); 
      padding: clamp(24px, 4vw, 40px); 
      border: 1px solid var(--v-border);
      border-radius: var(--v-radius-lg);
      box-shadow: var(--v-shadow-sm);
  }
  
  .upload-form__main-title { 
      font-family: var(--v-font-display);
      font-size: clamp(1.8rem, 3vw, 2.2rem); 
      font-weight: 600; 
      margin-bottom: 4px;
      color: var(--v-text-main);
  }
  .upload-form__subtitle {
      color: var(--v-text-muted);
      margin-bottom: 32px;
      font-size: 1.05rem;
  }
  
  .upload-form__form { display: flex; flex-direction: column; gap: 24px; }
  .upload-form__input-group { display: flex; flex-direction: column; gap: 8px; }
  
  .upload-form__label-wrapper { display: flex; justify-content: space-between; align-items: flex-end; }
  .upload-form__label { 
      font-size: 0.95rem; font-weight: 600; 
      color: var(--v-text-main);
  }
  .upload-form__label-muted { font-weight: 400; color: var(--v-text-muted); font-size: 0.85rem;}
  .required { color: var(--v-danger); margin-left: 2px;}
  
  .upload-form__word-counter { font-size: 0.8rem; font-weight: 500; color: var(--v-danger); transition: var(--v-transition); }
  
  .upload-form__input { 
      width: 100%; padding: 14px 16px; 
      background: var(--v-bg); 
      border: 1px solid transparent;
      border-radius: var(--v-radius-md);
      color: var(--v-text-main); font-size: 1rem;
      transition: var(--v-transition);
  }
  .upload-form__input::placeholder { color: #80868b; }
  .upload-form__input:focus, 
  .upload-form__editor-container:focus-within { 
      outline: none; background: var(--v-surface);
      border-color: var(--v-primary); 
      box-shadow: 0 0 0 3px var(--v-primary-bg); 
  }

  .upload-form__grid-container { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 768px) { .upload-form__grid-container { grid-template-columns: 1fr; gap: 16px; } }
  
  /* Quill overrides */
  .upload-form__editor-container { 
      background: var(--v-bg); border: 1px solid transparent; 
      border-radius: var(--v-radius-md); overflow: hidden;
      transition: var(--v-transition); 
  }
  .upload-form__editor-container .ql-toolbar { 
      border: none; border-bottom: 1px solid var(--v-border); 
      background: var(--v-surface); font-family: inherit;
  }
  .upload-form__editor-container .ql-container { border: none; min-height: 150px; font-size: 1rem; font-family: var(--v-font-sans); }
  
  /* Coupon Section */
  .upload-form__coupon-section { 
      background: var(--v-bg); padding: 20px; 
      border-radius: var(--v-radius-md);
      border: 1px solid var(--v-border);
  }
  .upload-form__coupon-details { display: none; margin-top: 16px; }
  .upload-form__coupon-details.visible { display: block; animation: fadeIn 0.3s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
  
  /* Checkboxes */
  .upload-form__checkbox-group { display: flex; align-items: center; gap: 12px; }
  .upload-form__checkbox-group--agreement { margin: 8px 0; align-items: flex-start; }
  .upload-form__checkbox-input { 
      height: 20px; width: 20px; flex-shrink: 0; margin-top: 1px;
      border: 2px solid var(--v-text-muted); border-radius: 4px;
      appearance: none; cursor: pointer; transition: var(--v-transition);
      background: var(--v-surface);
  }
  .upload-form__checkbox-input:checked {
      background-color: var(--v-primary); border-color: var(--v-primary);
      background-image: url("data:image/svg+xml,%3csvg viewBox='0 0 16 16' fill='white' xmlns='http://www.w3.org/2000/svg'%3e%3cpath d='M12.207 4.793a1 1 0 010 1.414l-5 5a1 1 0 01-1.414 0l-2-2a1 1 0 011.414-1.414L6.5 9.086l4.293-4.293a1 1 0 011.414 0z'/%3e%3c/svg%3e");
  }
  .upload-form__checkbox-label { color: var(--v-text-main); font-weight: 500; cursor: pointer; font-size: 0.95rem; }
  .upload-form__checkbox-label--small { font-size: 0.85rem; color: var(--v-text-muted); line-height: 1.4; }
  
  /* Drag & Drop Areas */
  .upload-form__drop-area { 
      border: 2px dashed var(--v-border); border-radius: var(--v-radius-md);
      padding: 32px 24px; text-align: center; cursor: pointer; 
      background: var(--v-surface); transition: var(--v-transition); 
  }
  .upload-form__drop-area:hover, .upload-form__drop-area.dragover { 
      border-color: var(--v-primary); background-color: var(--v-primary-bg); 
  }
  .upload-form__drop-area-content { display: flex; flex-direction: column; align-items: center; gap: 12px; color: var(--v-text-muted); }
  .upload-form__drop-area-icon { font-size: 2rem; color: var(--v-primary); }
  .upload-form__drop-area-text { font-weight: 500; font-size: 0.95rem;}
  .upload-form__drop-area.file-selected { 
      border-color: var(--v-success); border-style: solid; 
      background-color: var(--v-success-bg);
  }
  .upload-form__drop-area.file-selected .upload-form__drop-area-icon,
  .upload-form__drop-area.file-selected .upload-form__drop-area-text { color: var(--v-success); }

  /* Buttons */
  .v-btn-primary { 
      width: 100%; padding: 16px; border-radius: var(--v-radius-pill);
      font-size: 1.1rem; font-weight: 500; font-family: var(--v-font-sans);
      background: var(--v-primary); color: white; border: none;
      cursor: pointer; transition: var(--v-transition); 
      display: flex; justify-content: center; align-items: center;
  }
  .v-btn-primary:hover:not(:disabled) { 
      background: var(--v-primary-hover); box-shadow: var(--v-shadow-md); transform: translateY(-1px);
  }
  .v-btn-primary:disabled { 
      background: var(--v-border); color: #9aa0a6; cursor: not-allowed;
  }
  
  .v-btn-secondary {
      padding: 12px 24px; border-radius: var(--v-radius-pill);
      font-weight: 500; background: var(--v-surface); color: var(--v-text-main);
      border: 1px solid var(--v-border); cursor: pointer; transition: var(--v-transition);
  }
  .v-btn-secondary:hover { background: var(--v-bg); }
  
  .v-btn-danger {
      padding: 12px 24px; border-radius: var(--v-radius-pill);
      font-weight: 500; background: var(--v-surface); color: var(--v-danger);
      border: 1px solid var(--v-danger); cursor: pointer; transition: var(--v-transition);
  }
  .v-btn-danger:hover { background: var(--v-danger-bg); }
  
  /* Preview Stage */
  .upload-form__preview-header { 
      display: flex; align-items: center; gap: 16px; margin-bottom: 32px;
      border-bottom: 1px solid var(--v-border); padding-bottom: 24px;
  }
  .upload-form__back-btn { 
      background: var(--v-bg); border: none; border-radius: 50%;
      color: var(--v-text-muted); cursor: pointer; font-size: 1.2rem; 
      width: 44px; height: 44px; transition: var(--v-transition);
      display: flex; align-items: center; justify-content: center;
  }
  .upload-form__back-btn:hover { background: var(--v-border); color: var(--v-text-main); }
  .upload-form__main-title--preview { margin-bottom: 0; }
  
  .upload-form__section { margin-bottom: 32px; }
  .upload-form__section-title { 
      font-family: var(--v-font-display); font-size: 1.2rem; font-weight: 600; 
      margin-bottom: 16px; color: var(--v-text-main);
  }
  .upload-form__preview-box { display: flex; gap: 20px; border: 1px solid var(--v-border); padding: 16px; border-radius: var(--v-radius-md); background: var(--v-bg); align-items: center;}
  .upload-form__preview-image { width: 100px; height: 75px; border-radius: 8px; background-size: cover; background-position: center; flex-shrink: 0; border: 1px solid var(--v-border); }
  .upload-form__preview-file-title { font-weight: 600; font-size: 0.9rem; color: var(--v-text-muted); text-transform: uppercase; letter-spacing: 0.5px;}
  .upload-form__preview-file-name { color: var(--v-text-main); font-size: 1.1rem; font-weight: 500;}
  
  .upload-form__metadata-grid { display: grid; grid-template-columns: 120px 1fr; gap: 16px; align-items: start;}
  .upload-form__metadata-key { font-weight: 500; color: var(--v-text-muted); font-size: 0.95rem; margin-top: 4px;}
  .upload-form__metadata-value { font-weight: 500; color: var(--v-text-main); font-size: 1rem;}
  .upload-form__metadata-value--description { border: 1px solid var(--v-border); border-radius: var(--v-radius-sm); padding: 12px; max-height: 200px; overflow-y: auto; background: var(--v-bg); font-weight: 400;}
  .upload-form__metadata-coupon-row { display: contents; }
  
  /* Progress Stage */
  .upload-form__card--progress { text-align: center; max-width: 500px; padding: 48px 32px;}
  .upload-form__progress-loader { margin: 0 auto 24px auto; width: 64px; height: 64px; color: var(--v-primary); }
  .upload-form__progress-status { color: var(--v-text-muted); margin-bottom: 32px; font-weight: 500;}
  
  .upload-form__progress-bar-wrapper { margin-bottom: 24px; text-align: left;}
  .upload-form__progress-bar-info { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.85rem; font-weight: 600; color: var(--v-text-muted);}
  .upload-form__progress-bar { 
      width: 100%; height: 8px; border-radius: 4px;
      -webkit-appearance: none; appearance: none;
  }
  .upload-form__progress-bar::-webkit-progress-bar { background-color: var(--v-bg); border-radius: 4px; }
  .upload-form__progress-bar::-webkit-progress-value { background-color: var(--v-primary); border-radius: 4px; transition: width 0.2s ease;}
  
  .upload-form__progress-stats-grid { display: flex; justify-content: space-between; font-size: 0.9rem; color: var(--v-text-muted); margin-bottom: 32px; background: var(--v-bg); padding: 12px 16px; border-radius: var(--v-radius-sm);}
  .upload-form__progress-controls { display: flex; gap: 16px; justify-content: center; }

  /* Error state for inputs */
  .upload-form__input:invalid,
  .upload-form__input.error { 
      border-color: var(--v-danger); 
      background-color: var(--v-danger-bg);
  }
  .error-msg { 
      font-size: 0.8rem; 
      color: var(--v-danger); 
      margin-top: 4px; 
      display: block; 
      font-weight: 500;
  }

  /* Success Modal */
  .upload-form__modal-container { 
      position: fixed; inset: 0; z-index: 1050; display: flex; 
      align-items: center; justify-content: center; 
      background: rgba(32, 33, 36, 0.6); backdrop-filter: blur(2px); 
      opacity: 0; visibility: hidden; transition: opacity 0.3s ease;
  }
  .upload-form__modal-container.visible { opacity: 1; visibility: visible; }
  .upload-form__modal-content { 
      background: var(--v-surface); padding: 48px 32px; text-align: center; 
      max-width: 450px; width: 90%;
      border-radius: var(--v-radius-lg); box-shadow: var(--v-shadow-md);
      transform: scale(0.95); opacity: 0; transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .upload-form__modal-container.visible .upload-form__modal-content { transform: scale(1); opacity: 1; }
  .upload-form__modal-title { font-family: var(--v-font-display); font-size: 1.8rem; font-weight: 600; margin-bottom: 12px; color: var(--v-text-main);}
  .upload-form__modal-text { color: var(--v-text-muted); margin-bottom: 32px; font-size: 1.05rem; }
  
  /* SVG Spinner */
  .upload-form__progress-spinner { animation: v-rotate 2s linear infinite; }
  .upload-form__progress-spinner-circle { stroke: currentColor; stroke-width: 4; stroke-dasharray: 1, 200; stroke-dashoffset: 0; animation: v-dash 1.5s ease-in-out infinite; stroke-linecap: round; fill: none; }
  @keyframes v-rotate { 100% { transform: rotate(360deg); } }
  @keyframes v-dash { 0% { stroke-dasharray: 1, 200; stroke-dashoffset: 0; } 50% { stroke-dasharray: 90, 200; stroke-dashoffset: -35px; } 100% { stroke-dasharray: 90, 200; stroke-dashoffset: -124px; } }
</style>

<script>
  (function() {
    if (!document.querySelector('.v-upload-master')) return;

    document.addEventListener('DOMContentLoaded', () => {
      if (typeof Quill === 'undefined') {
        const quillJs = document.createElement('script');
        quillJs.src = 'https://cdn.quilljs.com/1.3.6/quill.js';
        quillJs.onload = () => initializeComponent(true);
        document.body.appendChild(quillJs);
      } else {
        initializeComponent(true);
      }
    });

    function initializeComponent(isQuillAvailable) {
      
      class UIHandler {
        constructor(containerId) { this.appContainer = document.getElementById(containerId); }
        render(templateId, onRender) {
          this.appContainer.innerHTML = '';
          const template = document.getElementById(templateId);
          if (!template) return;
          const clone = template.content.cloneNode(true);
          this.appContainer.appendChild(clone);
          if (onRender) onRender();
        }
        showModal(onDismiss) {
            const template = document.getElementById('template-modal');
            if (!template) return;
            if (document.getElementById('successModalContainer')) return;
            
            const clone = template.content.cloneNode(true);
            document.body.appendChild(clone);
            
            const modalContainer = document.getElementById('successModalContainer');
            const dismissBtn = document.getElementById('dismissModalBtn');
            
            setTimeout(() => modalContainer.classList.add('visible'), 10);
            
            const dismiss = () => {
                modalContainer.classList.remove('visible');
                setTimeout(() => {
                    modalContainer.remove();
                    if (onDismiss) onDismiss();
                }, 300);
            };

            dismissBtn.addEventListener('click', dismiss);
        }
      }

      class Uploader {
        constructor() { this.CHUNK_SIZE_MB = 5; this.queue = []; this.currentIndex = 0; this.state = this._resetState(); this.MAX_RETRIES = 3; }
        _resetState() { return { file: null, fileType: null, fileId: null, key: null, generatedFileName: null, uploadId: null, completedParts: [], bytesUploadedFromCompletedParts: 0, isUploading: false, isPaused: false, currentXhr: null, uploadStartTime: null }; }
        _saveState() { sessionStorage.setItem('uploadState', JSON.stringify({ queue: this.queue, currentIndex: this.currentIndex, state: this.state, timestamp: Date.now() })); }
        _restoreState() { const saved = sessionStorage.getItem('uploadState'); if (saved) { try { const data = JSON.parse(saved); if (Date.now() - data.timestamp < 3600000) { this.queue = data.queue; this.currentIndex = data.currentIndex; this.state = data.state; return true; } } catch(e) {} sessionStorage.removeItem('uploadState'); } return false; }
        _clearState() { sessionStorage.removeItem('uploadState'); }
        enqueueFiles(files) { this.queue = files; this.currentIndex = 0; }
        async startNext(onSuccess, onFail, onProgressUpdate) { if (this.currentIndex >= this.queue.length) { if (onSuccess) onSuccess(); return; } this.state = this._resetState(); const currentFile = this.queue[this.currentIndex]; this.state.file = currentFile.file; this.state.fileType = currentFile.type; this.state.fileId = currentFile.id; try { onProgressUpdate({ type: 'status', message: `Preparing to upload ${this.state.file.name}...` }); const response = await fetch(`/start-multipart-upload`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ fileName: this.state.file.name, contentType: this.state.file.type, fileType: this.state.fileType, fileId: this.state.fileId }) }); if (!response.ok) throw new Error("Failed to initiate multipart upload."); const data = await response.json(); this.state.uploadId = data.uploadId; this.state.key = data.key; this.state.generatedFileName = data.generatedFileName; this.state.uploadStartTime = Date.now(); await this._uploadChunks(onProgressUpdate); if (this.state.isPaused) { return; } await this._completeUpload(onProgressUpdate); this.currentIndex++; await this.startNext(onSuccess, onFail, onProgressUpdate); } catch (error) { if (onFail) onFail(error); } }
        _uploadChunks(onProgressUpdate) { return new Promise(async (resolve, reject) => { this.state.isUploading = true; const chunkSize = this.CHUNK_SIZE_MB * 1024 * 1024; const totalChunks = Math.ceil(this.state.file.size / chunkSize); for (let partNumber = this.state.completedParts.length + 1; partNumber <= totalChunks; partNumber++) { if (this.state.isPaused) { this.state.isUploading = false; return resolve(); } const start = (partNumber - 1) * chunkSize; const end = Math.min(start + chunkSize, this.state.file.size); const chunk = this.state.file.slice(start, end); onProgressUpdate({ type: 'status', message: `Uploading ${this.state.file.name} (part ${partNumber} of ${totalChunks})...` }); try { await this._uploadPart(partNumber, chunk, onProgressUpdate); } catch (error) { this.state.isUploading = false; return reject(error); } } this.state.isUploading = false; resolve(); }); }
        _uploadPart(partNumber, chunk, onProgressUpdate, retryCount = 0) { return new Promise(async (resolve, reject) => { try { const queryString = `?key=${encodeURIComponent(this.state.key)}&uploadId=${this.state.uploadId}&partNumber=${partNumber}&fileType=${this.state.fileType}`; const response = await fetch(`/get-presigned-part-url${queryString}`); if (!response.ok) return reject(new Error("Failed to get presigned URL.")); const { url } = await response.json(); const xhr = new XMLHttpRequest(); this.state.currentXhr = xhr; xhr.upload.onprogress = (e) => { const totalBytesUploaded = this.state.bytesUploadedFromCompletedParts + e.loaded; const totalProgress = (totalBytesUploaded / this.state.file.size) * 100; const elapsedTime = (Date.now() - this.state.uploadStartTime) / 1000; const speed = totalBytesUploaded / elapsedTime; const timeRemaining = speed > 0 ? (this.state.file.size - totalBytesUploaded) / speed : Infinity; onProgressUpdate({ type: 'progress', progress: totalProgress, speed, timeRemaining, uploadedBytes: totalBytesUploaded, totalBytes: this.state.file.size }); }; xhr.onload = () => { if (xhr.status === 200) { this.state.completedParts.push({ ETag: xhr.getResponseHeader("ETag"), PartNumber: partNumber }); this.state.bytesUploadedFromCompletedParts += chunk.size; this._saveState(); resolve(); } else { reject(new Error(`Part upload failed with status ${xhr.status}.`)); } }; xhr.onerror = async () => { if (retryCount < this.MAX_RETRIES) { const waitTime = 1000 * (retryCount + 1); onProgressUpdate({ type: 'status', message: `Network error. Retrying part ${partNumber}... (${retryCount + 1}/${this.MAX_RETRIES})` }); setTimeout(() => { this._uploadPart(partNumber, chunk, onProgressUpdate, retryCount + 1).then(resolve).catch(reject); }, waitTime); } else { reject(new Error(`Part ${partNumber} upload failed after ${this.MAX_RETRIES} retries.`)); } }; xhr.onabort = () => resolve(); xhr.open("PUT", url); xhr.setRequestHeader("Content-Type", "application/octet-stream"); xhr.send(chunk); } catch (error) { reject(error); } }); }
        async _completeUpload(onProgressUpdate) { onProgressUpdate({ type: 'status', message: "Finalizing upload..." }); const response = await fetch("/complete-multipart-upload", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ key: this.state.key, uploadId: this.state.uploadId, parts: this.state.completedParts, fileType: this.state.fileType, fileId: this.state.fileId, generatedFileName: this.state.generatedFileName, fileSize: this.state.file.size }), }); if (!response.ok) throw new Error("Failed to complete upload."); }
        togglePause(onProgressUpdate) { this.state.isPaused = !this.state.isPaused; if(this.state.isPaused) { if (this.state.currentXhr) this.state.currentXhr.abort(); onProgressUpdate({ type: 'status', message: 'Upload paused.' }); } else { onProgressUpdate({ type: 'status', message: 'Resuming upload...' }); this._uploadChunks(onProgressUpdate); } }
        cancel(onCancel) { if (this.state.currentXhr) this.state.currentXhr.abort(); this.state = this._resetState(); this.queue = []; this.currentIndex = 0; this._clearState(); if(onCancel) onCancel(); }
      }

      const ui = new UIHandler('upload-form-app-container');
      const uploader = new Uploader();
      let formData = {};
      let imageFile, mainFile, quillEditor;
      let hasRestoredSession = false;
      let currentFileId = null;
      let savedFormState = null; // Save form state when going to preview

      const cleanupFailedUpload = async (fileId) => {
        try {
          const response = await fetch('/api/cleanup-failed-upload', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ fileId })
          });
          if (response.ok) {
            // Cleanup successful
          } else {
            console.warn(`⚠ Cleanup failed for ${fileId}`);
          }
        } catch (err) {
          console.error('Cleanup error:', err.message);
        }
      };

      const saveFormState = () => {
        savedFormState = {
          title: document.getElementById('uploadFormTitle')?.value || '',
          price: document.getElementById('uploadFormPrice')?.value || '',
          category: document.getElementById('uploadFormCategory')?.value || '',
          description: quillEditor ? quillEditor.root.innerHTML : '',
          couponToggle: document.getElementById('couponToggleCheckbox')?.checked || false,
          couponCode: document.getElementById('couponCode')?.value || '',
          couponPercentage: document.getElementById('couponPercentage')?.value || '',
          couponExpiry: document.getElementById('couponExpiry')?.value || '',
          imageFile: imageFile,
          mainFile: mainFile
        };
      };

      const restoreFormState = () => {
        if (!savedFormState) return;
        
        const titleInput = document.getElementById('uploadFormTitle');
        const priceInput = document.getElementById('uploadFormPrice');
        const categoryInput = document.getElementById('uploadFormCategory');
        const couponToggle = document.getElementById('couponToggleCheckbox');
        const couponCode = document.getElementById('couponCode');
        const couponPercentage = document.getElementById('couponPercentage');
        const couponExpiry = document.getElementById('couponExpiry');
        const couponDetails = document.getElementById('couponDetailsContainer');
        const imageInput = document.getElementById('imageUploadInput');
        const fileInput = document.getElementById('fileUploadInput');
        const imageUploadText = document.getElementById('imageUploadText');
        const fileUploadText = document.getElementById('fileUploadText');
        const imageUploadArea = document.getElementById('imageUploadArea');
        const fileUploadArea = document.getElementById('fileUploadArea');

        // Restore text inputs
        if (titleInput) titleInput.value = savedFormState.title;
        if (priceInput) priceInput.value = savedFormState.price;
        if (categoryInput) categoryInput.value = savedFormState.category;
        
        // Restore quill editor
        if (quillEditor) {
          quillEditor.root.innerHTML = savedFormState.description;
        }

        // Restore coupon fields
        if (couponToggle) {
          couponToggle.checked = savedFormState.couponToggle;
          if (couponDetails) {
            couponDetails.classList.toggle('visible', savedFormState.couponToggle);
          }
        }
        if (couponCode) couponCode.value = savedFormState.couponCode;
        if (couponPercentage) couponPercentage.value = savedFormState.couponPercentage;
        if (couponExpiry) couponExpiry.value = savedFormState.couponExpiry;

        // Restore file selections
        imageFile = savedFormState.imageFile;
        mainFile = savedFormState.mainFile;

        if (imageFile && imageInput) {
          const dataTransfer = new DataTransfer();
          dataTransfer.items.add(imageFile);
          imageInput.files = dataTransfer.files;
          if (imageUploadArea) imageUploadArea.classList.add('file-selected');
          if (imageUploadText) imageUploadText.textContent = imageFile.name.length <= 25 ? imageFile.name : `${imageFile.name.slice(0, 21)}...`;
        }

        if (mainFile && fileInput) {
          const dataTransfer = new DataTransfer();
          dataTransfer.items.add(mainFile);
          fileInput.files = dataTransfer.files;
          if (fileUploadArea) fileUploadArea.classList.add('file-selected');
          if (fileUploadText) fileUploadText.textContent = mainFile.name.length <= 25 ? mainFile.name : `${mainFile.name.slice(0, 21)}...`;
        }

        // Trigger validation to update review button state
        const form = document.getElementById('upload-form-main');
        if (form) {
          form.dispatchEvent(new Event('input'));
        }
      };

      const formatBytes = (bytes) => (bytes === 0 ? '0 B' : ( (k=1024, sizes=['B', 'KB', 'MB', 'GB'], i=Math.floor(Math.log(bytes)/Math.log(k))) => `${parseFloat((bytes/Math.pow(k,i)).toFixed(2))} ${sizes[i]}`)() );
      const formatRate = (bytes) => `${formatBytes(bytes)}/s`;
      const formatTime = (seconds) => (seconds === Infinity || seconds < 0 ? "--:--" : `${Math.floor(seconds/60)}m ${Math.floor(seconds%60)}s`);
      
      const getWordCount = (text) => text.trim().split(/\s+/).filter(word => word.length > 0).length;

      const updateProgressUI = (event) => {
        const status=document.getElementById('uploadStatusMessage'), progressText=document.getElementById('uploadProgressText'), progressBar=document.getElementById('uploadProgressBar'), bytesText=document.getElementById('uploadBytesText'), speedText=document.getElementById('uploadSpeed'), timeText=document.getElementById('uploadTime');
        if (event.type === 'status' && status) status.textContent = event.message;
        if (event.type === 'progress') {
          if(progressBar) progressBar.value = event.progress;
          if(progressText) progressText.textContent = `${event.progress.toFixed(1)}%`;
          if(bytesText) bytesText.textContent = `${formatBytes(event.uploadedBytes)} / ${formatBytes(event.totalBytes)}`;
          if(speedText) speedText.textContent = formatRate(event.speed);
          if(timeText) timeText.textContent = formatTime(event.timeRemaining);
        }
      };
      
      const checkAndRestoreUpload = () => {
        if (uploader._restoreState()) {
          const saved = JSON.parse(sessionStorage.getItem('uploadState'));
          if (confirm('We found an incomplete upload. Would you like to resume it?')) {
            hasRestoredSession = true;
            goToUploadProgressStage();
            return true;
          } else {
            uploader._clearState();
          }
        }
        return false;
      };

      const initializeFormStage = () => {
        ui.render('template-upload-form', () => {
          if (isQuillAvailable) { quillEditor = new Quill('#descriptionEditorContainer', { theme: 'snow', modules: { toolbar: [['bold', 'italic', 'underline'], [{ 'list': 'ordered'}, { 'list': 'bullet' }]] } }); }
          setupFormListeners();
          restoreFormState(); // Restore any previous form state
        });
      };

      const setupFormListeners = () => {
          const form = document.getElementById('upload-form-main');
          const reviewBtn = document.getElementById('reviewUploadBtn');
          const titleInput = document.getElementById('uploadFormTitle');
          const titleCounter = document.getElementById('titleWordCounter');
          const descCounter = document.getElementById('descriptionWordCounter');
          const imageInput = document.getElementById('imageUploadInput');
          const fileInput = document.getElementById('fileUploadInput');
          const couponToggle = document.getElementById('couponToggleCheckbox');
          const couponDetails = document.getElementById('couponDetailsContainer');
          
          const truncateFilename = (name, max=25) => name.length <= max ? name : `${name.slice(0, max-4)}...${name.split('.').pop()}`;
          
          const checkFormValidity = () => {
            let isValid = true;
            
            // Check native required fields
            form.querySelectorAll('[required]').forEach(input => { 
                if ((input.type === 'checkbox' && !input.checked) || (input.type !== 'checkbox' && !input.value.trim())) isValid = false; 
            });
            
            // Check Title Minimum Words
            const titleWords = getWordCount(titleInput.value);
            if (titleWords < 5) isValid = false;
            
            // Check Description Minimum Words
            if (quillEditor) {
                const descWords = getWordCount(quillEditor.getText());
                if (descWords < 20) isValid = false;
            }

            reviewBtn.disabled = !isValid;
          };
          
          // Form input listener for native fields
          form.addEventListener('input', checkFormValidity);
          
          // Title Word Counter Updates
          titleInput.addEventListener('input', () => {
              const words = getWordCount(titleInput.value);
              titleCounter.textContent = `${words} / 5 min words`;
              titleCounter.style.color = words >= 5 ? 'var(--v-success)' : 'var(--v-danger)';
              checkFormValidity();
          });
          
          // Description Word Counter Updates
          if (quillEditor) {
            quillEditor.on('text-change', () => {
              const words = getWordCount(quillEditor.getText());
              descCounter.textContent = `${words} / 20 min words`;
              descCounter.style.color = words >= 20 ? 'var(--v-success)' : 'var(--v-danger)';
              checkFormValidity();
            });
          }
          
          couponToggle.addEventListener('change', () => couponDetails.classList.toggle('visible', couponToggle.checked));
          
          const setupDropArea = (areaId, inputId, textId) => {
            const area = document.getElementById(areaId), input = document.getElementById(inputId), text = document.getElementById(textId);
            const MAX_FILE_SIZE_BYTES = 8 * 1024 * 1024 * 1024; // 8 GB
            
            // Keyboard accessibility
            area.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); input.click(); } });
            
            area.addEventListener('click', () => input.click());
            ['dragenter', 'dragover'].forEach(eName => area.addEventListener(eName, e => { e.preventDefault(); area.classList.add('dragover'); }));
            ['dragleave', 'drop'].forEach(eName => area.addEventListener(eName, e => { e.preventDefault(); area.classList.remove('dragover'); }));
            area.addEventListener('drop', e => { input.files = e.dataTransfer.files; input.dispatchEvent(new Event('change')); });
            input.addEventListener('change', () => {
              if (input.files.length > 0) {
                const file = input.files[0];
                if (inputId === 'fileUploadInput' && file.size > MAX_FILE_SIZE_BYTES) {
                  alert(`File is too large (${formatBytes(file.size)}). Maximum allowed size is 8 GB.`);
                  input.value = ''; area.classList.remove('file-selected'); text.textContent = 'PDF, ZIP, PPT, DOCS';
                  return;
                }
                text.textContent = truncateFilename(file.name);
                area.classList.add('file-selected');
              }
              checkFormValidity();
            });
          };
          
          setupDropArea('imageUploadArea', 'imageUploadInput', 'imageUploadText');
          setupDropArea('fileUploadArea', 'fileUploadInput', 'fileUploadText');
          
          reviewBtn.addEventListener('click', (e) => {
            e.preventDefault(); if (reviewBtn.disabled) return;
            formData = {
              title: document.getElementById('uploadFormTitle').value,
              descriptionHTML: isQuillAvailable ? quillEditor.root.innerHTML : "Description not available.",
              price: document.getElementById('uploadFormPrice').value,
              category: document.getElementById('uploadFormCategory').value,
              fileSize: document.getElementById('fileUploadInput').files[0].size,
              couponCode: couponToggle.checked ? document.getElementById('couponCode').value : null,
              couponPercentage: couponToggle.checked ? document.getElementById('couponPercentage').value : null,
              couponExpiry: couponToggle.checked ? document.getElementById('couponExpiry').value : null,
              imageType: document.getElementById('imageUploadInput').files[0].type.split('/')[1].toLowerCase().replace('jpeg', 'jpg')
            };
            imageFile = imageInput.files[0]; mainFile = fileInput.files[0];
            goToPreviewStage();
          });
      };

      const goToPreviewStage = () => {
        saveFormState(); // Save all form data before switching views
        ui.render('template-preview', () => {
          document.getElementById('backToFormBtn').addEventListener('click', () => {
            ui.render('template-upload-form', () => {
              if (isQuillAvailable) { quillEditor = new Quill('#descriptionEditorContainer', { theme: 'snow', modules: { toolbar: [['bold', 'italic', 'underline'], [{ 'list': 'ordered'}, { 'list': 'bullet' }]] } }); }
              restoreFormState(); // Restore saved form data
              setupFormListeners(); // Re-attach all event listeners
            });
          });
          document.getElementById('previewImage').style.backgroundImage = `url(${URL.createObjectURL(imageFile)})`;
          document.getElementById('previewFileName').textContent = mainFile.name;
          document.getElementById('previewTitle').textContent = formData.title;
          document.getElementById('previewDescription').querySelector('.ql-editor').innerHTML = formData.descriptionHTML;
          document.getElementById('previewPrice').textContent = `₹ ${formData.price}`;
          document.getElementById('previewCategory').textContent = formData.category;
          const couponSection = document.getElementById('previewCouponSection');
          if (formData.couponCode) {
            couponSection.style.display = 'contents';
            document.getElementById('previewCoupon').textContent = `${formData.couponCode} (${formData.couponPercentage}%)`;
            document.getElementById('previewCouponExpiry').textContent = formData.couponExpiry ? new Date(formData.couponExpiry).toLocaleDateString() : 'No expiry date';
          } else {
            couponSection.style.display = 'none';
          }
          const publishBtn = document.getElementById('publishBtn');
          publishBtn.addEventListener('click', async () => {
            try {
              publishBtn.disabled = true; publishBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i> Preparing...';
              const response = await fetch('/api/create-file-record', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json'},
                body: JSON.stringify(formData)
              });
              if (!response.ok) {
                const errData = await response.json();
                throw new Error(errData.error || 'Could not create file record on server.');
              }
              const { fileId } = await response.json();
              currentFileId = fileId; // Store for cleanup if needed
              uploader.enqueueFiles([
                { type: 'main', file: mainFile, id: fileId },
                { type: 'image', file: imageFile, id: fileId }
              ]);
              uploader._saveState();
              goToUploadProgressStage();
            } catch (error) {
              alert(`Error: ${error.message}`);
              publishBtn.disabled = false; publishBtn.innerHTML = '<i class="fa-solid fa-cloud-arrow-up me-2"></i> Publish Resource';
            }
          });
        });
      };

      const goToUploadProgressStage = () => {
        ui.render('template-upload-progress', () => {
          document.getElementById('pauseResumeBtn').addEventListener('click', (e) => {
            uploader.togglePause(updateProgressUI);
            e.target.textContent = uploader.state.isPaused ? 'Resume' : 'Pause';
          });
          document.getElementById('cancelBtn').addEventListener('click', () => uploader.cancel(() => {
            alert("Upload cancelled.");
            initializeFormStage();
          }));
          
          uploader.startNext(
            () => { uploader._clearState(); currentFileId = null; ui.showModal(initializeFormStage); }, 
            (err) => { 
              uploader._clearState(); 
              // Cleanup MongoDB record if upload fails completely
              if (currentFileId) {
                cleanupFailedUpload(currentFileId).then(() => {
                  alert(`Upload failed: ${err.message}\n\nFile record has been automatically deleted.`);
                  currentFileId = null;
                  initializeFormStage();
                });
              } else {
                alert(`Upload failed: ${err.message}`);
                initializeFormStage();
              }
            },
            updateProgressUI
          );
        });
      };
      
      if (!checkAndRestoreUpload()) {
        initializeFormStage();
      }
    }
  })();
</script>