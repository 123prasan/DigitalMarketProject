                                            </span>
                                            <span style="color: #e0e6ed;">•</span>
                                            <span class="v-card-meta-item" style="display: flex; align-items: center; gap: 4px; color: #5f6368;">
                                                <i class="fa-solid fa-cloud-arrow-down"></i> ${downloads}
                                            </span>
                                        </div>

                                        <div class="v-card-author-row" style="padding: 8px 0; border-top: 1px solid #e0e6ed;">
                                            <div class="v-card-author">
                                                <div class="v-card-author-avatar" style="background: linear-gradient(135deg, #0b57d0, #0842a0); color: white; font-weight: 700;">${authorInitial}</div>
                                                <span style="font-size: 0.9rem; color: #202124; font-weight: 500;">${item.user || 'Vidyari'}</span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="v-card-footer">
                                        <div class="v-price ${isFree ? 'is-free' : ''}" style="font-weight: 700; font-size: 1.1rem;">${Utils.formatPrice(item.price)}</div>
                                        <div class="v-card-action-group">
                                            <button class="v-card-action-btn v-share-btn" data-share-link="${fullLink}" title="Copy Link" onclick="event.preventDefault(); EventManager.share('${fullLink}');">
                                                <i class="fa-solid fa-share-nodes"></i>
                                            </button>
                                            <div class="v-card-action-btn main"><i class="fa-solid fa-arrow-right"></i></div>
                                        </div>
                                    </div>
                                </a>
                            `;
                        }).join('');
                        
                        // Show the section
                        document.getElementById('vRecommendations').style.display = 'block';
                        console.log('✅ Recommendations section displayed successfully');
                    } else {
                        console.log('ℹ️ No recommendations to display');
                    }
                } catch (error) {
                    console.error('❌ Error loading recommendations:', error);
                    // Silently fail - don't show section if recommendations can't be loaded
                }
            };

            // Load recommendations after a short delay to ensure context is ready
            setTimeout(loadRecommendations, 500);

            // --- 10. LOAD POPULAR/TRENDING ITEMS ---
            const loadPopular = async () => {
                try {
                    const response = await fetch('/api/trending-content?days=7&limit=12');
                    const data = await response.json();
                    
                    // Transform trending data with more robust handling
                    const trendingItems = (Array.isArray(data) ? data : []).map((item, idx) => {
                        try {
                            // Extract content - it can be nested or flat
                            const content = item.content || item;
                            
                            // Get ID from various locations
                            const itemId = content._id || item._id?.fileId || item._id?.courseId || item._id;
                            
                            // Get title from various locations
                            const itemTitle = content.title || content.filename || item.title || item.filename;
                            
                            // Get slug, category, etc
                            const itemSlug = content.slug || Utils.slugify(itemTitle);
                            const itemCategory = content.category || 'Resource';
                            const itemPrice = content.price || 0;
                            
                            // Get download/engagement count
                            const itemDownloads = content.downloads || content.downloadCount || item._id?.count || item.count || Math.floor(Math.random() * 1000) + 100;
                            
                            // Get rating
                            const itemRating = content.rating || item.rating || 4.8;
                            
                            // Get file type and user
                            const itemFileType = content.fileType || item._id?.fileType || 'pdf';
                            const itemUser = item.userId || content.user || item.user || 'Vidyari';
                            
                            // Get preview URL
                            const itemPreviewUrl = content.previewUrl || (content.imageType ? `https://d3epchi0htsp3c.cloudfront.net/files-previews/images/${itemId}.${content.imageType}` : null);
                            
                            const transformed = {
                                _id: itemId,
                                title: itemTitle,
                                filename: itemTitle,
                                slug: itemSlug,
                                category: itemCategory,
                                price: itemPrice,
                                downloadCount: itemDownloads,
                                rating: itemRating,
                                fileType: itemFileType,
                                user: itemUser,
                                previewUrl: itemPreviewUrl
                            };
                            
                            return transformed;
                        } catch (err) {
                            return null;
                        }
                    }).filter(item => item && item._id && item.title);
                    
                    // Only show section if there are trending items
                    if (trendingItems && trendingItems.length > 0) {
                        const popGrid = document.getElementById('vPopularGrid');
                        
                        popGrid.innerHTML = trendingItems.map((item, index) => {
                            const isFree = item.price === 0 || item.price === '0';
                            const link = `/file/${item.slug}/${item._id}`;
                            const fullLink = window.location.origin + link;
                            
                            // Generate fallback image
                            const textForImage = (item.title || 'File').substring(0, 20);
                            const fallbackImage = `https://placehold.co/400x250/fee2e2/ea580c?text=${encodeURIComponent(textForImage)}&font=Outfit`;
                            
                            // Use previewUrl if available, otherwise use fallback
                            const previewImage = (item.previewUrl && item.previewUrl.trim() && item.previewUrl.trim() !== 'null' && item.previewUrl.trim() !== 'undefined')
                                ? item.previewUrl 
                                : fallbackImage;
                            
                            const fileIcon = Utils.getFileIcon(item.fileType);
                            const authorInitial = item.user ? String(item.user).charAt(0).toUpperCase() : 'V';
                            const rating = parseFloat(item.rating) || 4.8;
                            const downloads = parseInt(item.downloadCount) || Math.floor(Math.random() * 1000) + 100;

                            return `
                                <a href="${link}" class="v-card" style="animation: slideUp 0.5s cubic-bezier(0.23, 1, 0.320, 1) ${index * 0.06}s forwards; opacity: 0; transform: translateY(30px);">
                                    <div class="v-card-img-box" style="position: relative;">
                                        <div class="v-popular-badge">
                                            <i class="fa-solid fa-fire"></i> Trending
                                        </div>
                                        <button 
                                            type="button"
                                            class="v-card-wishlist-btn" 
                                            data-wishlist-btn 
                                            data-file-id="${item._id}" 
                                            data-file-title="${(item.title || 'File').replace(/'/g, "'")}"
                                            title="Add to wishlist"
                                            style="position: absolute; bottom: 12px; right: 12px; z-index: 999; width: 36px; height: 36px; border-radius: 50%; background: white; border: 2px solid #f0f4f9; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 16px; color: #ccc; transition: all 0.2s ease; box-shadow: 0 2px 8px rgba(0,0,0,0.1); pointer-events: auto; padding: 0;"
                                        >
                                            <i class="fa-regular fa-heart"></i>
                                        </button>
                                        <div class="v-card-badges">
                                            <span class="v-badge-category">${item.category}</span>
                                            <span class="v-badge-type" title="${item.fileType}"><i class="fa-solid ${fileIcon}"></i></span>
                                        </div>
                                        <img src="${previewImage}" class="v-card-img" loading="lazy" onerror="this.src='/images/File_Demo.svg'" style="transition: transform 0.6s cubic-bezier(0.23, 1, 0.320, 1);">
                                        <div class="v-card-overlay-gradient" style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.3) 100%); opacity: 0; transition: opacity 0.4s ease;"></div>
                                    </div>
                                    
                                    <div class="v-card-content">
                                        <h3 class="v-card-title" title="${item.title}">${item.title}</h3>
                                        
                                        <div class="v-card-meta" style="display: flex; align-items: center; gap: 12px; margin: 10px 0;">
                                            <span class="v-card-meta-item" style="display: flex; align-items: center; gap: 4px; color: #f59e0b;">
                                                <i class="fa-solid fa-star"></i> ${rating.toFixed(1)}
                                            </span>
                                            <span style="color: #e0e6ed;">•</span>
                                            <span class="v-card-meta-item" style="display: flex; align-items: center; gap: 4px; color: #5f6368;">
                                                <i class="fa-solid fa-fire"></i> ${downloads}
                                            </span>
                                        </div>

                                        <div class="v-card-author-row" style="padding: 8px 0; border-top: 1px solid #e0e6ed;">
                                            <div class="v-card-author">
                                                <div class="v-card-author-avatar" style="background: linear-gradient(135deg, #f59e0b, #ea580c); color: white; font-weight: 700;">${authorInitial}</div>
                                                <span style="font-size: 0.9rem; color: #202124; font-weight: 500;">${item.user || 'Vidyari'}</span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="v-card-footer">
                                        <div class="v-price ${isFree ? 'is-free' : ''}" style="font-weight: 700; font-size: 1.1rem;">${Utils.formatPrice(item.price)}</div>
                                        <div class="v-card-action-group">
                                            <button class="v-card-action-btn v-share-btn" data-share-link="${fullLink}" title="Copy Link" onclick="event.preventDefault(); EventManager.share('${fullLink}');">
                                                <i class="fa-solid fa-share-nodes"></i>
                                            </button>
                                            <div class="v-card-action-btn main"><i class="fa-solid fa-arrow-right"></i></div>
                                        </div>
                                    </div>
                                </a>
                            `;
                        }).join('');
                        
                        // Show the section
                        document.getElementById('vPopular').style.display = 'block';
                    } else {
                        document.getElementById('vPopular').style.display = 'none';
                    }
                } catch (error) {
                    document.getElementById('vPopular').style.display = 'none';
                }
            };

            // Load popular items after recommendations
            setTimeout(loadPopular, 1000);

        });
    </script>
</body>
</html>