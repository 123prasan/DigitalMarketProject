<%-include("header")%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vidyari | Find Your Edge</title>
    
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3321203820490717" crossorigin="anonymous"></script>
    <meta name="google-site-verification" content="Hcnu9BHn9udbxOrSebP2NCm4kTf0IwYg9mStgcwI0BU" />
    <link rel="icon" type="image/svg+xml" href="/images/logo.svg">
    <link rel="alternate icon" type="image/png" href="/images/logo.png">
    <link rel="manifest" href="/manifest.json">
    
    <meta property="og:title" content="Vidyari">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.vidyari.com/">
    <meta property="og:image" content="https://www.vidyari.com/images/logo.svg">
    <meta property="og:description" content="Vidyari - Study materials, courses, and resources for learners">
    <meta property="og:site_name" content="Vidyari">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Vidyari">
    <meta name="twitter:description" content="Vidyari - Study materials, courses, and resources for learners">
    <meta name="twitter:image" content="https://www.vidyari.com/images/logo.svg">
    
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Vidyari",
      "url": "https://www.vidyari.com",
      "logo": "https://www.vidyari.com/images/logo.svg"
    }
    </script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lexend:wght@400;600;800&display=swap" rel="stylesheet">

    <style>
        /* --- DESIGN TOKENS (Neo-Brutalist Theme) --- */
        :root {
            --font-heading: 'Lexend', sans-serif;
            --font-body: 'Inter', sans-serif;
            
            --clr-bg: #f8f9fa;
            --clr-white: #ffffff;
            --clr-black: #000000;
            --clr-gray-100: #f1f3f5;
            --clr-gray-200: #e9ecef;
            
            /* Accent Colors */
            --clr-primary: #00ff88;   /* Neon Green */
            --clr-secondary: #ff3399; /* Hot Pink */
            --clr-accent: #ffcc00;    /* Cyber Yellow */
            
            /* Structural Elements */
            --brdr-main: 2px solid #000000;
            --shdw-hard: 5px 5px 0px #000000;
            --shdw-hover: 2px 2px 0px #000000;
            
            --transit: 0.15s cubic-bezier(0.17, 0.67, 0.83, 0.67);
        }

        /* --- GLOBAL RESET --- */
        body {
            font-family: var(--font-body);
            background-color: var(--clr-bg);
            color: var(--clr-black);
            margin: 0; padding: 0;
            overflow-x: hidden;
            background-image: radial-gradient(#00000015 1.5px, transparent 0);
            background-size: 25px 25px;
        }

        * { box-sizing: border-box; border-radius: 0 !important; }

        h1, h2, h3, h4, h5 {
            font-family: var(--font-heading);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: -0.02em;
            color: var(--clr-black);
        }

        a { text-decoration: none; color: inherit; }

        /* --- APP LAYOUT --- */
        .app-wrapper {
            display: grid;
            grid-template-columns: 1fr;
            min-height: 100vh;
            max-width: 1600px;
            margin: 0 auto;
        }

        @media (min-width: 992px) {
            .app-wrapper {
                grid-template-columns: 280px 1fr;
                grid-template-areas: "sidebar main";
            }
        }

        /* --- SIDEBAR FILTERS (Desktop) --- */
        .sidebar {
            grid-area: sidebar;
            background: var(--clr-white);
            border-right: var(--brdr-main);
            padding: 2rem;
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            display: none; 
            z-index: 100;
        }

        @media (min-width: 992px) { .sidebar { display: block; } }

        .sidebar-header {
            border-bottom: 4px solid var(--clr-primary);
            margin-bottom: 1.5rem;
            padding-bottom: 0.5rem;
        }

        .filter-group {
            margin-bottom: 1.5rem;
            background: var(--clr-gray-100);
            border: var(--brdr-main);
            padding: 1rem;
            box-shadow: var(--shdw-hover);
        }

        .filter-label {
            font-family: var(--font-heading);
            font-size: 0.75rem;
            font-weight: 800;
            background: var(--clr-black);
            color: var(--clr-white);
            padding: 2px 6px;
            display: inline-block;
            margin-bottom: 0.8rem;
        }

        .form-control, .form-select {
            border: var(--brdr-main);
            font-weight: 600;
            font-size: 0.9rem;
            box-shadow: none !important;
        }

        .form-check-input {
            border: 2px solid var(--clr-black);
            cursor: pointer;
        }
        
        .form-check-input:checked {
            background-color: var(--clr-secondary);
            border-color: var(--clr-black);
        }

        /* --- MAIN CONTENT AREA --- */
        .main-content {
            grid-area: main;
            padding: 2rem;
            width: 100%;
        }

        /* --- SEARCH BAR --- */
        .search-container {
            margin-bottom: 2.5rem;
            position: relative;
        }

        .search-wrapper {
            display: flex;
            background: var(--clr-white);
            border: var(--brdr-main);
            box-shadow: var(--shdw-hard);
            transition: var(--transit);
        }

        .search-wrapper:focus-within {
            transform: translate(-2px, -2px);
            box-shadow: 8px 8px 0px var(--clr-secondary);
        }

        #inlineSearchInput {
            flex-grow: 1;
            border: none;
            padding: 1rem 1.5rem;
            font-size: 1.1rem;
            font-weight: 600;
            outline: none;
            background: transparent;
        }

        #searchSubmitBtn {
            background: var(--clr-primary);
            border: none;
            border-left: var(--brdr-main);
            padding: 0 2rem;
            font-size: 1.2rem;
            cursor: pointer;
            transition: var(--transit);
        }

        #searchSubmitBtn:hover { background: var(--clr-black); color: var(--clr-primary); }

        #inlineSuggestions {
            position: absolute;
            top: 100%; left: 0; right: 0;
            background: var(--clr-white);
            border: var(--brdr-main);
            z-index: 1000;
            display: none;
            max-height: 300px;
            overflow-y: auto;
        }
        #inlineSuggestions.is-open { display: block; }

        .suggestion-item {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--clr-gray-200);
            cursor: pointer;
            display: flex; align-items: center; gap: 10px;
        }
        .suggestion-item:hover { background: var(--clr-gray-100); }
        .suggestion-thumb { width: 30px; height: 30px; border: 1px solid #000; object-fit: cover; }

        /* --- FILE GRID --- */
        .file-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .file-card {
            background: var(--clr-white);
            border: var(--brdr-main);
            box-shadow: var(--shdw-hard);
            display: flex;
            flex-direction: column;
            transition: var(--transit);
            opacity: 0; /* For animation */
            position: relative;
        }

        .file-card:hover {
            transform: translate(-3px, -3px);
            box-shadow: 8px 8px 0px var(--clr-primary);
        }

        .card-preview {
            aspect-ratio: 3/4;
            background: var(--clr-gray-200);
            border-bottom: var(--brdr-main);
            position: relative;
            overflow: hidden;
        }

        .card-preview img {
            width: 100%; height: 100%;
            object-fit: cover;
            transition: transform 0.3s ease;
        }

        .file-card:hover .card-preview img { transform: scale(1.05); }

        .card-tag {
            position: absolute;
            top: 8px; left: 8px;
            background: var(--clr-black);
            color: var(--clr-white);
            font-size: 0.7rem;
            font-weight: 700;
            padding: 2px 6px;
            z-index: 2;
        }

        .card-body {
            padding: 1rem;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
            justify-content: space-between;
        }

        .card-title {
            font-family: var(--font-body);
            font-weight: 700;
            font-size: 0.95rem;
            margin-bottom: 0.5rem;
            line-height: 1.3;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .card-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 0.5rem;
        }

        .price-badge {
            font-weight: 800;
            font-size: 0.8rem;
            padding: 2px 8px;
            border: 2px solid var(--clr-black);
            text-transform: uppercase;
        }
        .price-free { background: var(--clr-primary); }
        .price-paid { background: var(--clr-accent); }

        /* --- BUTTONS --- */
        .btn-neo {
            font-family: var(--font-heading);
            font-weight: 800;
            text-transform: uppercase;
            padding: 10px 20px;
            border: var(--brdr-main);
            background: var(--clr-white);
            box-shadow: var(--shdw-hover);
            transition: var(--transit);
            cursor: pointer;
            display: inline-block;
            text-align: center;
        }
        .btn-neo:hover { transform: translate(-2px, -2px); box-shadow: 4px 4px 0px var(--clr-black); }
        .btn-neo:active { transform: translate(2px, 2px); box-shadow: none; }
        .btn-neo-primary { background: var(--clr-primary); }
        .btn-neo-dark { background: var(--clr-black); color: var(--clr-white); }

        /* --- MOBILE MODAL --- */
        .filter-modal-overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(4px);
            z-index: 2000;
            display: none;
            justify-content: center;
            align-items: center;
        }
        .filter-modal-overlay.is-open { display: flex; }
        
        .filter-modal-content {
            background: var(--clr-white);
            width: 90%; max-width: 400px;
            border: var(--brdr-main);
            box-shadow: 10px 10px 0px var(--clr-secondary);
            max-height: 85vh;
            display: flex; flex-direction: column;
        }
        .filter-modal-header { padding: 1rem; border-bottom: var(--brdr-main); display: flex; justify-content: space-between; align-items: center; }
        .filter-modal-body { padding: 1.5rem; overflow-y: auto; }
        .filter-modal-footer { padding: 1rem; border-top: var(--brdr-main); display: flex; gap: 1rem; }

        /* --- NOTIFICATION MODAL --- */
        .notification-content {
            border: var(--brdr-main) !important;
            box-shadow: 8px 8px 0px var(--clr-black) !important;
            border-radius: 0 !important;
        }
        .notify-gif-wrapper {
            width: 80px; height: 80px; margin: 0 auto 1rem;
            border: 2px solid #000; overflow: hidden;
        }
        .notify-gif-wrapper img { width: 100%; height: 100%; object-fit: cover; }

        /* --- UTILS --- */
        @keyframes slideUp { to { opacity: 1; transform: translateY(0); } }
        .stagger-in { animation: slideUp 0.4s ease forwards; }
        .pagination-container { display: flex; justify-content: center; gap: 0.5rem; margin-top: 3rem; }
    </style>
</head>
<body>

    <div class="app-wrapper">
        
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>Filters</h2>
            </div>

            <div class="filter-group">
                <span class="filter-label">Sort By</span>
                <select class="form-select" id="sortBySidebar">
                    <option value="popular">Popularity</option>
                    <option value="newest">Newest</option>
                    <option value="price-asc">Price: Low to High</option>
                    <option value="price-desc">Price: High to Low</option>
                </select>
            </div>

            <div class="filter-group">
                <span class="filter-label">Pricing</span>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="priceFreeOnlySidebar">
                    <label class="form-check-label" for="priceFreeOnlySidebar">Free Only</label>
                </div>
                <div class="d-flex gap-2">
                    <input type="number" id="minPriceSidebar" class="form-control" placeholder="Min ₹">
                    <input type="number" id="maxPriceSidebar" class="form-control" placeholder="Max ₹">
                </div>
            </div>

            <div class="filter-group">
                <span class="filter-label">Category</span>
                <div id="categoryFiltersSidebar" style="max-height: 200px; overflow-y: auto;">
                    <p class="text-muted small">Loading...</p>
                </div>
            </div>

            <div class="filter-group">
                <span class="filter-label">File Type</span>
                <div id="fileTypeFiltersSidebar" style="max-height: 150px; overflow-y: auto;">
                    <p class="text-muted small">Loading...</p>
                </div>
            </div>

            <button class="btn-neo btn-neo-primary w-100 mb-2" id="applyFiltersBtnSidebar">APPLY FILTERS</button>
            <button class="btn-neo w-100" id="clearFiltersBtnSidebar">RESET ALL</button>
        </aside>

        <main class="main-content">
            
            <section class="search-container">
                <div class="search-wrapper">
                    <input type="text" id="inlineSearchInput" placeholder="Search for notes, papers, authors..." autocomplete="off">
                    <button id="searchSubmitBtn"><i class="fas fa-search"></i></button>
                </div>
                <div id="inlineSuggestions"></div>
            </section>

            <div class="d-flex justify-content-between align-items-end mb-4">
                <div>
                    <h1 id="grid-main-title" style="font-size: 2.5rem; margin-bottom: 0;">Library</h1>
                    <p id="resultsCounter" class="text-muted fw-bold mb-0">Loading resources...</p>
                </div>
                <button class="btn-neo d-lg-none" id="openFilterModalBtnMobile">
                    <i class="fas fa-sliders me-2"></i> Filter <span id="filterCountBadgeMobile" class="badge bg-dark ms-1" style="display:none;">0</span>
                </button>
            </div>

            <div class="file-grid" id="fileGrid">
                </div>

            <div id="loadingIndicator" class="text-center py-5" style="display: none;">
                <h3 style="font-family: monospace;">LOADING_DATA...</h3>
            </div>
            <div id="noResultsBlock" class="text-center py-5" style="display: none;">
                <h3 style="color: var(--clr-secondary);">NO RESULTS FOUND</h3>
                <p>Try adjusting your search or filters.</p>
            </div>

            <div id="pagination-controls" class="pagination-container"></div>

        </main>
    </div>

    <div class="filter-modal-overlay" id="filterModal">
        <div class="filter-modal-content">
            <div class="filter-modal-header">
                <h3 class="m-0">Filters</h3>
                <button type="button" class="btn-close" id="closeFilterModalBtn"></button>
            </div>
            <div class="filter-modal-body">
                <div class="mb-4">
                    <label class="filter-label">Sort</label>
                    <select class="form-select" id="sortByMobile">
                        <option value="popular">Popularity</option>
                        <option value="newest">Newest</option>
                        <option value="price-asc">Price: Low to High</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="filter-label">Price</label>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="priceFreeOnlyMobile">
                        <label class="form-check-label">Free Only</label>
                    </div>
                    <div class="d-flex gap-2">
                        <input type="number" id="minPriceMobile" class="form-control" placeholder="Min">
                        <input type="number" id="maxPriceMobile" class="form-control" placeholder="Max">
                    </div>
                </div>
                <div class="mb-4">
                    <label class="filter-label">Categories</label>
                    <div id="categoryFiltersMobile"></div>
                </div>
            </div>
            <div class="filter-modal-footer">
                <button class="btn-neo w-50" id="clearFiltersBtnMobile">Reset</button>
                <button class="btn-neo btn-neo-primary w-50" id="applyFiltersBtnMobile">Apply</button>
            </div>
        </div>
    </div>

    <% if(isLoggedin) { %>
    <div id="notifyModal" class="modal fade" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content notification-content">
                <div class="modal-header border-0 justify-content-center p-4">
                    <div class="notify-gif-wrapper">
                        <img src="/kiss.gif" alt="Notification">
                    </div>
                </div>
                <div class="modal-body text-center pt-0">
                    <h5 class="mb-3">Get <span style="color: var(--clr-secondary);">Real-Time</span> Updates!</h5>
                    <p class="small text-muted">Don't miss out on new uploads and exclusive notes.</p>
                </div>
                <div class="modal-footer border-0 justify-content-center pb-4">
                    <button type="button" id="allowNotifications" class="btn-neo btn-neo-primary w-100 mb-2">
                        YES, NOTIFY ME!
                    </button>
                    <button type="button" class="btn btn-link text-muted text-decoration-none small" data-bs-dismiss="modal">
                        Maybe later
                    </button>
                </div>
            </div>
        </div>
    </div>
    <% } %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // --- STATE MANAGEMENT ---
            const state = {
                page: 1,
                limit: 50,
                totalPages: 1,
                filters: {
                    search: '',
                    sort: 'popular',
                    minPrice: null, maxPrice: null, isFree: false,
                    categories: [], fileTypes: []
                }
            };

            // --- DOM ELEMENTS ---
            const ui = {
                grid: document.getElementById('fileGrid'),
                loader: document.getElementById('loadingIndicator'),
                noResults: document.getElementById('noResultsBlock'),
                counter: document.getElementById('resultsCounter'),
                pagination: document.getElementById('pagination-controls'),
                searchInput: document.getElementById('inlineSearchInput'),
                suggestions: document.getElementById('inlineSuggestions'),
                
                // Desktop Filters
                sidebarApply: document.getElementById('applyFiltersBtnSidebar'),
                sidebarClear: document.getElementById('clearFiltersBtnSidebar'),
                
                // Mobile Filters
                mobileModal: document.getElementById('filterModal'),
                mobileOpenBtn: document.getElementById('openFilterModalBtnMobile'),
                mobileCloseBtn: document.getElementById('closeFilterModalBtn'),
                mobileApply: document.getElementById('applyFiltersBtnMobile'),
                mobileClear: document.getElementById('clearFiltersBtnMobile')
            };

            // --- HELPER: Slugify ---
            const slugify = (text) => text ? text.toString().toLowerCase().trim().replace(/\s+/g, '-').replace(/[^\w\-]+/g, '') : 'file';

            // --- HELPER: Create Card HTML ---
            const createCard = (file, index) => {
                const isFree = file.price === 0;
                const wrapper = document.createElement('div');
                wrapper.innerHTML = `
                    <a href="/file/${file.slug || slugify(file.filename)}/${file._id}" class="file-card" style="animation-delay: ${index * 50}ms">
                        <div class="card-preview">
                            <span class="card-tag">${file.category || 'General'}</span>
                            <img src="${file.previewUrl || './images/File_Demo.svg'}" loading="lazy" onerror="this.src='./images/File_Demo.svg'">
                        </div>
                        <div class="card-body">
                            <h3 class="card-title" title="${file.filename}">${file.filename}</h3>
                            <div class="card-meta">
                                <span class="price-badge ${isFree ? 'price-free' : 'price-paid'}">
                                    ${isFree ? 'FREE' : '₹' + file.price}
                                </span>
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </div>
                    </a>
                `;
                const card = wrapper.firstElementChild;
                card.classList.add('stagger-in');
                return card;
            };

            // --- FETCH DATA ---
            const fetchData = async (isInit = false) => {
                ui.loader.style.display = 'block';
                ui.grid.style.opacity = '0.5';
                ui.noResults.style.display = 'none';

                const params = new URLSearchParams({
                    page: state.page,
                    limit: state.limit,
                    search: state.filters.search,
                    sort: state.filters.sort,
                });

                if(state.filters.isFree) params.append('price', 'free');
                else {
                    if(state.filters.minPrice) params.append('minPrice', state.filters.minPrice);
                    if(state.filters.maxPrice) params.append('maxPrice', state.filters.maxPrice);
                }
                state.filters.categories.forEach(c => params.append('category', c));
                state.filters.fileTypes.forEach(t => params.append('fileType', t));

                try {
                    const res = await fetch(`/files?${params.toString()}`);
                    const data = await res.json();

                    ui.loader.style.display = 'none';
                    ui.grid.style.opacity = '1';
                    ui.grid.innerHTML = '';

                    // Initialize Filters on first load
                    if(isInit) {
                        populateFilters(data.allCategories || [], data.allFileTypes || []);
                    }

                    if(!data.files || data.files.length === 0) {
                        ui.noResults.style.display = 'block';
                        ui.counter.textContent = '0 Results';
                        return;
                    }

                    data.files.forEach((file, idx) => {
                        ui.grid.appendChild(createCard(file, idx));
                    });

                    ui.counter.textContent = `Showing ${data.files.length} of ${data.totalFiles} docs`;
                    state.totalPages = data.totalPages || 1;
                    renderPagination();

                } catch (err) {
                    console.error(err);
                    ui.loader.style.display = 'none';
                }
            };

            // --- RENDER FILTERS ---
            const populateFilters = (cats, types) => {
                const renderChecks = (items, prefix, containerId) => {
                    const html = items.map(item => `
                        <div class="form-check">
                            <input class="form-check-input ${prefix}-cb" type="checkbox" value="${item}" id="${prefix}-${item.replace(/\s+/g, '')}">
                            <label class="form-check-label" for="${prefix}-${item.replace(/\s+/g, '')}">${item}</label>
                        </div>
                    `).join('');
                    
                    // Desktop
                    const desktopCont = document.getElementById(containerId + 'Sidebar');
                    if(desktopCont) desktopCont.innerHTML = html;
                    
                    // Mobile
                    const mobileCont = document.getElementById(containerId + 'Mobile');
                    if(mobileCont) mobileCont.innerHTML = html;
                };

                renderChecks(cats, 'cat', 'categoryFilters');
                renderChecks(types, 'type', 'fileTypeFilters');
            };

            // --- FILTER LOGIC ---
            const getFilterValues = (suffix) => {
                const sort = document.getElementById('sortBy' + suffix).value;
                const free = document.getElementById('priceFreeOnly' + suffix).checked;
                const min = document.getElementById('minPrice' + suffix).value;
                const max = document.getElementById('maxPrice' + suffix).value;
                
                // Get checked categories (shared class logic needs adjustment for suffix specific selection)
                const catChecks = document.querySelectorAll(`#categoryFilters${suffix} input:checked`);
                const typeChecks = document.querySelectorAll(`#fileTypeFilters${suffix} input:checked`);

                state.filters.sort = sort;
                state.filters.isFree = free;
                state.filters.minPrice = min;
                state.filters.maxPrice = max;
                state.filters.categories = Array.from(catChecks).map(c => c.value);
                state.filters.fileTypes = Array.from(typeChecks).map(t => t.value);
                
                state.page = 1;
                fetchData();
            };

            const clearAllFilters = (suffix) => {
                document.getElementById('sortBy' + suffix).value = 'popular';
                document.getElementById('priceFreeOnly' + suffix).checked = false;
                document.getElementById('minPrice' + suffix).value = '';
                document.getElementById('maxPrice' + suffix).value = '';
                document.querySelectorAll(`#categoryFilters${suffix} input`).forEach(i => i.checked = false);
                
                state.filters = { search: state.filters.search, sort: 'popular', minPrice: null, maxPrice: null, isFree: false, categories: [], fileTypes: [] };
                fetchData();
            };

            // --- EVENT LISTENERS ---
            ui.sidebarApply.addEventListener('click', () => getFilterValues('Sidebar'));
            ui.sidebarClear.addEventListener('click', () => clearAllFilters('Sidebar'));
            
            ui.mobileApply.addEventListener('click', () => {
                getFilterValues('Mobile');
                ui.mobileModal.classList.remove('is-open');
            });
            ui.mobileClear.addEventListener('click', () => clearAllFilters('Mobile'));
            ui.mobileOpenBtn.addEventListener('click', () => ui.mobileModal.classList.add('is-open'));
            ui.mobileCloseBtn.addEventListener('click', () => ui.mobileModal.classList.remove('is-open'));

            // Search with Debounce
            let debounceTimer;
            ui.searchInput.addEventListener('input', (e) => {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(() => {
                    state.filters.search = e.target.value.trim();
                    state.page = 1;
                    fetchData();
                }, 400);
            });

            // Pagination Render
            const renderPagination = () => {
                ui.pagination.innerHTML = '';
                if(state.totalPages <= 1) return;
                
                // Simple Prev/Next logic
                const createBtn = (text, page, disabled) => {
                    const btn = document.createElement('button');
                    btn.className = 'btn-neo btn-sm mx-1';
                    btn.textContent = text;
                    btn.disabled = disabled;
                    if(page === state.page) btn.classList.add('btn-neo-primary');
                    btn.onclick = () => { state.page = page; fetchData(); window.scrollTo(0,0); };
                    return btn;
                };

                if(state.page > 1) ui.pagination.appendChild(createBtn('Prev', state.page - 1, false));
                ui.pagination.appendChild(createBtn(state.page, state.page, true)); // Current Page
                if(state.page < state.totalPages) ui.pagination.appendChild(createBtn('Next', state.page + 1, false));
            };

            // Init
            fetchData(true);
        });
    </script>

