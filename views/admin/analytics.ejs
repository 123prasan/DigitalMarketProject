                    <h2 class="card-title text-red-600"><i class="fa-solid fa-shield-virus"></i> Refund Risk Queue</h2>
                    <span class="badge badge-warn">Action Required</span>
                </div>
                <div class="flex flex-col gap-3 mt-2" id="risk-queue-container">
                    <p class="text-xs font-mono text-gray-500">Analyzing recent transactions...</p>
                </div>
            </div>

            <div class="bento-card col-span-12 lg:col-span-4" style="grid-column: span 12;">
                <div class="card-header">
                    <h2 class="card-title"><i class="fa-solid fa-boxes-stacked text-indigo-500"></i> Affinity Engine</h2>
                    <span class="badge badge-ai">Bundle AI</span>
                </div>
                <div class="flex-grow flex flex-col justify-center gap-4 mt-2" id="affinity-container">
                     <p class="text-xs font-mono text-gray-500">Analyzing co-purchasing data...</p>
                </div>
            </div>

        </div>
    </main>

    <script>
        document.addEventListener("DOMContentLoaded", async () => {
            Chart.defaults.font.family = "'JetBrains Mono', monospace";
            Chart.defaults.color = '#64748b';

            try {
                // Fetch real data from the backend route
                const response = await fetch('/api/creator/deep-analytics');
                const data = await response.json();

                if (data.success) {
                    
                    // --- 1. Populate Revenue KPI ---
                    const revEl = document.getElementById('stat-revenue');
                    if (revEl) revEl.textContent = `₹${data.kpis.revenue.toLocaleString('en-IN')}`;
                    
                    const trendEl = document.getElementById('stat-trend');
                    if (trendEl && data.kpis.velocityTrend > 0) {
                        trendEl.innerHTML = `<i class="fa-solid fa-arrow-trend-up"></i> ${data.kpis.velocityTrend}%`;
                    }

                    // --- 2. Populate Elasticity Card ---
                    if (data.elasticity.name !== "No Data") {
                        document.getElementById('elast-product-name').textContent = `Optimal price for "${data.elasticity.name.substring(0,20)}..."`;
                        document.getElementById('elast-suggested-price').textContent = `₹${data.elasticity.suggestedPrice}`;
                        document.getElementById('elast-current-price').textContent = `Current: ₹${data.elasticity.currentPrice}`;
                        
                        const ctxElast = document.getElementById('elasticityChart').getContext('2d');
                        const base = data.elasticity.currentPrice;
                        const prices = [`₹${Math.round(base*0.5)}`, `₹${Math.round(base*0.8)}`, `₹${base}`, `₹${data.elasticity.suggestedPrice}`, `₹${Math.round(base*1.5)}`, `₹${Math.round(base*2)}`];
                        const yieldData = [5000, 12000, 18000, 24000, 16000, 8000];

                        new Chart(ctxElast, {
                            type: 'line',
                            data: {
                                labels: prices,
                                datasets: [{
                                    data: yieldData, borderColor: '#a855f7', borderWidth: 2, tension: 0.4,
                                    pointRadius: [0,0,0, 6, 0,0], pointBackgroundColor: '#fff', pointBorderColor: '#a855f7', pointBorderWidth: 2
                                }]
                            },
                            options: {
                                responsive: true, maintainAspectRatio: false,
                                plugins: { legend: { display: false }, tooltip: { enabled: false } },
                                scales: { x: { grid: { display: false }, ticks: { font: { size: 9 }, color: '#94a3b8' } }, y: { display: false } },
                                layout: { padding: { top: 10 } }
                            }
                        });
                    }

                    // --- 3. Render Velocity Chart ---
                    const ctxVel = document.getElementById('velocityChart').getContext('2d');
                    const gradient = ctxVel.createLinearGradient(0, 0, 0, 250);
                    gradient.addColorStop(0, 'rgba(59, 130, 246, 0.15)');
                    gradient.addColorStop(1, 'rgba(59, 130, 246, 0)');

                    new Chart(ctxVel, {
                        type: 'line',
                        data: {
                            labels: data.velocityChart.labels,
                            datasets: [{
                                label: 'Actual Revenue',
                                data: data.velocityChart.actual,
                                borderColor: '#3b82f6', backgroundColor: gradient, borderWidth: 2, fill: true, tension: 0.4, pointRadius: 0, pointHoverRadius: 4
                            }, {
                                label: 'AI Prediction',
                                data: data.velocityChart.predicted,
                                borderColor: '#8b5cf6', borderDash: [4, 4], borderWidth: 2, fill: false, tension: 0.4, pointRadius: 0, pointHoverRadius: 4
                            }]
                        },
                        options: {
                            responsive: true, maintainAspectRatio: false,
                            interaction: { mode: 'index', intersect: false },
                            plugins: { 
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: '#0f172a', titleFont: { size: 11 }, bodyFont: { size: 12, weight: 'bold' },
                                    padding: 10, cornerRadius: 6,
                                    callbacks: { label: context => '₹' + context.parsed.y + 'k' }
                                }
                            },
                            scales: {
                                x: { grid: { display: false }, ticks: { font: { size: 9 } } },
                                y: { grid: { color: '#f1f5f9', borderDash: [4, 4] }, ticks: { font: { size: 9 }, callback: value => '₹' + value + 'k' }, border: { display: false } }
                            }
                        }
                    });

                    // --- 4. Populate Risk Queue ---
                    const riskContainer = document.getElementById('risk-queue-container');
                    if (riskContainer && data.risks.length > 0) {
                        riskContainer.innerHTML = data.risks.map(risk => `
                            <div class="bg-white border border-red-200 p-3 rounded-lg shadow-sm flex items-center justify-between mb-2">
                                <div>
                                    <p class="text-xs font-bold text-gray-800 truncate w-32">${risk.product}</p>
                                    <p class="text-[10px] text-gray-600 mt-1"><strong>Cause:</strong> ${risk.cause}</p>
                                </div>
                                <div class="flex flex-col items-end gap-2">
                                    <span class="text-[10px] font-mono font-bold text-red-500 bg-red-50 px-2 py-0.5 rounded border border-red-100">${risk.riskPercentage}% Risk</span>
                                    <button class="px-3 py-1 bg-white border border-gray-300 text-[10px] font-bold rounded hover:bg-gray-50">Investigate</button>
                                </div>
                            </div>
                        `).join('');
                    } else if (riskContainer) {
                        riskContainer.innerHTML = `<p class="text-xs text-gray-500 mt-2 font-mono">No high-risk transactions detected.</p>`;
                    }

                    // --- 5. Populate Affinity Engine ---
                    const affinityContainer = document.getElementById('affinity-container');
                    if (affinityContainer && data.affinity.length > 0) {
                        let html = `<div class="grid grid-cols-1 md:grid-cols-2 gap-4">`;
                        
                        html += data.affinity.map(aff => `
                            <div class="border border-gray-100 p-3 rounded-lg hover:bg-gray-50 transition-colors">
                                <div class="flex justify-between items-center text-[10px] font-bold text-gray-700 mb-2">
                                    <span class="truncate w-1/3">${aff.product1}</span> <i class="fa-solid fa-plus text-gray-300"></i> <span class="truncate w-1/3 text-right">${aff.product2}</span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <div class="flex-grow h-1.5 bg-gray-100 rounded-full overflow-hidden"><div class="h-full bg-indigo-500" style="width: ${aff.matchScore}%;"></div></div>
                                    <span class="font-mono text-[10px] font-bold text-gray-500">${aff.matchScore}% Match</span>
                                </div>
                            </div>
                        `).join('');
                        
                        html += `</div><button class="w-48 py-2 mt-4 self-center bg-black text-white text-[10px] font-bold font-mono uppercase tracking-widest rounded hover:bg-gray-800 transition-colors">Generate Bundle Links</button>`;
                        affinityContainer.innerHTML = html;
                    } else if (affinityContainer) {
                        affinityContainer.innerHTML = `<p class="text-xs text-gray-500 mt-2 font-mono">Insufficient data to generate bundles.</p>`;
                    }

                    // --- 6. Live Terminal Simulator ---
                    const terminal = document.getElementById('terminal-feed');
                    let eventIndex = 0;
                    terminal.innerHTML = '<div class="absolute bottom-0 left-0 w-full h-8 bg-gradient-to-t from-[#09090b] to-transparent z-10"></div>';

                    if (data.terminal && data.terminal.length > 0) {
                        setInterval(() => {
                            const event = data.terminal[eventIndex % data.terminal.length];
                            const newDiv = document.createElement('div');
                            newDiv.className = event.wrapper || 'text-gray-400';
                            newDiv.innerHTML = `<span class="${event.color}">[${event.type}]</span> ${event.msg}`;
                            
                            terminal.insertBefore(newDiv, terminal.children[1]); 
                            if(terminal.children.length > 6) { terminal.removeChild(terminal.lastChild); }
                            eventIndex++;
                        }, 2800);
                    }

                }
            } catch (err) {
                console.error("Failed to fetch analytics:", err);
            }

            // ----------------------------------------------------
            // Static UI Elements (Heatmap & Device Chart)
            // ----------------------------------------------------
            const heatmapGrid = document.getElementById('hourly-heatmap');
            if (heatmapGrid) {
                for(let i=0; i<49; i++) {
                    const block = document.createElement('div');
                    block.className = 'heatmap-cell';
                    let heatLevel = Math.floor(Math.random() * 3); 
                    if (i === 37 || i === 38) heatLevel = 5; 
                    if (i === 30 || i === 44) heatLevel = 4;
                    block.classList.add(`heat-${heatLevel}`);
                    heatmapGrid.appendChild(block);
                }
            }

            const ctxDevice = document.getElementById('deviceChart');
            if (ctxDevice) {
                new Chart(ctxDevice.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Mobile', 'Desktop', 'Tablet'],
                        datasets: [{
                            data: [72, 21, 7],
                            backgroundColor: ['#3b82f6', '#34d399', '#cbd5e1'],
                            borderWidth: 0, hoverOffset: 4
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, cutout: '75%', animation: { animateRotate: true } }
                });
            }
        });
    </script>
</body>
</html>