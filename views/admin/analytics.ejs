                                <td style="background: rgba(16, 185, 129, 0.5);">55%</td>
                                <td style="background: rgba(16, 185, 129, 0.3);">31%</td>
                                <td style="background: rgba(16, 185, 129, 0.2);">22%</td>
                                <td style="background: rgba(16, 185, 129, 0.1);">14%</td>
