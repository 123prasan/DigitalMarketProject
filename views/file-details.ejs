<%- include("header") %>
<!DOCTYPE html>
<html lang="en" class="scroll-smooth" data-file-id="<%= file._id %>" data-user-id="<%= uId || '' %>">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover" />

    <title>
        <% if(file.price == 0) { %>
            <%= file.filename || 'Download' %> | Free on Vidyari
        <% } else { %>
            <%= file.filename || 'Checkout' %> | Secure Purchase | Vidyari
        <% } %>
    </title>

    <meta name="description" content="Download '<%= file.filename %>' on Vidyari. <%= priceDetails.total == 0 ? 'Free access' : '₹' + priceDetails.total %> — Verified creator, 4.8★ rating.">
    <meta property="og:type" content="product">
    <meta property="og:title" content="<%= file.filename %> | Download on Vidyari">
    <meta property="og:image" content="<%= previewUrl || 'https://vidyari.com/images/logo-1200x630.png' %>">
    <meta property="og:url" content="https://vidyari.com/file/<%= file.slug %>/<%= file._id %>">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="canonical" href="https://vidyari.com/file/<%= file.slug %>/<%= file._id %>">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "Product",
      "name": "<%- (file.filename || 'Digital Resource').replace(/"/g, '&quot;') %>",
      "image": ["<%= previewUrl || 'https://vidyari.com/images/logo.png' %>"],
      "description": "<%- (file.filedescription || 'Premium educational resource').substring(0, 160).replace(/"/g, '&quot;') %>",
      "offers": {
        "@type": "Offer",
        "priceCurrency": "INR",
        "price": "<%= priceDetails.total %>",
        "availability": "https://schema.org/InStock"
      }
    }
    </script>

    <link rel="icon" href="/images/logo.svg" type="image/svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3321203820490717" crossorigin="anonymous"></script>

    <style>
        /* ============================================================
           VIDYARI FILE CHECKOUT — LUXURY EDITORIAL WHITE THEME
           ============================================================ */
        :root {
            --ink:        #0e0f11;
            --ink-2:      #3a3d44;
            --ink-3:      #7a7e8a;
            --ink-4:      #b4b8c4;
            --rule:       #e8eaee;
            --rule-light: #f4f5f7;
            --surface:    #ffffff;
            --bg:         #f9fafb;
            --accent:     #1a56f0;
            --accent-2:   #f0f4ff;
            --accent-ink: #0d37b8;
            --green:      #0b7a45;
            --green-bg:   #edfaf3;
            --amber:      #e8811f;
            --amber-bg:   #fef6ee;

            --serif:  'DM Serif Display', Georgia, serif;
            --sans:   'DM Sans', system-ui, sans-serif;

            --r-sm:   8px;
            --r-md:   14px;
            --r-lg:   20px;
            --r-xl:   28px;
            --r-pill: 9999px;

            --shadow-xs:    0 1px 2px rgba(14,15,17,0.05);
            --shadow-sm:    0 2px 8px rgba(14,15,17,0.07);
            --shadow-md:    0 6px 20px rgba(14,15,17,0.08);
            --shadow-card:  0 0 0 1px rgba(14,15,17,0.06), 0 4px 16px rgba(14,15,17,0.06);
            --shadow-float: 0 0 0 1px rgba(14,15,17,0.06), 0 20px 48px rgba(14,15,17,0.1);
            --ease-out:     cubic-bezier(0.22, 1, 0.36, 1);
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; min-width: 0; }
        html { -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }
        body {
            font-family: var(--sans);
            background: var(--bg);
            color: var(--ink);
            overflow-x: hidden;
        }

        /* ── LAYOUT ── */
        .page-wrap {
            max-width: 1380px;
            margin: 0 auto;
            padding: 0 clamp(16px, 3vw, 40px);
        }

        .back-btn {
            display: inline-flex; align-items: center; gap: 8px;
            font-size: 0.875rem; font-weight: 500;
            color: var(--ink-3); text-decoration: none;
            padding: 9px 16px;
            background: var(--surface); border: 1px solid var(--rule);
            border-radius: var(--r-pill); margin: 24px 0;
            transition: all 0.2s var(--ease-out);
            box-shadow: var(--shadow-xs);
        }
        .back-btn:hover { color: var(--accent); border-color: rgba(26,86,240,0.3); transform: translateX(-3px); }

        .main-grid {
            display: grid;
            grid-template-columns: 1fr 352px;
            gap: 28px;
            padding-bottom: 100px;
            align-items: start;
        }

        /* ── LEFT COLUMN ── */
        .left-col { display: flex; flex-direction: column; gap: 20px; }

        /* ── HERO / TITLE AREA ── */
        .file-hero {
            background: var(--surface);
            border: 1px solid var(--rule);
            border-radius: var(--r-xl);
            padding: 32px 36px;
            box-shadow: var(--shadow-card);
        }

        .file-category-pill {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 0.7rem; font-weight: 600;
            letter-spacing: 0.1em; text-transform: uppercase;
            color: var(--accent);
            background: var(--accent-2);
            border: 1px solid rgba(26,86,240,0.15);
            padding: 4px 12px; border-radius: var(--r-pill);
            margin-bottom: 16px;
        }

        .file-title {
            font-family: var(--serif);
            font-size: clamp(1.6rem, 3vw, 2.3rem);
            font-weight: 400; line-height: 1.15;
            color: var(--ink);
            margin-bottom: 20px;
            overflow-wrap: break-word;
        }

        .creator-card {
            display: inline-flex; align-items: center; gap: 11px;
            padding: 8px 16px 8px 8px;
            background: var(--rule-light);
            border: 1px solid var(--rule);
            border-radius: var(--r-pill);
            text-decoration: none; color: inherit;
            transition: all 0.2s var(--ease-out);
            max-width: 100%;
        }
        .creator-card:hover { border-color: rgba(26,86,240,0.25); background: var(--accent-2); transform: translateY(-1px); box-shadow: var(--shadow-sm); }
        .creator-avatar { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid var(--rule); flex-shrink: 0; }
        .creator-name { font-size: 0.9rem; font-weight: 600; color: var(--ink); display: flex; align-items: center; gap: 6px; }
        .creator-name img { width: 14px; flex-shrink: 0; }

        /* ── PREVIEW IMAGE ── */
        .preview-card {
            background: var(--surface);
            border: 1px solid var(--rule);
            border-radius: var(--r-xl);
            overflow: hidden;
            box-shadow: var(--shadow-card);
            position: relative;
            cursor: zoom-in;
        }
        .preview-card img {
            width: 100%; aspect-ratio: 16/10;
            object-fit: cover; display: block;
            transition: transform 0.5s var(--ease-out);
        }
        .preview-card:hover img { transform: scale(1.02); }
        .preview-zoom-hint {
            position: absolute; bottom: 16px; right: 16px;
            background: rgba(14,15,17,0.7);
            backdrop-filter: blur(8px);
            color: white; font-size: 0.75rem; font-weight: 500;
            padding: 6px 14px; border-radius: var(--r-pill);
            opacity: 0; transition: opacity 0.2s;
            display: flex; align-items: center; gap: 6px;
        }
        .preview-card:hover .preview-zoom-hint { opacity: 1; }

        /* ── CONTENT CARD ── */
        .content-card {
            background: var(--surface);
            border: 1px solid var(--rule);
            border-radius: var(--r-xl);
            padding: 28px 32px;
            box-shadow: var(--shadow-card);
        }
        .content-card-title {
            font-family: var(--serif);
            font-size: 1.25rem; font-weight: 400;
            color: var(--ink);
            margin-bottom: 18px;
            padding-bottom: 14px;
            border-bottom: 1px solid var(--rule-light);
            display: flex; align-items: center; gap: 10px;
        }
        .content-card-title i { color: var(--accent); font-size: 1rem; }
        .desc-text {
            font-size: 0.96rem; font-weight: 300;
            line-height: 1.75; color: var(--ink-2);
            overflow-wrap: break-word;
        }
        .desc-text p { margin-bottom: 14px; }
        .desc-text p:last-child { margin-bottom: 0; }
        .desc-text strong { color: var(--ink); font-weight: 600; }
        .desc-text img { max-width: 100% !important; height: auto !important; border-radius: var(--r-md); margin: 16px 0; }

        /* ── AD ZONE ── */
        .ad-zone {
            width: 100%; overflow: hidden;
            display: flex; justify-content: center;
            background: var(--rule-light);
            border: 1px dashed var(--rule);
            border-radius: var(--r-lg);
            min-height: 90px;
        }

        /* ── ENHANCED RELATED FILES ── */
        .related-section-premium {
            background: var(--surface) !important;
            margin-top: 40px !important;
            border: 1px solid var(--rule) !important;
            border-radius: var(--r-xl) !important;
            padding: 36px 32px !important;
            box-shadow: var(--shadow-sm);
        }
        
        .related-header {
            margin-bottom: 28px;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .related-title {
            font-family: var(--serif);
            font-size: 1.8rem;
            color: var(--ink);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .related-title i {
            font-size: 1.3rem;
            color: var(--accent);
        }

        .related-subtitle {
            font-size: 0.95rem;
            color: var(--ink-3);
            margin: 0;
        }

        .related-grid-container {
            display: flex;
            flex-direction: column;
            gap: 40px;
        }

        /* Group Author Label */
        .related-author-label {
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--ink-2);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .related-author-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--rule);
        }

        /* The Grid / Mobile Carousel */
        .related-author-section {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
        }

        /* The Card */
        .related-item {
            display: flex;
            flex-direction: column;
            text-decoration: none;
            background: var(--surface);
            border: 1px solid var(--rule);
            border-radius: var(--r-lg);
            overflow: hidden;
            transition: all 0.3s var(--ease-out);
            height: 100%;
        }

        .related-item:hover {
            transform: translateY(-6px);
            border-color: rgba(26,86,240,0.4);
            box-shadow: 0 12px 24px rgba(14,15,17,0.06);
        }

        .related-item-thumb {
            width: 100%;
            aspect-ratio: 16/10;
            background: var(--bg);
            position: relative;
            overflow: hidden;
            border-bottom: 1px solid var(--rule-light);
        }

        .related-item-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s var(--ease-out);
        }

        .related-item:hover .related-item-thumb img {
            transform: scale(1.05);
        }

        .related-item-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            font-size: 0.65rem;
            font-weight: 800;
            letter-spacing: 0.05em;
            padding: 5px 10px;
            border-radius: var(--r-pill);
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(4px);
            color: var(--ink);
            text-transform: uppercase;
            box-shadow: var(--shadow-xs);
            z-index: 2;
        }

        .related-item-badge.free {
            background: var(--green);
            color: white;
        }

        .related-item-content {
            padding: 16px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .related-item-name {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--ink);
            line-height: 1.4;
            margin-bottom: 6px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            min-height: 2.8em;
        }

        .related-item-author {
            font-size: 0.8rem;
            color: var(--ink-3);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .related-item-stats {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: auto;
            padding-top: 12px;
            border-top: 1px dashed var(--rule);
        }

        .related-item-price {
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--ink);
        }

        .related-item-price.free {
            color: var(--green);
        }

        .related-item-metrics {
            font-size: 0.75rem;
            color: var(--ink-3);
            display: flex;
            gap: 10px;
        }

        /* Skeleton Loader Animation */
        @keyframes pulse-shimmer {
            0% { background-color: var(--rule-light); }
            50% { background-color: var(--rule); }
            100% { background-color: var(--rule-light); }
        }
        .skeleton-card {
            border: 1px solid var(--rule);
            border-radius: var(--r-lg);
            height: 280px;
            animation: pulse-shimmer 1.5s infinite ease-in-out;
        }

        /* Mobile Adjustments (Swipeable Carousel) */
        @media (max-width: 768px) {
            .related-section-premium { padding: 24px 20px !important; }
            
            .related-author-section {
                display: flex;
                overflow-x: auto;
                scroll-snap-type: x mandatory;
                padding-bottom: 16px;
                scrollbar-width: none; /* Firefox */
                -webkit-overflow-scrolling: touch;
            }
            .related-author-section::-webkit-scrollbar { display: none; } /* Chrome/Safari */
            
            .related-item, .skeleton-card {
                flex: 0 0 240px;
                scroll-snap-align: start;
            }
        }

        /* ── REVIEWS ── */
        .rating-summary-block {
            display: flex; align-items: center; gap: 24px;
            padding: 20px 22px;
            background: var(--rule-light);
            border: 1px solid var(--rule);
            border-radius: var(--r-lg);
            margin-bottom: 20px;
        }
        .rating-num { font-family: var(--serif); font-size: 3.5rem; line-height: 1; color: var(--ink); }
        .rating-stars-row { color: var(--amber); font-size: 1rem; letter-spacing: 1px; margin-bottom: 4px; }
        .rating-count-label { font-size: 0.78rem; color: var(--ink-3); }

        .rating-dist { flex: 1; display: flex; flex-direction: column; gap: 6px; }
        .dist-row { display: flex; align-items: center; gap: 10px; font-size: 0.78rem; color: var(--ink-3); }
        .dist-label { width: 36px; text-align: right; flex-shrink: 0; }
        .dist-track { flex: 1; height: 6px; background: var(--rule); border-radius: 3px; overflow: hidden; }
        .dist-fill { height: 100%; background: var(--amber); border-radius: 3px; transition: width 0.6s var(--ease-out); }
        .dist-count { width: 24px; text-align: right; flex-shrink: 0; }

        .write-review-btn {
            display: inline-flex; align-items: center; gap: 8px;
            font-family: var(--sans); font-size: 0.875rem; font-weight: 600;
            color: var(--accent); background: var(--accent-2);
            border: 1.5px solid rgba(26,86,240,0.2);
            border-radius: var(--r-md); padding: 10px 20px;
            cursor: pointer; transition: all 0.2s var(--ease-out);
            margin-bottom: 20px;
        }
        .write-review-btn:hover { background: var(--accent); color: white; border-color: var(--accent); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(26,86,240,0.25); }

        .review-list { display: flex; flex-direction: column; gap: 12px; }
        .review-item {
            background: var(--surface); border: 1px solid var(--rule);
            border-radius: var(--r-lg); padding: 18px 20px;
            transition: box-shadow 0.2s;
        }
        .review-item:hover { box-shadow: var(--shadow-sm); }
        .review-item-head { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
        .review-initials {
            width: 36px; height: 36px; border-radius: 50%;
            background: var(--accent-2); color: var(--accent);
            font-size: 0.8rem; font-weight: 700;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; border: 1.5px solid rgba(26,86,240,0.15);
        }
        .review-user-name { font-size: 0.875rem; font-weight: 600; color: var(--ink); }
        .review-user-date { font-size: 0.74rem; color: var(--ink-4); margin-top: 1px; }
        .review-item-stars { color: var(--amber); font-size: 0.78rem; margin-left: auto; }
        .review-item-stars .empty { color: var(--rule); }
        .review-item-title { font-size: 0.875rem; font-weight: 600; color: var(--ink); margin-bottom: 5px; }
        .review-item-body { font-size: 0.84rem; color: var(--ink-2); line-height: 1.65; margin-bottom: 12px; }
        .review-helpful-row { display: flex; align-items: center; gap: 8px; }
        .helpful-btn {
            display: inline-flex; align-items: center; gap: 5px;
            font-size: 0.75rem; font-weight: 500; color: var(--ink-3);
            background: var(--rule-light); border: 1px solid var(--rule);
            border-radius: var(--r-pill); padding: 4px 12px;
            cursor: pointer; transition: all 0.15s; user-select: none;
        }
        .helpful-btn:hover, .helpful-btn.active { color: var(--accent); background: var(--accent-2); border-color: rgba(26,86,240,0.2); }
        .helpful-label { font-size: 0.74rem; color: var(--ink-4); margin-right: auto; }

        .no-reviews-state {
            text-align: center; padding: 40px 20px;
            background: var(--rule-light);
            border: 1px solid var(--rule);
            border-radius: var(--r-lg);
        }
        .no-reviews-state i { font-size: 2.5rem; color: var(--ink-4); margin-bottom: 12px; display: block; }
        .no-reviews-state p { font-size: 0.9rem; color: var(--ink-3); }

        /* ── SIDEBAR ── */
        .right-col { position: sticky; top: 24px; display: flex; flex-direction: column; gap: 14px; }

        /* Price card dark header */
        .checkout-card {
            background: var(--surface);
            border: 1px solid var(--rule);
            border-radius: var(--r-xl);
            overflow: hidden;
            box-shadow: var(--shadow-float);
        }

        .price-hero {
            background: linear-gradient(135deg, #0e0f11 0%, #1a2340 100%);
            padding: 22px 22px 18px;
            position: relative; overflow: hidden;
        }
        .price-hero::before {
            content: ''; position: absolute; top: -24px; right: -24px;
            width: 100px; height: 100px; border-radius: 50%;
            background: rgba(26,86,240,0.18); pointer-events: none;
        }
        .price-hero::after {
            content: ''; position: absolute; bottom: -16px; left: 16px;
            width: 64px; height: 64px; border-radius: 50%;
            background: rgba(26,86,240,0.08); pointer-events: none;
        }
        .price-thumb {
            width: 100%; aspect-ratio: 16/9;
            object-fit: cover; display: block;
            border-radius: var(--r-md);
            margin-bottom: 16px;
            border: 1px solid rgba(255,255,255,0.08);
        }
        .price-tag-row { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; margin-bottom: 4px; }
        .price-amount {
            font-family: var(--serif);
            font-size: 2.2rem; line-height: 1;
            color: white;
        }
        .price-amount.free { color: #6ee7b7; font-size: 1.7rem; }
        .price-original { font-size: 0.9rem; color: rgba(255,255,255,0.38); text-decoration: line-through; }
        .price-badge-pill {
            font-size: 0.68rem; font-weight: 700;
            letter-spacing: 0.06em; text-transform: uppercase;
            padding: 3px 9px; border-radius: var(--r-pill);
            background: rgba(110,231,183,0.15);
            color: #6ee7b7;
            border: 1px solid rgba(110,231,183,0.3);
        }
        .price-note { font-size: 0.72rem; color: rgba(255,255,255,0.45); margin-top: 5px; display: flex; align-items: center; gap: 5px; }
        .price-note i { color: #fbbf24; font-size: 0.65rem; }

        .checkout-body { padding: 20px 22px; }

        /* Invoice rows */
        .invoice-section { margin-bottom: 16px; }
        .invoice-row {
            display: flex; justify-content: space-between; align-items: center;
            font-size: 0.85rem; padding: 7px 0; color: var(--ink-3);
        }
        .invoice-row.total {
            border-top: 1px dashed var(--rule);
            margin-top: 10px; padding-top: 14px;
            color: var(--ink); font-weight: 700; font-size: 1.05rem;
        }
        .invoice-discount-row {
            display: flex; justify-content: space-between; align-items: center;
            font-size: 0.82rem; padding: 7px 10px; margin: 6px 0;
            background: var(--green-bg); color: var(--green);
            border-radius: var(--r-sm); font-weight: 500;
        }

        /* Coupon */
        .coupon-wrap {
            display: flex;
            border: 1.5px solid var(--rule);
            border-radius: var(--r-md);
            overflow: hidden; margin: 14px 0;
            transition: border-color 0.2s, box-shadow 0.2s;
            background: var(--rule-light);
        }
        .coupon-wrap:focus-within { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(26,86,240,0.1); }
        .coupon-input {
            flex: 1; border: none; padding: 10px 14px;
            font-family: var(--sans); font-size: 0.875rem;
            color: var(--ink); background: transparent; outline: none;
            text-transform: uppercase; font-weight: 500;
        }
        .coupon-input::placeholder { text-transform: none; color: var(--ink-4); font-weight: 400; }
        .coupon-apply-btn {
            background: transparent; border: none; border-left: 1.5px solid var(--rule);
            color: var(--accent); padding: 0 16px;
            font-family: var(--sans); font-size: 0.82rem; font-weight: 600;
            cursor: pointer; transition: background 0.15s; white-space: nowrap;
        }
        .coupon-apply-btn:hover { background: var(--accent-2); }

        /* CTA Button */
        .cta-btn {
            width: 100%; display: flex; align-items: center; justify-content: center; gap: 9px;
            font-family: var(--sans); font-size: 1rem; font-weight: 700;
            color: white; background: var(--accent);
            border: none; border-radius: var(--r-lg);
            padding: 15px; cursor: pointer; margin: 14px 0 10px;
            transition: all 0.25s var(--ease-out);
            box-shadow: 0 4px 20px rgba(26,86,240,0.35);
            position: relative; overflow: hidden;
            letter-spacing: 0.01em;
        }
        .cta-btn::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 60%);
            opacity: 0; transition: opacity 0.2s;
        }
        .cta-btn:hover { background: var(--accent-ink); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(26,86,240,0.4); }
        .cta-btn:hover::before { opacity: 1; }
        .cta-btn:active { transform: translateY(0); }
        .cta-btn:disabled { opacity: 0.65; cursor: not-allowed; transform: none; box-shadow: none; }
        .cta-btn.free-btn { background: var(--green); box-shadow: 0 4px 20px rgba(11,122,69,0.3); }
        .cta-btn.free-btn:hover { background: #096636; box-shadow: 0 8px 28px rgba(11,122,69,0.35); }

        .guarantee-row {
            display: flex; align-items: center; justify-content: center; gap: 6px;
            font-size: 0.76rem; color: var(--ink-3); margin-bottom: 16px;
        }
        .guarantee-row i { color: var(--green); }

        /* Action row */
        .action-row { display: flex; gap: 8px; margin-bottom: 16px; }
        .action-pill {
            flex: 1; display: flex; align-items: center; justify-content: center; gap: 7px;
            font-family: var(--sans); font-size: 0.82rem; font-weight: 500;
            color: var(--ink-2); background: var(--rule-light);
            border: 1px solid var(--rule); border-radius: var(--r-md);
            padding: 9px; cursor: pointer;
            transition: all 0.15s; user-select: none;
        }
        .action-pill:hover { background: var(--rule); color: var(--ink); }
        .action-pill.liked { color: var(--accent); background: var(--accent-2); border-color: rgba(26,86,240,0.2); }

        .divider { height: 1px; background: var(--rule-light); margin: 4px 0 16px; }

        /* Specs list */
        .specs-label {
            font-size: 0.7rem; font-weight: 700;
            letter-spacing: 0.1em; text-transform: uppercase;
            color: var(--ink-3); margin-bottom: 10px;
        }
        .specs-list { list-style: none; }
        .spec-row {
            display: flex; align-items: center; gap: 12px;
            padding: 9px 0; border-bottom: 1px solid var(--rule-light);
        }
        .spec-row:last-child { border-bottom: none; }
        .spec-icon-wrap {
            width: 36px; height: 36px; border-radius: var(--r-sm);
            background: var(--rule-light); border: 1px solid var(--rule);
            display: flex; align-items: center; justify-content: center;
            color: var(--ink-3); font-size: 0.85rem; flex-shrink: 0;
        }
        .spec-label { font-size: 0.74rem; color: var(--ink-3); }
        .spec-value { font-size: 0.875rem; font-weight: 600; color: var(--ink); margin-top: 1px; }

        /* Share card */
        .share-card {
            background: var(--surface); border: 1px solid var(--rule);
            border-radius: var(--r-lg); padding: 18px;
            box-shadow: var(--shadow-xs);
        }
        .share-label {
            font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em;
            text-transform: uppercase; color: var(--ink-3); margin-bottom: 10px;
        }
        .share-row { display: flex; gap: 7px; flex-wrap: wrap; }
        .share-pill {
            display: inline-flex; align-items: center; gap: 5px;
            font-size: 0.76rem; font-weight: 500;
            color: var(--ink-2); background: var(--rule-light);
            border: 1px solid var(--rule); border-radius: var(--r-pill);
            padding: 6px 13px; cursor: pointer; transition: all 0.15s;
            text-decoration: none;
        }
        .share-pill:hover { background: var(--rule); color: var(--ink); }

        /* ── MOBILE STICKY BAR ── */
        .mobile-cta-bar {
            display: none;
            position: fixed; bottom: 0; left: 0; right: 0;
            background: rgba(255,255,255,0.96);
            backdrop-filter: blur(16px);
            border-top: 1px solid var(--rule);
            padding: 12px 20px calc(12px + env(safe-area-inset-bottom));
            z-index: 800;
            box-shadow: 0 -4px 20px rgba(14,15,17,0.08);
        }
        .mobile-cta-inner { display: flex; align-items: center; gap: 14px; }
        .mobile-price {
            font-family: var(--serif); font-size: 1.35rem;
            color: var(--ink); white-space: nowrap;
        }
        .mobile-price.free { color: var(--green); }
        .mobile-enroll-btn {
            flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px;
            font-family: var(--sans); font-size: 0.95rem; font-weight: 700;
            color: white; background: var(--accent);
            border: none; border-radius: var(--r-md);
            padding: 13px; cursor: pointer;
            transition: all 0.2s var(--ease-out);
            box-shadow: 0 3px 12px rgba(26,86,240,0.3);
        }
        .mobile-enroll-btn.free-btn { background: var(--green); box-shadow: 0 3px 12px rgba(11,122,69,0.3); }
        .mobile-enroll-btn:hover { transform: translateY(-1px); }

        /* ── REVIEW MODAL ── */
        .modal-veil {
            position: fixed; inset: 0;
            background: rgba(14,15,17,0.5);
            backdrop-filter: blur(6px);
            display: none; align-items: center; justify-content: center;
            z-index: 9000;
        }
        .modal-veil.open { display: flex; animation: fadeVeil 0.25s ease; }
        @keyframes fadeVeil { from { opacity: 0; } to { opacity: 1; } }

        .review-modal {
            background: var(--surface); border-radius: var(--r-xl);
            padding: 32px 28px; width: 90%; max-width: 460px;
            box-shadow: var(--shadow-float);
            animation: modalPop 0.35s var(--ease-out);
        }
        @keyframes modalPop { from { opacity:0; transform: translateY(16px) scale(0.97); } to { opacity:1; transform: none; } }

        .modal-title { font-family: var(--serif); font-size: 1.3rem; color: var(--ink); margin-bottom: 6px; }
        .modal-sub { font-size: 0.85rem; color: var(--ink-3); margin-bottom: 22px; }

        /* Star picker in modal */
        .modal-stars {
            display: flex; justify-content: center; gap: 10px;
            flex-direction: row-reverse; margin-bottom: 22px;
        }
        .modal-stars input { display: none; }
        .modal-stars label {
            font-size: 2.2rem; color: var(--rule);
            cursor: pointer;
            transition: color 0.15s, transform 0.2s var(--ease-out);
        }
        .modal-stars label:hover { color: var(--amber); transform: scale(1.2); }
        .modal-stars label:hover ~ label { color: var(--amber); }
        .modal-stars input:checked ~ label { color: var(--amber); }

        .modal-input {
            width: 100%; padding: 10px 13px;
            font-family: var(--sans); font-size: 0.875rem; color: var(--ink);
            background: var(--rule-light); border: 1.5px solid var(--rule);
            border-radius: var(--r-md); outline: none; margin-bottom: 12px;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .modal-input::placeholder { color: var(--ink-4); }
        .modal-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(26,86,240,0.1); background: var(--surface); }
        textarea.modal-input { resize: vertical; min-height: 90px; }

        .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 8px; }
        .modal-cancel-btn {
            font-family: var(--sans); font-size: 0.875rem; font-weight: 500;
            color: var(--ink-2); background: var(--rule-light);
            border: 1px solid var(--rule); border-radius: var(--r-md);
            padding: 10px 20px; cursor: pointer; transition: all 0.15s;
        }
        .modal-cancel-btn:hover { background: var(--rule); }
        .modal-submit-btn {
            font-family: var(--sans); font-size: 0.875rem; font-weight: 700;
            color: white; background: var(--amber);
            border: none; border-radius: var(--r-md);
            padding: 10px 24px; cursor: pointer;
            transition: all 0.2s var(--ease-out);
            box-shadow: 0 3px 10px rgba(232,129,31,0.3);
        }
        .modal-submit-btn:hover:not(:disabled) { background: #c96c10; transform: translateY(-1px); }
        .modal-submit-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

        /* ── TOAST ── */
        #vToast {
            position: fixed; top: 24px; left: 50%;
            transform: translateX(-50%) translateY(-12px);
            background: var(--ink); color: white;
            padding: 12px 20px; border-radius: var(--r-pill);
            font-family: var(--sans); font-size: 0.875rem; font-weight: 500;
            display: flex; align-items: center; gap: 10px;
            box-shadow: var(--shadow-md);
            opacity: 0; visibility: hidden;
            transition: all 0.3s var(--ease-out);
            z-index: 9999; white-space: nowrap;
        }
        #vToast.show { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
        #vToast .toast-icon.success { color: #6ee7b7; }
        #vToast .toast-icon.error { color: #f87171; }

        /* ── IMAGE MODAL ── */
        .img-modal-veil {
            position: fixed; inset: 0;
            background: rgba(14,15,17,0.92);
            backdrop-filter: blur(10px);
            display: none; align-items: center; justify-content: center;
            z-index: 9100;
        }
        .img-modal-veil.open { display: flex; }
        .img-modal-veil img { max-width: 95vw; max-height: 90vh; object-fit: contain; border-radius: var(--r-lg); }
        .img-modal-close {
            position: absolute; top: 20px; right: 24px;
            width: 40px; height: 40px; border-radius: 50%;
            background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
            color: white; font-size: 1rem;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: background 0.15s;
        }
        .img-modal-close:hover { background: rgba(255,255,255,0.2); }

        /* ── RESPONSIVE ── */
        @media (max-width: 1024px) {
            .main-grid { grid-template-columns: 1fr; }
            .right-col { position: static; }
            .checkout-card { max-width: 520px; }
            .mobile-cta-bar { display: block; }
            .checkout-body .cta-btn,
            .checkout-body .guarantee-row { display: none; }
        }
        @media (max-width: 640px) {
            .file-hero, .content-card { padding: 20px 18px; }
            .rating-summary-block { flex-direction: column; align-items: flex-start; gap: 14px; }
        }
    </style>
</head>
<body>

<%
const formatBytes = (bytes, decimals=2) => {
    if (!+bytes) return 'N/A';
    const k=1024, dm=decimals<0?0:decimals, sizes=['B','KB','MB','GB','TB'];
    const i=Math.floor(Math.log(bytes)/Math.log(k));
    return parseFloat((bytes/Math.pow(k,i)).toFixed(dm))+' '+sizes[i];
};
const isFree = Number(priceDetails.total) === 0;
%>

<div class="page-wrap">
    <a href="/files" class="back-btn"><i class="fa-solid fa-arrow-left"></i> Back to Files</a>

    <div class="main-grid">

        <!-- ════════ LEFT COLUMN ════════ -->
        <div class="left-col">

            <!-- FILE HERO -->
            <div class="file-hero">
                <div class="file-category-pill">
                    <i class="fa-solid fa-folder-open"></i>
                    <%= file.category || 'Resource' %>
                </div>
                <h1 class="file-title"><%- file.title || file.filename %></h1>
                <a href="/profile/<%= file.user || 'admin' %>" class="creator-card">
                    <img src="<%= sellerprofilepic && sellerprofilepic.trim() !== '' ? sellerprofilepic : '/images/avatar.jpg' %>"
                         alt="Creator"
                         class="creator-avatar"
                         onerror="this.src='/images/avatar.jpg'">
                    <span class="creator-name">
                        <%= file.user || 'Vidyari Team' %>
                        <% if (typeof ISVERIFIED !== 'undefined' && ISVERIFIED) { %>
                            <img src="/images/verify.png" alt="Verified" style="width:14px;">
                        <% } %>
                    </span>
                </a>
            </div>

            <!-- PREVIEW -->
            <div class="preview-card" onclick="openImgModal(this.querySelector('img').src)">
                <img src="<%= (previewUrl && previewUrl.trim()) ? previewUrl : '/images/File_Demo.svg' %>"
                     alt="Preview of <%= file.filename %>"
                     onerror="this.src='/images/File_Demo.svg'">
                <div class="preview-zoom-hint"><i class="fa-solid fa-expand"></i> Tap to expand</div>
            </div>

            <!-- AD -->
            <div class="ad-zone">
                <ins class="adsbygoogle" style="display:block" data-ad-format="auto" data-full-width-responsive="true" data-ad-client="ca-pub-3321203820490717"></ins>
            </div>

            <!-- DESCRIPTION -->
            <% if (file.filedescription) { %>
            <div class="content-card">
                <h2 class="content-card-title"><i class="fa-solid fa-circle-info"></i> About this resource</h2>
                <div class="desc-text"><%- file.filedescription %></div>
            </div>
            <% } %>

            <!-- REPORT -->
            <div class="mt-1"><%- include("reporttemplate") %></div>

            <!-- REVIEWS -->
            <div class="content-card">
                <h2 class="content-card-title"><i class="fa-solid fa-star"></i> Student Reviews</h2>
                <div id="reviewsArea"><p style="color:var(--ink-3);font-size:0.875rem;">Loading reviews…</p></div>
            </div>

            <!-- RELATED -->
            <div class="content-card related-section-premium">
                <div class="related-header">
                    <h2 class="related-title"><i class="fa-solid fa-sparkles"></i> You Might Also Like</h2>
                    <p class="related-subtitle">Handpicked recommendations based on this file</p>
                </div>
                <div id="relatedArea"><p style="color:var(--ink-3);font-size:0.875rem;text-align:center;padding:40px 20px;">Loading suggestions…</p></div>
            </div>

        </div><!-- /left-col -->

        <!-- ════════ RIGHT SIDEBAR ════════ -->
        <aside class="right-col">

            <!-- CHECKOUT CARD -->
            <div class="checkout-card">
                <div class="price-hero">
                    <img src="<%= (previewUrl && previewUrl.trim()) ? previewUrl : '/images/File_Demo.svg' %>"
                         alt="Thumbnail" class="price-thumb" onerror="this.style.display='none'">
                    <div class="price-tag-row">
                        <% if (isFree) { %>
                            <div class="price-amount free">Free</div>
                            <span class="price-badge-pill">Open Access</span>
                        <% } else { %>
                            <div class="price-amount">₹<%= priceDetails.total.toFixed(0) %></div>
                            <% if (priceDetails.originalPrice && priceDetails.originalPrice > priceDetails.total) { %>
                                <span class="price-original">₹<%= priceDetails.originalPrice.toFixed(0) %></span>
                                <span class="price-badge-pill"><%= Math.round((1 - priceDetails.total / priceDetails.originalPrice) * 100) %>% OFF</span>
                            <% } %>
                        <% } %>
                    </div>
                    <% if (!isFree) { %>
                        <div class="price-note"><i class="fa-solid fa-fire"></i> Limited-time price</div>
                    <% } %>
                </div>

                <div class="checkout-body">
                    <!-- Invoice breakdown -->
                    <div class="invoice-section">
                        <div class="invoice-row">
                            <span>Base price</span>
                            <span>₹<%= priceDetails.originalPrice.toFixed(2) %></span>
                        </div>
                        <div class="invoice-row">
                            <span>Platform fee + GST</span>
                            <span>₹<%= (priceDetails.serviceFee + priceDetails.gstTax).toFixed(2) %></span>
                        </div>
                        <div id="discountRow"></div>
                        <div class="invoice-row total">
                            <span>Total</span>
                            <span id="finalTotal">₹<%= priceDetails.total.toFixed(2) %></span>
                        </div>
                    </div>

                    <!-- Coupon -->
                    <div class="coupon-wrap">
                        <input type="text" id="couponInput" class="coupon-input" placeholder="Promo code" autocomplete="off" spellcheck="false">
                        <button id="couponApplyBtn" class="coupon-apply-btn">Apply</button>
                    </div>

                    <!-- CTA -->
                    <% if (isFree) { %>
                        <a href="/download?file_id=<%= file._id %>" class="cta-btn free-btn" style="text-decoration:none;">
                            <i class="fa-solid fa-cloud-arrow-down"></i> Download Free
                        </a>
                    <% } else { %>
                        <button class="cta-btn" id="payBtn">
                            <i class="fa-solid fa-lock"></i> Secure Checkout
                        </button>
                    <% } %>

                    <div class="guarantee-row">
                        <i class="fa-solid fa-shield-halved"></i> 30-day money-back guarantee
                    </div>

                    <div class="divider"></div>

                    <!-- Like + Share -->
                    <div class="action-row">
                        <button class="action-pill" id="likeBtn" data-id="<%= file._id %>" data-count="<%= file.likes || 0 %>">
                            <i class="fa-regular fa-heart"></i>
                            <span id="likeCountLabel"><%= file.likes || 0 %></span>
                        </button>
                        <div style="flex:1;display:flex;min-width:0;"><%- include("share") %></div>
                    </div>

                    <div class="divider"></div>

                    <!-- File specs -->
                    <div class="specs-label">File details</div>
                    <ul class="specs-list">
                        <li class="spec-row">
                            <div class="spec-icon-wrap"><i class="fa-solid fa-star" style="color:var(--amber)"></i></div>
                            <div>
                                <div class="spec-label">Rating</div>
                                <div class="spec-value" id="avgRatingDisplay">4.8 / 5.0</div>
                            </div>
                        </li>
                        <li class="spec-row">
                            <div class="spec-icon-wrap"><i class="fa-solid fa-cloud-arrow-down"></i></div>
                            <div>
                                <div class="spec-label">Downloads</div>
                                <div class="spec-value"><%= (file.downloadCount || 0).toLocaleString() %></div>
                            </div>
                        </li>
                        <li class="spec-row">
                            <div class="spec-icon-wrap"><i class="fa-regular fa-file-code"></i></div>
                            <div>
                                <div class="spec-label">Format</div>
                                <div class="spec-value"><%= file.fileType || 'PDF' %></div>
                            </div>
                        </li>
                        <li class="spec-row">
                            <div class="spec-icon-wrap"><i class="fa-regular fa-hard-drive"></i></div>
                            <div>
                                <div class="spec-label">Size</div>
                                <div class="spec-value"><%= file.fileSize ? formatBytes(file.fileSize) : 'N/A' %></div>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- SHARE CARD -->
            <div class="share-card">
                <div class="share-label">Share this file</div>
                <div class="share-row">
                    <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent('https://vidyari.com/file/' + file.slug + '/' + file._id) %>&text=<%= encodeURIComponent(file.filename || '') %>"
                       target="_blank" class="share-pill">
                        <i class="fa-brands fa-x-twitter"></i> X
                    </a>
                    <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent('https://vidyari.com/file/' + file.slug + '/' + file._id) %>"
                       target="_blank" class="share-pill">
                        <i class="fa-brands fa-linkedin-in"></i> LinkedIn
                    </a>
                    <a href="https://wa.me/?text=<%= encodeURIComponent((file.filename || '') + ' - https://vidyari.com/file/' + file.slug + '/' + file._id) %>"
                       target="_blank" class="share-pill">
                        <i class="fa-brands fa-whatsapp"></i> WhatsApp
                    </a>
                    <button class="share-pill" onclick="copyPageLink(event)">
                        <i class="fa-solid fa-link"></i> Copy
                    </button>
                </div>
            </div>

        </aside>

    </div><!-- /main-grid -->
</div><!-- /page-wrap -->

<!-- MOBILE STICKY BAR -->
<div class="mobile-cta-bar">
    <div class="mobile-cta-inner">
        <% if (isFree) { %>
            <div class="mobile-price free">Free</div>
            <a href="/download?file_id=<%= file._id %>" class="mobile-enroll-btn free-btn" style="text-decoration:none;display:flex;align-items:center;gap:8px;">
                <i class="fa-solid fa-cloud-arrow-down"></i> Download Free
            </a>
        <% } else { %>
            <div class="mobile-price">₹<span id="mobileFinalPrice"><%= priceDetails.total.toFixed(0) %></span></div>
            <button class="mobile-enroll-btn" id="payBtnMobile">
                <i class="fa-solid fa-lock"></i> Checkout
            </button>
        <% } %>
    </div>
</div>

<!-- IMAGE MODAL -->
<div class="img-modal-veil" id="imgModalVeil" onclick="closeImgModal()">
    <button class="img-modal-close" onclick="closeImgModal()"><i class="fa-solid fa-times"></i></button>
    <img id="imgModalSrc" src="" alt="Preview">
</div>

<!-- REVIEW MODAL -->
<div class="modal-veil" id="reviewModalVeil">
    <div class="review-modal" onclick="event.stopPropagation()">
        <div class="modal-title">Rate this Document</div>
        <p class="modal-sub">Your review helps other students make better decisions.</p>
        <form id="reviewForm">
            <div class="modal-stars">
                <input type="radio" name="rating" id="s5" value="5" required>
                <label for="s5">★</label>
                <input type="radio" name="rating" id="s4" value="4">
                <label for="s4">★</label>
                <input type="radio" name="rating" id="s3" value="3">
                <label for="s3">★</label>
                <input type="radio" name="rating" id="s2" value="2">
                <label for="s2">★</label>
                <input type="radio" name="rating" id="s1" value="1">
                <label for="s1">★</label>
            </div>
            <input type="text" id="rvTitle" class="modal-input" placeholder="Review title" required>
            <textarea id="rvText" class="modal-input" placeholder="What did you think? Was it helpful?" required></textarea>
            <div class="modal-actions">
                <button type="button" class="modal-cancel-btn" onclick="closeReviewModal()">Cancel</button>
                <button type="submit" class="modal-submit-btn" id="rvSubmitBtn">Submit Review</button>
            </div>
        </form>
    </div>
</div>

<!-- TOAST -->
<div id="vToast"><i class="toast-icon"></i><span id="vToastText"></span></div>

<%- include('footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
// Activity Tracker already loaded in header.ejs
const FILE_ID   = "<%= file._id %>";
const FILE_NAME = "<%- (file.filename || 'Resource').replace(/"/g,'&quot;') %>";
let   activeTotal = <%= priceDetails.total %>;

// Wait for tracker to be ready, then initialize for this page
if (typeof window.ActivityTracker_Instance !== 'undefined') {
  console.log('📍 [file-details] Tracker found, initializing...');
  window.ActivityTracker_Instance.init({ autoTrack: true });
  console.log('✅ [file-details] Tracker initialized');
} else {
  console.warn('⚠️  [file-details] Tracker not available yet, will retry...');
  // Retry after short delay
  setTimeout(() => {
    if (typeof window.ActivityTracker_Instance !== 'undefined') {
      console.log('📍 [file-details] Retrying tracker initialization...');
      window.ActivityTracker_Instance.init({ autoTrack: true });
    } else {
      console.error('❌ [file-details] Tracker failed to initialize');
    }
  }, 500);
}

/* ════════ ACTIVITY TRACKING ════════ */
// Track downloads when user clicks download button
document.addEventListener('click', (e) => {
  const downloadBtn = e.target.closest('a[href*="/download"]');
  if (downloadBtn && window.ActivityTracker_Instance) {
    window.ActivityTracker_Instance.trackActivity({
      activityType: 'file_download',
      pageType: 'file',
      fileId: FILE_ID,
      elementClicked: 'download-btn',
      metadata: { fileName: FILE_NAME }
    });
    
    // Track cart interaction (file added to cart/download)
    window.ActivityTracker_Instance.trackCartInteraction('add', {
      fileId: FILE_ID,
      fileName: FILE_NAME,
      price: activeTotal
    });
  }
});

// Track purchase/checkout button
const payBtn = document.getElementById('payBtn');
if (payBtn && window.ActivityTracker_Instance) {
  payBtn.addEventListener('click', () => {
    // Track checkout start for cart abandonment detection
    window.ActivityTracker_Instance.trackCartInteraction('checkout_start', {
      fileId: FILE_ID,
      fileName: FILE_NAME,
      amount: activeTotal
    });
    
    window.ActivityTracker_Instance.trackActivity({
      activityType: 'purchase_view',
      pageType: 'file',
      fileId: FILE_ID,
      metadata: { fileName: FILE_NAME, amount: activeTotal }
    });
  });
}

// Track like button
const likeBtn = document.getElementById('likeBtn');
if (likeBtn && window.ActivityTracker_Instance) {
  likeBtn.addEventListener('click', () => {
    window.ActivityTracker_Instance.trackActivity({
      activityType: 'click',
      pageType: 'file',
      fileId: FILE_ID,
      elementClicked: 'like-btn',
      metadata: { fileName: FILE_NAME }
    });
  });
}

// Track review modal open and review submissions
const origOpenReviewModal = window.openReviewModal;
window.openReviewModal = function() {
  if (window.ActivityTracker_Instance) {
    window.ActivityTracker_Instance.trackReviewInteraction(FILE_ID, 'view');
  }
  origOpenReviewModal?.call(this);
};

// Track review form submission
const reviewForm = document.getElementById('reviewForm');
if (reviewForm && window.ActivityTracker_Instance) {
  reviewForm.addEventListener('submit', (e) => {
    const ratingInput = reviewForm.querySelector('input[type="range"]');
    const reviewText = reviewForm.querySelector('textarea');
    
    const rating = ratingInput ? parseInt(ratingInput.value) : null;
    const text = reviewText ? reviewText.value : null;
    
    window.ActivityTracker_Instance.trackReviewInteraction(FILE_ID, 'submit', rating, text);
  });
}

// Track category affinity when page loads
if (window.ActivityTracker_Instance && typeof FILE_CATEGORY !== 'undefined') {
  window.ActivityTracker_Instance.trackCategoryAffinity(FILE_CATEGORY, 0);
}

// Track helpful review clicks
document.addEventListener('click', (e) => {
  if (e.target.closest('.helpful-btn') && window.ActivityTracker_Instance) {
    window.ActivityTracker_Instance.trackReviewInteraction(FILE_ID, 'helpful');
  }
});


/* ════════ TOAST ════════ */
function showToast(msg, type='success') {
    const el   = document.getElementById('vToast');
    const icon = el.querySelector('.toast-icon');
    icon.className = `toast-icon ${type} ` + (type==='success' ? 'fa-solid fa-circle-check' : 'fa-solid fa-circle-exclamation');
    document.getElementById('vToastText').textContent = msg;
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 4000);
}

/* ════════ IMAGE MODAL ════════ */
function openImgModal(src) {
    document.getElementById('imgModalSrc').src = src;
    document.getElementById('imgModalVeil').classList.add('open');
}
function closeImgModal() { document.getElementById('imgModalVeil').classList.remove('open'); }

/* ════════ REVIEW MODAL ════════ */
function openReviewModal() { document.getElementById('reviewModalVeil').classList.add('open'); }
function closeReviewModal() {
    document.getElementById('reviewModalVeil').classList.remove('open');
    document.getElementById('reviewForm').reset();
}
document.getElementById('reviewModalVeil').addEventListener('click', e => {
    if (e.target === e.currentTarget) closeReviewModal();
});

/* ════════ LIKE BUTTON ════════ */
(function initLike() {
    const btn    = document.getElementById('likeBtn');
    if (!btn) return;
    const fileId = btn.dataset.id;
    let count    = parseInt(btn.dataset.count) || 0;
    const stored = JSON.parse(localStorage.getItem('vidyari_likes') || '{}');
    let liked    = !!stored[fileId];

    const render = () => {
        btn.classList.toggle('liked', liked);
        const icon = liked ? 'fa-solid fa-heart' : 'fa-regular fa-heart';
        btn.innerHTML = `<i class="${icon}"></i><span>${count}</span>`;
    };
    render();

    btn.addEventListener('click', () => {
        liked = !liked;
        count += liked ? 1 : -1;
        stored[fileId] = liked || undefined;
        if (!liked) delete stored[fileId];
        localStorage.setItem('vidyari_likes', JSON.stringify(stored));
        render();
        fetch(`/files/impression/${fileId}/${liked ? 'like' : 'dislike'}`).catch(()=>{});
    });
})();

/* ════════ SHARE ════════ */
function copyPageLink(e) {
    navigator.clipboard.writeText(location.href).then(() => {
        const btn = e.currentTarget;
        const orig = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
        setTimeout(() => btn.innerHTML = orig, 2000);
    });
}

/* ════════ COUPON ════════ */
document.getElementById('couponApplyBtn')?.addEventListener('click', async () => {
    const code = document.getElementById('couponInput').value.trim();
    if (!code) return;
    const btn = document.getElementById('couponApplyBtn');
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

    try {
        const res  = await fetch(`/check/coupon?fileId=${FILE_ID}&couponCode=${code}&quantity=1`);
        const data = await res.json();
        if (data.valid) {
            const p = data.priceDetails;
            const saving = p.originalPrice - p.discountedPrice;
            activeTotal  = p.total;
            document.getElementById('finalTotal').textContent = `₹${p.total.toFixed(2)}`;
            const mob = document.getElementById('mobileFinalPrice');
            if (mob) mob.textContent = p.total.toFixed(0);
            document.getElementById('discountRow').innerHTML = `
                <div class="invoice-discount-row">
                    <span><i class="fa-solid fa-tag" style="margin-right:6px;"></i>Promo Applied</span>
                    <span>−₹${saving.toFixed(2)}</span>
                </div>`;
            showToast(`Code applied! Saved ₹${saving.toFixed(2)}`);
            document.getElementById('couponInput').disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-check"></i>';
            btn.disabled  = true;
        } else {
            showToast(data.message || 'Invalid code.', 'error');
            btn.textContent = 'Apply';
        }
    } catch {
        showToast('Server error.', 'error');
        btn.textContent = 'Apply';
    }
});

/* ════════ PAYMENT ════════ */
async function initiatePayment(btn) {
    if (typeof Razorpay === 'undefined') { showToast('Payment gateway loading, please wait.', 'error'); return; }
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processing…';
    btn.disabled  = true;

    try {
        const res   = await fetch('/create-order', {
            method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'include',
            body: JSON.stringify({ fileId: FILE_ID, price: activeTotal, filename: FILE_NAME, couponCode: document.getElementById('couponInput')?.value.trim() || '' })
        });
        const order = await res.json();

        if (res.status === 401 || order.requiresLogin) { window.location.href = order.loginRedirectUrl || '/login'; return; }
        if (!res.ok || !order.success) { btn.innerHTML = orig; btn.disabled = false; showToast(order.error || 'Order failed.', 'error'); return; }

        const rzp = new Razorpay({
            key: order.key, amount: order.amount, currency: 'INR',
            name: 'Vidyari', image: 'https://www.vidyari.com/images/logo.svg',
            description: FILE_NAME, order_id: order.order_id,
            theme: { color: '#1a56f0' },
            handler: async function(resp) {
                btn.innerHTML = '<i class="fa-solid fa-shield-check fa-fade"></i> Verifying…';
                try {
                    const vRes  = await fetch('/verify-payment', {
                        method:'POST', headers:{'Content-Type':'application/json'}, credentials:'include',
                        body: JSON.stringify({ razorpay_order_id: resp.razorpay_order_id, razorpay_payment_id: resp.razorpay_payment_id, razorpay_signature: resp.razorpay_signature, fileId: FILE_ID, totalprice: activeTotal })
                    });
                    const vData = await vRes.json();
                    if (vRes.status === 401 || vData.requiresLogin) { window.location.href = vData.loginRedirectUrl || '/login'; return; }
                    if (vData.success) {
                        btn.innerHTML = '<i class="fa-solid fa-check"></i> Success!';
                        btn.style.background = 'var(--green)';
                        showToast('Payment successful!');
                        setTimeout(() => window.location.href = vData.downloadUrl, 1200);
                    } else throw new Error(vData.message || 'Verification failed.');
                } catch (e) { showToast(e.message, 'error'); btn.innerHTML = orig; btn.disabled = false; btn.style.background = ''; }
            },
            modal: { ondismiss: () => { btn.innerHTML = orig; btn.disabled = false; } }
        });
        rzp.open();
    } catch (e) { showToast('Connection error.', 'error'); btn.innerHTML = orig; btn.disabled = false; }
}

document.getElementById('payBtn')?.addEventListener('click', e => initiatePayment(e.currentTarget));
document.getElementById('payBtnMobile')?.addEventListener('click', e => initiatePayment(document.getElementById('payBtn') || e.currentTarget));

/* ════════ REVIEWS ════════ */
async function loadReviews() {
    const area = document.getElementById('reviewsArea');
    try {
        const res  = await fetch(`/api/file-reviews/file/${FILE_ID}`);
        const data = await res.json();

        // Update rating display
        if (data.averageRating) document.getElementById('avgRatingDisplay').textContent = `${data.averageRating.toFixed(1)} / 5.0`;

        const genStars = (n, cls='') => '★'.repeat(n) + `<span class="empty">${'★'.repeat(5-n)}</span>`;

        if (data.count === 0) {
            area.innerHTML = `
                <div class="no-reviews-state">
                    <i class="fa-regular fa-star"></i>
                    <p style="font-weight:500;color:var(--ink);margin-bottom:6px;">No reviews yet</p>
                    <p>Be the first to share your experience!</p>
                    <button class="write-review-btn" style="margin:16px auto 0;display:inline-flex;" onclick="openReviewModal()">
                        <i class="fa-regular fa-pen-to-square"></i> Write a Review
                    </button>
                </div>`;
            return;
        }

        // Rating distribution
        const maxC = Math.max(...Object.values(data.ratingDistribution), 1);
        const distHTML = [5,4,3,2,1].map(s => `
            <div class="dist-row">
                <span class="dist-label">${s} ★</span>
                <div class="dist-track"><div class="dist-fill" style="width:${((data.ratingDistribution[s]||0)/maxC*100).toFixed(0)}%"></div></div>
                <span class="dist-count">${data.ratingDistribution[s]||0}</span>
            </div>`).join('');

        const reviewsHTML = data.reviews.map(rv => `
            <div class="review-item">
                <div class="review-item-head">
                    <div class="review-initials">${(rv.userId?.fullName||rv.userId?.username||'U').substring(0,2).toUpperCase()}</div>
                    <div>
                        <div class="review-user-name">${rv.userId?.fullName||rv.userId?.username||'Anonymous'}</div>
                        <div class="review-user-date">${new Date(rv.createdAt).toLocaleDateString('en-IN',{year:'numeric',month:'short',day:'numeric'})}</div>
                    </div>
                    <div class="review-item-stars">${genStars(rv.rating)}</div>
                </div>
                <div class="review-item-title">${rv.title||''}</div>
                <div class="review-item-body">${rv.reviewText||''}</div>
                <div class="review-helpful-row">
                    <span class="helpful-label">Was this helpful?</span>
                    <button class="helpful-btn" onclick="markHelpful('${rv._id}',this)">
                        <i class="fa-regular fa-thumbs-up"></i> ${rv.helpful||0}
                    </button>
                </div>
            </div>`).join('');

        area.innerHTML = `
            <div class="rating-summary-block">
                <div>
                    <div class="rating-num">${data.averageRating.toFixed(1)}</div>
                    <div class="rating-stars-row">${genStars(Math.round(data.averageRating))}</div>
                    <div class="rating-count-label">${data.count} reviews</div>
                </div>
                <div class="rating-dist">${distHTML}</div>
            </div>
            <button class="write-review-btn" onclick="openReviewModal()">
                <i class="fa-regular fa-pen-to-square"></i> Write a Review
            </button>
            <div class="review-list">${reviewsHTML}</div>`;
    } catch {
        area.innerHTML = '<p style="color:var(--ink-3);font-size:0.875rem;">Unable to load reviews.</p>';
    }
}

async function markHelpful(id, btn) {
    try {
        const res = await fetch(`/api/file-reviews/${id}/helpful`, { method:'POST', headers:{'Content-Type':'application/json'} });
        if (res.ok) { btn.classList.add('active'); loadReviews(); }
    } catch {}
}

document.getElementById('reviewForm').addEventListener('submit', async e => {
    e.preventDefault();
    const rating = document.querySelector('input[name="rating"]:checked')?.value;
    if (!rating) { showToast('Please select a rating.', 'error'); return; }
    const title = document.getElementById('rvTitle').value.trim();
    const text  = document.getElementById('rvText').value.trim();
    const btn   = document.getElementById('rvSubmitBtn');
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Submitting…';
    btn.disabled  = true;
    try {
        const res  = await fetch('/api/file-reviews/submit', {
            method:'POST', headers:{'Content-Type':'application/json'},
            body: JSON.stringify({ fileId: FILE_ID, rating: +rating, title, reviewText: text })
        });
        const data = await res.json();
        if (res.ok) {
            btn.innerHTML = '<i class="fa-solid fa-check"></i> Submitted!';
            btn.style.background = 'var(--green)';
            showToast('Review submitted! Thank you.');
            setTimeout(() => { closeReviewModal(); loadReviews(); }, 1500);
        } else {
            showToast(data.message || 'Submission failed.', 'error');
            btn.innerHTML = 'Submit Review'; btn.disabled = false; btn.style.background = '';
        }
    } catch { showToast('Error. Try again.', 'error'); btn.innerHTML = 'Submit Review'; btn.disabled = false; }
});

/* ════════ RELATED FILES ════════ */
async function loadRelated() {
    const area = document.getElementById('relatedArea');
    if (!area) return;

    // 1. Show Premium Skeleton Loaders initially
    area.innerHTML = `
        <div class="related-grid-container">
            <div class="related-author-section">
                <div class="skeleton-card"></div>
                <div class="skeleton-card"></div>
                <div class="skeleton-card"></div>
                <div class="skeleton-card" style="display:none;" media="(min-width: 768px)"></div>
            </div>
        </div>
    `;

    try {
        const res = await fetch(`/products/related?fileId=${FILE_ID}`);
        if (!res.ok) throw new Error('Failed to fetch');
        const docs = await res.json();

        // 2. Empty State
        if (!docs?.length) {
            area.innerHTML = `
                <div style="text-align:center;padding:40px 20px;">
                    <i class="fa-solid fa-layer-group" style="font-size:2.5rem;color:var(--rule);margin-bottom:12px;display:block;"></i>
                    <p style="color:var(--ink-3);font-size:0.95rem;margin:0;">No similar resources found yet.</p>
                </div>`;
            return;
        }

        // 3. Group by author
        const groups = {};
        docs.forEach(d => {
            const author = d.user || 'Vidyari Creator';
            if (!groups[author]) groups[author] = [];
            groups[author].push(d);
        });

        // 4. Render Layout
        area.innerHTML = `
            <div class="related-grid-container">
                ${Object.entries(groups).map(([author, files]) => `
                    <div>
                        <h3 class="related-author-label">Created by ${author}</h3>
                        <div class="related-author-section">
                            ${files.map(f => {
                                const isFree = f.price === 0 || f.price === '0';
                                const rating = (f.rating || 4.8).toFixed(1);
                                const downloads = f.downloadCount || 0;
                                const downDisplay = downloads > 1000 ? (downloads/1000).toFixed(1) + 'k' : downloads;
                                
                                return `
                                    <a href="/file/${f.slug || f._id}/${f._id}" class="related-item">
                                        <div class="related-item-thumb">
                                            <img src="${f.previewUrl || '/images/File_Demo.svg'}" alt="${f.filename}" loading="lazy" onerror="this.src='/images/File_Demo.svg'">
                                            <span class="related-item-badge ${isFree ? 'free' : ''}">
                                                ${isFree ? 'Free' : 'Premium'}
                                            </span>
                                        </div>
                                        
                                        <div class="related-item-content">
                                            <div class="related-item-name">${f.filename}</div>
                                            <div class="related-item-author">
                                                <i class="fa-solid fa-circle-user"></i> ${author}
                                            </div>
                                            
                                            <div class="related-item-stats">
                                                <div class="related-item-price ${isFree ? 'free' : ''}">
                                                    ${isFree ? 'Free' : '₹' + f.price}
                                                </div>
                                                <div class="related-item-metrics">
                                                    <span title="Rating"><i class="fa-solid fa-star" style="color:var(--amber)"></i> ${rating}</span>
                                                    <span title="Downloads"><i class="fa-solid fa-cloud-arrow-down"></i> ${downDisplay}</span>
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                `;
                            }).join('')}
                        </div>
                    </div>
                `).join('')}
            </div>
        `;

    } catch (err) {
        console.error('Error loading related:', err);
        area.innerHTML = `
            <div style="text-align:center;padding:40px 20px;color:var(--ink-3);">
                <i class="fa-solid fa-triangle-exclamation" style="font-size:2rem;color:var(--rule);margin-bottom:12px;display:block;"></i>
                <p>Unable to load suggestions right now.</p>
            </div>`;
    }
}

