<%-include("header")%>
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover" />

    <title>
        <% if(file.price == 0) { %>
            <%= file.filename || 'Download' %> | Free on Vidyari
        <% } else { %>
            <%= file.filename || 'Checkout' %> | Secure Purchase | Vidyari
        <% } %>
    </title>

    <meta name="description" content="Download '<%= file.filename %>' on Vidyari - Premium study material by <%= file.user %>. <%= priceDetails.total == 0 ? 'Free access' : '₹' + priceDetails.total %> - Verified creator, 4.8★ rating, <%= file.downloadCount || 0 %> downloads.">
    <meta name="keywords" content="<%= file.category %>, <%= file.filename %>, study notes, digital resources, download, online learning, <%= file.user %>">
    <meta name="author" content="<%= file.user %>">
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <link rel="canonical" href="https://vidyari.com/file/<%= file.slug %>/<%= file._id %>">
    
    <meta property="og:type" content="product">
    <meta property="og:title" content="<%= file.filename %> | Download on Vidyari">
    <meta property="og:description" content="Premium study material. <%= priceDetails.total == 0 ? 'Free' : '₹' + priceDetails.total %>. By <%= file.user %>. <%= file.downloadCount || 0 %> downloads, 4.8★ rating.">
    <meta property="og:image" content="<%= previewUrl || 'https://vidyari.com/images/logo-1200x630.png' %>">
    <meta property="og:url" content="https://vidyari.com/file/<%= file.slug %>/<%= file._id %>">
    <meta property="og:site_name" content="Vidyari">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= file.filename %> | Vidyari">
    <meta name="twitter:description" content="<%= priceDetails.total == 0 ? 'Free study material' : 'Premium resource ₹' + priceDetails.total %> by <%= file.user %>">
    <meta name="twitter:image" content="<%= previewUrl %>">
    <meta name="twitter:site" content="@vidyari">
    
    <script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "Product",
      "@id": "https://vidyari.com/file/<%= file.slug %>/<%= file._id %>",
      "name": "<%- file.filename ? file.filename.replace(/"/g, '&quot;') : 'Digital Resource' %>",
      "image": ["<%= previewUrl || 'https://vidyari.com/images/logo.png' %>"],
      "description": "<%- file.filedescription ? file.filedescription.substring(0, 160).replace(/"/g, '&quot;') : 'Premium educational resource' %>",
      "category": "<%= file.category || 'Educational' %>",
      "author": {
        "@type": "Person",
        "@id": "https://vidyari.com/profile/<%= file.user %>",
        "name": "<%= file.user || 'Vidyari Creator' %>"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "ratingCount": "<%= Math.max((file.downloadCount || 0) + 50, 100) %>",
        "bestRating": "5",
        "worstRating": "1"
      },
      "brand": {
        "@type": "Brand",
        "name": "Vidyari"
      },
      "offers": {
        "@type": "Offer",
        "@id": "https://vidyari.com/file/<%= file.slug %>/<%= file._id %>#offer",
        "url": "https://vidyari.com/file/<%= file.slug %>/<%= file._id %>",
        "priceCurrency": "INR",
        "price": "<%= priceDetails.total %>",
        "availability": "https://schema.org/InStock",
        "seller": {
          "@type": "Person",
          "@id": "https://vidyari.com/profile/<%= file.user %>",
          "name": "<%= file.user || 'Vidyari Creator' %>"
        }
      }
    }
    </script>
    <link rel="icon" href="/images/logo.svg" type="image/svg" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3321203820490717" crossorigin="anonymous"></script>

    <style>
        /* ==========================================================================
           VIDYARI CHECKOUT: PREMIUM MATERIAL 3 THEME
           ========================================================================== */
        :root {
            --v-bg: #f8fafd;           
            --v-surface: #ffffff;      
            --v-text-main: #202124;    
            --v-text-muted: #5f6368;   
            
            --v-primary: #0b57d0;      
            --v-primary-hover: #0842a0;
            --v-primary-bg: #e8f0fe;
            
            --v-success: #137333;      
            --v-success-bg: #e6f4ea;
            
            --v-border: #dadce0;       
            --v-border-light: #f1f3f4;
            
            --v-font-display: 'Outfit', sans-serif;
            --v-font-sans: 'Inter', sans-serif;
            
            --v-radius-sm: 8px;
            --v-radius-md: 12px;
            --v-radius-lg: 24px;
            --v-radius-pill: 9999px;
            
            --v-shadow-subtle: 0 1px 3px rgba(60,64,67,0.08);
            --v-shadow-card: 0 4px 12px rgba(60,64,67,0.06);
            --v-shadow-float: 0 8px 24px rgba(11, 87, 208, 0.12);
            
            --v-transition: all 0.25s cubic-bezier(0.2, 0, 0, 1);
        }

        /* * GLOBAL AD-DEFENSE & LAYORT PROTECTION
         * These rules guarantee Google Ads cannot break the layout.
         */
        html, body {
            margin: 0;
            padding: 0;
            max-width: 100vw;
            overflow-x: hidden; /* Hard stop on horizontal scrolling */
            font-family: var(--v-font-sans);
            background-color: var(--v-bg);
            color: var(--v-text-main);
            -webkit-font-smoothing: antialiased;
        }

        * { 
            box-sizing: border-box; 
            min-width: 0; /* Prevents flex/grid children from bursting out */
        } 

        a { text-decoration: none; color: inherit; transition: var(--v-transition); }

        /* UNBREAKABLE AD CONTAINERS */
        .ad-safe-zone {
            width: 100%;
            max-width: 100%;
            overflow: hidden !important; /* Clips any oversized ads */
            display: flex;
            justify-content: center;
            background: var(--v-border-light);
            border-radius: var(--v-radius-md);
            margin: 24px 0;
            min-height: 50px;
        }
        
        .ad-safe-zone ins.adsbygoogle, 
        .ad-safe-zone iframe {
            max-width: 100% !important;
            overflow: hidden !important;
        }

        /* --- Layout Architecture --- */
        .checkout-layout {
            width: 100%;
            max-width: 1240px;
            margin: 0 auto;
            padding: clamp(24px, 4vw, 48px) clamp(16px, 4vw, 32px);
            display: grid;
            /* minmax(0, 1fr) prevents the left column from expanding infinitely */
            grid-template-columns: minmax(0, 1fr) minmax(300px, 400px);
            gap: clamp(32px, 5vw, 64px);
            align-items: start;
        }

        /* ==========================================================================
           LEFT: MAIN CONTENT (Image, Title, Description)
           ========================================================================== */
        .main-column {
            display: flex;
            flex-direction: column;
            gap: 24px;
            width: 100%;
        }

        .v-badge {
            align-self: flex-start;
            background: var(--v-primary-bg);
            color: var(--v-primary);
            padding: 6px 16px;
            border-radius: var(--v-radius-pill);
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .v-product-title {
            font-family: var(--v-font-display);
            font-size: clamp(1.8rem, 4vw, 2.8rem);
            font-weight: 700;
            color: var(--v-text-main);
            line-height: 1.2;
            margin: 0;
            letter-spacing: -0.5px;
            overflow-wrap: break-word;
            word-wrap: break-word;
        }

        .creator-link {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 6px 20px 6px 6px;
            background: var(--v-surface);
            border-radius: var(--v-radius-pill);
            transition: var(--v-transition);
            border: 1px solid var(--v-border);
            box-shadow: var(--v-shadow-subtle);
            width: fit-content;
            max-width: 100%;
        }
        .creator-link:hover { box-shadow: var(--v-shadow-card); transform: translateY(-2px); }
        .creator-avatar { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; border: 1px solid var(--v-border); flex-shrink: 0; }
        .creator-name { font-weight: 600; color: var(--v-text-main); font-size: 1.05rem; display: flex; align-items: center; gap: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        /* Image Gallery/Preview */
        .preview-wrapper {
            width: 100%;
            aspect-ratio: 16/10;
            background: var(--v-border-light);
            border-radius: var(--v-radius-lg);
            overflow: hidden;
            border: 1px solid var(--v-border);
            box-shadow: var(--v-shadow-card);
            cursor: zoom-in;
            position: relative;
        }
        .preview-wrapper img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s cubic-bezier(0.2, 0, 0, 1); }
        .preview-wrapper:hover img { transform: scale(1.02); }
        .zoom-hint {
            position: absolute; bottom: 20px; right: 20px;
            background: rgba(32, 33, 36, 0.75); color: white; padding: 8px 16px; 
            border-radius: var(--v-radius-pill); font-size: 0.9rem; font-weight: 500;
            backdrop-filter: blur(8px); opacity: 0; transition: var(--v-transition);
        }
        .preview-wrapper:hover .zoom-hint { opacity: 1; }

        /* Description */
        .content-box {
            background: var(--v-surface); border-radius: var(--v-radius-lg);
            padding: clamp(24px, 4vw, 40px); box-shadow: var(--v-shadow-card);
            border: 1px solid var(--v-border);
            width: 100%;
            overflow: hidden;
        }
        .section-title {
            font-family: var(--v-font-display); font-size: 1.4rem; font-weight: 600;
            color: var(--v-text-main); margin-bottom: 20px; display: flex; align-items: center; gap: 12px;
        }
        .section-title i { color: var(--v-primary); }
        
        .desc-content {
            font-size: 1.05rem; line-height: 1.8; color: var(--v-text-muted); 
            overflow-wrap: break-word; word-wrap: break-word;
        }
        .desc-content p { margin-bottom: 16px; }
        .desc-content strong { color: var(--v-text-main); font-weight: 600; }
        .desc-content img { max-width: 100% !important; height: auto !important; border-radius: var(--v-radius-md); margin: 20px 0;}

        /* ==========================================================================
           GOOGLE PLAY STORE STYLE: RELATED ITEMS (MOBILE SWIPEABLE)
           ========================================================================== */
        .v-author-section { margin-bottom: 32px; width: 100%; overflow: hidden; }
        .v-author-section-title {
            font-family: var(--v-font-display); font-size: 1.2rem; font-weight: 600;
            color: var(--v-text-main); margin-bottom: 16px; display: flex; align-items: center; gap: 8px;
        }

        .related-scroll-container {
            display: flex;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            gap: 16px;
            padding-bottom: 16px;
            scrollbar-width: none; 
            -webkit-overflow-scrolling: touch;
        }
        .related-scroll-container::-webkit-scrollbar { display: none; }

        .related-card { 
            background: transparent; border: none; border-radius: 0; 
            display: flex; flex-direction: column; transition: var(--v-transition); 
            text-decoration: none; color: inherit;
            width: 130px; min-width: 130px; /* Compact Play Store Book size */
            scroll-snap-align: start; flex-shrink: 0;
        }
        .related-card:hover { transform: translateY(-4px); }
        
        .related-img-box { 
            aspect-ratio: 3/4; /* Portrait for books/docs */
            background: var(--v-border-light); border: 1px solid var(--v-border); 
            border-radius: var(--v-radius-md); position: relative; overflow: hidden;
            margin-bottom: 10px; box-shadow: var(--v-shadow-subtle);
        }
        .related-img-box img { width: 100%; height: 100%; object-fit: cover; }
        
        .related-content { display: flex; flex-direction: column; flex: 1; }
        .related-title { 
            font-family: var(--v-font-sans); font-size: 0.85rem; font-weight: 500; 
            margin-bottom: 4px; display: -webkit-box; -webkit-line-clamp: 2; 
            -webkit-box-orient: vertical; overflow: hidden; line-height: 1.3; color: var(--v-text-main); 
        }
        .related-author { font-size: 0.75rem; color: var(--v-text-muted); margin-bottom: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;}
        .related-price { font-weight: 600; color: var(--v-text-main); margin-top: auto; font-size: 0.85rem;}
        .related-price.is-free { color: var(--v-success); }


        /* ==========================================================================
           RIGHT: SIDEBAR (Order Summary, Checkout)
           ========================================================================== */
        .sidebar-column {
            display: flex; flex-direction: column; gap: 24px; position: sticky; top: 32px;
            width: 100%;
        }

        .checkout-card {
            background: var(--v-surface); border-radius: var(--v-radius-lg);
            box-shadow: var(--v-shadow-card); border: 1px solid var(--v-border);
            padding: 32px; display: flex; flex-direction: column; width: 100%;
        }

        .price-display {
            font-family: var(--v-font-display); font-size: 3rem; font-weight: 700;
            color: var(--v-text-main); line-height: 1; margin-bottom: 24px; letter-spacing: -1px;
            word-break: break-all;
        }
        .price-display.is-free { color: var(--v-success); }

        .invoice-row {
            display: flex; justify-content: space-between; align-items: center;
            font-size: 0.95rem; padding: 10px 0; color: var(--v-text-muted); font-weight: 500;
        }
        .invoice-row.total {
            border-top: 1px dashed var(--v-border); margin-top: 16px; padding-top: 20px;
            color: var(--v-text-main); font-weight: 700; font-size: 1.2rem;
        }
        .invoice-row.discount { color: var(--v-success); background: var(--v-success-bg); padding: 8px 12px; border-radius: var(--v-radius-sm); margin: 8px 0;}

        /* Coupon Field */
        .coupon-box {
            display: flex; border: 1px solid var(--v-border); border-radius: var(--v-radius-pill);
            overflow: hidden; margin: 24px 0; background: var(--v-bg); transition: var(--v-transition);
        }
        .coupon-box:focus-within { border-color: var(--v-primary); box-shadow: 0 0 0 3px var(--v-primary-bg); }
        .coupon-input {
            flex: 1; border: none; padding: 12px 20px; font-family: var(--v-font-sans);
            font-weight: 500; font-size: 0.95rem; outline: none; background: transparent; color: var(--v-text-main); text-transform: uppercase;
            min-width: 0; /* Important for flex child inputs */
        }
        .coupon-input::placeholder { color: #9aa0a6; text-transform: none;}
        .coupon-btn {
            background: transparent; color: var(--v-primary); border: none; border-left: 1px solid var(--v-border);
            padding: 0 20px; font-family: var(--v-font-sans); font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: var(--v-transition);
        }
        .coupon-btn:hover { background: var(--v-primary-bg); }

        /* CTA Button */
        .v-pay-btn {
            width: 100%; background: var(--v-primary); color: white; border: none;
            border-radius: var(--v-radius-pill); padding: 18px; font-family: var(--v-font-sans);
            font-size: 1.15rem; font-weight: 600; box-shadow: var(--v-shadow-float); cursor: pointer;
            transition: var(--v-transition); display: flex; justify-content: center; align-items: center; gap: 12px; margin-bottom: 24px;
        }
        .v-pay-btn:hover { background: var(--v-primary-hover); transform: translateY(-2px); box-shadow: 0 12px 24px rgba(11,87,208,0.2); }
        .v-pay-btn:active { transform: translateY(0); }
        .v-pay-btn.is-free { background: var(--v-success); box-shadow: 0 8px 24px rgba(20, 108, 46, 0.15);}
        .v-pay-btn.is-free:hover { background: #115926; }

        /* Action Row (Like / Share) */
        .action-row { display: flex; gap: 12px; width: 100%; }
        .v-btn-icon-text {
            flex: 1; background: var(--v-bg); border: 1px solid var(--v-border);
            border-radius: var(--v-radius-pill); padding: 12px; font-family: var(--v-font-sans);
            font-size: 0.95rem; font-weight: 500; color: var(--v-text-muted); cursor: pointer; transition: var(--v-transition);
            display: flex; justify-content: center; align-items: center; gap: 8px; min-width: 0;
        }
        .v-btn-icon-text:hover { background: var(--v-border-light); transform: translateY(-1px); color: var(--v-text-main); }
        .v-btn-icon-text.liked { color: var(--v-primary); background: var(--v-primary-bg); border-color: transparent; }

        /* Specs Card */
        .specs-card {
            background: var(--v-surface); border-radius: var(--v-radius-lg); border: 1px solid var(--v-border); padding: 32px; box-shadow: var(--v-shadow-card); width: 100%;
        }
        .specs-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 20px; }
        .spec-item { display: flex; align-items: center; gap: 16px; color: var(--v-text-main); font-size: 1rem; font-weight: 600; }
        .spec-icon {
            width: 48px; height: 48px; border-radius: 50%; background: var(--v-bg); color: var(--v-primary);
            display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0;
        }
        .spec-label { color: var(--v-text-muted); font-size: 0.85rem; font-weight: 500; margin-bottom: 2px;}

        /* Security Note */
        .security-note {
            display: flex; align-items: center; justify-content: center; gap: 12px;
            color: var(--v-text-muted); font-size: 0.85rem; font-weight: 500; margin-top: 20px;
            padding-top: 20px; border-top: 1px solid var(--v-border);
        }

        /* Mobile Buy Bar */
        .mobile-buy-bar {
            display: none; position: fixed; bottom: 0; left: 0; right: 0;
            background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            border-top: 1px solid rgba(0,0,0,0.05); padding: 16px 24px; z-index: 1000;
            align-items: center; justify-content: space-between; gap: 16px;
            box-shadow: 0 -10px 30px rgba(0,0,0,0.08);
            padding-bottom: calc(16px + env(safe-area-inset-bottom)); /* iPhone safe area */
        }

        /* Toast Notification */
        #toast-msg {
            position: fixed; top: 24px; left: 50%; transform: translateX(-50%) translateY(-20px);
            background: #202124; color: white; padding: 14px 24px; border-radius: var(--v-radius-pill); 
            box-shadow: 0 8px 24px rgba(0,0,0,0.2); font-family: var(--v-font-sans); font-weight: 500; font-size: 0.95rem;
            display: flex; align-items: center; gap: 12px; opacity: 0; visibility: hidden; transition: all 0.3s cubic-bezier(0.2, 0, 0, 1); z-index: 9999;
        }
        #toast-msg.show { transform: translateX(-50%) translateY(0); opacity: 1; visibility: visible; }
        #toast-msg.success i { color: #81c995; }
        #toast-msg.error i { color: #f28b82; }

        /* Modal Overrides */
        #imageModal .modal-content { background: rgba(32,33,36,0.95); backdrop-filter: blur(10px); border: none; }
        #imageModal .btn-close { filter: invert(1); opacity: 0.8; margin: 24px; }
        #imageModal img { max-width: 95vw; max-height: 85vh; object-fit: contain; border-radius: var(--v-radius-sm); }

        /* ==========================================================================
           MOBILE RESPONSIVENESS
           ========================================================================== */
        @media (max-width: 991px) {
            .checkout-layout { 
                grid-template-columns: minmax(0, 1fr); /* 1 Column, strict overflow protection */
                gap: 24px; 
                padding: 16px 16px calc(100px + env(safe-area-inset-bottom)) 16px; 
                width: 100vw;
            }
            .sidebar-column { position: relative; top: 0; gap: 24px; width: 100%;}
            .checkout-card, .specs-card, .content-box { padding: 24px; width: 100%; }
            
            /* Order Change */
            .v-product-title { font-size: 1.8rem; order: -2; margin-bottom: 12px;}
            .v-badge { order: -3; }
            .creator-link { order: -1; margin-bottom: 24px; align-self: flex-start;}
            
            /* Hide desktop buy elements, show mobile sticky bar */
            .checkout-card .v-pay-btn, .checkout-card .price-display { display: none; } 
            .mobile-buy-bar { display: flex; }
            .mobile-buy-bar .price-display { margin: 0; font-size: 1.8rem; display: block; }
            .mobile-buy-bar .v-pay-btn { width: auto; padding: 14px 32px; margin: 0; flex-shrink: 0;}

            /* Related Row Bleed to edges on mobile */
            .related-scroll-container { margin-right: -16px; padding-right: 16px; margin-left: -16px; padding-left: 16px;}
        }
        
        @media (min-width: 992px) {
            /* Desktop Fallback for Related Grid */
            .related-scroll-container {
                flex-wrap: wrap; margin-right: 0; padding-right: 0; overflow-x: visible;
            }
            .related-card { width: 140px; min-width: 140px; }
        }
    </style>
</head>

<body>
    <% 
    const formatBytes = (bytes, decimals=2) => {
        if (!+bytes) return '0 Bytes';
        const k = 1024; const dm = decimals < 0 ? 0 : decimals;
        const sizes = ['Bytes', 'KB' , 'MB' , 'GB' , 'TB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return `${parseFloat((bytes / Math.pow(k, i)).toFixed(dm))} ${sizes[i]}`;
    }; 
    %>

    <div class="checkout-layout">
        
        <main class="main-column">
            
            <div style="display: flex; flex-direction: column;">
                <span class="v-badge"><i class="fa-solid fa-folder-open me-2"></i> <%= file.category || 'Resource' %></span>
                <h1 class="v-product-title"><%- file.title || file.filename %></h1>
                
                <a href="/profile/<%= file.user || 'admin' %>" class="creator-link">
                    <img src="<%= sellerprofilepic && sellerprofilepic.trim() !== '' ? sellerprofilepic : '/images/avatar.jpg' %>" alt="Creator" class="creator-avatar" onerror="this.onerror=null; this.src='/images/avatar.jpg';">
                    <span class="creator-name">
                        <%= file.user || 'Vidyari Team' %>
                        <% if (typeof ISVERIFIED !== 'undefined' && ISVERIFIED) { %> <img style="width:16px;" src="/images/verify.png" alt="Verified"> <% } %>
                    </span>
                </a>
            </div>

            <div class="preview-wrapper" data-bs-toggle="modal" data-bs-target="#imageModal">
                <img id="mainPreviewImage" 
                    src="<%= (previewUrl && typeof previewUrl === 'string' && previewUrl.trim() !== '') ? previewUrl : '/images/File_Demo.svg' %>" 
                    alt="<%= file.filename %>" 
                    loading="eager"
                    onerror="this.onerror=null;this.src='/images/File_Demo.svg';">
                <div class="zoom-hint"><i class="fa-solid fa-expand me-2"></i> Tap to Expand</div>
            </div>
            
            <div class="ad-safe-zone">
                </div>

            <% if (file.filedescription) { %>
                <div class="content-box">
                    <h2 class="section-title"><i class="fa-solid fa-circle-info"></i> About this resource</h2>
                    <div class="desc-content">
                        <%- file.filedescription %>
                    </div>
                </div>
            <% } %>

            <div class="mt-2"><%- include("reporttemplate") %></div>

            <div class="mt-4" style="width: 100%; overflow: hidden;">
                <h2 class="section-title border-0 mb-2" style="font-size: 1.4rem;"><i class="fa-solid fa-layer-group text-muted"></i> You might also like</h2>
                <div id="relatedGridContainer" style="width: 100%;">
                    <p class="text-muted ps-2">Loading similar files...</p>
                </div>
            </div>
            
            <div class="mt-2" style="width: 100%;"><%- include("chat") %></div>

        </main>

        <aside class="sidebar-column">
            
            <div class="checkout-card">
                <div class="price-display <%= Number(priceDetails.total) === 0 ? 'is-free' : '' %>">
                    <%= Number(priceDetails.total) === 0 ? 'Free' : '₹' + priceDetails.total.toFixed(2) %>
                </div>

                <div class="invoice-row">
                    <span>Base Asset Price</span>
                    <span>₹<%=priceDetails.originalPrice.toFixed(2)%></span>
                </div>
                <div class="invoice-row muted">
                    <span>Platform Processing</span>
                    <span>₹<%=(priceDetails.serviceFee + priceDetails.gstTax).toFixed(2)%></span>
                </div>
                <div id="dynamic-discount-row"></div>

                <div class="coupon-box">
                    <input type="text" id="coupon-code" class="coupon-input" placeholder="Promo code" autocomplete="off" spellcheck="false">
                    <button id="apply-coupon-btn" class="coupon-btn">Apply</button>
                </div>

                <div class="invoice-row total">
                    <span>Total Due</span>
                    <span id="finalTotalPrice">₹<%=priceDetails.total.toFixed(2)%></span>
                </div>

                <div class="mt-4">
                    <% if (Number(priceDetails.total) === 0) { %>
                        <a href="/download?file_id=<%=file._id%>" class="v-pay-btn is-free" id="downloadBtn">
                            Download Now <i class="fa-solid fa-cloud-arrow-down"></i>
                        </a>
                    <% } else { %>
                        <button type="button" class="v-pay-btn" id="razorpay-pay-btn">
                            Secure Checkout <i class="fa-solid fa-lock"></i>
                        </button>
                    <% } %>
                </div>

                <div class="action-row">
                    <button class="v-btn-icon-text" id="likeButton" data-file-id="<%= file._id %>" data-likes="<%= file.likes %>">
                        </button>
                    <div style="flex:1; display:flex; min-width: 0;"><%- include("share") %></div>
                </div>

                <div class="security-note">
                    <i class="fa-solid fa-shield-check text-success" style="font-size: 1.1rem;"></i> 
                    <span>Guaranteed Safe & Secure Checkout</span>
                </div>
            </div>

            <div class="specs-card">
                <h3 class="section-title border-0 mb-4" style="font-size: 1.2rem;">File Information</h3>
                <ul class="specs-list">
                    <li class="spec-item">
                        <div class="spec-icon"><i class="fa-solid fa-star text-warning"></i></div>
                        <div>
                            <div class="spec-label">Average Rating</div>
                            <div>4.8 / 5.0</div>
                        </div>
                    </li>
                    <li class="spec-item">
                        <div class="spec-icon"><i class="fa-solid fa-cloud-arrow-down"></i></div>
                        <div>
                            <div class="spec-label">Total Downloads</div>
                            <div><%= (file.downloadCount || 0).toLocaleString() %></div>
                        </div>
                    </li>
                    <li class="spec-item">
                        <div class="spec-icon"><i class="fa-regular fa-file-code"></i></div>
                        <div>
                            <div class="spec-label">Format Type</div>
                            <div><%= file.fileType || 'PDF' %></div>
                        </div>
                    </li>
                    <li class="spec-item">
                        <div class="spec-icon"><i class="fa-regular fa-hard-drive"></i></div>
                        <div>
                            <div class="spec-label">File Size</div>
                            <div><%= file.fileSize ? formatBytes(file.fileSize) : 'N/A' %></div>
                        </div>
                    </li>
                </ul>
            </div>
            
            <div class="ad-safe-zone d-none d-lg-flex">
                </div>

        </aside>
    </div>

    <div class="mobile-buy-bar">
        <% if (Number(priceDetails.total) === 0) { %>
            <div class="price-display is-free">Free</div>
            <a href="/download?file_id=<%=file._id%>" class="v-pay-btn is-free mb-0">Download</a>
        <% } else { %>
            <div class="price-display">₹<span id="mobileFinalPrice"><%=priceDetails.total.toFixed(2)%></span></div>
            <button id="razorpay-button-mobile" class="v-pay-btn mb-0">Checkout</button>
        <% } %>
    </div>

    <div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen">
            <div class="modal-content">
                <div class="modal-header border-0 position-absolute top-0 end-0 z-3">
                    <button type="button" class="btn-close btn-close-white fs-5" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body d-flex align-items-center justify-content-center p-0 p-md-4">
                    <img id="modalFullImage" src="" alt="Full preview">
                </div>
            </div>
        </div>
    </div>
    
    <%- include('footer') %>

    <div id="toast-msg">
        <i class="icon"></i> <span class="text"></span>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <script>
        const slugifyJS = (text) => text ? text.toLowerCase().trim().replace(/\s+/g, '-').replace(/[^\w\-]+/g, '').replace(/\-\-+/g, '-') : 'file';

        // Template for Compact Google Play Store style cards
        const renderFileCardJS = (doc) => {
            const fileUrl = `/file/${doc.slug || slugifyJS(doc.filename)}/${doc._id}`;
            const isFree = doc.price === 0 || doc.price === '0';
            const priceBadgeText = isFree ? `Free` : `₹${doc.price}`;
            const priceBadgeClass = isFree ? `is-free` : ``;

            return `
                <a href="${fileUrl}" class="related-card">
                    <div class="related-img-box">
                        <div class="v-badge-card">${doc.category || 'Resource'}</div>
                        <img src="${doc.previewUrl && doc.previewUrl.trim() !== '' ? doc.previewUrl : '/images/File_Demo.svg'}" 
                             alt="${doc.filename}" loading="lazy" 
                             onerror="this.onerror=null;this.src='/images/File_Demo.svg';">
                    </div>
                    <div class="related-content">
                        <h3 class="related-title">${doc.filename}</h3>
                        <div class="related-author">${doc.user || 'Vidyari Creator'}</div>
                        <div class="related-price ${priceBadgeClass}">${priceBadgeText}</div>
                    </div>
                </a>
            `;
        };

        document.addEventListener('DOMContentLoaded', function() {
            const currentFileId = "<%= file._id %>";
            const relatedGrid = document.getElementById('relatedGridContainer'); 
            
            // Initialize AdSense manually to ensure it triggers after layout
            try {
                (adsbygoogle = window.adsbygoogle || []).push({});
            } catch (e) {
                console.log('Adsense error', e);
            }
            
            // Modal Sync
            const mainPreviewImage = document.getElementById('mainPreviewImage');
            const modalFullImage = document.getElementById('modalFullImage');
            const imageModalElement = document.getElementById('imageModal');

            if (imageModalElement && mainPreviewImage) {
                imageModalElement.addEventListener('show.bs.modal', () => {
                    if (modalFullImage) modalFullImage.src = mainPreviewImage.src;
                });
            }

            // Like Logic
            const likeButton = document.getElementById('likeButton');
            
            if (likeButton) {
                const fileId = likeButton.dataset.fileId;
                let likeCount = parseInt(likeButton.dataset.likes, 10) || 0;
                let allFiles = JSON.parse(localStorage.getItem("fileData")) || {};
                let isLiked = (allFiles[fileId] && allFiles[fileId].liked) || false;

                const updateUI = () => {
                    likeButton.classList.toggle('liked', isLiked);
                    likeButton.innerHTML = `<i class="fa-${isLiked ? 'solid' : 'regular'} fa-heart"></i> <span>${likeCount} Likes</span>`;
                };

                updateUI();

                likeButton.addEventListener('click', () => {
                    isLiked = !isLiked;
                    likeCount += isLiked ? 1 : -1;
                    
                    if (!allFiles[fileId]) allFiles[fileId] = {};
                    allFiles[fileId].liked = isLiked;
                    localStorage.setItem("fileData", JSON.stringify(allFiles));

                    updateUI();
                    fetch(`/files/impression/${fileId}/${isLiked ? 'like' : 'dislike'}`).catch(console.error);
                });
            }

            // --- Payment & Coupon Logic ---
            const couponInput = document.getElementById('coupon-code');
            const applyBtn = document.getElementById('apply-coupon-btn');
            const totalAmountDisplay = document.getElementById('finalTotalPrice');
            const mobileTotalAmountDisplay = document.getElementById('mobileFinalPrice');
            const discountRowContainer = document.getElementById('dynamic-discount-row');
            
            const payButton = document.getElementById('razorpay-pay-btn');
            const payButtonMobile = document.getElementById('razorpay-button-mobile');
            const toast = document.getElementById('toast-msg');

            let activeData = { total: <%=priceDetails.total%>, discount: 0 };

            function showToast(message, type = 'success') {
                toast.className = `show ${type}`;
                toast.querySelector('.text').textContent = message;
                toast.querySelector('i').className = type === 'success' ? 'fa-solid fa-circle-check' : 'fa-solid fa-circle-exclamation';
                setTimeout(() => { toast.classList.remove('show'); }, 4000);
            }

            function renderSummary() {
                if (activeData.discount > 0) {
                    discountRowContainer.innerHTML = `
                        <div class="invoice-row discount">
                            <span><i class="fa-solid fa-tag me-2"></i> Promo Applied</span>
                            <span>-₹${activeData.discount.toFixed(2)}</span>
                        </div>
                    `;
                } else {
                    discountRowContainer.innerHTML = '';
                }
                const formattedTotal = activeData.total.toFixed(2);
                if(totalAmountDisplay) totalAmountDisplay.textContent = `${formattedTotal}`;
                if(mobileTotalAmountDisplay) mobileTotalAmountDisplay.textContent = formattedTotal;
            }

            if(applyBtn && couponInput) {
                applyBtn.addEventListener('click', async () => {
                    const code = couponInput.value.trim();
                    if(!code) return;
                    
                    applyBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
                    
                    try {
                        const res = await fetch(`/check/coupon?fileId=${currentFileId}&couponCode=${code}&quantity=1`);
                        const data = await res.json();
                        
                        if(data.valid) {
                            const p = data.priceDetails;
                            activeData.total = p.total;
                            activeData.discount = p.originalPrice - p.discountedPrice;
                            renderSummary();
                            showToast(`Code Applied! Saved ₹${activeData.discount.toFixed(2)}`, 'success');
                            couponInput.disabled = true; 
                            applyBtn.innerHTML = '<i class="fa-solid fa-check"></i>';
                            applyBtn.disabled = true;
                        } else {
                            showToast(data.message || "Invalid Code", 'error');
                            applyBtn.textContent = "Apply";
                        }
                    } catch (e) { 
                        showToast("Server Error", 'error');
                        applyBtn.textContent = "Apply";
                    }
                });
            }

            const handlePayment = async function(e) {
                e.preventDefault();
                const btn = e.currentTarget;
                
                const originalContent = btn.innerHTML;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processing...';
                btn.disabled = true;
                
                try {
                    const res = await fetch('/create-order', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ fileId: currentFileId, price: activeData.total, filename: "<%- file.filename ? file.filename.replace(/"/g, '&quot;') : 'Resource' %>", couponCode: couponInput ? couponInput.value.trim() : '' })
                    });
                    const order = await res.json();
                    
                    const options = {
                        key: order.key,
                        amount: order.amount,
                        name: "Vidyari",
                        image:"https://www.vidyari.com/images/logo.svg",
                        description: "<%- file.filename ? file.filename.replace(/"/g, '&quot;') : 'Resource' %>",
                        order_id: order.order_id,
                        theme: { color: "#0b57d0" }, // Google Blue Theme
                        handler: async function (response) {
                            btn.innerHTML = '<i class="fa-solid fa-shield-check"></i> Verifying...';
                            const verify = await fetch('/verify-payment', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    razorpay_order_id: response.razorpay_order_id,
                                    razorpay_payment_id: response.razorpay_payment_id,
                                    razorpay_signature: response.razorpay_signature,
                                    fileId: currentFileId,
                                    totalprice: activeData.total
                                })
                            });
                            const d = await verify.json();
                            if(d.success) {
                                btn.innerHTML = '<i class="fa-solid fa-check"></i> Success!';
                                btn.style.background = 'var(--v-success)';
                                window.location.href = d.downloadUrl;
                            }
                        },
                        modal: { 
                            ondismiss: () => { 
                                btn.disabled = false; 
                                btn.innerHTML = originalContent; 
                            } 
                        }
                    };
                    new Razorpay(options).open();
                } catch (err) { 
                    showToast("Failed to initialize gateway.", "error");
                    btn.disabled = false; 
                    btn.innerHTML = originalContent;
                }
            };

            if(payButton) payButton.addEventListener('click', handlePayment);
            if(payButtonMobile) payButtonMobile.addEventListener('click', handlePayment);

            // Fetch Related Grid - Segregated by Author
            const fetchRelatedFiles = async () => { 
                try {
                    const response = await fetch(`/products/related?fileId=${currentFileId}`);
                    if (!response.ok) throw new Error(`HTTP Error`);
                    const relatedDocs = await response.json();
                    
                    if (relatedDocs && relatedDocs.length > 0) {
                        // Group by Author
                        const groupedDocs = {};
                        relatedDocs.forEach(doc => {
                            const author = doc.user || 'Vidyari Creators';
                            if (!groupedDocs[author]) groupedDocs[author] = [];
                            groupedDocs[author].push(doc);
                        });

                        let finalHTML = '';
                        for (const [author, docs] of Object.entries(groupedDocs)) {
                            const cardsHTML = docs.map(doc => renderFileCardJS(doc)).join('');
                            finalHTML += `
                                <div class="v-author-section">
                                    <h3 class="v-author-section-title">
                                        <i class="fa-regular fa-circle-user text-muted"></i> More from ${author}
                                    </h3>
                                    <div class="related-scroll-container">
                                        ${cardsHTML}
                                    </div>
                                </div>
                            `;
                        }
                        relatedGrid.innerHTML = finalHTML;
                    } else {
                        relatedGrid.innerHTML = '<p class="text-muted ps-2" style="font-size: 0.95rem;">No related files found.</p>';
                    }
                } catch (error) {
                    relatedGrid.innerHTML = '<p class="text-danger ps-2" style="font-size: 0.95rem;">Error loading related files.</p>';
                }
            };
            fetchRelatedFiles();
        }); 
    </script>
</body>
</html>