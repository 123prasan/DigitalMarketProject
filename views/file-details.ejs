<%-include("header")%>
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover" />

    <title>
        <% if(file.price==0) { %>
            <%= file.filename || 'File Download' %> • Download | Vidyari
        <% } else { %>
            <%= file.filename || 'File Checkout' %> • Secure Checkout | Vidyari
        <% } %>
    </title>

    <meta name="description" content="Securely purchase and instantly download '<%= file.filename %>'. <%= file.filedescription %> | Vidyari Checkout">
    <meta property="og:type" content="product">
    <meta property="og:title" content="Checkout • <%= file.filename %> | Vidyari">
    <meta property="og:image" content="<%= previewUrl || 'https://vidyari.com/images/logo-1200x630.png' %>">

    <link rel="icon" href="/images/logo.svg" type="image/svg" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;800;900&family=Space+Grotesk:wght@700;900&family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        /* ==========================================================================
           VIDYARI CHECKOUT: RESTRUCTURED NEO-BRUTALISM
           ========================================================================== */
        .vidyari-checkout-master {
            --v-bg: #fdfdfc; 
            --v-black: #09090b;
            --v-white: #ffffff;
            --v-pink: #ff66a3; 
            --v-green: #4ade80; 
            --v-yellow: #ffd60a; 
            --v-blue: #1ac2ff; 
            --v-gray-50: #fafafa;
            --v-gray-100: #f4f4f5;
            --v-gray-200: #e4e4e7;
            --v-gray-800: #27272a;
            
            --v-font-sans: 'Inter', sans-serif;
            --v-font-head: 'Montserrat', sans-serif;
            --v-font-loud: 'Space Grotesk', sans-serif;
            
            --v-border-thin: 2px solid var(--v-black);
            --v-border-thick: 4px solid var(--v-black);
            
            --v-shadow-sm: 4px 4px 0 var(--v-black);
            --v-shadow-md: 8px 8px 0 var(--v-black);
            --v-shadow-hover: 12px 12px 0 var(--v-black);
            
            --v-transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);

            background-color: var(--v-bg);
            /* Subtle Dot Pattern Background to make boxes pop */
            background-image: radial-gradient(var(--v-gray-300) 1px, transparent 1px);
            background-size: 20px 20px;
            
            color: var(--v-black);
            font-family: var(--v-font-sans);
            min-height: 100vh;
            width: 100%;
            overflow-x: hidden; /* Strict horizontal overflow prevention */
            padding-top: clamp(20px, 4vw, 60px);
            padding-bottom: clamp(100px, 10vw, 120px); /* Space for mobile bar */
            box-sizing: border-box;
        }

        .vidyari-checkout-master * { box-sizing: border-box; }
        .vidyari-checkout-master a { text-decoration: none; color: inherit; }
        .vidyari-checkout-master ul { padding: 0; margin: 0; list-style: none; }

        /* Container & Grid Layout */
        .v-container {
            width: 100%;
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 clamp(16px, 5vw, 32px);
        }

        .v-layout-grid {
            display: grid;
            /* grid-template-columns: 1fr 380px; */
            gap: clamp(24px, 4vw, 40px);
            align-items: start;
        }

        /* UI Building Blocks */
        .v-box {
            background: var(--v-white);
            border: var(--v-border-thick);
            border-radius: 20px;
            box-shadow: var(--v-shadow-md);
            padding: clamp(20px, 4vw, 40px);
            margin-bottom: clamp(24px, 4vw, 40px);
            position: relative;
        }

        .v-title {
            font-family: var(--v-font-loud);
            font-size: clamp(2.2rem, 6vw, 4rem);
            text-transform: uppercase;
            line-height: 1.05;
            margin-bottom: 20px;
            text-shadow: 3px 3px 0 var(--v-pink);
            letter-spacing: -1px;
        }

        .v-subtitle {
            font-family: var(--v-font-loud);
            font-weight: 900;
            font-size: clamp(1.5rem, 3vw, 2rem);
            text-transform: uppercase;
            border-bottom: var(--v-border-thick);
            padding-bottom: 12px;
            margin-bottom: 24px;
        }

        .v-badge {
            display: inline-block;
            background: var(--v-yellow);
            border: var(--v-border-thin);
            border-radius: 8px;
            padding: 6px 16px;
            font-family: var(--v-font-loud);
            font-weight: 900;
            font-size: 0.9rem;
            text-transform: uppercase;
            box-shadow: 2px 2px 0 var(--v-black);
            margin-bottom: 20px;
        }

        /* Preview Image */
        .preview-wrapper {
            border: var(--v-border-thick);
            border-radius: 16px;
            box-shadow: var(--v-shadow-md);
            overflow: hidden;
            background: var(--v-gray-100);
            /* aspect-ratio: 1 / 1.2; */
            width: 70%;


            cursor: zoom-in;
            transition: transform var(--v-transition);
        }
        .preview-wrapper:hover { transform: translate(-4px, -4px); box-shadow: var(--v-shadow-hover); }
        .preview-wrapper img { width: 100%; height: 100%; object-fit: cover; }

        /* Creator Bar */
        .creator-bar {
            display: flex;
            align-items: center;
            gap: 16px;
            background: var(--v-white);
            border: var(--v-border-thin);
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 24px;
            box-shadow: var(--v-shadow-sm);
        }
        .creator-pic {
            width: 56px; height: 56px;
            border-radius: 50%;
            border: var(--v-border-thin);
            object-fit: cover;
        }

        /* Spec Grid (New Restructure) */
        .spec-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
            gap: 16px;
            margin-bottom: 32px;
        }
        .spec-card {
            background: var(--v-gray-50);
            border: var(--v-border-thin);
            border-radius: 12px;
            padding: 16px;
            text-align: center;
            box-shadow: 3px 3px 0 var(--v-gray-300);
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .spec-card i { font-size: 1.5rem; color: var(--v-blue); }
        .spec-card .val { font-weight: 900; font-size: 1.1rem; }
        .spec-card .lbl { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: var(--v-gray-600); }

        /* Description Content */
        .desc-content {
            font-size: 1.1rem;
            line-height: 1.8;
            color: var(--v-gray-800);
        }
        .desc-content p { margin-bottom: 16px; }

        /* Sidebar Buy Box */
        .sidebar-sticky { position: sticky; top: 100px; }
        
        .price-display {
            font-family: var(--v-font-loud);
            font-size: clamp(3rem, 5vw, 4.5rem);
            color: var(--v-black);
            text-align: center;
            line-height: 1;
            margin: 10px 0 24px 0;
            text-shadow: 4px 4px 0 var(--v-green);
        }
        .price-display.is-free { text-shadow: 4px 4px 0 var(--v-pink); }

        .v-btn-buy {
            width: 100%;
            background: var(--v-green);
            border: var(--v-border-thick);
            border-radius: 12px;
            padding: 20px;
            font-family: var(--v-font-loud);
            font-size: 1.3rem;
            font-weight: 900;
            text-transform: uppercase;
            box-shadow: var(--v-shadow-md);
            transition: all var(--v-transition);
            display: flex; justify-content: center; align-items: center; gap: 12px;
            color: var(--v-black);
            cursor: pointer;
        }
        .v-btn-buy:hover { transform: translate(-4px, -4px); box-shadow: var(--v-shadow-hover); background: var(--v-yellow); }
        .v-btn-buy:active { transform: translate(2px, 2px); box-shadow: 2px 2px 0 var(--v-black); }
        .v-btn-buy.is-free { background: var(--v-pink); text-shadow: 1px 1px 0 var(--v-white); }

        .trust-badges { margin-top: 24px; padding-top: 24px; border-top: 3px dashed var(--v-gray-200); }
        .trust-badges li { display: flex; align-items: center; gap: 12px; font-weight: 800; font-size: 1rem; margin-bottom: 16px; }
        .trust-badges i { color: var(--v-blue); font-size: 1.4rem; }

        /* Action Buttons */
        .action-row { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 32px; }
        .v-btn-like {
            background: var(--v-white); border: var(--v-border-thin); border-radius: 12px;
            padding: 12px 24px; font-weight: 900; font-size: 1.1rem; box-shadow: 3px 3px 0 var(--v-black);
            display: inline-flex; align-items: center; gap: 10px; transition: all var(--v-transition);
        }
        .v-btn-like:hover { background: var(--v-yellow); transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--v-black); }
        .v-btn-like.liked { background: var(--v-pink); color: var(--v-white); }

        /* Related Grid */
        .v-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 24px; }
        .v-card { 
            background: var(--v-white); border: var(--v-border-thick); border-radius: 16px; 
            box-shadow: var(--v-shadow-md); display: flex; flex-direction: column; overflow: hidden; 
            transition: all var(--v-transition); text-decoration: none; color: inherit;
        }
        .v-card:hover { transform: translate(-6px, -6px); box-shadow: var(--v-shadow-hover); }
        .v-card-img-box { aspect-ratio: 4/3; border-bottom: var(--v-border-thick); overflow: hidden; position: relative; background: var(--v-gray-100); }
        .v-card-img { width: 100%; height: 100%; object-fit: cover; }
        .v-badge-card { position: absolute; top: 12px; left: 12px; background: var(--v-yellow); border: var(--v-border-thin); border-radius: 8px; padding: 4px 10px; font-size: 0.8rem; font-weight: 900; text-transform: uppercase; }
        .v-card-content { padding: 20px; flex: 1; }
        .v-card-title { font-size: 1.2rem; font-weight: 800; margin-bottom: 8px; line-height: 1.3; }
        .v-card-footer { padding: 16px 20px; border-top: var(--v-border-thick); background: var(--v-gray-50); display: flex; justify-content: space-between; align-items: center; }
        .v-price { font-size: 1.1rem; font-weight: 900; padding: 6px 16px; border: var(--v-border-thin); border-radius: 8px; box-shadow: 2px 2px 0 var(--v-black); }
        .v-price.is-free { background: var(--v-green); }
        .v-price.is-paid { background: var(--v-pink); }
        .v-card-action { width: 36px; height: 36px; border: var(--v-border-thin); border-radius: 50%; display: grid; place-items: center; background: var(--v-white); box-shadow: 2px 2px 0 var(--v-black); font-size: 1.2rem;}

        /* Modal Overrides */
        #imageModal .modal-content { background: rgba(0,0,0,0.95); }
        #imageModal .btn-close { filter: invert(1); opacity: 1; margin: 20px; }
        #imageModal img { max-width: 95vw; max-height: 90vh; object-fit: contain; }

        /* ==========================================================================
           MOBILE RESPONSIVENESS FIXES
           ========================================================================== */
        @media (max-width: 991px) {
            /* .v-layout-grid { grid-template-columns: 1fr; } */
            /* .sidebar-box { display: none; } Hide right column completely */
            
           .preview-wrapper {
             width: 100%;
           }
            
        }
        
    </style>
</head>

<body>
    <% 
    const formatBytes = (bytes, decimals=2) => {
        if (!+bytes) return '0 Bytes';
        const k = 1024; const dm = decimals < 0 ? 0 : decimals;
        const sizes = ['Bytes', 'KB' , 'MB' , 'GB' , 'TB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return `${parseFloat((bytes / Math.pow(k, i)).toFixed(dm))} ${sizes[i]}`;
    }; 
    %>

    <div class="vidyari-checkout-master">
        <div class="v-container">
            
            <div class="v-layout-grid">
                
                <div class="main-column">
                    <div class="v-box">
                        <span class="v-badge"><%= file.category || 'Resource' %></span>
                        <h1 class="v-title"><%- file.filename || 'Untitled Document' %></h1>
                        
                        <div class="creator-bar">
                            <img src="<%= sellerprofilepic && sellerprofilepic.trim() !== '' ? sellerprofilepic : '/images/avatar.jpg' %>" alt="Creator" class="creator-pic" onerror="this.onerror=null; this.src='/images/avatar.jpg';">
                            <div>
                                <div class="text-muted small fw-bold text-uppercase">Created By</div>
                                <a href="/profile/<%= file.user || 'admin' %>" class="fw-bold fs-5">
                                    <%= file.user || 'Vidyari Team' %>
                                    <% if (ISVERIFIED) { %> <img style="width:20px; margin-left:6px;" src="/images/verify.png" alt="Verified"> <% } %>
                                </a>
                            </div>
                        </div>

                        <div class="preview-wrapper mb-4" data-bs-toggle="modal" data-bs-target="#imageModal">
                            <img id="mainPreviewImage" 
                                src="<%= (previewUrl && typeof previewUrl === 'string' && previewUrl.trim() !== '') ? previewUrl : '/images/File_Demo.svg' %>" 
                                alt="<%= file.filename %>" 
                                onerror="this.onerror=null;this.src='/images/File_Demo.svg';">
                        </div>

                        <div class="action-row">
                            <button class="v-btn-like" id="likeButton" data-file-id="<%= file._id %>" data-likes="<%= file.likes %>">
                                </button>
                            <div><%-include("share")%></div>
                        </div>

                        <div class="spec-grid">
                            <div class="spec-card">
                                <i class="fas fa-star"></i>
                                <span class="val">4.5 / 5.0</span>
                                <span class="lbl">Rating</span>
                            </div>
                            <div class="spec-card">
                                <i class="fas fa-download"></i>
                                <span class="val"><%= (file.downloadCount || 0).toLocaleString() %></span>
                                <span class="lbl">Downloads</span>
                            </div>
                            <div class="spec-card">
                                <i class="fas fa-file-code"></i>
                                <span class="val"><%= file.fileType || 'PDF' %></span>
                                <span class="lbl">Format</span>
                            </div>
                            <div class="spec-card">
                                <i class="fas fa-hdd"></i>
                                <span class="val"><%= file.fileSize ? formatBytes(file.fileSize) : 'N/A' %></span>
                                <span class="lbl">Size</span>
                            </div>
                        </div>
                                        <div class="sidebar-box">
                    <div class="v-box sidebar-sticky" style="border-width: 6px;">
                        <div class="text-center fw-bold text-muted text-uppercase mb-2">Total Price</div>
                        
                        <% if (Number(file.price) === 0) { %>
                            <div class="price-display is-free">FREE</div>
                            <a href="/download?file_id=<%=file._id%>" class="v-btn-buy is-free" id="downloadBtn">
                                <i class="fa-solid fa-download"></i> Download
                            </a>
                        <% } else { %>
                            <div class="price-display">₹<%= Number(file.price).toLocaleString('en-IN') %></div>
                            <button id="rzp-button" class="v-btn-buy" type="button">
                                <i class="fa-solid fa-cart-shopping"></i> Checkout
                            </button>
                        <% } %>

                        
                    </div>
                </div>
                    </div>

                    <% if (file.filedescription) { %>
                        <div class="v-box">
                            <h2 class="v-subtitle">Description</h2>
                            <div class="desc-content">
                                <%- file.filedescription %>
                            </div>
                        </div>
                    <% } %>

                    <div class="mt-4 mb-5"><%- include("reporttemplate") %></div>

                    <div class="v-box" style="background: transparent; box-shadow: none; border: none; padding: 0;">
                        <h2 class="v-subtitle" style="border-color: var(--v-black);">More Like This</h2>
                        <div class="v-grid" id="relatedGrid">
                            <p class="fw-bold text-muted fs-5">Loading similar files...</p>
                        </div>
                    </div>
                </div>



            </div>
            
            <%- include("chat") %>

        </div>
    </div>

    <div class="mobile-buy-bar">
        <% if (Number(file.price) === 0) { %>
            <div class="price-display is-free">FREE</div>
            <a href="/download?file_id=<%=file._id%>" class="v-btn-buy is-free">Download</a>
        <% } else { %>
            <div class="price-display">₹<%= Number(file.price).toLocaleString('en-IN') %></div>
            <button id="rzp-button-mobile" class="v-btn-buy">Checkout</button>
        <% } %>
    </div>

    <div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen">
            <div class="modal-content">
                <div class="modal-header border-0 position-absolute top-0 end-0 z-3">
                    <button type="button" class="btn-close fs-1" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body d-flex align-items-center justify-content-center p-0">
                    <img id="modalFullImage" src="" alt="Full preview" style="border: 6px solid white; border-radius: 16px; background: white;">
                </div>
            </div>
        </div>
    </div>
    
    <%- include('footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const slugifyJS = (text) => text ? text.toLowerCase().trim().replace(/\s+/g, '-').replace(/[^\w\-]+/g, '').replace(/\-\-+/g, '-') : 'file';

        const renderFileCardJS = (doc) => {
            const fileUrl = `/file/${doc.slug || slugifyJS(doc.filename)}/${doc._id}`;
            const isFree = doc.price === 0 || doc.price === '0';
            const priceBadgeText = isFree ? `FREE` : `₹${doc.price}`;
            const priceBadgeClass = isFree ? `is-free` : `is-paid`;

            return `
                <a href="${fileUrl}" class="v-card">
                    <div class="v-card-img-box">
                        <div class="v-badge-card">${doc.category || 'Resource'}</div>
                        <img src="${doc.previewUrl && doc.previewUrl.trim() !== '' ? doc.previewUrl : '/images/File_Demo.svg'}" 
                             alt="${doc.filename}" class="v-card-img" loading="lazy" 
                             onerror="this.onerror=null;this.src='/images/File_Demo.svg';">
                    </div>
                    <div class="v-card-content">
                        <h3 class="v-card-title">${doc.filename}</h3>
                        <div class="small fw-bold text-muted"><i class="fas fa-user-circle"></i> ${doc.user || 'Admin'}</div>
                    </div>
                    <div class="v-card-footer">
                        <div class="v-price ${priceBadgeClass}">${priceBadgeText}</div>
                        <div class="v-card-action"><i class="fas fa-arrow-right"></i></div>
                    </div>
                </a>
            `;
        };

        document.addEventListener('DOMContentLoaded', function() {
            const currentFileId = "<%= file._id %>";
            const relatedGrid = document.getElementById('relatedGrid'); 
            
            // Modal Sync
            const mainPreviewImage = document.getElementById('mainPreviewImage');
            const modalFullImage = document.getElementById('modalFullImage');
            const imageModalElement = document.getElementById('imageModal');

            if (imageModalElement && mainPreviewImage) {
                imageModalElement.addEventListener('show.bs.modal', () => {
                    if (modalFullImage) modalFullImage.src = mainPreviewImage.src;
                });
            }

            // Neo-Brutalist Like Logic
            const likeButton = document.getElementById('likeButton');
            if (likeButton) {
                const fileId = likeButton.dataset.fileId;
                let likeCount = parseInt(likeButton.dataset.likes, 10);
                let allFiles = JSON.parse(localStorage.getItem("fileData")) || {};
                let isLiked = (allFiles[fileId] && allFiles[fileId].liked) || false;

                const updateUI = () => {
                    likeButton.classList.toggle('liked', isLiked);
                    likeButton.innerHTML = `
                        <i class="fa-${isLiked ? 'solid' : 'regular'} fa-heart"></i>
                        <span>${likeCount}</span>
                    `;
                };

                updateUI();

                likeButton.addEventListener('click', () => {
                    isLiked = !isLiked;
                    likeCount += isLiked ? 1 : -1;
                    
                    if (!allFiles[fileId]) allFiles[fileId] = {};
                    allFiles[fileId].liked = isLiked;
                    localStorage.setItem("fileData", JSON.stringify(allFiles));

                    updateUI();
                    fetch(`/files/impression/${fileId}/${isLiked ? 'like' : 'dislike'}`).catch(console.error);
                });
            }
            
            // Checkout Handlers (Bind both Desktop and Mobile buttons)
            const rzpBtn = document.getElementById('rzp-button');
            const rzpBtnMobile = document.getElementById('rzp-button-mobile');
            const handleCheckout = (e) => {
                window.location.href = "/checkout?fileId=" + currentFileId;
                e.preventDefault();
            };
            if (rzpBtn) rzpBtn.onclick = handleCheckout;
            if (rzpBtnMobile) rzpBtnMobile.onclick = handleCheckout;

            // Fetch Related Grid
            const fetchRelatedFiles = async () => { 
                try {
                    const response = await fetch(`/products/related?fileId=${currentFileId}`);
                    if (!response.ok) throw new Error(`HTTP Error`);
                    const relatedDocs = await response.json();
                    
                    if (relatedDocs && relatedDocs.length > 0) {
                        relatedGrid.innerHTML = relatedDocs.map(doc => renderFileCardJS(doc)).join(''); 
                    } else {
                        relatedGrid.innerHTML = '<p class="fw-bold text-muted fs-5">No related files found.</p>';
                    }
                } catch (error) {
                    relatedGrid.innerHTML = '<p class="fw-bold text-danger fs-5">Error loading files.</p>';
                }
            };
            fetchRelatedFiles();
        }); 
    </script>
</body>
</html>