    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* ==========================================================================
           VIDYARI PRICING: GEMINI / MATERIAL 3 THEME
           ========================================================================== */
        
        :root {
            --v-bg: #f0f4f9;           
            --v-surface: #ffffff;      
            
            --v-text-main: #1f1f1f;
            --v-text-muted: #444746;
            
            --v-primary: #0b57d0;      
            --v-primary-hover: #1a73e8;
            --v-primary-bg: #e8f0fe;
            
            --v-success: #146c2e;
            --v-success-bg: #e6f4ea;
            
            --v-border: #e3e3e3;
            
            --v-font-display: 'Outfit', sans-serif;
            --v-font-sans: 'Inter', sans-serif;
            
            --v-radius-sm: 12px;
            --v-radius-md: 16px;
            --v-radius-lg: 24px;
            --v-radius-pill: 9999px;
            
            --v-shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05);
            --v-shadow-md: 0 4px 12px rgba(0, 0, 0, 0.05);
            --v-shadow-hover: 0 8px 24px rgba(11, 87, 208, 0.08);
            
            --v-transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
        }

        .v-pricing-master {
            background-color: var(--v-bg);
            color: var(--v-text-main);
            font-family: var(--v-font-sans);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }

        .v-pricing-master *, .v-pricing-master *::before, .v-pricing-master *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        .v-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* Typography */
        .v-heading-xl {
            font-family: var(--v-font-display);
            font-size: clamp(3rem, 6vw, 4.5rem);
            font-weight: 700;
            color: var(--v-text-main);
            line-height: 1.1;
            letter-spacing: -1.5px;
            margin-bottom: 24px;
        }
        .v-heading-lg {
            font-family: var(--v-font-display);
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 600;
            color: var(--v-text-main);
            margin-bottom: 20px;
            letter-spacing: -1px;
        }
        .v-subtitle {
            font-size: clamp(1.1rem, 2vw, 1.3rem);
            color: var(--v-text-muted);
            line-height: 1.6;
            max-width: 700px;
            margin: 0 auto;
        }

        /* Hero Section */
        .v-hero {
            text-align: center;
            padding: clamp(60px, 10vw, 100px) 20px;
            position: relative;
        }
        .v-eyebrow {
            display: inline-block;
            background: var(--v-primary-bg);
            color: var(--v-primary);
            padding: 6px 16px;
            border-radius: var(--v-radius-pill);
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 24px;
        }

        /* Split Pricing Grid */
        .v-pricing-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
            margin-top: -20px;
            margin-bottom: 80px;
        }
        @media (max-width: 768px) {
            .v-pricing-grid { grid-template-columns: 1fr; }
        }

        .v-price-card {
            background: var(--v-surface);
            border: 1px solid var(--v-border);
            border-radius: var(--v-radius-lg);
            padding: 48px 32px;
            text-align: center;
            box-shadow: var(--v-shadow-sm);
            transition: var(--v-transition);
        }
        .v-price-card:hover {
            box-shadow: var(--v-shadow-md);
            transform: translateY(-4px);
        }
        .v-price-card.highlight {
            background: var(--v-primary-bg);
            border-color: var(--v-primary);
            box-shadow: var(--v-shadow-md);
        }

        .v-price-percent {
            font-family: var(--v-font-display);
            font-size: clamp(4rem, 8vw, 6rem);
            font-weight: 800;
            color: var(--v-text-main);
            line-height: 1;
            margin-bottom: 12px;
        }
        .v-price-card.highlight .v-price-percent { color: var(--v-primary); }
        
        .v-price-label {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--v-text-main);
            margin-bottom: 16px;
        }
        .v-price-desc {
            color: var(--v-text-muted);
            font-size: 1.1rem;
            line-height: 1.5;
            max-width: 300px;
            margin: 0 auto;
        }

        /* Features Section */
        .v-features-section {
            background: var(--v-surface);
            border-radius: var(--v-radius-lg);
            padding: clamp(40px, 8vw, 80px) clamp(24px, 5vw, 60px);
            margin-bottom: 80px;
            box-shadow: var(--v-shadow-sm);
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
        }
        @media (max-width: 992px) {
            .v-features-section { grid-template-columns: 1fr; gap: 40px; }
        }
        
        .v-feature-list { list-style: none; display: flex; flex-direction: column; gap: 24px; }
        .v-feature-item { display: flex; align-items: flex-start; gap: 16px; }
        .v-feature-icon {
            width: 32px; height: 32px; border-radius: 50%;
            background: var(--v-success-bg); color: var(--v-success);
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; flex-shrink: 0; margin-top: 4px;
        }
        .v-feature-text h4 { font-size: 1.2rem; font-weight: 600; margin-bottom: 4px; }
        .v-feature-text p { color: var(--v-text-muted); font-size: 1rem; }

        /* FAQ Section */
        .v-faq-section {
            max-width: 800px;
            margin: 0 auto 100px;
        }
        .v-faq-item {
            background: var(--v-surface);
            border: 1px solid var(--v-border);
            border-radius: var(--v-radius-md);
            margin-bottom: 16px;
            transition: var(--v-transition);
            overflow: hidden;
        }
        .v-faq-item:hover { border-color: #d2e3fc; box-shadow: var(--v-shadow-sm); }
        .v-faq-trigger {
            padding: 24px;
            display: flex; justify-content: space-between; align-items: center;
            cursor: pointer; width: 100%; text-align: left;
            font-family: var(--v-font-display); font-size: 1.2rem; font-weight: 500;
            color: var(--v-text-main); background: transparent; border: none; outline: none;
        }
        .v-faq-icon {
            color: var(--v-text-muted); transition: transform 0.3s ease;
        }
        .v-faq-item.active .v-faq-icon {
            transform: rotate(45deg); color: var(--v-primary);
        }
        .v-faq-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }
        .v-faq-content-inner {
            padding: 0 24px 24px;
            color: var(--v-text-muted);
            font-size: 1.05rem;
            line-height: 1.6;
        }

        /* CTA Section */
        .v-cta-section {
            background: var(--v-surface);
            border-radius: var(--v-radius-lg);
            padding: clamp(60px, 10vw, 100px) 20px;
            text-align: center;
            box-shadow: var(--v-shadow-sm);
            margin-bottom: 60px;
        }
        .v-btn-primary {
            display: inline-flex; align-items: center; justify-content: center;
            background: var(--v-primary); color: white;
            padding: 18px 40px; border-radius: var(--v-radius-pill);
            font-family: var(--v-font-sans); font-size: 1.15rem; font-weight: 500;
            text-decoration: none; transition: var(--v-transition);
            margin-top: 32px;
        }
        .v-btn-primary:hover {
            background: var(--v-primary-hover);
            box-shadow: var(--v-shadow-hover);
            transform: translateY(-2px);
        }
    </style>
</head>
<body>

    <div class="v-pricing-master">
        
        <header class="v-hero">
            <div class="v-container">
                <span class="v-eyebrow">Pricing</span>
                <h1 class="v-heading-xl">Simple, transparent pricing.</h1>
                <p class="v-subtitle">We only make money when you do. No monthly subscriptions, no setup fees, and absolutely no hidden costs.</p>
            </div>
        </header>

        <div class="v-container">
            
            <div class="v-pricing-grid">
                <div class="v-price-card highlight">
                    <div class="v-price-percent">70%</div>
                    <div class="v-price-label">You Keep</div>
                    <p class="v-price-desc">Your earnings on every lecture note, video course, or digital asset you sell.</p>
                </div>
                <div class="v-price-card">
                    <div class="v-price-percent">30%</div>
                    <div class="v-price-label">Platform Fee</div>
                    <p class="v-price-desc">Covers secure file hosting, global payment processing, and high-speed bandwidth.</p>
                </div>
            </div>

            <div class="v-features-section">
                <div>
                    <span class="v-eyebrow" style="background: var(--v-success-bg); color: var(--v-success);">All-In-One Infrastructure</span>
                    <h2 class="v-heading-lg" style="margin-bottom: 24px; text-align: left;">Focus on creating.</h2>
                    <p class="v-subtitle" style="margin: 0; text-align: left; max-width: 100%;">Whether you're selling course videos, e-books, or robust code templates, we handle the heavy lifting of delivery and security so you can focus entirely on scaling your audience.</p>
                </div>
                
                <ul class="v-feature-list">
                    <li class="v-feature-item">
                        <div class="v-feature-icon"><i class="fas fa-check"></i></div>
                        <div class="v-feature-text">
                            <h4>Instant Storefront</h4>
                            <p>Beautiful product pages generated automatically upon file upload.</p>
                        </div>
                    </li>
                    <li class="v-feature-item">
                        <div class="v-feature-icon"><i class="fas fa-check"></i></div>
                        <div class="v-feature-text">
                            <h4>Massive File Support</h4>
                            <p>Upload and sell large resource bundles and files up to 8GB seamlessly.</p>
                        </div>
                    </li>
                    <li class="v-feature-item">
                        <div class="v-feature-icon"><i class="fas fa-check"></i></div>
                        <div class="v-feature-text">
                            <h4>Built-in Video Player</h4>
                            <p>Native, secure streaming integration for your premium video courses.</p>
                        </div>
                    </li>
                </ul>
            </div>

            <div class="v-faq-section">
                <h2 class="v-heading-lg" style="text-align: center; margin-bottom: 48px;">Frequently asked questions</h2>
                
                <div class="v-faq-item">
                    <button class="v-faq-trigger">
                        How do I get paid?
                        <i class="fas fa-plus v-faq-icon"></i>
                    </button>
                    <div class="v-faq-content">
                        <div class="v-faq-content-inner">
                            Once your earnings reach the threshold amount of ₹1000, you can request a withdrawal. Your total earnings will be credited directly to your connected UPI ID or bank account.
                        </div>
                    </div>
                </div>

                <div class="v-faq-item">
                    <button class="v-faq-trigger">
                        What can I sell?
                        <i class="fas fa-plus v-faq-icon"></i>
                    </button>
                    <div class="v-faq-content">
                        <div class="v-faq-content-inner">
                            If it's digital, you can sell it. Our creators successfully sell study guides, video lectures, software source code, research papers, design templates, and complete online courses.
                        </div>
                    </div>
                </div>

                <div class="v-faq-item">
                    <button class="v-faq-trigger">
                        Are there any hidden fees?
                        <i class="fas fa-plus v-faq-icon"></i>
                    </button>
                    <div class="v-faq-content">
                        <div class="v-faq-content-inner">
                            No. Vidyari charges a simple, flat 30% fee on each sale. This single fee covers all payment gateway processing charges, file hosting, bandwidth, and customer support. There are zero monthly subscription fees to use the platform.
                        </div>
                    </div>
                </div>
            </div>

            <div class="v-cta-section">
                <h2 class="v-heading-xl" style="margin-bottom: 16px;">Your Knowledge.<br>Your Currency.</h2>
                <p class="v-subtitle">Join thousands of creators earning money doing what they love.</p>
                <a href="/dashboard" class="v-btn-primary">
                    Start Selling Now <i class="fas fa-arrow-right ms-2"></i>
                </a>
            </div>

        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const faqItems = document.querySelectorAll('.v-faq-item');
            
            faqItems.forEach(item => {
                const trigger = item.querySelector('.v-faq-trigger');
                const content = item.querySelector('.v-faq-content');
                
                trigger.addEventListener('click', () => {
                    const isOpen = item.classList.contains('active');
                    
                    // Close all other accordions
                    faqItems.forEach(otherItem => {
                        otherItem.classList.remove('active');
                        otherItem.querySelector('.v-faq-content').style.maxHeight = null;
                    });

                    // Open clicked if it wasn't already open
                    if (!isOpen) {
                        item.classList.add('active');
                        content.style.maxHeight = content.scrollHeight + 'px';
                    }
                });
            });
        });
    </script>

</body>
</html>
<%- include("../components/footer") %>