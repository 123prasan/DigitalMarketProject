<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover">
    <title>Secure Checkout | Vidyari</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@700;900&display=swap" rel="stylesheet">

<style>
    /* ==========================================================================
       VIDYARI: THE ULTIMATE CONVERSION CHECKOUT
       ========================================================================== */
    :root {
        --font-display: 'Space Grotesk', sans-serif;
        --font-main: 'Inter', sans-serif;
        
        --v-black: #09090b;
        --v-white: #ffffff;
        --v-pink: #ff66a3;
        --v-yellow: #ffd60a;
        --v-green: #00e676;
        --v-blue: #1ac2ff;
        
        --v-gray-50: #f8f9fa;
        --v-gray-200: #e4e4e7;
        --v-gray-800: #27272a;
        
        --border-thick: 3px solid var(--v-black);
        --shadow-hard: 6px 6px 0 var(--v-black);
        --shadow-hover: 10px 10px 0 var(--v-black);
        --transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    body {
        margin: 0;
        font-family: var(--font-main);
        background-color: var(--v-white);
        color: var(--v-black);
        min-height: 100vh;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
    }

    .checkout-layout {
        display: flex;
        min-height: 100vh;
        width: 100%;
    }

    /* ==========================================================================
       LEFT SIDE: PRODUCT SHOWCASE
       ========================================================================== */
    .showcase-panel {
        flex: 1;
        background-color: var(--v-yellow);
        background-image: radial-gradient(#d4b300 2px, transparent 2px);
        background-size: 24px 24px;
        border-right: var(--border-thick);
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        justify-content: center;
        padding: 60px;
        position: relative;
    }

    .showcase-inner {
        max-width: 480px;
        width: 100%;
        background: var(--v-white);
        border: var(--border-thick);
        box-shadow: var(--shadow-hard);
        border-radius: 24px;
        padding: 40px;
    }

    .product-preview-box {
        width: 100%;
        aspect-ratio: 4/3;
        border: var(--border-thick);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 30px;
        background: var(--v-gray-50);
    }
    .product-preview-box img {
        width: 100%; height: 100%; object-fit: cover;
    }

    .v-title-label {
        font-family: var(--font-display);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--v-pink);
        font-weight: 900;
        margin-bottom: 8px;
    }

    .v-product-title {
        font-family: var(--font-display);
        font-size: clamp(2rem, 4vw, 2.8rem);
        line-height: 1.1;
        margin: 0 0 10px 0;
        text-transform: uppercase;
    }

    .v-product-id {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--v-gray-800);
        margin-bottom: 30px;
    }

    .included-list {
        list-style: none;
        padding: 0; margin: 0;
        border-top: 2px dashed var(--v-gray-200);
        padding-top: 24px;
    }
    .included-list li {
        display: flex; align-items: center; gap: 12px;
        font-weight: 700; font-size: 1rem;
        margin-bottom: 16px;
    }
    .included-list i { color: var(--v-green); font-size: 1.2rem; }

    /* ==========================================================================
       RIGHT SIDE: PAYMENT TERMINAL
       ========================================================================== */
    .payment-panel {
        flex: 1.2;
        background-color: var(--v-bg);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 60px;
    }

    .payment-inner {
        max-width: 520px;
        width: 100%;
        margin: 0 auto;
    }

    /* Progress Tracker */
    .progress-tracker {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 50px;
    }
    .step {
        display: flex; align-items: center; gap: 8px;
        font-family: var(--font-display); font-size: 0.85rem; font-weight: 700; text-transform: uppercase;
        color: var(--v-gray-800); opacity: 0.5;
    }
    .step.active { opacity: 1; color: var(--v-black); }
    .step-icon {
        width: 24px; height: 24px; border-radius: 50%; border: 2px solid currentColor;
        display: grid; place-items: center; font-size: 0.7rem;
    }
    .step.active .step-icon { background: var(--v-black); color: var(--v-white); }
    .step-divider { flex: 1; height: 2px; background: var(--v-gray-200); }

    /* Invoice Summary */
    .invoice-section {
        background: var(--v-gray-50);
        border: var(--border-thick);
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 30px;
    }

    .invoice-row {
        display: flex; justify-content: space-between; align-items: center;
        font-size: 1.1rem; font-weight: 600; padding: 12px 0;
    }
    .invoice-row.muted { color: #71717a; font-size: 0.95rem; }
    .invoice-row.discount { color: var(--v-green); font-weight: 800; }
    
    .invoice-total {
        display: flex; justify-content: space-between; align-items: flex-end;
        border-top: var(--border-thick);
        margin-top: 15px; padding-top: 25px;
    }
    .total-lbl { font-family: var(--font-display); font-size: 1.2rem; font-weight: 900; text-transform: uppercase; }
    .total-val { font-family: var(--font-display); font-size: 2.8rem; font-weight: 900; line-height: 1; }

    /* Coupon Field */
    .coupon-box {
        display: flex;
        border: var(--border-thick);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 40px;
        box-shadow: var(--shadow-hard);
        transition: var(--transition);
        background: var(--v-white);
    }
    .coupon-box:focus-within { box-shadow: var(--shadow-hover); transform: translate(-2px, -2px); }
    
    .coupon-input {
        flex: 1; border: none; padding: 20px; font-family: var(--font-main);
        font-weight: 700; font-size: 1rem; outline: none; text-transform: uppercase;
    }
    .coupon-input::placeholder { color: #a1a1aa; font-weight: 500; }
    
    .coupon-btn {
        background: var(--v-black); color: var(--v-white); border: none;
        border-left: var(--border-thick); padding: 0 30px; font-family: var(--font-display);
        font-weight: 900; font-size: 1.1rem; cursor: pointer; transition: background 0.2s;
    }
    .coupon-btn:hover { background: var(--v-blue); color: var(--v-black); }

    /* The Ultimate CTA Button */
    .v-pay-btn {
        width: 100%;
        background: var(--v-green);
        color: var(--v-black);
        border: var(--border-thick);
        border-radius: 16px;
        padding: 24px;
        font-family: var(--font-display);
        font-size: 1.6rem;
        font-weight: 900;
        text-transform: uppercase;
        box-shadow: var(--shadow-hard);
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 16px;
    }
    .v-pay-btn:hover { transform: translate(-4px, -4px); box-shadow: var(--shadow-hover); background: var(--v-yellow); }
    .v-pay-btn:active { transform: translate(2px, 2px); box-shadow: 0 0 0 #000; }

    /* Security Footer */
    .security-footer {
        display: flex; justify-content: center; gap: 30px; margin-top: 40px;
    }
    .sec-item { display: flex; align-items: center; gap: 8px; font-weight: 800; font-size: 0.85rem; color: #71717a; text-transform: uppercase;}
    .sec-item i { font-size: 1.2rem; color: var(--v-black); }

    /* Toast Notification */
    #toast-msg {
        position: fixed; top: 20px; right: 20px;
        background: var(--v-white); border: var(--border-thick);
        padding: 20px 30px; border-radius: 12px; box-shadow: var(--shadow-hard);
        font-family: var(--font-display); font-weight: 900; font-size: 1.1rem; text-transform: uppercase;
        display: flex; align-items: center; gap: 15px;
        transform: translateX(150%); transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        z-index: 9999;
    }
    #toast-msg.show { transform: translateX(0); }
    #toast-msg.success { border-color: var(--v-green); }
    #toast-msg.success i { color: var(--v-green); }
    #toast-msg.error { border-color: var(--v-pink); }
    #toast-msg.error i { color: var(--v-pink); }

    /* Mobile Restructure */
    @media (max-width: 1024px) {
        .checkout-layout { flex-direction: column; }
        .showcase-panel { 
            align-items: center; padding: 40px 20px; border-right: none; 
            border-bottom: var(--border-thick); position: relative; height: auto; 
        }
        .showcase-inner { box-shadow: none; border: none; padding: 0; background: transparent; }
        .product-preview-box { border-radius: 16px; border: var(--border-thick); box-shadow: var(--shadow-hard); background: var(--v-white);}
        
        .payment-panel { padding: 40px 20px; }
        .progress-tracker { display: none; } /* Hide on mobile to save space */
        .invoice-total .total-val { font-size: 2.2rem; }
    }
</style>
</head>
<body>

<div class="checkout-layout">
    
    <aside class="showcase-panel">
        <div class="showcase-inner">
            <div class="v-title-label">You are purchasing</div>
            <h1 class="v-product-title"><%=file.title%></h1>
            <div class="v-product-id"><%=file.filename%> • Ref: #<%= file._id.toString().substring(0,6).toUpperCase() %></div>

            <div class="product-preview-box">
                <img src="<%= file.imageType ? `https://d3epchi0htsp3c.cloudfront.net/files-previews/images/${file._id}.${file.imageType}` : '/images/File-Demo.svg' %>" alt="<%= file.filename %>">
            </div>

            <ul class="included-list">
                <li><i class="fas fa-circle-check"></i> Lifetime Digital Access</li>
                <li><i class="fas fa-circle-check"></i> Instant Download Link</li>
                <li><i class="fas fa-circle-check"></i> Verified Creator Asset</li>
            </ul>
        </div>
    </aside>

    <main class="payment-panel">
        <div class="payment-inner">
            
            <div class="progress-tracker">
                <div class="step"><div class="step-icon"><i class="fas fa-check"></i></div> Account</div>
                <div class="step-divider"></div>
                <div class="step active"><div class="step-icon">2</div> Payment</div>
                <div class="step-divider"></div>
                <div class="step"><div class="step-icon">3</div> Download</div>
            </div>

            <div class="invoice-section">
                <div class="invoice-row">
                    <span>Base Asset Price</span>
                    <span>₹<%=priceDetails.originalPrice.toFixed(2)%></span>
                </div>
                <div class="invoice-row muted">
                    <span>Platform </span>
                    <span>₹<%=(priceDetails.serviceFee + priceDetails.gstTax).toFixed(2)%></span>
                </div>
                <div id="dynamic-discount-row">
                    </div>

                <div class="invoice-total">
                    <div class="total-lbl">Total Due</div>
                    <div class="total-val">₹<span id="finalTotalPrice"><%=priceDetails.total%></span></div>
                </div>
            </div>

            <div class="coupon-box">
                <input type="text" id="coupon-code" class="coupon-input" placeholder="Enter Promo Code" autocomplete="off" spellcheck="false">
                <button id="apply-coupon-btn" class="coupon-btn">Apply</button>
            </div>

            <button type="button" class="v-pay-btn" id="razorpay-pay-btn">
                <span>Buy Now</span>
                <i class="fas fa-lock"></i>
            </button>

            <div class="security-footer">
                <div class="sec-item"><i class="fas fa-shield-halved"></i> 256-Bit SSL</div>
                <div class="sec-item"><i class="fas fa-credit-card"></i> Secure Gateway</div>
            </div>

        </div>
    </main>
</div>

<div id="toast-msg">
    <i class="icon"></i> <span class="text"></span>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
    const fileId = "<%=file._id%>";
    const originalPrice = <%=priceDetails.originalPrice%>; 
    const fees = <%=priceDetails.serviceFee + priceDetails.gstTax%>;

    const couponInput = document.getElementById('coupon-code');
    const applyBtn = document.getElementById('apply-coupon-btn');
    const totalAmountDisplay = document.getElementById('finalTotalPrice');
    const discountRowContainer = document.getElementById('dynamic-discount-row');
    const payButton = document.getElementById('razorpay-pay-btn');
    const toast = document.getElementById('toast-msg');

    let activeData = { total: <%=priceDetails.total%>, discount: 0 };

    // --- Toast Function ---
    function showToast(message, type = 'success') {
        toast.className = `show ${type}`;
        toast.querySelector('.text').textContent = message;
        toast.querySelector('i').className = type === 'success' ? 'fas fa-check-circle' : 'fas fa-exclamation-circle';
        setTimeout(() => { toast.classList.remove('show'); }, 4000);
    }

    // --- Render Pricing ---
    function renderSummary() {
        if (activeData.discount > 0) {
            discountRowContainer.innerHTML = `
                <div class="invoice-row discount">
                    <span><i class="fas fa-tag me-2"></i> Promo Applied</span>
                    <span>-₹${activeData.discount.toFixed(2)}</span>
                </div>
            `;
        } else {
            discountRowContainer.innerHTML = '';
        }
        totalAmountDisplay.textContent = activeData.total.toFixed(2);
    }

    // --- Coupon Logic ---
    applyBtn.addEventListener('click', async () => {
        const code = couponInput.value.trim();
        if(!code) return;
        
        applyBtn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i>';
        
        try {
            const res = await fetch(`/check/coupon?fileId=${fileId}&couponCode=${code}&quantity=1`);
            const data = await res.json();
            
            if(data.valid) {
                const p = data.priceDetails;
                activeData.total = p.total;
                activeData.discount = p.originalPrice - p.discountedPrice;
                renderSummary();
                showToast(`Code Applied! Saved ₹${activeData.discount.toFixed(2)}`, 'success');
                couponInput.disabled = true; // Lock input after success
                applyBtn.innerHTML = '<i class="fas fa-check"></i>';
                applyBtn.disabled = true;
            } else {
                showToast(data.message || "Invalid Code", 'error');
                applyBtn.textContent = "Apply";
            }
        } catch (e) { 
            showToast("Server Error", 'error');
            applyBtn.textContent = "Apply";
        }
    });

    // --- Razorpay Payment Logic ---
    payButton.onclick = async function(e) {
        e.preventDefault();
        
        // Button Loading State
        const originalContent = payButton.innerHTML;
        payButton.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i>';
        payButton.style.background = 'var(--v-yellow)';
        payButton.disabled = true;
        
        try {
            const res = await fetch('/create-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ fileId: fileId, price: activeData.total, filename: "<%= file.filename %>", couponCode: couponInput.value.trim() })
            });
            const order = await res.json();
            
            const options = {
                key: order.key,
                amount: order.amount,
                name: "Vidyari",
                description: "<%= file.filename %>",
                order_id: order.order_id,
                theme: { color: "#09090b" }, // Jet Black Theme
                handler: async function (response) {
                    payButton.innerHTML = 'VERIFYING... <i class="fas fa-shield-check"></i>';
                    const verify = await fetch('/verify-payment', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            razorpay_order_id: response.razorpay_order_id,
                            razorpay_payment_id: response.razorpay_payment_id,
                            razorpay_signature: response.razorpay_signature,
                            fileId: fileId,
                            totalprice: activeData.total
                        })
                    });
                    const d = await verify.json();
                    if(d.success) {
                        payButton.innerHTML = 'SUCCESS! <i class="fas fa-check"></i>';
                        payButton.style.background = 'var(--v-green)';
                        window.location.href = d.downloadUrl;
                    }
                },
                modal: { 
                    ondismiss: () => { 
                        payButton.disabled = false; 
                        payButton.innerHTML = originalContent; 
                        payButton.style.background = 'var(--v-green)';
                    } 
                }
            };
            new Razorpay(options).open();
        } catch (err) { 
            showToast("Failed to initialize gateway.", "error");
            payButton.disabled = false; 
            payButton.innerHTML = originalContent;
            payButton.style.background = 'var(--v-green)';
        }
    };
</script>
</body>
</html>