<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vidyari</title>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3321203820490717" crossorigin="anonymous"></script>
    <meta name="google-site-verification" content="Hcnu9BHn9udbxOrSebP2NCm4kTf0IwYg9mStgcwI0BU" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;800;900&family=Space+Grotesk:wght@700;900&family=Inter:wght@400;600;700;800&family=Poppins:wght@900&display=swap" rel="stylesheet">
    
    <link rel="icon" type="image/svg+xml" href="/images/logo.svg">
    <link rel="alternate icon" type="image/png" href="/images/logo.png">
    <link rel="manifest" href="/manifest.json">
    <meta property="og:title" content="Vidyari">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.vidyari.com/">
    <meta property="og:image" content="https://www.vidyari.com/images/logo.svg">
    <meta property="og:description" content="Vidyari - Study materials, courses, and resources for learners">
    <meta property="og:site_name" content="Vidyari">

    <style>
/* ------------------------------------------------------------------- */
/* ------------------- BEAUTIFIED NEO-BRUTALIST CSS ------------------ */
/* ------------------------------------------------------------------- */

        :root {
            --font-main: 'Inter', sans-serif;
            --font-logo: 'Poppins', sans-serif; 
            --font-display: 'Montserrat', sans-serif;
            --color-bg: #fdfdfc; /* Slightly warmer white for premium feel */
            --color-black: #09090b;
            --color-primary: #ff66a3; /* Vibrant Pink */
            --color-secondary: #4ade80; /* Punchy Green */
            --color-accent: #ffd60a;   /* Electric Yellow */
            --color-focus: #1ac2ff;   
            --color-purple: #c4b5fd;
            --color-error: #ff3333;  
            /* Spring physics for beautiful bounce effects */
            --bounce-fast: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            --transition-smooth: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            --border-width: 3px;
        }

        body {
            background-color: var(--color-bg);
            font-family: var(--font-main);
            color: var(--color-black);
            line-height: 1.6;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* ========================================================= */
        /* HEADER STYLES                                             */
        /* ========================================================= */
        .site-header {
            background-color: var(--color-bg);
            border-bottom: 2px solid rgba(0,0,0,0.03); 
            position: sticky;
            top: 0;
            z-index: 1020;
            padding: 1.25rem 2.5rem; 
            transition: all var(--transition-smooth); 
        }
        .site-header.scrolled {
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
            padding: 0.85rem 2.5rem; 
            background-color: rgba(253, 253, 252, 0.95);
            backdrop-filter: blur(8px);
        }
        
        /* Logo - Glowing & Bouncy */
        .brand-name { 
            font-family: var(--font-logo); 
            font-size: 2.8rem; 
            font-weight: 900; 
            color: var(--color-black); 
            line-height: 1;
            text-shadow: 3px 3px 0 var(--color-primary), 0px 0px 12px rgba(255,102,163,0.5); 
            letter-spacing: -1.5px;
            transition: all var(--bounce-fast);
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }
        .brand-name:hover {
            transform: scale(1.05) rotate(-1deg);
            text-shadow: 4px 4px 0 var(--color-accent), 0px 0px 16px rgba(255,214,10,0.6);
            color: var(--color-black);
        }

        /* Highlighter Nav Links */
        .main-nav {
            display: flex;
            gap: 2.5rem;
            align-items: center;
        }
        .main-nav a {
            color: var(--color-black); 
            font-weight: 800; 
            font-size: 1.05rem; 
            text-decoration: none;
            font-family: var(--font-display);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            position: relative;
            padding: 4px 8px;
            z-index: 1;
            transition: color var(--transition-smooth);
        }
        .main-nav a::before {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 35%;
            background-color: var(--color-accent);
            z-index: -1;
            transform: scaleY(0);
            transform-origin: bottom;
            transition: transform var(--bounce-fast);
            border-radius: 2px;
        }
        .main-nav a:hover::before {
            transform: scaleY(1.2);
        }
        
        /* The Pill Buttons (Bell, Chat, Apps) */
        .header-actions-group { 
            display: flex;
            align-items: center;
            gap: 1.2rem; 
        }
        
        .neo-pill-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: var(--border-width) solid var(--color-black);
            border-radius: 16px; /* Smooth pill */
            padding: 10px 26px; 
            font-size: 1.3rem;
            color: var(--color-black);
            box-shadow: 4px 4px 0 var(--color-black); 
            transition: all var(--bounce-fast);
            cursor: pointer;
            text-decoration: none;
            height: 52px; /* Fixed height for perfect alignment */
        }
        
        .neo-pill-btn:hover {
            transform: translate(2px, 2px);
            box-shadow: 2px 2px 0 var(--color-black);
        }
        .neo-pill-btn:active {
            transform: translate(4px, 4px);
            box-shadow: 0 0 0 var(--color-black);
        }
        
        /* Playful icon hover animations */
        .neo-pill-btn:hover i.fa-bell { animation: ring 0.4s ease-in-out; }
        .neo-pill-btn:hover i.fa-comments { transform: scale(1.1); transition: transform 0.2s; }
        
        @keyframes ring {
            0% { transform: rotate(0deg); }
            25% { transform: rotate(15deg); }
            50% { transform: rotate(-15deg); }
            75% { transform: rotate(10deg); }
            100% { transform: rotate(0deg); }
        }

        .pill-pink { background-color: var(--color-primary); }
        .pill-white { background-color: #ffffff; }
        .pill-yellow { background-color: var(--color-accent); }

        /* Premium Avatar Ring */
        .header-avatar-container {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3px; 
            border-radius: 50%;
            border: 3px solid var(--color-primary); 
            box-shadow: 0 0 0 4px rgba(255,102,163,0.1); 
            margin-left: 0.5rem;
            cursor: pointer;
            transition: all var(--bounce-fast);
        }
        .header-avatar-container:hover {
            transform: scale(1.1);
            box-shadow: 0 0 0 6px rgba(255,102,163,0.2); 
            border-color: var(--color-accent);
        }
        .user-avatar { 
            width: 44px; 
            height: 44px; 
            border-radius: 50%; 
            object-fit: cover;
            border: 2px solid var(--color-black);
        } 

        /* ========================================================= */
        /* DROPDOWNS & MENUS                                         */
        /* ========================================================= */
        
        .dropdown-menu {
            border: 4px solid var(--color-black) !important;
            box-shadow: 8px 8px 0 var(--color-black) !important;
            border-radius: 16px !important;
            padding: 0 !important;
            overflow: hidden;
            margin-top: 18px !important;
            transform-origin: top right;
            animation: popIn var(--bounce-fast) forwards;
        }
        
        @keyframes popIn {
            0% { opacity: 0; transform: scale(0.9) translateY(-10px); }
            100% { opacity: 1; transform: scale(1) translateY(0); }
        }

        .dropdown-item {
            font-family: var(--font-display);
            font-weight: 800 !important;
            text-transform: uppercase;
            font-size: 0.9rem !important;
            padding: 14px 24px !important;
            border-bottom: 2px solid #f0f0f0;
            transition: all var(--transition-smooth);
        }
        .dropdown-item:hover {
            background-color: var(--color-accent) !important;
            color: var(--color-black) !important;
            padding-left: 30px !important; /* Slide arrow effect */
        }

        /* Apps Grid Dropdown */
        .apps-dropdown { 
            width: 340px; background: #ffffff; border: 4px solid #000; 
            border-radius: 18px; padding: 24px; box-shadow: 8px 8px 0 #000; 
            display: none; position: absolute; top: calc(100% + 15px); right: 0; z-index: 1021; 
            transform-origin: top right;
        }
        .apps-dropdown.is-open { display: block; animation: popIn var(--bounce-fast) forwards; }

        .apps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
        .app-item { 
            text-decoration: none; color: #000; background: #fff; 
            border: 3px solid #000; border-radius: 14px; padding: 16px 10px; 
            display: flex; flex-direction: column; align-items: center; gap: 10px; 
            transition: all var(--bounce-fast); 
            box-shadow: 3px 3px 0 #000;
        }
        .app-item:hover { 
            transform: translate(-3px, -3px); box-shadow: 6px 6px 0 #000; 
            background: var(--color-bg); 
        }
        .app-icon { 
            width: 44px; height: 44px; border: 3px solid #000; border-radius: 12px;
            display: grid; place-items: center; font-size: 20px; background: #fff; 
        }
        .app-label { font-size: 11px; font-weight: 900; font-family: var(--font-display); text-transform: uppercase; text-align: center; }
        
        .app-icon.dashboard { background: var(--color-yellow); }
        .app-icon.downloads { background: var(--color-focus); }
        .app-icon.transactions { background: var(--color-primary); }

        /* Standard chunky button for Login states */
        .chunky-btn {
            border: 3px solid var(--color-black); 
            box-shadow: 4px 4px 0 var(--color-black);
            border-radius: 12px; font-weight: 900; font-family: var(--font-display); text-transform: uppercase;
            transition: all var(--bounce-fast); 
            cursor: pointer; padding: 12px 28px; 
            background-color: var(--color-primary); color: var(--color-black); 
            text-decoration: none; display: inline-flex; align-items: center; justify-content: center;
        }
        .chunky-btn:hover { transform: translate(2px, 2px); box-shadow: 2px 2px 0 var(--color-black); }
        .chunky-btn.secondary { background-color: var(--color-secondary); }

        /* Mobile Hamburger */
        .hamburger-btn { 
            width: 52px; height: 52px; font-size: 2rem; border: none; background: transparent; cursor: pointer; color: var(--color-black);
        }
        .hamburger-btn i { transition: transform 0.4s var(--bounce-fast), opacity 0.3s ease; position: relative; }
        .hamburger-btn.is-open .fa-bars { transform: rotate(180deg) scale(0); opacity: 0; }
        .hamburger-btn.is-open .fa-xmark { transform: rotate(0deg) scale(1); opacity: 1; }
        .hamburger-btn .fa-xmark { position: absolute; transform: rotate(-180deg) scale(0); opacity: 0; left: 12px;}

        /* Mobile Nav Panel */
        .mobile-nav-panel { 
            width: 320px; background-color: #fff; border-right: 6px solid var(--color-black); 
            z-index: 1045; transform: translateX(-100%); will-change: transform; transition: transform 0.4s var(--bounce-fast); 
            display: flex; flex-direction: column; position: fixed; top: 0; bottom: 0; left: 0; height: 100vh; 
        }
        .mobile-nav-panel.is-open { transform: translateX(0); box-shadow: 20px 0 0 rgba(0,0,0,1); }
        
        .nav-overlay { background-color: rgba(0, 0, 0, 0.6); transition: opacity 0.3s ease; position: fixed; inset: 0; opacity: 0; pointer-events: none; z-index: 1040; backdrop-filter: blur(4px); }
        .nav-overlay.is-open { opacity: 1; pointer-events: auto; }

        @keyframes slide-in-stagger { 0% { opacity: 0; transform: translateX(-30px); } 100% { opacity: 1; transform: translateX(0); } }
        .panel-link-stagger { opacity: 0; transform: translateX(-30px); position: relative; z-index: 2;}

        .panel-header { padding: 1.5rem; border-bottom: 4px solid var(--color-black); flex-shrink: 0; background: #fff; position: relative; z-index: 2;}
        .panel-body { padding: 1.5rem; flex-grow: 1; overflow-y: auto; position: relative; z-index: 2;}
        .panel-footer { padding: 1.5rem; border-top: 4px solid var(--color-black); flex-shrink: 0; background: #fff; position: relative; z-index: 2;}
        
        .panel-link { display: flex; align-items: center; gap: 1.2rem; padding: 1rem 1.2rem; margin-bottom: 0.85rem; border-radius: 12px; color: var(--color-black); text-decoration: none; font-weight: 900; font-family: var(--font-display); text-transform: uppercase; font-size: 1.1rem; border: 3px solid var(--color-black); background: #fff; transition: all var(--bounce-fast); box-shadow: 4px 4px 0 #000;}
        .panel-link:hover { background-color: var(--color-accent); box-shadow: 6px 6px 0 var(--color-black); transform: translate(-2px, -2px); color: var(--color-black);}
        
        .icon-wrapper { width: 38px; height: 38px; display: inline-flex; align-items: center; justify-content: center; border-radius: 10px; font-size: 1.2rem; color: var(--color-black); border: 3px solid #000;}
        .icon-docs { background-color: #fde68a; }
        .icon-courses { background-color: #bfdbfe; }
        .icon-focus { background-color: #1ac2ff; }

        /* Notifications */
        .notification-modal-content { border: 4px solid var(--color-black) !important; box-shadow: 10px 10px 0 var(--color-black) !important; border-radius: 24px !important; background-color: #fff; overflow: hidden; }

    </style>
</head>

<body>
    <header class="site-header" id="siteHeader">
        <div class="container-fluid d-flex align-items-center justify-content-between">
            
            <a href="/" class="brand-name">Vidyari</a>

            <div class="d-none d-lg-flex align-items-center justify-content-center flex-grow-1">
                <nav class="main-nav"> 
                    <a href="/documents">Documents</a>
                    <a href="/courses">Courses</a>
                    <a href="/pricing">Pricing</a>
                    <a href="/about">About Us</a>
                </nav>
            </div>

            <div class="d-flex align-items-center header-actions-group">
                
                <% if(isLoggedin) { %>
                    <button onclick="window.location.href='/user-notifications'" type="button" class="neo-pill-btn pill-pink d-none d-md-flex" aria-label="Notifications">
                        <i class="fa-regular fa-bell"></i>
                    </button>
                    
                    <div class="chat-popup-wrapper">
                        <a href="/chats" id="chat-icon-btn" class="neo-pill-btn pill-white d-none d-md-flex" aria-label="Chats">
                            <i class="fa-solid fa-comments"></i>
                        </a>
                    </div>

                    <div class="position-relative d-none d-md-block" id="grip-container">
                        <button id="grip-button" type="button" class="neo-pill-btn pill-yellow" aria-label="Quick Links">
                            <i class="fas fa-grip"></i>
                        </button>
                        <div class="apps-dropdown" id="grip-menu">
                          <div class="apps-grid">
                            <a href="/dashboard" class="app-item">
                              <span class="app-icon dashboard"><i class="fas fa-table-columns"></i></span>
                              <span class="app-label">Dashboard</span>
                            </a>
                            <a href="/downloads" class="app-item">
                              <span class="app-icon downloads"><i class="fas fa-cloud-arrow-down"></i></span>
                              <span class="app-label">Downloads</span>
                            </a>
                            <a href="/transactions" class="app-item">
                              <span class="app-icon transactions"><i class="fas fa-receipt"></i></span>
                              <span class="app-label">Receipts</span>
                            </a>
                          </div>
                        </div>
                    </div>
                    
                    <div class="dropdown">
                        <div class="header-avatar-container" data-bs-toggle="dropdown" aria-expanded="false">
                            <img
                                src="/images/avatar.jpg"
                                alt="User Avatar"
                                class="user-avatar"
                                id="userAvatar"
                                loading="lazy"
                                decoding="async"
                                data-user-id="<%= uId %>"
                                data-profile-url="<%= profileUrl || '' %>"
                            >
                        </div>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li class="px-4 pt-3 pb-3 border-bottom border-dark" style="border-width: 3px !important; background: #fafafa;">
                                <p class="fw-bold mb-0" style="font-family: var(--font-display); text-transform: uppercase; font-size: 1.1rem;"><%= username %></p>
                                <p class="small text-muted mb-0 fw-bold"><%= useremail %></p>
                            </li>
                            <li><a class="dropdown-item mt-2" href="/user-profile"><i class="fa-solid fa-user-gear fa-fw me-3 text-secondary"></i> Profile</a></li>
                            <li><a class="dropdown-item" href="/dashboard"><i class="fa-solid fa-store fa-fw me-3 text-warning"></i> Seller Dashboard</a></li>
                            <li><a class="dropdown-item text-danger mb-2" style="border-bottom:none;" href="/logout"><i class="fa-solid fa-arrow-right-from-bracket fa-fw me-3"></i> Logout</a></li>
                        </ul>
                    </div>

                <% } else { %>
                    <button onclick="window.location.href='/dashboard'" class="chunky-btn d-none d-md-block secondary">Become Seller</button>
                    <button onclick="window.location.href='/user-login'" class="chunky-btn primary">Login</button>
                <% } %>

                <button class="hamburger-btn d-lg-none ms-3" id="hamburgerBtn" type="button" aria-label="Toggle navigation">
                    <i class="fa-solid fa-bars"></i>
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        </div>
    </header>
    

    <div class="mobile-nav-panel" id="mobileNavPanel">
        <div class="panel-header">
            <a href="/" class="brand-name text-decoration-none">Vidyari</a> 
        </div>

        <div class="panel-body" id="mobilePanelBody">
            <% if(isLoggedin) { %>
                <div class="panel-section mb-4 panel-link-stagger">
                    <div style="display: flex; align-items: center; gap: 1rem; background: var(--color-bg); padding: 12px; border: 3px solid #000; border-radius: 16px; box-shadow: 4px 4px 0 #000;">
                        <img src="<%= profileUrl || '/images/avatar.jpg' %>" alt="User Avatar" style="width: 50px; height: 50px; border-radius: 12px; border: 2px solid #000; object-fit: cover;" onerror="this.onerror=null; this.src='/images/avatar.jpg';">
                        <div>
                            <p style="font-weight: 900; font-family: var(--font-display); text-transform: uppercase; margin: 0; line-height: 1.2;"><%= username %></p>
                            <p style="font-size: 0.85rem; color: #666; margin: 0; font-weight: 600;"><%= useremail %></p>
                        </div>
                    </div>
                </div>
            <% } %>

            <div class="panel-section">
                <a href="/documents" class="panel-link panel-link-stagger"><span class="icon-wrapper icon-docs"><i class="fa-solid fa-file-lines"></i></span><span>Documents</span></a>
                <a href="/courses" class="panel-link panel-link-stagger"><span class="icon-wrapper icon-courses"><i class="fa-solid fa-book-open-reader"></i></span><span>Courses</span></a>
                <a href="/pricing" class="panel-link panel-link-stagger"><span style="background-color: var(--color-secondary);" class="icon-wrapper"><i class="fa-solid fa-hand-holding-dollar"></i></span><span>Pricing</span></a>
                <a href="/about" class="panel-link panel-link-stagger"><span style="background-color: var(--color-primary);" class="icon-wrapper"><i class="fa-solid fa-users"></i></span><span>About Us</span></a>

                <% if(isLoggedin) { %>
                    <a href="/chats" class="panel-link panel-link-stagger"><span class="icon-wrapper icon-focus"><i class="fa-solid fa-comments"></i></span><span>Chats</span></a>
                <% } %>
            </div>

            <% if(isLoggedin) { %>
                <div style="height: 4px; background: #000; margin: 2rem 0; opacity: 0.1;" class="panel-link-stagger"></div>
                
                <div class="panel-section">
                                        <a href="/transactions" class="panel-link panel-link-stagger"><span class="icon-wrapper icon-transactions"><i class="fa-solid fa-receipt"></i></span><span>Transactions</span></a>

                                        <a href="/downloads" class="panel-link panel-link-stagger"><span class="icon-wrapper icon-downloads"><i class="fa-solid fa-cloud-arrow-down"></i></span><span>My Downloads</span></a>

                    <a href="/user-notifications" class="panel-link panel-link-stagger"><span class="icon-wrapper" style="background-color: var(--color-primary);"><i class="fa-regular fa-bell"></i></span><span>Notifications</span></a>
                    <a href="/user-profile" class="panel-link panel-link-stagger"><span class="icon-wrapper" style="background-color: #d1d5db;"><i class="fa-solid fa-user-gear"></i></span><span>My Profile</span></a>
                    <a href="/dashboard" class="panel-link panel-link-stagger"><span class="icon-wrapper" style="background-color: var(--color-yellow);"><i class="fa-solid fa-store"></i></span><span>Dashboard</span></a>
                </div>
            <% } %>
        </div>
        
        <div class="panel-footer panel-link-stagger">
            <% if(isLoggedin) { %>
                <a href="/logout" class="chunky-btn w-100 text-center" style="background-color: var(--color-error); color: white;"><i class="fa-solid fa-arrow-right-from-bracket fa-fw me-2"></i>Logout</a>
            <% } else { %>
                <button onclick="window.location.href='/user-login'" class="chunky-btn w-100 primary">Login / Sign Up</button>
            <% } %>
        </div>
    </div>
    <div class="nav-overlay" id="navOverlay"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>
    <script defer>
    document.addEventListener('DOMContentLoaded', () => {
        
        // Dynamic Header Shadow
        const siteHeader = document.getElementById('siteHeader');
        if (siteHeader) {
            window.addEventListener('scroll', () => {
                if (window.scrollY > 10) siteHeader.classList.add('scrolled');
                else siteHeader.classList.remove('scrolled');
            });
        }

        // Dropdown Toggle Logic
        const gripButton = document.getElementById('grip-button');
        const gripMenu = document.getElementById('grip-menu');
        const gripContainer = document.getElementById('grip-container');
        
        if (gripButton) {
            gripButton.addEventListener('click', (e) => {
                e.stopPropagation();
                gripMenu.classList.toggle('is-open');
            });
            document.addEventListener('click', (e) => {
                if (gripContainer && !gripContainer.contains(e.target)) gripMenu.classList.remove('is-open');
            });
        }

        // Mobile Nav Logic
        const mobileNavPanel = document.getElementById('mobileNavPanel');
        const navOverlay = document.getElementById('navOverlay');
        const hamburgerBtn = document.getElementById('hamburgerBtn');
        const panelStaggerLinks = document.querySelectorAll('.panel-link-stagger'); 

        const toggleMobileNav = () => {
            const isOpen = mobileNavPanel.classList.toggle('is-open');
            navOverlay.classList.toggle('is-open');
            hamburgerBtn.classList.toggle('is-open'); 
            document.body.style.overflow = isOpen ? 'hidden' : ''; 

            if (isOpen) {
                panelStaggerLinks.forEach((el, index) => {
                    const delay = index * 40; 
                    el.style.animation = `slide-in-stagger 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards ${delay}ms`;
                });
            } else {
                panelStaggerLinks.forEach(el => { el.style.animation = 'none'; el.offsetHeight; });
            }
        };

        if (hamburgerBtn) hamburgerBtn.addEventListener('click', toggleMobileNav);
        if (navOverlay) navOverlay.addEventListener('click', toggleMobileNav);

        // Avatar Image Caching Logic (Preserved)
        (() => {
            const img = document.getElementById('userAvatar');
            if (!img) return;
            const { userId, profileUrl, avatarVersion } = img.dataset;
            const DEFAULT_AVATAR = '/images/avatar.jpg';
            if (!userId || !profileUrl) { img.src = DEFAULT_AVATAR; return; }
            const CACHE_KEY = `avatar:${userId}`;
            let cached;
            try { cached = JSON.parse(localStorage.getItem(CACHE_KEY)); } catch { localStorage.removeItem(CACHE_KEY); }
            if (cached && cached.url === profileUrl && cached.version === avatarVersion && Date.now() - cached.time < 86400000) {
                img.src = cached.url; return;
            }
            img.src = DEFAULT_AVATAR;
            const testImg = new Image(); testImg.src = profileUrl;
            testImg.onload = () => { img.src = profileUrl; try { localStorage.setItem(CACHE_KEY, JSON.stringify({ url: profileUrl, version: avatarVersion, time: Date.now() })); } catch {} };
            testImg.onerror = () => { img.src = DEFAULT_AVATAR; localStorage.removeItem(CACHE_KEY); };
        })();
    });
    </script>
    
    <% if(isLoggedin) { %>
    <div id="notifyModal" class="modal fade" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content notification-modal-content">
                <div class="modal-header text-center justify-content-center p-4" style="background-color: var(--color-yellow); border-bottom: 4px solid #000;">
                    <div class="notify-gif-wrapper" style="border: 4px solid #000; box-shadow: 6px 6px 0 #000;">
                        <img src="/kiss.gif" alt="Excited notification" class="animated-notification-gif">
                    </div>
                </div>
                <div class="modal-body text-center p-4 pt-4">
                    <h5 class="modal-title-custom mb-3">Don't Miss a Beat!</h5>
                    <p class="mb-3 text-dark font-weight-bold" style="font-size: 1rem; font-family: var(--font-main);">
                        Be the first to know about new content, exclusive offers, and important news!
                    </p>
                </div>
                <div class="modal-footer justify-content-center border-top-0 pt-0 pb-4">
                    <button type="button" id="allowNotifications" class="chunky-btn primary w-100 mb-2">Enable</button>
                    <button type="button" class="btn btn-sm btn-link text-muted font-weight-bold" data-bs-dismiss="modal" style="font-size: 0.85rem; text-decoration: underline;">No thanks</button>
                </div>
            </div>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/12.4.0/firebase-app.js";
        import { getMessaging, getToken, onMessage } from "https://www.gstatic.com/firebasejs/12.4.0/firebase-messaging.js";
        const firebaseConfig = { apiKey: "AIzaSyCewKKaSGXDAiBPQRYqOtFJ_DV6A-OborA", authDomain: "vidyari-notification.firebaseapp.com", projectId: "vidyari-notification", storageBucket: "vidyari-notification.appspot.com", messagingSenderId: "1061582963767", appId: "1:1061582963767:web:f97da1a865022e6d172bb2" };
        try {
            const app = initializeApp(firebaseConfig);
            const messaging = getMessaging(app);
            if ('serviceWorker' in navigator) { navigator.serviceWorker.register('/firebase-messaging-sw.js').catch(err => console.error(err)); }
            const modalElement = document.getElementById('notifyModal');
            const allowBtn = document.getElementById('allowNotifications');
            let notifyModal; 
            if (!modalElement || !allowBtn) return;
            try { notifyModal = new bootstrap.Modal(modalElement, {backdrop: 'static', keyboard: false}); } catch (e) { return; }
            if (Notification.permission === 'default') { try { notifyModal.show(); } catch(e) {} }
            allowBtn.addEventListener('click', async () => {
                const hideModal = () => { if (notifyModal) { try { notifyModal.hide(); } catch (e) {} } };
                try {
                    const permission = await Notification.requestPermission();
                    if (permission !== 'granted') { hideModal(); return; }
                    const token = await getToken(messaging, { vapidKey: "BHsfuRpT67uCNIc_2p6h5cj0Ze6y09HsR0ZTZsvHaWDz9OjFLC6k2LlVWW7nWZuuBX90IAjwTMSFgQ5Mz2V_pt8" });
                    if (!token) throw new Error('No token.');
                    const response = await fetch('/register-token', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ userId: '<%=uId%>', token }) });
                    if (!response.ok) throw new Error(`Server failed: ${response.status}`);
                    hideModal(); 
                } catch (err) { hideModal(); }
            });
            onMessage(messaging, payload => { if (payload.notification) alert(`Notification: ${payload.notification.title}\n${payload.notification.body}`); });
        } catch (e) {}
    </script>
    <% } %>
</body>
