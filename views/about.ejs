    <meta property="og:title" content="About Vidyari | The Knowledge Economy">
    <meta property="og:description" content="Sell study materials, video courses, and large digital files effortlessly. Join the ultimate ecosystem where students teach students.">
    <meta property="og:image" content="https://www.vidyari.com/images/og-about.jpg">
    <meta property="og:site_name" content="Vidyari">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="https://www.vidyari.com/about">
    <meta name="twitter:title" content="About Vidyari | The Knowledge Economy">
    <meta name="twitter:description" content="Turn your brain into a business. The marketplace for students and creators.">
    <meta name="twitter:image" content="https://www.vidyari.com/images/twitter-about.jpg">

    <script type="application/ld+json">
    {
