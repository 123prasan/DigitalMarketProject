    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        :root {
            --color-bg: #f4f4f0;
            --color-black: #0a0a0a;
            --color-pink: #ff66a3;
            --color-green: #4ade80;
            --color-yellow: #ffd60a;
            --color-blue: #1ac2ff;
        }

        body {
            background-color: var(--color-bg);
            color: var(--color-black);
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        h1, h2, h3, h4 { font-family: 'Montserrat', sans-serif; }
        .font-extreme { font-family: 'Space Grotesk', sans-serif; }

        /* Typography Effects */
        .text-outline {
            color: transparent;
            -webkit-text-stroke: 2px var(--color-black);
            text-shadow: 4px 4px 0 var(--color-black);
            transition: all 0.3s ease;
        }
        .text-outline:hover {
            color: var(--color-black);
            -webkit-text-stroke: 0px;
            text-shadow: 6px 6px 0 var(--color-yellow);
        }

        /* Brutalist Utilities */
        .chunky-card {
            background-color: #fff;
            border: 6px solid var(--color-black);
            box-shadow: 12px 12px 0 var(--color-black);
            border-radius: 24px;
            transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s ease;
        }
        .chunky-card:hover {
            transform: translate(-6px, -6px);
            box-shadow: 18px 18px 0 var(--color-black);
        }

        /* 3D Button System */
        .chunky-btn-wrapper { position: relative; display: inline-block; }
        .chunky-btn-bg {
            position: absolute; inset: 0; background: var(--color-black);
            border-radius: 12px; transform: translate(8px, 8px); transition: transform 0.2s ease;
        }
        .chunky-btn {
            position: relative; z-index: 10; display: inline-flex; align-items: center; justify-content: center;
            border: 6px solid var(--color-black); border-radius: 12px;
            padding: 18px 36px; font-size: 1.25rem; font-weight: 900; font-family: 'Montserrat', sans-serif;
            text-transform: uppercase; cursor: pointer; transition: transform 0.2s ease;
            text-decoration: none; color: var(--color-black);
        }
        .chunky-btn-wrapper:hover .chunky-btn { transform: translate(-4px, -4px); }
        .chunky-btn-wrapper:hover .chunky-btn-bg { transform: translate(12px, 12px); }
        .chunky-btn-wrapper:active .chunky-btn { transform: translate(4px, 4px); }
        .chunky-btn-wrapper:active .chunky-btn-bg { transform: translate(4px, 4px); }

        /* Kinetic Marquee */
        .marquee-container {
            border-top: 6px solid var(--color-black);
            border-bottom: 6px solid var(--color-black);
            background: var(--color-black);
            color: white;
            overflow: hidden;
            white-space: nowrap;
            padding: 1.5rem 0;
            display: flex;
        }
        .marquee-content {
            display: inline-flex;
            animation: marquee 25s linear infinite;
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 900;
            font-size: 2.5rem;
            text-transform: uppercase;
        }
        @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

        /* Scroll Animations (AOS replacement) */
        .reveal-up { opacity: 0; transform: translateY(50px); transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
        .reveal-scale { opacity: 0; transform: scale(0.9); transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
        .is-revealed { opacity: 1; transform: translateY(0) scale(1); }

        /* Pattern Definitions for SVG Shapes */
        .pattern-dots { fill: url(#dots); }
        .pattern-stripes { fill: url(#stripes); }
    </style>
</head>
<body>

    <svg style="width:0;height:0;position:absolute;" aria-hidden="true" focusable="false">
        <defs>
            <pattern id="dots" x="0" y="0" width="12" height="12" patternUnits="userSpaceOnUse">
                <circle fill="#0a0a0a" cx="4" cy="4" r="3"></circle>
            </pattern>
            <pattern id="stripes" width="10" height="10" patternTransform="rotate(45 0 0)" patternUnits="userSpaceOnUse">
                <line x1="0" y1="0" x2="0" y2="10" stroke="#0a0a0a" stroke-width="6" />
            </pattern>
        </defs>
    </svg>

    <section class="relative pt-32 pb-24 px-6 lg:pt-56 lg:pb-40 overflow-hidden" id="parallax-container">
        
