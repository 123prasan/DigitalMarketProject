    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>
        /* ==========================================================================
           VIDYARI ABOUT: GEMINI / MATERIAL 3 THEME
           ========================================================================== */
        
        :root {
            --v-bg: #f0f4f9;           
            --v-surface: #ffffff;      
            
            --v-text-main: #1f1f1f;
            --v-text-muted: #444746;
            
            --v-primary: #0b57d0;      
            --v-primary-hover: #1a73e8;
            --v-primary-bg: #e8f0fe;
            
            --v-success: #146c2e;
            --v-success-bg: #e6f4ea;
            
            --v-warning: #b38700;
            --v-warning-bg: #fef7e0;
            
            --v-purple: #673ab7;
            --v-purple-bg: #f3e8fd;
            
            --v-border: #e3e3e3;
            
            --v-font-display: 'Outfit', sans-serif;
            --v-font-sans: 'Inter', sans-serif;
            
            --v-radius-sm: 12px;
            --v-radius-md: 16px;
            --v-radius-lg: 24px;
            --v-radius-pill: 9999px;
            
            --v-shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05);
            --v-shadow-md: 0 4px 12px rgba(0, 0, 0, 0.05);
            --v-shadow-hover: 0 8px 24px rgba(11, 87, 208, 0.08);
            
            --v-transition: all 0.4s cubic-bezier(0.2, 0, 0, 1);
        }

        .v-about-master {
            background-color: var(--v-bg);
            color: var(--v-text-main);
            font-family: var(--v-font-sans);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
            position: relative;
        }

        .v-about-master *, .v-about-master *::before, .v-about-master *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        .v-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
            position: relative;
            z-index: 2;
        }

        /* Ambient Background Glows */
        .v-ambient-glow {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            z-index: 0;
            opacity: 0.6;
            pointer-events: none;
            animation: floatGlow 10s infinite alternate ease-in-out;
        }
        .glow-1 { top: -10%; left: -10%; width: 50vw; height: 50vw; background: rgba(232, 240, 254, 1); }
        .glow-2 { top: 40%; right: -10%; width: 40vw; height: 40vw; background: rgba(230, 244, 234, 0.8); animation-delay: -5s; }
        
        @keyframes floatGlow {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(5%, 10%) scale(1.1); }
        }

        /* Typography */
        .v-heading-xl {
            font-family: var(--v-font-display);
            font-size: clamp(3.5rem, 8vw, 6rem);
            font-weight: 700;
            color: var(--v-text-main);
            line-height: 1.05;
            letter-spacing: -2px;
            margin-bottom: 24px;
        }
        .v-heading-lg {
            font-family: var(--v-font-display);
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 600;
            color: var(--v-text-main);
            margin-bottom: 20px;
            letter-spacing: -1px;
            line-height: 1.2;
        }
        .v-text-primary { color: var(--v-primary); }
        
        .v-subtitle {
            font-size: clamp(1.1rem, 2.5vw, 1.4rem);
            color: var(--v-text-muted);
            line-height: 1.6;
            max-width: 760px;
            margin: 0 auto 40px auto;
        }
        
        .v-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--v-surface);
            border: 1px solid var(--v-border);
            color: var(--v-text-main);
            padding: 8px 20px;
            border-radius: var(--v-radius-pill);
            font-weight: 500;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 32px;
            box-shadow: var(--v-shadow-sm);
        }
        .v-eyebrow i { color: var(--v-primary); }

        /* Hero Section */
        .v-hero {
            text-align: center;
            padding: clamp(80px, 15vw, 140px) 20px;
            position: relative;
        }

        /* Buttons */
        .v-btn-primary {
            display: inline-flex; align-items: center; justify-content: center;
            background: var(--v-primary); color: white;
            padding: 18px 40px; border-radius: var(--v-radius-pill);
            font-family: var(--v-font-sans); font-size: 1.15rem; font-weight: 500;
            text-decoration: none; transition: var(--v-transition);
            gap: 12px;
        }
        .v-btn-primary:hover {
            background: var(--v-primary-hover);
            box-shadow: var(--v-shadow-hover);
            transform: translateY(-2px);
        }

        /* Trust Strip (Replaces Marquee) */
        .v-trust-strip {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            align-items: center;
            gap: clamp(24px, 4vw, 48px);
            padding: 32px 24px;
            background: var(--v-surface);
            border-top: 1px solid var(--v-border);
            border-bottom: 1px solid var(--v-border);
            color: var(--v-text-muted);
            font-family: var(--v-font-display);
            font-weight: 500;
            font-size: 1.1rem;
        }
        .v-trust-item { display: flex; align-items: center; gap: 8px; }
        .v-trust-item i { color: var(--v-primary); }

        /* Value Grid (Why we built this) */
        .v-values-section {
            padding: clamp(80px, 12vw, 120px) 0;
        }
        .v-values-grid {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            gap: 24px;
            margin-top: 48px;
        }

        .v-value-card {
            background: var(--v-surface);
            border: 1px solid var(--v-border);
            border-radius: var(--v-radius-lg);
            padding: 40px;
            box-shadow: var(--v-shadow-sm);
            transition: var(--v-transition);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .v-value-card:hover {
            box-shadow: var(--v-shadow-md);
            transform: translateY(-4px);
            border-color: #d2e3fc;
        }

        .v-col-8 { grid-column: span 8; }
        .v-col-4 { grid-column: span 4; }
        .v-col-5 { grid-column: span 5; }
        .v-col-7 { grid-column: span 7; }

        @media (max-width: 992px) {
            .v-col-8, .v-col-4, .v-col-5, .v-col-7 { grid-column: span 12; }
            .v-value-card { padding: 32px 24px; }
        }

        .v-icon-circle {
            width: 64px; height: 64px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 24px; margin-bottom: 24px;
        }
        .v-value-card h3 { font-size: 1.8rem; margin-bottom: 16px; color: var(--v-text-main); }
        .v-value-card p { font-size: 1.1rem; color: var(--v-text-muted); line-height: 1.6; }

        /* Color Variations for Cards */
        .card-blue .v-icon-circle { background: var(--v-primary-bg); color: var(--v-primary); }
        .card-green .v-icon-circle { background: var(--v-success-bg); color: var(--v-success); }
        .card-yellow .v-icon-circle { background: var(--v-warning-bg); color: var(--v-warning); }
        .card-purple .v-icon-circle { background: var(--v-purple-bg); color: var(--v-purple); }

        /* Stats Section */
        .v-stats-section {
            background: var(--v-surface);
            border-top: 1px solid var(--v-border);
            border-bottom: 1px solid var(--v-border);
            padding: 80px 24px;
        }
        .v-stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 40px;
            text-align: center;
            max-width: 1000px;
            margin: 0 auto;
        }
        @media (max-width: 768px) {
            .v-stats-grid { grid-template-columns: 1fr; gap: 48px; }
        }
        .v-stat-number {
            font-family: var(--v-font-display);
            font-size: clamp(3rem, 6vw, 4.5rem);
            font-weight: 700;
            color: var(--v-primary);
            margin-bottom: 8px;
            line-height: 1;
        }
        .v-stat-label {
            font-size: 1.1rem;
            font-weight: 500;
            color: var(--v-text-muted);
        }

        /* Final CTA Section */
        .v-cta-section {
            padding: clamp(80px, 12vw, 140px) 24px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .v-cta-card {
            background: var(--v-surface);
            border: 1px solid var(--v-border);
            border-radius: var(--v-radius-lg);
            padding: clamp(40px, 8vw, 80px) 24px;
            max-width: 900px;
            margin: 0 auto;
            box-shadow: var(--v-shadow-sm);
            position: relative;
            z-index: 2;
        }

        /* Scroll Animations */
        .reveal-up { opacity: 0; transform: translateY(40px); transition: all 0.8s cubic-bezier(0.2, 0, 0, 1); }
        .is-revealed { opacity: 1; transform: translateY(0); }
    </style>
</head>
<body>

    <div class="v-about-master">
        
        <div class="v-ambient-glow glow-1"></div>
        <div class="v-ambient-glow glow-2"></div>

        <section class="v-hero">
            <div class="v-container reveal-up">
                <div class="v-eyebrow">
                    <i class="fa-solid fa-earth-americas"></i> The Vidyari Mission
                </div>
                <h1 class="v-heading-xl">Unlock your <span class="v-text-primary">knowledge.</span></h1>
                <p class="v-subtitle">
                    The ultimate peer-to-peer ecosystem where students learn from top students, and creators get paid fairly for their hard work and expertise.
                </p>
                <a href="/register" class="v-btn-primary">
                    Join the Ecosystem <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>
        </section>

        <div class="v-trust-strip reveal-up">
            <div class="v-trust-item"><i class="fa-solid fa-check-circle"></i> Students Teaching Students</div>
            <div class="v-trust-item"><i class="fa-solid fa-check-circle"></i> Monetize Your Expertise</div>
            <div class="v-trust-item"><i class="fa-solid fa-check-circle"></i> Zero Gatekeeping</div>
            <div class="v-trust-item"><i class="fa-solid fa-check-circle"></i> Secure Digital Delivery</div>
        </div>

        <section class="v-values-section">
            <div class="v-container">
                <div class="text-center reveal-up">
                    <h2 class="v-heading-lg">Why we built this.</h2>
                    <p class="v-subtitle">Education is evolving. We built the tools to help you evolve with it.</p>
                </div>

                <div class="v-values-grid">
                    
                    <div class="v-value-card v-col-8 card-blue reveal-up">
                        <div class="v-icon-circle"><i class="fa-solid fa-book-open"></i></div>
                        <h3>The Student Struggle</h3>
                        <p>Textbooks are outdated and expensive. The absolute best study materials are the raw, unfiltered notes taken by the student who aced the exact same class last semester. We built a streamlined marketplace to help you find exactly that.</p>
                    </div>

                    <div class="v-value-card v-col-4 card-green text-center items-center reveal-up" style="transition-delay: 0.1s;">
                        <div class="v-icon-circle"><i class="fa-solid fa-hand-holding-dollar"></i></div>
                        <h3 style="margin-bottom: 8px;">Creator Freedom</h3>
                        <p style="font-size: 1rem;">Stop giving away your hard work for free. Set your price and monetize your expertise instantly.</p>
                    </div>

                    <div class="v-value-card v-col-5 card-yellow reveal-up">
                        <div class="v-icon-circle"><i class="fa-solid fa-unlock-keyhole"></i></div>
                        <h3>Zero Gatekeeping</h3>
                        <p>Whether it's a complete video course, an 8GB code repository, or a simple PDF study guide, there are no monthly subscriptions or complex approvals required to start selling.</p>
                    </div>

                    <div class="v-value-card v-col-7 card-purple reveal-up" style="transition-delay: 0.1s;">
                        <div class="v-icon-circle"><i class="fa-solid fa-bolt"></i></div>
                        <h3>Instant & Secure Delivery</h3>
                        <p>We handle the heavy lifting. Enjoy secure UPI and card payments, instant automated digital fulfillment to buyers, and a protected environment that scales with your ambition.</p>
                    </div>

                </div>
            </div>
        </section>

        <section class="v-stats-section">
            <div class="v-container">
                <div class="v-stats-grid">
                    <div class="reveal-up">
                        <div class="v-stat-number"><span class="counter" data-target="30000">0</span>+</div>
                        <div class="v-stat-label">Active Learners</div>
                    </div>
                    <div class="reveal-up" style="transition-delay: 0.1s;">
                        <div class="v-stat-number"><span class="counter" data-target="3000">0</span>+</div>
                        <div class="v-stat-label">Creators Earning</div>
                    </div>
                    <div class="reveal-up" style="transition-delay: 0.2s;">
                        <div class="v-stat-number" style="color: var(--v-success);"><span class="counter" data-target="100">0</span>%</div>
                        <div class="v-stat-label">Creative Control</div>
                    </div>
                </div>
            </div>
        </section>

        <section class="v-cta-section">
            <div class="v-container reveal-up">
                <div class="v-cta-card">
                    <h2 class="v-heading-lg" style="margin-bottom: 16px;">Ready to share what you know?</h2>
                    <p class="v-subtitle" style="margin-bottom: 0;">
                        Join thousands of creators and students dominating the knowledge economy. Setup takes less than 2 minutes.
                    </p>
                    <a href="/register" class="v-btn-primary" style="margin-top: 32px;">
                        Launch Your Storefront <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </section>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            
            // Intersection Observer for Scroll Reveals
            const revealElements = document.querySelectorAll('.reveal-up');
            
            const revealOptions = {
                threshold: 0.15,
                rootMargin: "0px 0px -50px 0px"
            };

            const revealOnScroll = new IntersectionObserver(function(entries, observer) {
                entries.forEach(entry => {
                    if (!entry.isIntersecting) return;
                    
                    entry.target.classList.add('is-revealed');
                    
                    // Trigger counter if this element contains counters
                    const counters = entry.target.querySelectorAll('.counter');
                    if(counters.length > 0) {
                        runCounters(counters);
                    }
                    
                    observer.unobserve(entry.target);
                });
            }, revealOptions);

            revealElements.forEach(el => revealOnScroll.observe(el));

            // Animated Number Counters
            function runCounters(counters) {
                counters.forEach(counter => {
                    const target = +counter.getAttribute('data-target');
                    const duration = 2000; // 2 seconds
                    const increment = target / (duration / 16); // 60fps approx
                    
                    let current = 0;
                    
                    const updateCounter = () => {
                        current += increment;
                        if (current < target) {
                            counter.innerText = Math.ceil(current).toLocaleString();
                            requestAnimationFrame(updateCounter);
                        } else {
                            counter.innerText = target.toLocaleString();
                        }
                    };
                    
                    updateCounter();
                });
            }
        });
    </script>
</body>
</html>
<%-include("footer")%>