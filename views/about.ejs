                <a href="/register" class="chunky-btn bg-white">Join the Ecosystem <i class="fa-solid fa-arrow-right ml-4"></i></a>
            </div>
        </div>
    </section>

    <div class="marquee-container">
        <div class="marquee-content">
            <span class="mx-8 text-[#ffd60a]">•</span> STUDENTS TEACHING STUDENTS 
            <span class="mx-8 text-[#ff66a3]">•</span> MONETIZE YOUR BRAIN 
            <span class="mx-8 text-[#1ac2ff]">•</span> ZERO GATEKEEPING 
            <span class="mx-8 text-[#4ade80]">•</span> SELL DIGITAL FILES UP TO 8GB 
            <span class="mx-8 text-[#ffd60a]">•</span> STUDENTS TEACHING STUDENTS 
            <span class="mx-8 text-[#ff66a3]">•</span> MONETIZE YOUR BRAIN 
            <span class="mx-8 text-[#1ac2ff]">•</span> ZERO GATEKEEPING 
            <span class="mx-8 text-[#4ade80]">•</span> SELL DIGITAL FILES UP TO 8GB 
        </div>
    </div>

    <section class="py-24 px-6 bg-white border-b-[6px] border-black">
        <div class="max-w-7xl mx-auto">
            <h2 class="text-5xl md:text-7xl font-extreme mb-12 text-center uppercase tracking-tight reveal-up">Why we built this.</h2>
            
            <div class="w-full flex justify-center mb-16 reveal-scale">
                
            </div>

            <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mt-12">
                
                <div class="md:col-span-8 bg-[#e0f6ff] chunky-card p-10 flex flex-col justify-center group reveal-up">
