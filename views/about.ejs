            <circle cx="50" cy="50" r="46" fill="#ff66a3" stroke="#0a0a0a" stroke-width="6"/>
            <circle cx="50" cy="50" r="46" class="pattern-dots" opacity="0.3"/>
        </svg>

        <svg class="absolute z-0 parallax-shape" data-speed="-0.08" style="bottom: 15%; right: 10%; width: 130px; height: 130px; filter: drop-shadow(8px 8px 0px #0a0a0a); transform: rotate(15deg);" viewBox="0 0 100 100">
            <rect x="5" y="5" width="90" height="90" fill="#1ac2ff" stroke="#0a0a0a" stroke-width="6"/>
            <rect x="5" y="5" width="90" height="90" class="pattern-stripes" opacity="0.2"/>
        </svg>

        <svg class="absolute z-0 parallax-shape hidden md:block" data-speed="0.1" style="top: 30%; right: 20%; width: 150px; height: 150px; filter: drop-shadow(8px 8px 0px #0a0a0a); transform: rotate(-10deg);" viewBox="0 0 100 100">
            <polygon points="50,5 95,90 5,90" fill="#ffd60a" stroke="#0a0a0a" stroke-width="6" stroke-linejoin="round"/>
        </svg>

        <div class="max-w-6xl mx-auto text-center relative z-10 reveal-up">
