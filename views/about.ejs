    <section class="py-32 px-6 bg-[#ffd60a] text-center relative overflow-hidden">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(var(--color-black) 3px, transparent 3px); background-size: 40px 40px;"></div>
        
        <div class="max-w-5xl mx-auto relative z-10 reveal-scale">
            <h2 class="text-6xl md:text-[7rem] font-extreme tracking-tighter mb-8 leading-[0.9] uppercase">
                Ready to share <br> <span class="text-outline">what you know?</span>
            </h2>
            <p class="text-2xl font-bold mb-14 text-gray-900">
                Join thousands of creators and students dominating the knowledge economy.
            </p>
            
            <div class="chunky-btn-wrapper scale-110">
                <div class="chunky-btn-bg bg-[#ff66a3]"></div>
                <a href="/register" class="chunky-btn bg-white py-6 px-12">Launch Your Storefront</a>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            
            // 1. Mouse Tracking Parallax for SVG Shapes
            const container = document.getElementById('parallax-container');
            const shapes = document.querySelectorAll('.parallax-shape');
            
            if (window.matchMedia("(min-width: 768px)").matches) {
                container.addEventListener('mousemove', (e) => {
                    const x = e.clientX;
                    const y = e.clientY;
                    const centerX = window.innerWidth / 2;
                    const centerY = window.innerHeight / 2;

                    shapes.forEach(shape => {
                        const speed = parseFloat(shape.getAttribute('data-speed'));
                        // Calculate offset from center, multiply by speed
                        const moveX = (x - centerX) * speed;
                        const moveY = (y - centerY) * speed;
                        
                        // Apply transform (retaining original rotation if set in inline style)
                        const currentTransform = shape.style.transform;
                        let rotateMatch = currentTransform.match(/rotate\([^)]+\)/);
                        let rotateStr = rotateMatch ? rotateMatch[0] : '';
                        
                        shape.style.transform = `translate(${moveX}px, ${moveY}px) ${rotateStr}`;
                    });
                });

                // Reset shapes on mouse leave
                container.addEventListener('mouseleave', () => {
                    shapes.forEach(shape => {
                        let rotateMatch = shape.style.transform.match(/rotate\([^)]+\)/);
                        let rotateStr = rotateMatch ? rotateMatch[0] : '';
                        shape.style.transform = `translate(0px, 0px) ${rotateStr}`;
                    });
                });
            }

            // 2. Intersection Observer for Scroll Reveals
            const revealElements = document.querySelectorAll('.reveal-up, .reveal-scale');
            
            const revealOptions = {
                threshold: 0.15,
                rootMargin: "0px 0px -50px 0px"
            };

            const revealOnScroll = new IntersectionObserver(function(entries, observer) {
                entries.forEach(entry => {
                    if (!entry.isIntersecting) return;
                    
                    entry.target.classList.add('is-revealed');
                    
                    // Trigger counter if this element contains counters
                    const counters = entry.target.querySelectorAll('.counter');
                    if(counters.length > 0) {
                        runCounters(counters);
                    }
                    
                    observer.unobserve(entry.target);
                });
            }, revealOptions);

            revealElements.forEach(el => revealOnScroll.observe(el));

            // 3. Animated Number Counters
            function runCounters(counters) {
                counters.forEach(counter => {
                    const target = +counter.getAttribute('data-target');
                    const duration = 2000; // 2 seconds
                    const increment = target / (duration / 16); // 60fps
                    
                    let current = 0;
                    
                    const updateCounter = () => {
                        current += increment;
                        if (current < target) {
                            counter.innerText = Math.ceil(current).toLocaleString();
                            requestAnimationFrame(updateCounter);
                        } else {
                            counter.innerText = target.toLocaleString();
                        }
                    };
                    
                    updateCounter();
                });
            }
        });
    </script>
</body>
