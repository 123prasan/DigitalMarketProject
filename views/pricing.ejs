<%-include("header")%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pricing | Vidyari Marketplace</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;900&display=swap" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Montserrat', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            pink: '#ff66a3',
                            green: '#4ade80',
                            yellow: '#ffd60a',
                            blue: '#1ac2ff',
                            purple: '#b1a1ff',
                            orange: '#ff90e8'
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body { -webkit-font-smoothing: antialiased; }
        /* Custom border thickness for brutalist look */
        .brutal-border { border: 3px solid #000; }
        .brutal-border-b { border-bottom: 3px solid #000; }
        .brutal-border-t { border-top: 3px solid #000; }
        .brutal-border-r { border-right: 3px solid #000; }
        
        /* Accordion transition */
        .accordion-content { transition: max-height 0.3s ease-in-out; }
    </style>
</head>
<body class="bg-white text-black font-sans text-base font-normal leading-relaxed tracking-tight">

    <div class="flex flex-col lg:flex-row min-h-screen">
        <main class="flex-1 flex flex-col lg:h-screen overflow-y-auto">
            <div class="flex-1 flex flex-col">

                <header class="relative flex flex-col items-center justify-center h-auto brutal-border-b bg-brand-yellow text-center gap-12 px-8 pt-16 pb-20 md:pt-20 md:pb-24 lg:pt-28 lg:pb-36 overflow-hidden">
                    <div class="flex flex-col max-w-2xl gap-8 lg:gap-10 lg:max-w-4xl relative z-10">
                        <div class="text-xl md:text-2xl font-bold uppercase tracking-widest">Pricing</div>
                        <h1 class="text-5xl font-black md:text-6xl md:leading-[1.1] lg:text-8xl">Simple, transparent pricing.</h1>
                        <div class="text-xl md:text-2xl font-medium">We only make money when you do. No monthly fees, no hidden costs.</div>
                    </div>
                    
                    <div class="absolute -left-10 top-10 w-32 h-32 bg-brand-pink rounded-full brutal-border z-0 hidden lg:block"></div>
                    <div class="absolute right-10 bottom-10 w-24 h-24 bg-brand-blue brutal-border rotate-12 z-0 hidden lg:block"></div>
                </header>

                <div class="flex flex-col brutal-border-b overflow-hidden lg:flex-row">
                    <div class="bg-brand-pink flex items-center justify-center text-center lg:w-1/2 px-4 py-16 md:p-24 xl:p-32 border-b-3 border-black lg:border-b-0 lg:brutal-border-r">
                        <div class="max-w-xl space-y-12 md:space-y-8">
                            <div class="space-y-8">
                                <h3 class="font-black text-6xl lg:text-7xl">70%</h3>
                                <p class="text-xl lg:text-3xl font-bold uppercase tracking-wide">You Keep</p>
                                <p class="text-lg lg:text-xl font-medium mt-4">
                                    Per transaction on every lecture note, video course, or digital asset you sell.
                                </p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-brand-green flex items-center justify-center text-center lg:w-1/2 px-4 py-16 md:p-16 xl:p-32">
                        <div class="max-w-xl space-y-12 md:space-y-8">
                            <div class="space-y-8">
                                <h3 class="font-black text-6xl lg:text-7xl">30%</h3>
                                <p class="text-xl lg:text-3xl font-bold uppercase tracking-wide">Platform Fee</p>
                                <p class="text-lg lg:text-xl font-medium mt-4">
                                    Covers secure file hosting, global payment processing, and bandwidth.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="px-8 pb-24 pt-20 md:px-12 md:pb-32 md:pt-24 bg-white">
                    <div class="mx-auto max-w-5xl">
                        <div class="flex flex-col items-start gap-7 text-left md:items-center md:text-center">
                            <div class="text-lg font-bold uppercase lg:text-xl text-brand-blue">All-In-One Infrastructure</div>
                            <h2 class="text-5xl font-black md:text-6xl lg:text-7xl xl:text-8xl">Focus on creating.</h2>
                            <div class="max-w-3xl text-lg md:text-2xl lg:leading-10 xl:text-3xl font-medium">Whether you're selling course videos, e-books, or robust code templates, we handle the heavy lifting of delivery and security so you can scale your audience.</div>
                        </div>
                    </div>
                </div>

                <div class="brutal-border-b"></div>

                <div class="flex flex-col brutal-border-b overflow-hidden lg:flex-row">
                    <div class="bg-brand-purple h-auto lg:w-1/2 lg:brutal-border-r border-b-3 border-black lg:border-b-0 flex items-center justify-center p-12">
                        <div class="w-full max-w-sm aspect-square bg-white brutal-border shadow-[12px_12px_0px_rgba(0,0,0,1)] flex items-center justify-center rounded-xl rotate-3">
                            <i class="fas fa-server text-8xl"></i>
                        </div>
                    </div>
                    <div class="bg-black text-white py-16 px-8 flex items-center justify-center sm:p-12 md:p-16 lg:w-1/2 xl:p-24">
                        <div class="max-w-2xl space-y-12 md:space-y-8 w-full">
                            <div class="space-y-4">
                                <h3 class="font-black text-4xl lg:text-5xl xl:text-6xl text-brand-yellow">
                                    Everything included
                                </h3>
                            </div>
                            <ul class="grid grid-cols-1 gap-6 pl-0 text-xl font-medium">
                                <li class="flex items-start gap-4">
                                    <span class="text-brand-green text-2xl">→</span>
                                    Instant storefront creation upon upload
                                </li>
                                <li class="flex items-start gap-4">
                                    <span class="text-brand-green text-2xl">→</span>
                                    Support for massive files up to 8GB
                                </li>
                                <li class="flex items-start gap-4">
                                    <span class="text-brand-green text-2xl">→</span>
                                    Built-in video player for your courses
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="mx-auto my-16 max-w-6xl px-8 md:my-24 md:px-28 md:text-center lg:my-32">
                    <h2 class="text-5xl font-black md:text-6xl lg:text-7xl">
                        Frequently asked questions
                    </h2>
                </div>

                <div class="mx-auto mb-16 px-8 md:px-28 w-full max-w-6xl">
                    
                    <div class="accordion-item">
                        <div class="flex justify-between items-center py-6 sm:py-12 md:py-12 brutal-border-t cursor-pointer" data-accordion-trigger>
                            <div class="flex items-center w-full gap-[4vw] md:gap-[8vw]">
                                <div class="w-12 h-12 shrink-0 flex items-center justify-center">
                                    <svg width="48" height="48" viewBox="0 0 32 32">
                                        <line x1="8" y1="16" x2="24" y2="16" stroke="black" stroke-width="4"></line>
                                        <line x1="16" y1="8" x2="16" y2="24" stroke="black" stroke-width="4" class="icon-line transition-transform duration-300"></line>
                                    </svg>
                                </div>
                                <h3 class="text-2xl md:text-4xl font-bold">How do I get paid?</h3>
                            </div>
                        </div>
                        <div class="accordion-content overflow-hidden max-h-0" data-accordion-content>
                            <div class="pl-[calc(3rem+4vw)] md:pl-[calc(3rem+8vw)] pb-12">
                                <p class="text-xl md:text-2xl font-medium max-w-4xl">
                                    Once you reach the threshold amount of ₹1000, you can send a withdrawal request. Your total earnings will be credited directly to your connected UPI ID.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <div class="flex justify-between items-center py-6 sm:py-12 md:py-12 brutal-border-t cursor-pointer" data-accordion-trigger>
                            <div class="flex items-center w-full gap-[4vw] md:gap-[8vw]">
                                <div class="w-12 h-12 shrink-0 flex items-center justify-center">
                                    <svg width="48" height="48" viewBox="0 0 32 32">
                                        <line x1="8" y1="16" x2="24" y2="16" stroke="black" stroke-width="4"></line>
                                        <line x1="16" y1="8" x2="16" y2="24" stroke="black" stroke-width="4" class="icon-line transition-transform duration-300"></line>
                                    </svg>
                                </div>
                                <h3 class="text-2xl md:text-4xl font-bold">What can I sell?</h3>
                            </div>
                        </div>
                        <div class="accordion-content overflow-hidden max-h-0" data-accordion-content>
                            <div class="pl-[calc(3rem+4vw)] md:pl-[calc(3rem+8vw)] pb-12">
                                <p class="text-xl md:text-2xl font-medium max-w-4xl">
                                    If it's digital, you can sell it. Study guides, video lectures, source code, research papers, and complete online courses. 
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <div class="flex justify-between items-center py-6 sm:py-12 md:py-12 brutal-border-t cursor-pointer" data-accordion-trigger>
                            <div class="flex items-center w-full gap-[4vw] md:gap-[8vw]">
                                <div class="w-12 h-12 shrink-0 flex items-center justify-center">
                                    <svg width="48" height="48" viewBox="0 0 32 32">
                                        <line x1="8" y1="16" x2="24" y2="16" stroke="black" stroke-width="4"></line>
                                        <line x1="16" y1="8" x2="16" y2="24" stroke="black" stroke-width="4" class="icon-line transition-transform duration-300"></line>
                                    </svg>
                                </div>
                                <h3 class="text-2xl md:text-4xl font-bold">Are there any hidden fees?</h3>
                            </div>
                        </div>
                        <div class="accordion-content overflow-hidden max-h-0" data-accordion-content>
                            <div class="pl-[calc(3rem+4vw)] md:pl-[calc(3rem+8vw)] pb-12">
                                <p class="text-xl md:text-2xl font-medium max-w-4xl">
                                    No. Vidyari charges a simple, flat 30% fee on each sale. This covers all processing fees, file hosting, and customer support. No monthly subscriptions to use the platform.
                                </p>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="flex flex-col items-center justify-center text-center brutal-border-t bg-brand-blue gap-8 px-8 py-16 lg:px-[4vw] lg:py-24 lg:gap-16">
                    <h2 class="text-5xl font-black sm:text-6xl lg:text-8xl max-w-5xl">
                        Your Knowledge.<br>Your Currency.
                    </h2>
                    
                    <div class="relative inline-block group mt-4">
                        <div class="absolute inset-0 bg-brand-yellow brutal-border transition-transform duration-150 z-0"></div>
                        <div class="absolute inset-0 bg-brand-pink brutal-border transition-transform duration-150 group-hover:translate-x-2 group-hover:translate-y-2 z-10"></div>
                        <a href="/register" class="relative inline-flex no-underline items-center justify-center brutal-border transition-all duration-150 group-hover:-translate-x-2 group-hover:-translate-y-2 z-20 w-full lg:w-auto cursor-pointer h-16 px-10 text-xl lg:h-20 lg:px-14 lg:text-2xl font-black bg-black text-white uppercase tracking-wider">
                            Start Selling Now
                        </a>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const accordions = document.querySelectorAll('.accordion-item');
            
            accordions.forEach(item => {
                const trigger = item.querySelector('[data-accordion-trigger]');
                const content = item.querySelector('[data-accordion-content]');
                const icon = item.querySelector('.icon-line');
                
                trigger.addEventListener('click', () => {
                    const isOpen = content.style.maxHeight !== '0px' && content.style.maxHeight !== '';
                    
                    // Close all others
                    accordions.forEach(otherItem => {
                        const otherContent = otherItem.querySelector('[data-accordion-content]');
                        const otherIcon = otherItem.querySelector('.icon-line');
                        otherContent.style.maxHeight = '0px';
                        otherIcon.style.transform = 'rotate(0deg)';
                    });

                    // Open clicked if it wasn't already open
                    if (!isOpen) {
                        content.style.maxHeight = content.scrollHeight + 'px';
                        icon.style.transform = 'rotate(-90deg)';
                        icon.style.transformOrigin = 'center';
                    }
                });
            });
        });
    </script>

    </body>
</html>
<%-include("footer")%>