            },
            {
                id: 10,
                title: "AWS Certified Solutions Architect",
                instructor: "Stephane Maarek",
                category: "Cloud Computing",
                price: 94.99,
                originalPrice: 189.99,
                rating: 4.9,
                students: 73200,
                duration: 26,
                level: "Intermediate",
                thumbnail: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=800&h=600&fit=crop",
                tags: ["AWS", "Cloud", "DevOps"]
            },
            {
                id: 11,
                title: "Blockchain & Cryptocurrency",
                instructor: "Ivan on Tech",
                category: "Technology",
                price: 99.99,
                originalPrice: 199.99,
                rating: 4.6,
                students: 22100,
                duration: 45,
                level: "Advanced",
                thumbnail: "https://images.unsplash.com/photo-1639762681485-074b7f938ba0?w=800&h=600&fit=crop",
                tags: ["Blockchain", "Crypto", "Solidity"]
            },
            {
                id: 12,
                title: "Content Writing Excellence",
                instructor: "Sarah Turner",
                category: "Writing",
                price: 59.99,
                originalPrice: 119.99,
                rating: 4.7,
                students: 18600,
                duration: 22,
                level: "Beginner",
                thumbnail: "https://images.unsplash.com/photo-1455390582262-044cdead277a?w=800&h=600&fit=crop",
                tags: ["Writing", "Copywriting", "SEO"]
            }
        ];

        // Filter Options
        const categories = ["All Categories", "Programming", "Design", "Marketing", "Data Science", "Business", "Creative", "Cloud Computing", "Technology", "Writing"];
        const levels = ["All Levels", "Beginner", "Intermediate", "Advanced"];
        const durations = ["All Durations", "0-10 hours", "10-30 hours", "30-50 hours", "50+ hours"];
        const priceRanges = [
            { label: "All Prices", min: 0, max: Infinity },
            { label: "$0 - $50", min: 0, max: 50 },
            { label: "$50 - $100", min: 50, max: 100 },
            { label: "$100+", min: 100, max: Infinity }
        ];
        const ratings = [4.5, 4.0, 3.5, 3.0];

        // State
        let allCourses = [...coursesData];
        let filteredCourses = [...coursesData];
        let currentFilters = {
            search: '',
            category: 'All Categories',
            level: 'All Levels',
            duration: 'All Durations',
            priceRange: 'All Prices',
            minRating: 0,
            sort: 'popular'
        };

        // DOM Elements
        const searchInput = document.getElementById('searchInput');
        const clearBtn = document.getElementById('clearBtn');
        const resetFiltersBtn = document.getElementById('resetFilters');
        const sortSelect = document.getElementById('sortSelect');
        const coursesGrid = document.getElementById('coursesGrid');
        const resultsCount = document.getElementById('resultsCount');
        const totalCoursesEl = document.getElementById('totalCourses');
        const mobileFilterToggle = document.getElementById('mobileFilterToggle');
        const filterOverlay = document.getElementById('filterOverlay');
        const filtersEl = document.getElementById('filters');
        const closeFiltersBtn = document.getElementById('closeFiltersBtn');

        // Initialize
        function init() {
            renderFilterOptions();
            showSkeletonLoading();
            setTimeout(() => {
                applyFilters();
                totalCoursesEl.textContent = allCourses.length;
            }, 1500);
            attachEventListeners();
        }

        // Render Filter Options
        function renderFilterOptions() {
            // Category
            const categoryFiltersEl = document.getElementById('categoryFilters');
            categories.forEach(category => {
                const option = createFilterOption('category', category, category === 'All Categories');
                categoryFiltersEl.appendChild(option);
            });

            // Level
            const levelFiltersEl = document.getElementById('levelFilters');
            levels.forEach(level => {
                const option = createFilterOption('level', level, level === 'All Levels');
                levelFiltersEl.appendChild(option);
            });

            // Duration
            const durationFiltersEl = document.getElementById('durationFilters');
            durations.forEach(duration => {
                const option = createFilterOption('duration', duration, duration === 'All Durations');
                durationFiltersEl.appendChild(option);
            });

            // Price
            const priceFiltersEl = document.getElementById('priceFilters');
            priceRanges.forEach(range => {
                const option = createFilterOption('priceRange', range.label, range.label === 'All Prices');
                priceFiltersEl.appendChild(option);
            });

            // Rating
            const ratingFiltersEl = document.getElementById('ratingFilters');
            ratings.forEach(rating => {
                const option = createCheckboxOption('rating', rating);
                ratingFiltersEl.appendChild(option);
            });
        }

        function createFilterOption(type, value, checked = false) {
            const div = document.createElement('div');
            div.className = 'filter-option';
            div.innerHTML = `
                <input type="radio" name="${type}" id="${type}-${value.replace(/\s+/g, '-')}" value="${value}" ${checked ? 'checked' : ''}>
                <label for="${type}-${value.replace(/\s+/g, '-')}" class="filter-label">${value}</label>
            `;
            div.querySelector('input').addEventListener('change', (e) => {
                currentFilters[type] = e.target.value;
                applyFilters();
            });
            return div;
        }

        function createCheckboxOption(type, value) {
            const div = document.createElement('div');
            div.className = 'filter-option';
            div.innerHTML = `
                <input type="checkbox" id="${type}-${value}" value="${value}">
                <label for="${type}-${value}" class="filter-label">${value}+ Stars</label>
            `;
            div.querySelector('input').addEventListener('change', (e) => {
                currentFilters.minRating = e.target.checked ? value : 0;
                // Uncheck others
                document.querySelectorAll('input[id^="rating-"]').forEach(cb => {
                    if (cb.id !== e.target.id) cb.checked = false;
                });
                applyFilters();
            });
            return div;
        }

        // Show Skeleton Loading
        function showSkeletonLoading() {
            coursesGrid.innerHTML = '';
            for (let i = 0; i < 6; i++) {
                const skeleton = document.createElement('div');
                skeleton.className = 'skeleton-card';
                skeleton.innerHTML = `
                    <div class="skeleton-image"></div>
                    <div class="skeleton-content">
                        <div class="skeleton-line title"></div>
                        <div class="skeleton-line medium"></div>
                        <div class="skeleton-line short"></div>
                        <div class="skeleton-line"></div>
                        <div class="skeleton-line medium"></div>
                    </div>
                `;
                coursesGrid.appendChild(skeleton);
            }
        }

        // Apply Filters
        function applyFilters() {
            let filtered = [...allCourses];

            // Search
            if (currentFilters.search) {
                const searchLower = currentFilters.search.toLowerCase();
                filtered = filtered.filter(course => 
                    course.title.toLowerCase().includes(searchLower) ||
                    course.instructor.toLowerCase().includes(searchLower) ||
                    course.category.toLowerCase().includes(searchLower) ||
                    course.tags.some(tag => tag.toLowerCase().includes(searchLower))
                );
            }

            // Category
            if (currentFilters.category !== 'All Categories') {
                filtered = filtered.filter(course => course.category === currentFilters.category);
            }

            // Level
            if (currentFilters.level !== 'All Levels') {
                filtered = filtered.filter(course => course.level === currentFilters.level);
            }

            // Duration
            if (currentFilters.duration !== 'All Durations') {
                filtered = filtered.filter(course => {
                    const duration = course.duration;
                    if (currentFilters.duration === '0-10 hours') return duration <= 10;
                    if (currentFilters.duration === '10-30 hours') return duration > 10 && duration <= 30;
                    if (currentFilters.duration === '30-50 hours') return duration > 30 && duration <= 50;
                    if (currentFilters.duration === '50+ hours') return duration > 50;
                    return true;
                });
            }

            // Price
            if (currentFilters.priceRange !== 'All Prices') {
                const range = priceRanges.find(r => r.label === currentFilters.priceRange);
                filtered = filtered.filter(course => 
                    course.price >= range.min && course.price <= range.max
                );
            }

            // Rating
            if (currentFilters.minRating > 0) {
                filtered = filtered.filter(course => course.rating >= currentFilters.minRating);
            }

            // Sort
            filtered = sortCourses(filtered, currentFilters.sort);

            filteredCourses = filtered;
            renderCourses(filtered);
        }

        // Sort Courses
        function sortCourses(courses, sortType) {
            const sorted = [...courses];
            switch (sortType) {
                case 'rating':
                    return sorted.sort((a, b) => b.rating - a.rating);
                case 'price-low':
                    return sorted.sort((a, b) => a.price - b.price);
                case 'price-high':
                    return sorted.sort((a, b) => b.price - a.price);
                case 'popular':
                    return sorted.sort((a, b) => b.students - a.students);
                default:
                    return sorted;
            }
        }

        // Render Courses
        function renderCourses(courses) {
            coursesGrid.innerHTML = '';
            
            if (courses.length === 0) {
                coursesGrid.innerHTML = `
                    <div class="no-results" style="grid-column: 1 / -1;">
                        <div class="no-results-icon">
                            <svg class="icon icon-lg" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                            </svg>
                        </div>
                        <h2 class="no-results-title">No Courses Found</h2>
                        <p class="no-results-text">Try adjusting your filters or search terms</p>
                    </div>
                `;
                resultsCount.textContent = 'No results';
                return;
            }

            resultsCount.textContent = `${courses.length} ${courses.length === 1 ? 'Course' : 'Courses'} Found`;

            courses.forEach((course, index) => {
                const card = createCourseCard(course, index);
                coursesGrid.appendChild(card);
            });
        }

        // Create Course Card
        function createCourseCard(course, index) {
            const discount = Math.round((1 - course.price / course.originalPrice) * 100);
            const card = document.createElement('div');
            card.className = 'course-card';
            card.style.animationDelay = `${index * 0.05}s`;
            
            card.innerHTML = `
                <div class="course-image-container">
                    <img src="${course.thumbnail}" alt="${course.title}" class="course-image">
                    ${discount > 0 ? `<div class="discount-badge">${discount}% OFF</div>` : ''}
                    <div class="category-badge">${course.category}</div>
                </div>
                <div class="course-content">
                    <h3 class="course-title">${course.title}</h3>
                    <p class="course-instructor">By ${course.instructor}</p>
                    <div class="course-stats">
                        <div class="stat">
                            <svg class="icon icon-sm star-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                            </svg>
                            <span>${course.rating}</span>
                        </div>
                        <div class="stat">
                            <svg class="icon icon-sm" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="var(--icon-stroke)" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM12.75 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0z" />
                            </svg>
                            <span>${(course.students / 1000).toFixed(1)}k</span>
                        </div>
                        <div class="stat">
                            <svg class="icon icon-sm" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="var(--icon-stroke)" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>${course.duration}h</span>
                        </div>
                    </div>
                    <div class="course-level">${course.level}</div>
                    <div class="course-tags">
                        ${course.tags.slice(0, 3).map(tag => `<span class="tag">${tag}</span>`).join('')}
                    </div>
                    <div class="course-footer">
                        <div class="course-price">
                            <span class="current-price">$${course.price}</span>
                            <span class="original-price">$${course.originalPrice}</span>
                        </div>
                        <button class="enroll-btn" onclick="enrollCourse(${course.id})">Enroll</button>
                    </div>
                </div>
            `;
            
            return card;
        }

        // Enroll Course
        function enrollCourse(courseId) {
            event.stopPropagation(); // Prevent card click
            const course = allCourses.find(c => c.id === courseId);
            alert(`🎉 Enrolling in: ${course.title}\n\nThis is a demo. In production, this would redirect to the enrollment page.`);
        }

        // Attach Event Listeners
        function attachEventListeners() {
            // Search
            searchInput.addEventListener('input', (e) => {
                currentFilters.search = e.target.value;
                clearBtn.classList.toggle('active', e.target.value.length > 0);
                applyFilters();
            });

            clearBtn.addEventListener('click', () => {
                searchInput.value = '';
                currentFilters.search = '';
                clearBtn.classList.remove('active');
                applyFilters();
            });

            // Reset Filters
            resetFiltersBtn.addEventListener('click', () => {
                currentFilters = {
                    search: '',
                    category: 'All Categories',
                    level: 'All Levels',
                    duration: 'All Durations',
                    priceRange: 'All Prices',
                    minRating: 0,
                    sort: 'popular'
                };
                searchInput.value = '';
                clearBtn.classList.remove('active');
                sortSelect.value = 'popular';
                
                // Reset radio buttons
                document.querySelectorAll('input[type="radio"]').forEach(radio => {
                    radio.checked = radio.value.includes('All') || radio.value === 'popular';
                });
                
                // Reset checkboxes
                document.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                    cb.checked = false;
                });
                
                applyFilters();
            });

            // Sort
            sortSelect.addEventListener('change', (e) => {
                currentFilters.sort = e.target.value;
                applyFilters();
            });

            // Mobile Filter Toggle
            mobileFilterToggle.addEventListener('click', () => {
                filtersEl.classList.add('mobile-open');
                filterOverlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            });

            closeFiltersBtn.addEventListener('click', closeMobileFilters);
            filterOverlay.addEventListener('click', closeMobileFilters);
        }

        function closeMobileFilters() {
            filtersEl.classList.remove('mobile-open');
            filterOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        // Initialize on load
        init();
    </script>
