    <section class="search-section">
        <div class="container">
            <div class="search-wrapper">
                <svg class="icon search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="var(--icon-stroke)" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                </svg>
                <input 
                    type="text" 
                    class="search-input" 
                    id="searchInput"
                    placeholder="Search for courses, instructors, or topics..."
                >
                <button class="clear-btn" id="clearBtn">Clear</button>
            </div>
        </div>
    </section>

    <div class="container">
        <div class="main-content">
            <aside class="filters" id="filters">
                <button class="mobile-close-btn" id="closeFiltersBtn">
                    <svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="var(--icon-stroke)" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
                <div class="filter-header">
                    <h2 class="filter-title">Filters</h2>
                    <button class="reset-btn" id="resetFilters">Reset All</button>
                </div>

                <div class="filter-group">
                    <h3 class="filter-group-title">Category</h3>
                    <div id="categoryFilters"></div>
                </div>

                <div class="filter-group">
                    <h3 class="filter-group-title">Level</h3>
                    <div id="levelFilters"></div>
                </div>

                <div class="filter-group">
                    <h3 class="filter-group-title">Duration</h3>
                    <div id="durationFilters"></div>
                </div>

                <div class="filter-group">
                    <h3 class="filter-group-title">Price Range</h3>
                    <div id="priceFilters"></div>
                </div>

                <div class="filter-group">
                    <h3 class="filter-group-title">Minimum Rating</h3>
                    <div id="ratingFilters"></div>
                </div>
            </aside>

            <main class="courses-container">
                <div class="courses-header">
                    <div class="results-count" id="resultsCount">Loading courses...</div>
                    <select class="sort-select" id="sortSelect">
                        <option value="popular">Most Popular</option>
                        <option value="rating">Highest Rated</option>
                        <option value="price-low">Price: Low to High</option>
                        <option value="price-high">Price: High to Low</option>
                        <option value="newest">Newest First</option>
                    </select>
                </div>
                <div class="courses-grid" id="coursesGrid"></div>
            </main>
        </div>
    </div>

    <button class="mobile-filter-toggle" id="mobileFilterToggle">
        <svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="var(--icon-stroke)" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" />
        </svg>
    </button>

    <div class="filter-overlay" id="filterOverlay"></div>

    <script>
        // Mock Courses Data
        const coursesData = [
