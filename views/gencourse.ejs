    function createEditInput(textElement, onSave) {
        const originalText = textElement.textContent.trim();
        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'inline-edit-input bg-white text-gray-900 border border-gray-300 rounded-md py-1 px-2 w-full focus:ring-2 focus:ring-blue-500 focus:outline-none shadow-sm font-semibold text-sm sm:text-base';
        input.value = originalText;

        textElement.style.display = 'none'; 
        textElement.parentNode.insertBefore(input, textElement.nextSibling); 
        input.focus();
        input.select();

        const saveChanges = () => {
            const newText = input.value.trim();
            textElement.textContent = newText === '' ? originalText : newText; 
            input.remove(); 
            textElement.style.display = ''; 
            if (onSave) onSave(newText);
             input.removeEventListener('blur', saveChanges);
             input.removeEventListener('keydown', handleKeydown);
        };

        const handleKeydown = (e) => {
             if (e.key === 'Enter') saveChanges();
             else if (e.key === 'Escape') {
                 input.value = originalText;
                 saveChanges();
             }
         };

        input.addEventListener('blur', saveChanges);
        input.addEventListener('keydown', handleKeydown);
    }


