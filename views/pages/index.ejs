<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <title>Vidyari Library | Premium Academic Resources & Study Materials</title>
    <meta name="description" content="Discover premium academic resources, comprehensive study notes, video courses, and digital files on Vidyari.">
    <meta name="keywords" content="study materials, academic notes, research papers, educational resources, online learning">
    <meta name="author" content="Vidyari Inc.">
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#ffffff">
    <meta name="google-site-verification" content="Hcnu9BHn9udbxOrSebP2NCm4kTf0IwYg9mStgcwI0BU" />
    <meta property="og:title" content="Vidyari Library | The Knowledge Economy">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.vidyari.com/documents">
    <meta property="og:image" content="https://www.vidyari.com/images/og-library.jpg">
    <meta property="og:description" content="Browse thousands of professional study materials and academic resources.">
    <meta property="og:site_name" content="Vidyari">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="icon" type="image/svg+xml" href="/images/logo.svg">
    <link rel="canonical" href="https://www.vidyari.com/documents">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,400&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3321203820490717" crossorigin="anonymous"></script>
    <style>
      /* ═══════════════════════════════════════════════
       VIDYARI LIBRARY — GOOGLE BOOKS INSPIRED
       Light · Clean · Refined · Fast
    ═══════════════════════════════════════════════ */
      :root {
        /* Palette */
        --c-bg: #f8f9fa;
        --c-surface: #ffffff;
        --c-border: #e8eaed;
        --c-border-md: #dadce0;
        --c-text: #202124;
        --c-text-2: #3c4043;
        --c-muted: #5f6368;
        --c-faint: #80868b;
        --c-blue: #1a73e8;
        --c-blue-d: #1557b0;
        --c-blue-bg: #e8f0fe;
        --c-blue-lt: #f0f4ff;
        --c-amber: #f59e0b;
        --c-green: #137333;
        --c-green-bg: #e6f4ea;
        --c-red: #d93025;
        --c-orange: #f97316;
        --c-teal: #0097a7;
        /* Typography */
        --f-body: 'DM Sans', sans-serif;
        --f-display: 'Fraunces', serif;
        /* Radius */
        --r-sm: 6px;
        --r-md: 12px;
        --r-lg: 18px;
        --r-xl: 24px;
        --r-pill: 9999px;
        /* Shadows */
        --shadow-xs: 0 1px 3px rgba(0, 0, 0, .08);
        --shadow-sm: 0 2px 8px rgba(0, 0, 0, .10);
        --shadow-md: 0 4px 16px rgba(0, 0, 0, .12);
        --shadow-lg: 0 8px 32px rgba(0, 0, 0, .14);
        --shadow-book: 4px 6px 20px rgba(0, 0, 0, .18), -1px 0 0 rgba(0, 0, 0, .06), inset -3px 0 8px rgba(0, 0, 0, .06);
        --shadow-book-hover: 6px 20px 42px rgba(0, 0, 0, .22), -1px 0 0 rgba(0, 0, 0, .06), inset -3px 0 8px rgba(0, 0, 0, .06);
        /* Transitions */
        --t-fast: 0.18s ease;
        --t-base: 0.26s ease;
        --t-slow: 0.42s cubic-bezier(0.23, 1, 0.32, 1);
      }

      /* ── RESET & BASE ── */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        min-width: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        padding: 0;
        background: var(--c-bg);
        color: var(--c-text);
        font-family: var(--f-body);
        font-size: 15px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font-family: inherit;
        border: none;
        background: none;
        cursor: pointer;
      }

      ul,
      ol {
        margin: 0;
        padding: 0;
        list-style: none;
      }

      /* ── SCROLLBAR ── */
      ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
      }

      ::-webkit-scrollbar-track {
        background: transparent;
      }

      ::-webkit-scrollbar-thumb {
        background: #dadce0;
        border-radius: 10px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: #bdc1c6;
      }

      /* ══════════════════════════════════
       LAYOUT
    ══════════════════════════════════ */
      .vl-layout {
        display: grid;
        grid-template-columns: 272px minmax(0, 1fr);
        max-width: 1560px;
        margin: 0 auto;
        align-items: flex-start;
      }

      /* ── OVERLAY (mobile) ── */
      .vl-overlay {
        position: fixed;
        inset: 0;
        background: rgba(32, 33, 36, .55);
        backdrop-filter: blur(2px);
        z-index: 900;
        opacity: 0;
        visibility: hidden;
        transition: opacity var(--t-base);
      }

      .vl-overlay.is-active {
        opacity: 1;
        visibility: visible;
      }

      /* ══════════════════════════════════
       SIDEBAR
    ══════════════════════════════════ */
      .vl-sidebar {
        background: var(--c-surface);
        border-right: 1px solid var(--c-border);
        padding: 28px 20px;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .vl-sidebar-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 28px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--c-border);
      }

      .vl-sidebar-logo-icon {
        width: 36px;
        height: 36px;
        background: var(--c-blue);
        border-radius: 8px;
        display: grid;
        place-items: center;
        color: white;
        font-size: 1rem;
      }

      .vl-sidebar-logo-text {
        font-family: var(--f-display);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--c-text);
        letter-spacing: -0.3px;
      }

      .vl-filter-group {
        margin-bottom: 24px;
        padding-bottom: 24px;
        border-bottom: 1px solid var(--c-border);
      }

      .vl-filter-group:last-of-type {
        border-bottom: none;
      }

      .vl-filter-label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: var(--c-muted);
        margin-bottom: 12px;
      }

      .vl-check-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 7px 8px;
        margin: 0 -8px;
        border-radius: var(--r-sm);
        cursor: pointer;
        font-size: 0.88rem;
        color: var(--c-text-2);
        font-weight: 500;
        transition: background var(--t-fast);
      }

      .vl-check-row:hover {
        background: var(--c-blue-lt);
      }

      .vl-chk {
        appearance: none;
        width: 17px;
        height: 17px;
        border: 2px solid var(--c-border-md);
        border-radius: 4px;
        background: white;
        position: relative;
        cursor: pointer;
        flex-shrink: 0;
        transition: all var(--t-fast);
      }

      .vl-chk[type="radio"] {
        border-radius: 50%;
      }

      .vl-chk:checked {
        background: var(--c-blue);
        border-color: var(--c-blue);
      }

      .vl-chk[type="checkbox"]:checked::after {
        content: '';
        position: absolute;
        left: 4px;
        top: 1px;
        width: 5px;
        height: 9px;
        border: solid white;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg);
      }

      .vl-chk[type="radio"]:checked::after {
        content: '';
        position: absolute;
        left: 3px;
        top: 3px;
        width: 5px;
        height: 5px;
        background: white;
        border-radius: 50%;
      }

      .vl-select {
        width: 100%;
        padding: 8px 12px;
        border: 1.5px solid var(--c-border);
        border-radius: var(--r-sm);
        font-family: var(--f-body);
        font-size: 0.88rem;
        color: var(--c-text);
        background: white;
        cursor: pointer;
        transition: border-color var(--t-fast);
      }

      .vl-select:focus {
        outline: none;
        border-color: var(--c-blue);
      }

      .vl-price-range {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-top: 10px;
      }

      .vl-price-input {
        padding: 8px 10px;
        border: 1.5px solid var(--c-border);
        border-radius: var(--r-sm);
        font-family: var(--f-body);
        font-size: 0.85rem;
        color: var(--c-text);
        width: 100%;
        transition: border-color var(--t-fast);
      }

      .vl-price-input:focus {
        outline: none;
        border-color: var(--c-blue);
      }

      .vl-sidebar-actions {
        position: sticky;
        bottom: 0;
        background: var(--c-surface);
        padding-top: 16px;
        border-top: 1px solid var(--c-border);
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .vl-btn-apply {
        padding: 11px;
        border-radius: var(--r-sm);
        background: var(--c-blue);
        color: white;
        font-size: 0.9rem;
        font-weight: 600;
        transition: background var(--t-fast), box-shadow var(--t-fast);
        box-shadow: 0 2px 8px rgba(26, 115, 232, .25);
      }

      .vl-btn-apply:hover {
        background: var(--c-blue-d);
        box-shadow: 0 4px 16px rgba(26, 115, 232, .35);
      }

      .vl-btn-clear {
        padding: 10px;
        border-radius: var(--r-sm);
        background: transparent;
        color: var(--c-blue);
        font-size: 0.88rem;
        font-weight: 600;
        border: 1.5px solid var(--c-border);
        transition: all var(--t-fast);
      }

      .vl-btn-clear:hover {
        background: var(--c-blue-lt);
        border-color: var(--c-blue);
      }

      /* ══════════════════════════════════
       MAIN CONTENT
    ══════════════════════════════════ */
      .vl-main {
        padding: 32px 36px 80px;
        min-width: 0;
      }

      /* ══════════════════════════════════
       HERO BANNER
    ══════════════════════════════════ */
      .vl-hero {
        background: linear-gradient(135deg, #0d1b2a 0%, #1557b0 40%, #1a73e8 70%, #0d3b66 100%);
        border-radius: var(--r-xl);
        padding: 52px 56px;
        margin-bottom: 36px;
        position: relative;
        overflow: hidden;
      }

      .vl-hero::before {
        content: '';
        position: absolute;
        top: -80px;
        right: -80px;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(255, 255, 255, .07) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
      }

      .vl-hero::after {
        content: '';
        position: absolute;
        bottom: -50px;
        left: 30%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(26, 115, 232, .15) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
      }

      .vl-hero-inner {
        position: relative;
        z-index: 2;
        max-width: 680px;
      }

      .vl-hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, .12);
        border: 1px solid rgba(255, 255, 255, .2);
        border-radius: var(--r-pill);
        padding: 5px 14px;
        font-size: 0.78rem;
        font-weight: 600;
        color: rgba(255, 255, 255, .9);
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 16px;
      }

      .vl-hero-title {
        font-family: var(--f-display);
        font-size: clamp(1.8rem, 3vw, 2.8rem);
        font-weight: 700;
        color: white;
        line-height: 1.15;
        letter-spacing: -0.5px;
        margin-bottom: 12px;
      }

      .vl-hero-title em {
        font-style: italic;
        color: #93c5fd;
      }

      .vl-hero-sub {
        font-size: 1rem;
        color: rgba(255, 255, 255, .8);
        margin-bottom: 28px;
        font-weight: 300;
        line-height: 1.7;
      }

      .vl-hero-search {
        display: flex;
        background: white;
        border-radius: 50px;
        overflow: hidden;
        box-shadow: 0 12px 40px rgba(0, 0, 0, .2);
        max-width: 540px;
      }

      .vl-hero-input {
        flex: 1;
        border: none;
        outline: none;
        padding: 14px 20px;
        font-size: 0.95rem;
        font-family: var(--f-body);
        color: var(--c-text);
        background: transparent;
      }

      .vl-hero-input::placeholder {
        color: var(--c-faint);
      }

      .vl-hero-btn {
        background: var(--c-blue);
        color: white;
        padding: 0 24px;
        font-size: 0.9rem;
        font-weight: 600;
        transition: background var(--t-fast);
        flex-shrink: 0;
      }

      .vl-hero-btn:hover {
        background: var(--c-blue-d);
      }

      /* ══════════════════════════════════
       SECTION HEADERS (Google Books style)
    ══════════════════════════════════ */
      .vl-section {
        margin-bottom: 36px;
      }

      .vl-section-card {
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--r-lg);
        padding: 28px 28px 24px;
        box-shadow: var(--shadow-xs);
      }

      .vl-section-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 22px;
      }

      .vl-section-title {
        font-family: var(--f-display);
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--c-text);
        letter-spacing: -0.2px;
        margin: 0 0 3px;
        display: flex;
        align-items: center;
        gap: 9px;
      }

      .vl-section-title-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        font-size: 0.85rem;
        flex-shrink: 0;
      }

      .icon-orange {
        background: #fff4e6;
        color: var(--c-orange);
      }

      .icon-blue {
        background: var(--c-blue-bg);
        color: var(--c-blue);
      }

      .icon-purple {
        background: #f3e8ff;
        color: #7c3aed;
      }

      .icon-teal {
        background: #e0f7fa;
        color: var(--c-teal);
      }

      .icon-amber {
        background: #fffbeb;
        color: var(--c-amber);
      }

      .vl-section-sub {
        font-size: 0.82rem;
        color: var(--c-muted);
        font-weight: 400;
        margin: 0;
      }

      .vl-view-all {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--c-blue);
        border: 1.5px solid var(--c-border);
        border-radius: var(--r-pill);
        padding: 6px 14px;
        flex-shrink: 0;
        transition: all var(--t-fast);
        white-space: nowrap;
      }

      .vl-view-all:hover {
        border-color: var(--c-blue);
        background: var(--c-blue-lt);
      }

      /* ══════════════════════════════════
       CAROUSEL
    ══════════════════════════════════ */
      .vl-carousel-wrap {
        position: relative;
      }

      .vl-carousel {
        display: flex;
        gap: 14px;
        overflow-x: auto;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
        scroll-snap-type: x proximity;
        padding: 6px 4px 14px;
        scrollbar-width: none;
        -ms-overflow-style: none;
        will-change: scroll-position;
        cursor: grab;
      }

      .vl-carousel:active {
        cursor: grabbing;
      }

      .vl-carousel::-webkit-scrollbar {
        display: none;
      }

      /* ─ Book Card ─ */
      .vl-book-card {
        flex: 0 0 148px;
        min-width: 130px;
        max-width: 165px;
        display: flex;
        flex-direction: column;
        background: var(--c-surface);
        border-radius: 8px;
        scroll-snap-align: start;
        text-decoration: none;
        color: inherit;
        position: relative;
        transition: transform var(--t-base), box-shadow var(--t-base);
        transform: translateZ(0);
        will-change: transform;
        box-shadow: var(--shadow-book);
      }

      .vl-book-card:hover {
        transform: translateY(-8px) translateZ(0);
        box-shadow: var(--shadow-book-hover);
      }

      /* Book spine illusion */
      .vl-book-card::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 5px;
        background: linear-gradient(to right, rgba(0, 0, 0, .18), rgba(0, 0, 0, .03), transparent);
        border-radius: 8px 0 0 8px;
        z-index: 3;
        pointer-events: none;
      }

      /* Page stack illusion */
      .vl-book-card::after {
        content: '';
        position: absolute;
        right: -2px;
        top: 3px;
        bottom: 3px;
        width: 4px;
        background: repeating-linear-gradient(to bottom, #e8e8e8, #e8e8e8 2px, #f5f5f5 2px, #f5f5f5 4px);
        border-radius: 0 2px 2px 0;
        z-index: 0;
      }

      .vl-book-cover {
        width: 100%;
        aspect-ratio: 2/3;
        object-fit: cover;
        border-radius: 6px 6px 0 0;
        display: block;
        background: #e8eaed;
      }

      .vl-book-badge {
        position: absolute;
        top: 8px;
        left: 8px;
        font-size: 0.63rem;
        font-weight: 700;
        padding: 3px 7px;
        border-radius: var(--r-pill);
        z-index: 2;
        text-transform: uppercase;
        letter-spacing: 0.3px;
      }

      .badge-cat {
        background: rgba(255, 255, 255, .94);
        color: var(--c-blue);
      }

      .badge-new {
        background: var(--c-blue);
        color: white;
      }

      .badge-hot {
        background: var(--c-orange);
        color: white;
      }

      .badge-top {
        background: #7c3aed;
        color: white;
      }

      .vl-book-body {
        padding: 10px 12px 4px;
        flex: 1;
      }

      .vl-book-title {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--c-text);
        line-height: 1.35;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 3px;
      }

      .vl-book-author {
        font-size: 0.68rem;
        color: var(--c-faint);
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .vl-book-stars {
        font-size: 0.65rem;
        color: var(--c-amber);
        letter-spacing: 0.5px;
      }

      .vl-book-rating-val {
        font-size: 0.65rem;
        color: var(--c-muted);
        margin-left: 2px;
      }

      .vl-book-footer {
        padding: 6px 12px 10px;
      }

      .vl-book-price {
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--c-text);
      }

      .vl-book-price.is-free {
        color: var(--c-green);
        font-weight: 700;
      }

      /* ─ Carousel Nav Arrows ─ */
      .vl-carousel-btn {
        position: absolute;
        top: 45%;
        transform: translateY(-50%);
        width: 36px;
        height: 36px;
        background: var(--c-surface);
        border: 1.5px solid var(--c-border);
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-size: 0.9rem;
        color: var(--c-muted);
        cursor: pointer;
        z-index: 10;
        box-shadow: var(--shadow-sm);
        transition: all var(--t-fast);
      }

      .vl-carousel-btn:hover {
        background: var(--c-blue);
        border-color: var(--c-blue);
        color: white;
        box-shadow: 0 4px 14px rgba(26, 115, 232, .35);
        transform: translateY(-50%) scale(1.1);
      }

      .vl-carousel-btn.prev {
        left: -18px;
      }

      .vl-carousel-btn.next {
        right: -18px;
      }

      /* ── Loading skeleton ── */
      .vl-skel-book {
        flex: 0 0 148px;
        min-width: 130px;
        border-radius: 8px;
        overflow: hidden;
        background: #f1f3f4;
      }

      .vl-skel-cover {
        width: 100%;
        aspect-ratio: 2/3;
        background: linear-gradient(90deg, #f1f3f4 25%, #e8eaed 50%, #f1f3f4 75%);
        background-size: 200% 100%;
        animation: shimmer 1.6s infinite linear;
      }

      .vl-skel-line {
        height: 10px;
        background: linear-gradient(90deg, #f1f3f4 25%, #e8eaed 50%, #f1f3f4 75%);
        background-size: 200% 100%;
        animation: shimmer 1.6s infinite linear;
        border-radius: 4px;
        margin: 8px 12px;
      }

      .vl-skel-line.short {
        width: 60%;
      }

      @keyframes shimmer {
        0% {
          background-position: 200% 0
        }

        100% {
          background-position: -200% 0
        }
      }

      /* ══════════════════════════════════
       CATEGORY GRID
    ══════════════════════════════════ */
      .vl-cats {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 12px;
      }

      .vl-cat-card {
        background: white;
        border: 1.5px solid var(--c-border);
        border-radius: var(--r-md);
        padding: 20px 16px;
        text-align: center;
        text-decoration: none;
        color: inherit;
        transition: all var(--t-base);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
      }

      .vl-cat-card:hover {
        transform: translateY(-5px);
        border-color: var(--c-blue);
        box-shadow: 0 8px 24px rgba(26, 115, 232, .12);
      }

      .vl-cat-icon {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        display: grid;
        place-items: center;
        font-size: 1.3rem;
      }

      .vl-cat-name {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--c-text);
      }

      .vl-cat-cta {
        font-size: 0.72rem;
        color: var(--c-blue);
        font-weight: 500;
      }

      /* ══════════════════════════════════
       SEARCH & CONTROLS
    ══════════════════════════════════ */
      /* Search functionality removed */
      /* Controls row */
      .vl-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 10px;
      }

      .vl-count {
        font-size: 0.88rem;
        color: var(--c-muted);
        font-weight: 500;
      }

      .vl-count strong {
        color: var(--c-text);
        font-weight: 700;
      }

      .vl-controls-right {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .vl-sort {
        padding: 8px 12px;
        border: 1.5px solid var(--c-border);
        border-radius: var(--r-sm);
        font-family: var(--f-body);
        font-size: 0.85rem;
        color: var(--c-text);
        background: white;
        cursor: pointer;
      }

      .vl-view-btn {
        width: 34px;
        height: 34px;
        border: 1.5px solid var(--c-border);
        border-radius: var(--r-sm);
        display: grid;
        place-items: center;
        color: var(--c-muted);
        font-size: 0.85rem;
        transition: all var(--t-fast);
        background: white;
      }

      .vl-view-btn.active,
      .vl-view-btn:hover {
        background: var(--c-blue);
        color: white;
        border-color: var(--c-blue);
      }

      /* Active filter pills */
      .vl-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 16px;
      }

      .vl-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--c-blue-bg);
        color: var(--c-blue);
        border: 1px solid rgba(26, 115, 232, .2);
        border-radius: var(--r-pill);
        padding: 5px 12px;
        font-size: 0.8rem;
        font-weight: 600;
        animation: fadeUp .2s ease;
      }

      .vl-pill-x {
        cursor: pointer;
        opacity: .7;
        transition: opacity var(--t-fast);
      }

      .vl-pill-x:hover {
        opacity: 1;
      }

      /* ══════════════════════════════════
       MAIN GRID (Files)
    ══════════════════════════════════ */
      .vl-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(192px, 1fr));
        gap: 20px;
      }

      .vl-grid.is-list {
        grid-template-columns: 1fr;
      }

      /* File card */
      .vl-file-card {
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--r-md);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: all var(--t-base);
        position: relative;
        text-decoration: none;
        color: inherit;
        box-shadow: var(--shadow-xs);
      }

      .vl-file-card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateY(-6px);
        border-color: var(--c-border-md);
      }

      .vl-grid.is-list .vl-file-card {
        flex-direction: row;
      }

      .vl-file-img-wrap {
        aspect-ratio: 5/3;
        position: relative;
        overflow: hidden;
        background: #f1f3f4;
        flex-shrink: 0;
      }

      .vl-grid.is-list .vl-file-img-wrap {
        aspect-ratio: unset;
        width: 200px;
        height: auto;
      }

      .vl-file-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform .5s var(--t-slow);
      }

      .vl-file-card:hover .vl-file-img {
        transform: scale(1.08);
      }

      .vl-file-badges {
        position: absolute;
        top: 10px;
        left: 10px;
        right: 42px;
        display: flex;
        gap: 6px;
        z-index: 2;
      }

      .vl-file-cat-badge {
        background: rgba(255, 255, 255, .96);
        color: var(--c-blue);
        font-size: 0.62rem;
        font-weight: 700;
        padding: 4px 9px;
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, .1);
      }

      .vl-file-type-badge {
        background: var(--c-blue);
        color: white;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-size: 0.75rem;
        box-shadow: 0 2px 8px rgba(26, 115, 232, .3);
        margin-left: auto;
      }

      .vl-wish-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 32px;
        height: 32px;
        background: white;
        border-radius: 50%;
        border: 1.5px solid var(--c-border);
        display: grid;
        place-items: center;
        font-size: 0.85rem;
        color: #ccc;
        cursor: pointer;
        z-index: 5;
        box-shadow: var(--shadow-xs);
        transition: all var(--t-fast);
      }

      .vl-wish-btn:hover {
        color: var(--c-red);
        border-color: var(--c-red);
      }

      .vl-file-body {
        padding: 14px 14px 10px;
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      .vl-file-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--c-text);
        line-height: 1.35;
        margin-bottom: 8px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .vl-file-meta {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.72rem;
        color: var(--c-muted);
        margin-bottom: 10px;
      }

      .vl-star {
        color: var(--c-amber);
      }

      .vl-dot {
        color: var(--c-border);
      }

      .vl-file-author {
        display: flex;
        align-items: center;
        gap: 8px;
        padding-top: 10px;
        border-top: 1px solid var(--c-border);
        margin-top: auto;
      }

      .vl-author-avatar {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: var(--c-blue);
        display: grid;
        place-items: center;
        color: white;
        font-size: 0.7rem;
        font-weight: 700;
        flex-shrink: 0;
      }

      .vl-author-name {
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--c-text-2);
      }

      .vl-file-foot {
        padding: 10px 14px 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid var(--c-border);
      }

      .vl-price {
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--c-blue);
        font-variant-numeric: tabular-nums;
      }

      .vl-price.free {
        color: var(--c-green);
        font-size: 0.85rem;
      }

      .vl-card-actions {
        display: flex;
        gap: 6px;
      }

      .vl-action-btn {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: var(--c-bg);
        border: 1.5px solid var(--c-border);
        display: grid;
        place-items: center;
        font-size: 0.75rem;
        color: var(--c-muted);
        cursor: pointer;
        transition: all var(--t-fast);
      }

      .vl-action-btn:hover {
        background: white;
        color: var(--c-blue);
        border-color: var(--c-blue);
      }

      .vl-action-btn.primary {
        background: var(--c-blue);
        color: white;
        border-color: transparent;
      }

      /* Skeleton grid cards */
      .vl-skel-grid {
        border: 1px solid var(--c-border);
        border-radius: var(--r-md);
        overflow: hidden;
        background: var(--c-surface);
      }

      .vl-skel-img {
        aspect-ratio: 5/3;
        background: linear-gradient(90deg, #f1f3f4 25%, #e8eaed 50%, #f1f3f4 75%);
        background-size: 200% 100%;
        animation: shimmer 1.6s infinite linear;
      }

      .vl-skel-body {
        padding: 14px;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .vl-skel-text {
        height: 11px;
        background: linear-gradient(90deg, #f1f3f4 25%, #e8eaed 50%, #f1f3f4 75%);
        background-size: 200% 100%;
        animation: shimmer 1.6s infinite linear;
        border-radius: 4px;
      }

      /* Recommendations banner */
      .vl-rec-banner {
        background: linear-gradient(135deg, #1a73e8 0%, #1557b0 60%, #0d3b66 100%);
        border-radius: var(--r-lg);
        padding: 32px 28px;
        margin-bottom: 36px;
        position: relative;
        overflow: hidden;
      }

      .vl-rec-banner::before {
        content: '';
        position: absolute;
        top: -60px;
        right: -60px;
        width: 240px;
        height: 240px;
        background: radial-gradient(circle, rgba(255, 255, 255, .06) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
      }

      .vl-rec-inner {
        position: relative;
        z-index: 2;
      }

      .vl-rec-title {
        font-family: var(--f-display);
        font-size: 1.3rem;
        font-weight: 700;
        color: white;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .vl-rec-sub {
        color: rgba(255, 255, 255, .75);
        font-size: 0.85rem;
        margin-bottom: 24px;
      }

      .vl-rec-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 16px;
      }

      .vl-rec-card {
        background: white;
        border-radius: var(--r-md);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition: all var(--t-base);
        box-shadow: 0 4px 12px rgba(0, 0, 0, .1);
      }

      .vl-rec-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, .2);
      }

      .vl-rec-img {
        width: 100%;
        aspect-ratio: 5/3;
        object-fit: cover;
        display: block;
        background: #e8eaed;
      }

      .vl-rec-body {
        padding: 12px 14px 10px;
      }

      .vl-rec-name {
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--c-blue);
        margin-bottom: 6px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .vl-rec-meta {
        font-size: 0.72rem;
        color: var(--c-muted);
      }

      .vl-rec-foot {
        padding: 8px 14px 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      /* Trending banner */
      .vl-trend-banner {
        background: linear-gradient(135deg, #f59e0b 0%, #f97316 50%, #ea580c 100%);
        border-radius: var(--r-lg);
        padding: 32px 28px;
        margin-bottom: 36px;
        position: relative;
        overflow: hidden;
      }

      .vl-trend-banner::before {
        content: '';
        position: absolute;
        top: -80px;
        right: -80px;
        width: 260px;
        height: 260px;
        background: radial-gradient(circle, rgba(255, 255, 255, .08) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
      }

      .vl-trend-inner {
        position: relative;
        z-index: 2;
      }

      .vl-trend-title {
        font-family: var(--f-display);
        font-size: 1.3rem;
        font-weight: 700;
        color: white;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .vl-trend-sub {
        color: rgba(255, 255, 255, .8);
        font-size: 0.85rem;
        margin-bottom: 24px;
      }

      .vl-trend-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(148px, 1fr));
        gap: 14px;
      }

      .vl-trend-card {
        background: white;
        border-radius: 8px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition: all var(--t-base);
        box-shadow: var(--shadow-book);
        position: relative;
      }

      .vl-trend-card::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: linear-gradient(to right, rgba(0, 0, 0, .15), transparent);
        border-radius: 8px 0 0 8px;
        z-index: 3;
        pointer-events: none;
      }

      .vl-trend-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-book-hover);
      }

      .vl-trend-img {
        width: 100%;
        aspect-ratio: 2/3;
        object-fit: cover;
        display: block;
        background: #e8eaed;
      }

      .vl-trend-body {
        padding: 8px 10px 4px;
      }

      .vl-trend-name {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--c-text);
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 3px;
      }

      .vl-trend-foot {
        padding: 4px 10px 10px;
      }

      /* Pagination */
      .vl-pager {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin-top: 40px;
        flex-wrap: wrap;
      }

      .vl-page-btn {
        min-width: 38px;
        height: 38px;
        padding: 0 12px;
        border: 1.5px solid var(--c-border);
        border-radius: 8px;
        background: white;
        color: var(--c-blue);
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        transition: all var(--t-fast);
      }

      .vl-page-btn:hover:not(:disabled) {
        background: var(--c-blue-lt);
        border-color: var(--c-blue);
      }

      .vl-page-btn.active {
        background: var(--c-blue);
        color: white;
        border-color: var(--c-blue);
      }

      .vl-page-btn:disabled {
        opacity: .4;
        cursor: not-allowed;
      }

      /* Empty state */
      .vl-empty {
        grid-column: 1/-1;
        text-align: center;
        padding: 80px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .vl-empty-icon {
        font-size: 4rem;
        color: var(--c-border-md);
        margin-bottom: 20px;
      }

      .vl-empty-title {
        font-family: var(--f-display);
        font-size: 1.4rem;
        font-weight: 600;
        color: var(--c-text);
        margin-bottom: 8px;
      }

      .vl-empty-sub {
        color: var(--c-muted);
        margin-bottom: 24px;
      }

      /* Toast */
      .vl-toasts {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 10px;
        pointer-events: none;
      }

      .vl-toast {
        background: #202124;
        border-radius: 10px;
        padding: 13px 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        color: white;
        font-weight: 600;
        font-size: 0.9rem;
        box-shadow: var(--shadow-lg);
        animation: fadeUp .25s ease;
        pointer-events: auto;
      }

      .vl-toast.success {
        background: #1e7e34;
      }

      .vl-toast.error {
        background: #c5221f;
      }

      .vl-toast.info {
        background: var(--c-blue);
      }

      /* Mobile filter bar */
      .vl-fab {
        display: none;
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 500;
        background: #202124;
        color: white;
        border-radius: var(--r-pill);
        padding: 12px 24px;
        font-size: 0.88rem;
        font-weight: 600;
        align-items: center;
        gap: 8px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, .25);
        cursor: pointer;
        transition: all var(--t-fast);
      }

      .vl-fab:hover {
        background: #303134;
        transform: translateX(-50%) translateY(-2px);
      }

      .vl-fab-badge {
        background: var(--c-blue);
        color: white;
        border-radius: var(--r-pill);
        font-size: 0.72rem;
        padding: 2px 8px;
        font-weight: 700;
      }

      /* Ad */
      .vl-ad {
        width: 100%;
        max-width: 100%;
        overflow: hidden;
        display: flex;
        justify-content: center;
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--r-md);
        margin-bottom: 24px;
        min-height: 90px;
      }

      /* Divider section */
      .vl-divider {
        display: flex;
        align-items: center;
        gap: 16px;
        margin: 40px 0 32px;
      }

      .vl-divider-line {
        flex: 1;
        height: 1px;
        background: var(--c-border);
      }

      .vl-divider-text {
        font-family: var(--f-display);
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--c-text);
        white-space: nowrap;
      }

      /* ── Animations ── */
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(12px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes slideUpCard {
        from {
          opacity: 0;
          transform: translateY(24px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* ══════════════════════════════════
       RESPONSIVE — TABLET
    ══════════════════════════════════ */
      @media (max-width: 1100px) {
        .vl-layout {
          grid-template-columns: 240px minmax(0, 1fr);
        }

        .vl-main {
          padding: 28px 24px 80px;
        }
      }

      /* ══════════════════════════════════
       RESPONSIVE — MOBILE
    ══════════════════════════════════ */
      @media (max-width: 900px) {
        .vl-layout {
          grid-template-columns: 1fr;
        }

        .vl-sidebar {
          position: fixed;
          left: 0;
          top: 0;
          width: 300px;
          height: 100vh;
          z-index: 910;
          transform: translateX(-110%);
          transition: transform .3s cubic-bezier(.4, 0, .2, 1);
          border-right: 1px solid var(--c-border);
          box-shadow: var(--shadow-lg);
        }

        .vl-sidebar.open {
          transform: translateX(0);
        }

        .vl-main {
          padding: 20px 16px 100px;
        }

        .vl-hero {
          padding: 36px 24px;
          margin-bottom: 24px;
        }

        .vl-hero-title {
          font-size: 1.6rem;
        }

        .vl-hero-search {
          max-width: 100%;
        }

        .vl-fab {
          display: flex;
        }

        .vl-section-card {
          padding: 20px 18px 18px;
        }

        .vl-book-card {
          flex: 0 0 128px;
          min-width: 118px;
        }

        .vl-cats {
          grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        }

        .vl-grid {
          grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
          gap: 14px;
        }

        .vl-carousel-btn {
          display: none;
        }

        .vl-rec-grid {
          grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
          gap: 12px;
        }

        .vl-trend-grid {
          grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
          gap: 10px;
        }

        .vl-hero::after {
          display: none;
        }

        .vl-divider-text {
          font-size: 1.15rem;
        }
      }

      @media (max-width: 480px) {
        .vl-hero {
          padding: 28px 18px;
          border-radius: var(--r-md);
        }

        .vl-hero-title {
          font-size: 1.35rem;
        }

        .vl-hero-sub {
          font-size: 0.88rem;
        }

        .vl-book-card {
          flex: 0 0 118px;
          min-width: 108px;
        }

        .vl-grid {
          grid-template-columns: repeat(2, 1fr);
          gap: 12px;
        }

        .vl-rec-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .vl-trend-grid {
          grid-template-columns: repeat(3, 1fr);
        }

        .vl-cats {
          grid-template-columns: repeat(2, 1fr);
        }

        .vl-controls {
          flex-direction: column;
          align-items: flex-start;
        }
      }

      /* Sidebar mobile close btn */
      .vl-sidebar-close-row {
        display: none;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
      }

      @media (max-width: 900px) {
        .vl-sidebar-close-row {
          display: flex;
        }

        .vl-sidebar-logo {
          display: none;
        }
      }

      .vl-close-btn {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: var(--c-bg);
        display: grid;
        place-items: center;
        color: var(--c-muted);
