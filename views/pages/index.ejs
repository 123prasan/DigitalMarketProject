    <div class="vl-toasts" id="vToastContainer"></div><%- include("../components/footer") %> <script>
      /* ═══════════════════════════════════════════════════
           CAROUSEL ENGINE — Smooth eased scroll + drag
        ═══════════════════════════════════════════════════ */
      function carousel(id, dir) {
        const el = document.getElementById(id);
        if (!el) return;
        const w = el.clientWidth * 0.75;
        const start = el.scrollLeft;
        const end = start + dir * w;
        const dur = 400;
        let t0 = null;
        const ease = t => t < .5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
        const step = ts => {
          if (!t0) t0 = ts;
          const p = Math.min((ts - t0) / dur, 1);
          el.scrollLeft = start + (end - start) * ease(p);
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      }
      // Drag-to-scroll
      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.vl-carousel').forEach(el => {
          let down = false,
            sx, sl;
          el.addEventListener('mousedown', e => {
            down = true;
            sx = e.pageX - el.offsetLeft;
            sl = el.scrollLeft;
            el.style.cursor = 'grabbing';
          });
          el.addEventListener('mouseleave', () => {
            down = false;
            el.style.cursor = 'grab';
          });
          el.addEventListener('mouseup', () => {
            down = false;
            el.style.cursor = 'grab';
          });
          el.addEventListener('mousemove', e => {
            if (!down) return;
            e.preventDefault();
            el.scrollLeft = sl - (e.pageX - el.offsetLeft - sx) * 1.5;
          });
        });
      });
      /* ═══════════════════════════════════════════════════
         BOOK CARD FACTORY
      ═══════════════════════════════════════════════════ */
      function makeBookCard(item, badgeClass, badgeLabel) {
        const title = item.title || item.name || 'Untitled';
        const price = item.price || 0;
        const isFree = price === 0 || price === '0' || item.isFree;
        const rating = parseFloat(item.rating || item.avgRating || 0);
        const author = item.author || item.user || item.uploaderName || 'Vidyari';
        const id = item._id || item.id;
        const href = (item.type === 'course' ? '/course/' : '/file/') + item.slug + '/' + id;
        const stars = Math.min(5, Math.round(rating));
        const fallback = `https://placehold.co/300x450/${encodeURIComponent('1a237e')}/${encodeURIComponent('ffffff')}?text=${encodeURIComponent(title.substring(0, 14))}&font=Georgia`;
        const img = (item.image && item.image.trim() && item.image !== 'null') ? item.image : fallback;
        const priceStr = isFree ? 'Free' : '&#8377;' + Math.floor(price);
        return `
																																					<a href="${href}" class="vl-book-card">
    ${badgeLabel ? `
																																						<span class="vl-book-badge ${badgeClass}">${badgeLabel}</span>` : ''}
    
																																						<img src="${img}" class="vl-book-cover" loading="lazy" decoding="async" onerror="this.src='/images/File_Demo.svg'">
																																							<div class="vl-book-body">
																																								<div class="vl-book-title">${title.substring(0, 55)}</div>
																																								<div class="vl-book-author">${author}</div>
      ${rating > 0 ? `
																																								<div>
																																									<span class="vl-book-stars">${'★'.repeat(stars)}${'☆'.repeat(5 - stars)}</span>
																																									<span class="vl-book-rating-val"> ${rating.toFixed(1)}</span>
																																								</div>` : ''}
    
																																							</div>
																																							<div class="vl-book-footer">
																																								<span class="vl-book-price${isFree ? ' is-free' : ''}">${priceStr}</span>
																																							</div>
																																						</a>`;
      }
      async function loadCarousel(apiUrl, carouselId, badgeClass, badgeLabel) {
        try {
          const res = await fetch(apiUrl);
          const data = await res.json();
          const el = document.getElementById(carouselId);
          if (!el) return;
          const items = (data.results || []).slice(0, 12).map(item => ({
            ...item,
            image: item.image || (item.imageType ? `https://d3epchi0htsp3c.cloudfront.net/files-previews/images/${item._id}.${item.imageType}` : null)
          }));
          if (items.length) {
            el.innerHTML = items.map(i => makeBookCard(i, badgeClass, badgeLabel)).join('');
          } else {
            el.innerHTML = ' < p style = "padding:24px;color:var(--c-muted);" > No items available. < /p>';
          }
        } catch (e) {
          const el = document.getElementById(carouselId);
          if (el) el.innerHTML = ' < p style = "padding:24px;color:var(--c-muted);" > Failed to load. < /p>';
        }
      }
      async function loadCategories() {
        try {
          const res = await fetch('/api/search/filters-options');
          const data = await res.json();
          const el = document.getElementById('vCategoryShowcase');
          const icons = {
            'Technology': 'fas fa-laptop-code',
            'Mathematics': 'fas fa-calculator',
            'Science': 'fas fa-flask',
            'Business': 'fas fa-briefcase',
            'Language': 'fas fa-language',
            'Arts': 'fas fa-palette',
            'Engineering': 'fas fa-hammer',
            'Music': 'fas fa-music',
            'Health': 'fas fa-heart-pulse',
            'History': 'fas fa-book-open',
            'Programming': 'fas fa-code',
            'Writing': 'fas fa-pen-fancy',
            'Design': 'fas fa-paint-brush',
            'Finance': 'fas fa-chart-line',
            'Education': 'fas fa-graduation-cap'
          };
          const palettes = [{
            bg: '#fff4e6',
            color: '#f97316'
          }, {
            bg: '#e8f0fe',
            color: '#1a73e8'
          }, {
            bg: '#f3e8ff',
            color: '#7c3aed'
          }, {
            bg: '#e0f7fa',
            color: '#0097a7'
          }, {
            bg: '#fffbeb',
            color: '#f59e0b'
          }, {
            bg: '#fce7f3',
            color: '#db2777'
          }, {
            bg: '#ecfdf5',
            color: '#059669'
          }, {
            bg: '#fff1f2',
            color: '#e11d48'
          }];
          if (data.categories && data.categories.length) {
            el.innerHTML = data.categories.slice(0, 8).map((cat, i) => {
              const p = palettes[i % palettes.length];
              const ico = icons[cat] || 'fas fa-folder';
              return `
																																						<a href="/search?q=&category[]=${encodeURIComponent(cat)}" class="vl-cat-card">
																																							<div class="vl-cat-icon" style="background:${p.bg};color:${p.color};">
																																								<i class="${ico}"></i>
																																							</div>
																																							<div class="vl-cat-name">${cat}</div>
																																							<div class="vl-cat-cta">Explore →</div>
																																						</a>`;
            }).join('');
          } else {
            el.innerHTML = ' < p style = "grid-column:1/-1;text-align:center;padding:20px;color:var(--c-muted);" > Categories coming soon < /p>';
          }
        } catch (e) {
          document.getElementById('vCategoryShowcase').innerHTML = ' < p style = "text-align:center;padding:20px;color:var(--c-muted);" > Failed to load. < /p>';
        }
      }
      document.addEventListener('DOMContentLoaded', () => {
        // Adsense
        try {
          (adsbygoogle = window.adsbygoogle || []).push({});
        } catch (e) {}
        // Load featured
        setTimeout(() => {
          loadCarousel('/api/search/advanced?sortBy=trending&limit=20&assetType=files&page=1', 'vBestSellersCarousel', 'badge-hot', '🔥 Hot');
          loadCarousel('/api/search/advanced?sortBy=newest&limit=20&assetType=files&page=1', 'vNewReleasesCarousel', 'badge-new', 'New');
          loadCarousel('/api/search/advanced?sortBy=rating&limit=20&assetType=files&page=1', 'vTopRatedCarousel', 'badge-top', '★ Top');
          loadCategories();
        }, 300);
        // Hero search
        const heroBtn = document.getElementById('vHeroSearchBtn');
        const heroInp = document.getElementById('vHeroSearchInput');
        const go = () => {
          const q = heroInp.value.trim();
          if (q) location.href = `/search?query=${encodeURIComponent(q)}`;
        };
        heroBtn?.addEventListener('click', go);
        heroInp?.addEventListener('keypress', e => {
          if (e.key === 'Enter') go();
        });
        /* ═══════════════════════════════════════
           STATE MACHINE
        ═══════════════════════════════════════ */
        const State = {
          query: '',
          page: 1,
          limit: 24,
          totalPages: 1,
          totalItems: 0,
          sort: 'popular',
          filters: {
            priceTier: 'all',
            categories: [],
            fileTypes: [],
            assetType: 'all',
            priceMin: null,
            priceMax: null,
            minRating: null,
            dateRange: 'all'
          },
          availableCategories: [],
          availableFileTypes: [],
          viewMode: localStorage.getItem('vl-view') || 'grid',
          recentSearches: JSON.parse(localStorage.getItem('vl-recents') || '[]'),
          isFetching: false,
          fetchCtrl: null,
          suggestCtrl: null,
          suggCache: new Map()
        };
        const DOM = {
          grid: document.getElementById('vGrid'),
          pagination: document.getElementById('vPagination'),
          totalCount: document.getElementById('vTotalCount'),
          activeFilters: document.getElementById('vActiveFilters'),
          sidebar: document.getElementById('vlSidebar'),
          overlay: document.getElementById('vlOverlay'),
          mobileBtn: document.getElementById('vMobileFilterBtn'),
          mobileBadge: document.getElementById('vMobileBadge'),
          closeSidebar: document.getElementById('vlCloseSidebar'),
          catList: document.getElementById('vCategoryList'),
          typeList: document.getElementById('vFileTypeList'),
          sortSelect: document.getElementById('vSortSelect'),
          applyBtn: document.getElementById('vApplyBtn'),
          clearBtn: document.getElementById('vClearBtn'),
          viewBtns: document.querySelectorAll('.vl-view-btn'),
          toastBox: document.getElementById('vToastContainer')
        };
        /* UTILS */
        const U = {
          price: p => (p === 0 || p === '0') ? 'FREE' : `₹${parseFloat(p).toFixed(0)}`,
          slugify: s => s ? s.toLowerCase().trim().replace(/[^\w\-]+/g, '-') : 'file',
          fileIcon: t => {
            t = (t || '').toLowerCase();
            if (t.includes('pdf')) return 'fa-file-pdf';
            if (t.includes('zip') || t.includes('rar')) return 'fa-file-zipper';
            if (t.includes('mp4') || t.includes('video')) return 'fa-file-video';
            if (t.includes('ppt')) return 'fa-file-powerpoint';
            if (t.includes('doc')) return 'fa-file-word';
            return 'fa-file-lines';
          },
          debounce: (fn, ms) => {
            let t;
            return (...a) => {
              clearTimeout(t);
              t = setTimeout(() => fn(...a), ms);
            };
          },
          toast: (msg, type = 'success') => {
            const d = document.createElement('div');
            d.className = `vl-toast ${type}`;
            const icons = {
              success: 'fa-circle-check',
              error: 'fa-circle-exclamation',
              info: 'fa-circle-info'
            };
            d.innerHTML = `
																																						<i class="fas ${icons[type]}"></i>
																																						<span>${msg}</span>`;
            DOM.toastBox.appendChild(d);
            setTimeout(() => {
              d.style.opacity = '0';
              setTimeout(() => d.remove(), 300);
            }, 3000);
          },
          copy: async txt => {
            try {
              await navigator.clipboard.writeText(txt);
              U.toast('Link copied!');
            } catch (e) {
              U.toast('Failed to copy', 'error');
            }
          }
        };
        // Share delegation
        DOM.grid.addEventListener('click', e => {
          const btn = e.target.closest('.vl-share-btn');
          if (btn) {
            e.preventDefault();
            e.stopPropagation();
            U.copy(btn.dataset.shareLink);
          }
        });
        /* NETWORK */
        const Net = {
          suggest: async q => {
            const k = q.toLowerCase();
            if (State.suggCache.has(k)) return State.suggCache.get(k);
            if (State.suggestCtrl) State.suggestCtrl.abort();
            State.suggestCtrl = new AbortController();
            try {
              const r = await fetch(`/files?search=${encodeURIComponent(q)}&limit=5`, {
                signal: State.suggestCtrl.signal
              });
              if (!r.ok) throw new Error();
              const d = await r.json();
              const s = (d.files || []).map(f => ({
                text: f.filename,
                category: f.category || 'Match'
              }));
              if (State.suggCache.size > 20) State.suggCache.delete(State.suggCache.keys().next().value);
              State.suggCache.set(k, s);
              return s;
            } catch (e) {
              return e.name === 'AbortError' ? null : [];
            }
          },
          files: async (init = false) => {
            if (State.isFetching) return;
            if (State.fetchCtrl) State.fetchCtrl.abort();
            State.fetchCtrl = new AbortController();
            State.isFetching = true;
            Render.skeletons();
            try {
              const p = new URLSearchParams({
                page: State.page,
                limit: State.limit,
                sort: State.sort
              });
              if (State.query) p.append('search', State.query);
              if (State.filters.assetType !== 'all') p.append('assetType', State.filters.assetType);
              if (State.filters.priceMin !== null) p.append('priceMin', State.filters.priceMin);
              if (State.filters.priceMax !== null) p.append('priceMax', State.filters.priceMax);
              if (State.filters.priceTier !== 'all' && State.filters.priceMin === null && State.filters.priceMax === null) p.append('price', State.filters.priceTier);
              if (State.filters.minRating) p.append('minRating', State.filters.minRating);
              if (State.filters.dateRange !== 'all') p.append('dateRange', State.filters.dateRange);
              State.filters.categories.forEach(c => p.append('category', c));
              State.filters.fileTypes.forEach(t => p.append('fileType', t));
              const r = await fetch(`/files?${p}`, {
                signal: State.fetchCtrl.signal
              });
              if (!r.ok) throw new Error(`HTTP ${r.status}`);
              const d = await r.json();
              State.totalItems = d.totalFiles || 0;
              State.totalPages = d.totalPages || 1;
              if (init) {
                if (d.allCategories) State.availableCategories = d.allCategories;
                if (d.allFileTypes) State.availableFileTypes = d.allFileTypes;
                Render.sidebarFilters();
              }
              DOM.totalCount.textContent = State.totalItems;
              d.files && d.files.length ? (Render.grid(d.files), Render.pagination()) : Render.empty();
            } catch (e) {
              if (e.name === 'AbortError') return;
              Render.empty('Server error. Please try again.');
              U.toast('Failed to load resources', 'error');
            } finally {
              State.isFetching = false;
            }
          }
        };
        /* RENDER */
        const Render = {
          sidebarFilters: () => {
            DOM.catList.innerHTML = State.availableCategories.length ? State.availableCategories.map(c => `
																																						<label class="vl-check-row">
																																							<input type="checkbox" class="vl-chk cat-check" value="${c}" ${State.filters.categories.includes(c) ? 'checked' : ''}>
																																								<span>${c}</span>
																																							</label>`).join('') : ' < div style = "padding:8px;font-size:.85rem;color:var(--c-muted);" > None available < /div>';
            DOM.typeList.innerHTML = State.availableFileTypes.length ? State.availableFileTypes.map(t => `
																																							<label class="vl-check-row">
																																								<input type="checkbox" class="vl-chk type-check" value="${t}" ${State.filters.fileTypes.includes(t) ? 'checked' : ''}>
																																									<span style="text-transform:uppercase;">${t}</span>
																																								</label>`).join('') : ' < div style = "padding:8px;font-size:.85rem;color:var(--c-muted);" > None available < /div>';
          },
          pills: () => {
            let html = '',
              count = 0;
            if (State.filters.assetType !== 'all') {
              html += `
																																								<div class="vl-pill">${State.filters.assetType === 'files' ? 'Files Only' : 'Courses Only'} 
																																									<i class="fas fa-xmark vl-pill-x" onclick="Ev.removePill('asset')"></i>
																																								</div>`;
              count++;
            }
            if (State.filters.priceMin !== null || State.filters.priceMax !== null) {
              html += `
																																								<div class="vl-pill">₹${State.filters.priceMin || 0} – ₹${State.filters.priceMax || '∞'} 
																																									<i class="fas fa-xmark vl-pill-x" onclick="Ev.removePill('pricerange')"></i>
																																								</div>`;
              count++;
            } else if (State.filters.priceTier === 'free') {
              html += `
																																								<div class="vl-pill">Free Only 
																																									<i class="fas fa-xmark vl-pill-x" onclick="Ev.removePill('price')"></i>
																																								</div>`;
              count++;
            } else if (State.filters.priceTier === 'paid') {
              html += `
																																								<div class="vl-pill">Premium Only 
																																									<i class="fas fa-xmark vl-pill-x" onclick="Ev.removePill('price')"></i>
																																								</div>`;
              count++;
            }
            if (State.filters.minRating) {
              html += `
																																								<div class="vl-pill">${State.filters.minRating}+ Stars 
																																									<i class="fas fa-xmark vl-pill-x" onclick="Ev.removePill('rating')"></i>
																																								</div>`;
              count++;
            }
            if (State.filters.dateRange !== 'all') {
              const labels = {
                week: 'Past Week',
                month: 'Past Month',
                '3months': 'Past 3 Mo',
                '6months': 'Past 6 Mo',
                year: 'Past Year'
              };
              html += `
																																								<div class="vl-pill">${labels[State.filters.dateRange] || State.filters.dateRange} 
																																									<i class="fas fa-xmark vl-pill-x" onclick="Ev.removePill('date')"></i>
																																								</div>`;
              count++;
            }
            State.filters.categories.forEach(c => {
              html += `
																																								<div class="vl-pill">${c} 
																																									<i class="fas fa-xmark vl-pill-x" onclick="Ev.removePill('cat','${c}')"></i>
																																								</div>`;
              count++;
            });
            State.filters.fileTypes.forEach(t => {
              html += `
																																								<div class="vl-pill" style="text-transform:uppercase;">${t} 
																																									<i class="fas fa-xmark vl-pill-x" onclick="Ev.removePill('type','${t}')"></i>
																																								</div>`;
              count++;
            });
            DOM.activeFilters.innerHTML = html;
            DOM.mobileBadge.textContent = count;
            DOM.mobileBadge.style.display = count > 0 ? 'inline-block' : 'none';
          },
          skeletons: () => {
            DOM.grid.innerHTML = Array(8).fill('').map(() => `
																																								<div class="vl-skel-grid">
																																									<div class="vl-skel-img"></div>
																																									<div class="vl-skel-body">
																																										<div class="vl-skel-text"></div>
																																										<div class="vl-skel-text" style="width:60%;"></div>
																																										<div class="vl-skel-text" style="width:35%;height:14px;margin-top:8px;"></div>
																																									</div>
																																								</div>`).join('');
            DOM.pagination.innerHTML = '';
          },
          empty: (msg = 'No resources match your current filters.') => {
            DOM.grid.innerHTML = `
																																								<div class="vl-empty">
																																									<div class="vl-empty-icon">
																																										<i class="far fa-folder-open"></i>
																																									</div>
																																									<div class="vl-empty-title">No results found</div>
																																									<div class="vl-empty-sub">${msg}</div>
																																									<button class="vl-btn-apply" style="padding:10px 28px;border-radius:8px;" onclick="Ev.clearAll()">Clear Filters</button>
																																								</div>`;
          },
          grid: files => {
            DOM.grid.innerHTML = files.map((f, i) => {
              const isFree = f.price === 0 || f.price === '0';
              const link = `/file/${f.slug || U.slugify(f.filename)}/${f._id}`;
              const full = location.origin + link;
              const img = f.previewUrl && f.previewUrl.trim() !== '' ? f.previewUrl : `https://placehold.co/600x400/e8f0fe/1a73e8?text=${encodeURIComponent((f.filename || '').substring(0, 14))}&font=Outfit`;
              const ico = U.fileIcon(f.fileType);
              const avt = f.user ? f.user.charAt(0).toUpperCase() : 'V';
              const rating = f.rating || '4.8';
              const dl = f.downloadCount || Math.floor(Math.random() * 500) + 12;
              return `
																																								<a href="${link}" class="vl-file-card" style="animation:slideUpCard .4s ease ${i * .05}s forwards;opacity:0;transform:translateY(20px);">
																																									<div class="vl-file-img-wrap">
																																										<div class="vl-file-badges">
																																											<span class="vl-file-cat-badge">${f.category || 'Resource'}</span>
																																										</div>
																																										<button type="button" class="vl-wish-btn" data-wishlist-btn data-file-id="${f._id}" data-file-title="${f.filename.replace(/'/g, "'")}">
																																											<i class="far fa-heart"></i>
																																										</button>
																																										<img src="${img}" class="vl-file-img" loading="lazy" onerror="this.src='/images/File_Demo.svg'">
																																										</div>
																																										<div class="vl-file-body">
																																											<h3 class="vl-file-title" title="${f.filename}">${f.filename}</h3>
																																											<div class="vl-file-meta">
																																												<span>
																																													<i class="fas fa-star vl-star"></i> ${rating}
																																												</span>
																																												<span class="vl-dot">•</span>
																																												<span>
																																													<i class="fas fa-download" style="color:var(--c-blue);"></i> ${dl}
																																												</span>
																																											</div>
																																											<div class="vl-file-author">
																																												<div class="vl-author-avatar">${avt}</div>
																																												<span class="vl-author-name">${f.user || 'Vidyari Creator'}</span>
																																											</div>
																																										</div>
																																										<div class="vl-file-foot">
																																											<span class="vl-price${isFree ? ' free' : ''}">${U.price(f.price)}</span>
																																											<div class="vl-card-actions">
																																												<button class="vl-action-btn vl-share-btn" data-share-link="${full}" title="Copy link">
																																													<i class="fas fa-share-nodes"></i>
																																												</button>
																																												<div class="vl-action-btn primary">
																																													<i class="fas fa-arrow-right"></i>
																																												</div>
																																											</div>
																																										</div>
																																									</a>`;
            }).join('');
          },
          pagination: () => {
            if (State.totalPages <= 1) {
              DOM.pagination.innerHTML = '';
              return;
            }
            let h = `
																																									<button class="vl-page-btn" ${State.page === 1 ? 'disabled' : ''} data-p="${State.page - 1}">
																																										<i class="fas fa-chevron-left"></i>
																																									</button>`;
            let s = Math.max(1, State.page - 2),
              e = Math.min(State.totalPages, s + 4);
            if (e - s < 4) s = Math.max(1, e - 4);
            if (s > 1) {
              h += `
																																									<button class="vl-page-btn" data-p="1">1</button>`;
              if (s > 2) h += `
																																									<span style="padding:0 6px;align-self:center;color:var(--c-muted);">…</span>`;
            }
            for (let i = s; i <= e; i++) h += `
																																									<button class="vl-page-btn${i === State.page ? ' active' : ''}" data-p="${i}">${i}</button>`;
            if (e < State.totalPages) {
              if (e < State.totalPages - 1) h += `
																																									<span style="padding:0 6px;align-self:center;color:var(--c-muted);">…</span>`;
              h += `
																																									<button class="vl-page-btn" data-p="${State.totalPages}">${State.totalPages}</button>`;
            }
            h += `
																																									<button class="vl-page-btn" ${State.page === State.totalPages ? 'disabled' : ''} data-p="${State.page + 1}">
																																										<i class="fas fa-chevron-right"></i>
																																									</button>`;
            DOM.pagination.innerHTML = h;
            DOM.pagination.querySelectorAll('.vl-page-btn:not([disabled])').forEach(btn => {
              btn.addEventListener('click', e => {
                State.page = parseInt(e.currentTarget.dataset.p);
                Net.files();
                window.scrollTo({
                  top: 0,
                  behavior: 'smooth'
                });
              });
            });
          }
        };
        /* Search engine removed */
        /* EVENTS */
        const Ev = {
          init: () => {
            const toggleSidebar = open => {
              DOM.sidebar.classList.toggle('open', open);
              DOM.overlay.classList.toggle('is-active', open);
              document.body.style.overflow = open ? 'hidden' : '';
            };
            DOM.mobileBtn?.addEventListener('click', () => toggleSidebar(true));
            DOM.closeSidebar?.addEventListener('click', () => toggleSidebar(false));
            DOM.overlay.addEventListener('click', () => toggleSidebar(false));
            DOM.applyBtn.addEventListener('click', () => {
              Ev.syncState();
              Net.files();
              toggleSidebar(false);
              window.scrollTo({
                top: 0,
                behavior: 'smooth'
              });
            });
            DOM.clearBtn.addEventListener('click', () => {
              Ev.clearAll();
              toggleSidebar(false);
            });
            DOM.sortSelect.addEventListener('change', () => {
              State.sort = DOM.sortSelect.value;
              State.page = 1;
              Net.files();
            });
            DOM.viewBtns.forEach(btn => {
              btn.addEventListener('click', e => {
                const v = e.currentTarget.dataset.view;
                DOM.viewBtns.forEach(b => b.classList.remove('active'));
                e.currentTarget.classList.add('active');
                v === 'list' ? DOM.grid.classList.add('is-list') : DOM.grid.classList.remove('is-list');
                localStorage.setItem('vl-view', v);
              });
            });
            window.Ev = Ev;
          },
          syncState: () => {
            State.filters.priceTier = document.querySelector('input[name="priceTier"]:checked')?.value || 'all';
            State.filters.assetType = document.querySelector('input[name="assetType"]:checked')?.value || 'all';
            const mn = document.getElementById('vPriceMin'),
              mx = document.getElementById('vPriceMax');
            State.filters.priceMin = mn && mn.value ? parseInt(mn.value) : null;
            State.filters.priceMax = mx && mx.value ? parseInt(mx.value) : null;
            const rc = Array.from(document.querySelectorAll('.rating-check:checked')).map(c => c.value);
            State.filters.minRating = rc.length && rc[0] !== '0' ? rc[0] : null;
            const dr = document.getElementById('vDateRange');
            State.filters.dateRange = dr ? dr.value || 'all' : 'all';
            State.filters.categories = Array.from(document.querySelectorAll('.cat-check:checked')).map(c => c.value);
            State.filters.fileTypes = Array.from(document.querySelectorAll('.type-check:checked')).map(c => c.value);
            State.page = 1;
            Render.pills();
          },
          clearAll: () => {
            document.getElementById('vPriceAll').checked = true;
            document.querySelectorAll('input[name="assetType"]').forEach(c => c.checked = c.value === 'all');
            document.getElementById('vPriceMin').value = '0';
            document.getElementById('vPriceMax').value = '10000';
            document.querySelectorAll('.rating-check').forEach(c => c.checked = false);
            document.getElementById('vRating0').checked = true;
            document.getElementById('vDateRange').value = 'all';
            document.querySelectorAll('.vl-chk').forEach(c => c.checked = false);
            State.query = '';
            Ev.syncState();
            Net.files();
          },
          removePill: (type, val) => {
            if (type === 'price') document.getElementById('vPriceAll').checked = true;
            if (type === 'asset') {
              const c = document.querySelector('input[name="assetType"][value="all"]');
              if (c) c.checked = true;
            }
            if (type === 'pricerange') {
              document.getElementById('vPriceMin').value = '0';
              document.getElementById('vPriceMax').value = '10000';
            }
            if (type === 'rating') {
              document.querySelectorAll('.rating-check').forEach(c => c.checked = false);
              document.getElementById('vRating0').checked = true;
            }
            if (type === 'date') {
              document.getElementById('vDateRange').value = 'all';
            }
            if (type === 'cat') {
              const c = document.querySelector(`.cat-check[value="${val}"]`);
              if (c) c.checked = false;
            }
            if (type === 'type') {
              const c = document.querySelector(`.type-check[value="${val}"]`);
              if (c) c.checked = false;
            }
            Ev.syncState();
            Net.files();
          }
        };
        Ev.init();
        if (State.viewMode === 'list') {
          DOM.grid.classList.add('is-list');
          DOM.viewBtns.forEach(b => b.classList.toggle('active', b.dataset.view === 'list'));
        }
        Net.files(true);
        /* RECOMMENDATIONS */
        const loadRec = async () => {
          try {
            let t = 0;
            while (typeof window.ActivityTracker_Instance === 'undefined' && t < 50) {
              await new Promise(r => setTimeout(r, 100));
              t++;
            }
            if (!window.ActivityTracker_Instance) return;
            const {
              recommendations
            } = await window.ActivityTracker_Instance.getRecommendations(12, 'both');
            if (recommendations && recommendations.length) {
              const sec = document.getElementById('vRecommendations');
              const grid = document.getElementById('vRecommendationsGrid');
              grid.innerHTML = recommendations.map((item, i) => {
                const isFree = item.price === 0 || item.price === '0';
                const link = `/file/${item.slug || U.slugify(item.title || item.filename)}/${item._id}`;
                const img = (item.previewUrl && item.previewUrl.trim() && item.previewUrl !== 'null') ? item.previewUrl : `https://placehold.co/600x380/e8f0fe/1a73e8?text=${encodeURIComponent((item.title || item.filename || '').substring(0, 14))}&font=Outfit`;
                return `
																																									<a href="${link}" class="vl-rec-card" style="animation:slideUpCard .5s ease ${i * .06}s forwards;opacity:0;transform:translateY(20px);">
																																										<img src="${img}" class="vl-rec-img" loading="lazy" onerror="this.src='/images/File_Demo.svg'">
																																											<div class="vl-rec-body">
																																												<div class="vl-rec-name">${item.title || item.filename}</div>
																																												<div class="vl-rec-meta">
																																													<i class="fas fa-star" style="color:#f59e0b;"></i> ${item.rating || '4.8'} · ${item.category || 'Resource'}
																																												</div>
																																											</div>
																																											<div class="vl-rec-foot">
																																												<span class="vl-price${isFree ? ' free' : ''}">${U.price(item.price)}</span>
																																												<span style="font-size:.8rem;color:var(--c-blue);font-weight:600;">View →</span>
																																											</div>
																																										</a>`;
              }).join('');
              sec.style.display = 'block';
            }
          } catch (e) {}
        };
        /* TRENDING */
        const loadTrending = async () => {
          try {
            const res = await fetch('/api/search/trending?limit=30&assetType=files&page=1');
            const data = await res.json();
            const items = (data.results || []).map(item => ({
              ...item,
              image: item.image || (item.imageType ? `https://d3epchi0htsp3c.cloudfront.net/files-previews/images/${item._id}.${item.imageType}` : null)
            }));
            if (items.length > 0) {
              const sec = document.getElementById('vPopular');
              const grid = document.getElementById('vPopularGrid');
              grid.innerHTML = items.map((item, i) => {
                const isFree = item.price === 0 || item.price === '0';
                const link = `/file/${item.slug || U.slugify(item.title)}/${item._id}`;
                const fallback = `https://placehold.co/300x450/fff4e6/f97316?text=${encodeURIComponent((item.title || '').substring(0, 14))}&font=Georgia`;
                const img = (item.image && item.image.trim() && item.image !== 'null') ? item.image : fallback;
                const rating = parseFloat(item.rating || 0);
                const stars = Math.min(5, Math.round(rating));
                return `
																																										<a href="${link}" class="vl-trend-card" style="animation:slideUpCard .5s ease ${i * .05}s forwards;opacity:0;transform:translateY(20px);">
																																											<img src="${img}" class="vl-trend-img" loading="lazy" onerror="this.src='/images/File_Demo.svg'">
																																												<div class="vl-trend-body">
																																													<div class="vl-trend-name">${(item.title || '').substring(0, 45)}</div>
              ${rating > 0 ? `
																																													<div style="font-size:.65rem;color:#f59e0b;">${'★'.repeat(stars)}${'☆'.repeat(5 - stars)}</div>` : ''}
            
																																												</div>
																																												<div class="vl-trend-foot">
																																													<span class="vl-book-price${isFree ? ' is-free' : ''}" style="font-size:.8rem;">${isFree ? 'Free' : '₹' + Math.floor(item.price)}</span>
																																												</div>
																																											</a>`;
              }).join('');
              sec.style.display = 'block';
            }
          } catch (e) {}
        };
        setTimeout(loadRec, 800);
        setTimeout(loadTrending, 1000);
      });
    </script>
  </body>
</html>