<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>Vidyari | Buy & Sell Study Notes, Courses, and Digital Resources</title>
    <meta name="description" content="Join Vidyari, the ultimate creator marketplace. Buy and sell premium study materials, lecture notes, video courses, and ebooks. Turn your knowledge into income today!">
    <meta name="keywords" content="sell study notes, buy courses, digital marketplace, student resources, creator platform, Vidyari, online learning, sell ebooks">
    <meta name="author" content="Vidyari">
    <link rel="canonical" href="https://www.vidyari.com/" />
    
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3321203820490717" crossorigin="anonymous"></script>
    <meta name="google-site-verification" content="Hcnu9BHn9udbxOrSebP2NCm4kTf0IwYg9mStgcwI0BU" />
    
    <link rel="icon" type="image/svg+xml" href="/images/logo.svg">
    <link rel="alternate icon" type="image/png" href="/images/logo.png">
    <link rel="apple-touch-icon" href="/images/logo.png">
    <link rel="manifest" href="/manifest.json">

    <meta property="og:title" content="Vidyari | The Ultimate Creator Marketplace">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.vidyari.com/">
    <meta property="og:image" content="https://www.vidyari.com/images/logo.svg">
    <meta property="og:description" content="Turn your notes, guides, and courses into a sustainable income stream on Vidyari.">
    <meta property="og:site_name" content="Vidyari">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Vidyari | The Ultimate Creator Marketplace">
    <meta name="twitter:description" content="Turn your notes, guides, and courses into a sustainable income stream on Vidyari.">
    <meta name="twitter:image" content="https://www.vidyari.com/images/logo.svg">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "Vidyari",
          "url": "https://www.vidyari.com",
          "logo": "https://www.vidyari.com/images/logo.svg",
          "description": "A premier marketplace for creators to sell digital study materials."
        },
        {
          "@type": "WebSite",
          "url": "https://www.vidyari.com",
          "potentialAction": {
            "@type": "SearchAction",
            "target": "https://www.vidyari.com/documents?search={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        }
      ]
    }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* ------------------------------------------------------------------- */
        /* ------------------- GEMINI / MATERIAL 3 THEME --------------------- */
        /* ------------------------------------------------------------------- */
        
        :root {
            --font-display: 'Outfit', sans-serif;
            --font-body: 'Inter', sans-serif;
            
            --bg-main: #f0f4f9;        /* Gemini Soft Background */
            --bg-surface: #ffffff;     /* Clean White Cards */
            
            --primary: #0b57d0;        /* Gemini Blue */
            --primary-hover: #1a73e8;
            --primary-bg: #e8f0fe;     /* Soft Blue Background */
            
            --text-main: #1f1f1f;
            --text-muted: #444746;
            
            --border: #e3e3e3;
            --radius-pill: 9999px;
            --radius-card: 24px;
            --radius-sm: 16px;
            
            --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.05);
            --shadow-hover: 0 8px 24px rgba(11, 87, 208, 0.08);
            
            --transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
        }

        .vidyari-landing-wrapper {
            font-family: var(--font-body);
            background-color: var(--bg-main);
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
            position: relative;
        }
        .vidyari-landing-wrapper * { margin: 0; padding: 0; box-sizing: border-box; }

        /* Soft Decorative Background Elements */
        .landing-bg-glow {
            position: absolute;
            width: 60vw;
            height: 60vw;
            background: radial-gradient(circle, rgba(232,240,254,1) 0%, rgba(240,244,249,0) 70%);
            top: -20vh;
            left: -10vw;
            z-index: 0;
            pointer-events: none;
        }

        .main-content { position: relative; z-index: 1; }
        
        .section-padding { padding: 96px 24px; }
        .container { max-width: 1100px; margin: 0 auto; }
        
        /* Typography */
        .heading-xl {
            font-family: var(--font-display);
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 600;
            text-align: center;
            margin-bottom: 1.5rem;
            color: var(--text-main);
            letter-spacing: -1px;
            line-height: 1.1;
        }
        .heading-lg {
            font-family: var(--font-display);
            font-size: clamp(2rem, 4vw, 2.5rem);
            font-weight: 600;
            text-align: center;
            margin-bottom: 1rem;
            color: var(--text-main);
            letter-spacing: -0.5px;
        }
        .sub-heading {
            max-width: 680px; 
            margin: 0 auto 56px auto; 
            text-align: center;
            font-size: 1.125rem; 
            line-height: 1.6; 
            color: var(--text-muted);
        }

        /* Buttons */
        .btn-pill {
            display: inline-flex; 
            align-items: center;
            justify-content: center;
            padding: 16px 36px; 
            font-weight: 500;
            font-size: 1rem; 
            text-decoration: none; 
            border-radius: var(--radius-pill);
            transition: var(--transition);
            border: 1px solid transparent;
            font-family: var(--font-display);
        }
        .btn-primary { 
            background-color: var(--primary); 
            color: #fff; 
        }
        .btn-primary:hover { 
            background-color: var(--primary-hover); 
            box-shadow: var(--shadow-hover);
            transform: translateY(-2px);
        }
        .btn-secondary { 
            background-color: var(--bg-surface); 
            color: var(--text-main);
            border-color: var(--border);
        }
        .btn-secondary:hover { 
            background-color: var(--bg-main); 
            transform: translateY(-2px);
        }

        /* Cards */
        .glass-card {
            background: var(--bg-surface); 
            border: 1px solid var(--border);
            border-radius: var(--radius-card); 
            padding: 40px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
            height: 100%;
        }
        .glass-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-4px);
            border-color: #d2e3fc;
        }

        /* Hero Section */
        .hero-section { padding: 120px 24px 80px; text-align: center; position: relative; }
        .hero-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
        .hero-image { width: 100%; max-width: 450px; margin: 48px auto 0; display: block; filter: drop-shadow(0 20px 30px rgba(0,0,0,0.05)); }
        
        /* Grid Layouts */
        .grid-container { display: grid; gap: 24px; }
        .grid-2 { grid-template-columns: repeat(2, 1fr); }
        .grid-3 { grid-template-columns: repeat(3, 1fr); }

        /* Feature Cards */
        .icon-circle {
            width: 64px; height: 64px; border-radius: 50%;
            background-color: var(--primary-bg); color: var(--primary);
            display: grid; place-items: center; margin-bottom: 24px; font-size: 24px;
        }
        .card-title { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; margin-bottom: 12px; color: var(--text-main); }
        .card-desc { font-size: 1rem; color: var(--text-muted); line-height: 1.6; }
        
        .sell-card { text-align: center; display: flex; flex-direction: column; align-items: center; padding: 32px 24px;}
        .sell-image { max-height: 140px; margin-bottom: 24px; }
        
        /* Popular Products Cards */
        .product-card { padding: 16px; display: flex; flex-direction: column; }
        .product-thumbnail {
            width: 100%; aspect-ratio: 16 / 10; object-fit: cover;
            border-radius: var(--radius-sm); margin-bottom: 16px;
            background: var(--bg-main);
        }
        .product-title { font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; margin-bottom: 8px; color: var(--text-main); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;}
        .product-meta {
            display: flex; align-items: center; gap: 8px;
            margin-bottom: 16px; font-size: 0.875rem; color: var(--text-muted);
        }
        .creator-avatar { width: 24px; height: 24px; border-radius: 50%; object-fit: cover; background: var(--bg-main); }
        .product-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 16px; border-top: 1px solid var(--bg-main);}
        .product-price { font-size: 1.125rem; font-weight: 600; color: var(--text-main); }

        /* Learners Section */
        .learners-grid { align-items: center; gap: 48px; }
        .feature-list { list-style: none; display: flex; flex-direction: column; gap: 16px; }
        .feature-item {
            display: flex; align-items: center; gap: 16px;
            font-size: 1.1rem; color: var(--text-main);
        }
        .feature-icon { color: var(--primary); font-size: 1.25rem; }

        /* Pricing Section */
        .pricing-image { max-width: 280px; margin: 0 auto 32px; display: block; }
        .pricing-bar {
            display: flex; max-width: 700px; margin: 0 auto 40px;
            border-radius: var(--radius-pill); overflow: hidden;
            box-shadow: var(--shadow-sm);
        }
        .bar-creator {
            padding: 20px; font-weight: 600; font-size: 1.1rem;
            display: flex; justify-content: center; align-items: center;
            flex: 7; background: var(--primary); color: white;
            font-family: var(--font-display);
        }
        .bar-platform {
            padding: 20px; font-weight: 500; font-size: 1rem;
            display: flex; justify-content: center; align-items: center;
            flex: 3; background: #e3e3e3; color: var(--text-muted);
        }
        
        /* FAQ Section */
        .faq-item {
            background-color: var(--bg-surface); 
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            margin-bottom: 12px;
            transition: var(--transition);
        }
        .faq-item:hover { border-color: #d2e3fc; }
        .faq-question {
            padding: 24px; cursor: pointer; display: flex;
            justify-content: space-between; align-items: center;
            font-weight: 500; font-size: 1.1rem; color: var(--text-main);
            font-family: var(--font-display);
        }
        .faq-icon { transition: transform 0.3s ease; color: var(--text-muted); }
        .faq-item.active .faq-icon { transform: rotate(45deg); color: var(--primary); }
        .faq-answer {
            max-height: 0; overflow: hidden;
            transition: max-height 0.3s ease;
        }
        .faq-answer p { padding: 0 24px 24px; color: var(--text-muted); line-height: 1.6; }

        /* Scroll Animation */
        [data-animation="fade-in"] { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
        [data-animation="fade-in"].visible { opacity: 1; transform: translateY(0); }

        /* Responsive Design */
        @media (max-width: 768px) {
            .grid-2, .grid-3 { grid-template-columns: 1fr; }
            .section-padding { padding: 64px 20px; }
            .hero-section { padding: 80px 20px 40px; }
            .bar-creator, .bar-platform { font-size: 0.9rem; padding: 16px 8px; text-align: center; }
        }
    </style>
</head>
<body>
  <%- include("../components/header") %>

<div class="vidyari-landing-wrapper">
    <div class="landing-bg-glow"></div>

    <main class="main-content">
        <section class="hero-section">
            <div class="container" data-animation="fade-in">
                <h1 class="heading-xl">Your Knowledge, <span style="color: var(--primary);">Your Currency.</span></h1>
                <p class="sub-heading">Vidyari is the premier marketplace for creators to sell digital study materials. Turn your notes, guides, and courses into a sustainable income stream.</p>
                <div class="hero-buttons">
                    <a href="/dashboard" class="btn-pill btn-primary">Start Selling — It's Free</a>
                    <a href="/documents" class="btn-pill btn-secondary">Explore Docs</a>
                </div>
                <img src="./images/home1.png" class="hero-image" alt="Student using digital materials on a laptop">
            </div>
        </section>

        <section class="section-padding">
            <div class="container">
                <div data-animation="fade-in">
                    <h2 class="heading-lg">Everything You Need to Succeed</h2>
                    <p class="sub-heading">We handle the tech, payments, and delivery, so you can focus on creating amazing content.</p>
                </div>
                <div class="grid-container grid-2">
                    <div class="glass-card" data-animation="fade-in">
                        <div class="icon-circle"><i class="fas fa-store"></i></div>
                        <h3 class="card-title">Instant Storefront</h3>
                        <p class="card-desc">No website? No problem. Get a beautiful, high-converting product page the moment you upload a file.</p>
                    </div>
                    <div class="glass-card" data-animation="fade-in" style="transition-delay: 0.1s;">
                        <div class="icon-circle"><i class="fas fa-shield-halved"></i></div>
                        <h3 class="card-title">Secure Global Payments</h3>
                        <p class="card-desc">Accept payments from anyone, anywhere. We manage all payment processing and fraud prevention securely.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="section-padding" style="background-color: var(--bg-surface);">
            <div class="container">
                <div data-animation="fade-in">
                    <h2 class="heading-lg">What Can You Sell?</h2>
                    <p class="sub-heading">If you can save it, you can sell it. We support a vast range of file types for every kind of knowledge creator.</p>
                </div>
                <div class="grid-container grid-3">
                    <div class="glass-card sell-card" data-animation="fade-in" style="background-color: var(--bg-main); border: none;">
                        <img src="./images/Notes-bro.svg" class="sell-image" alt="Selling Lecture Notes Illustration">
                        <h3 class="card-title">Lecture Notes & Guides</h3>
                    </div>
                    <div class="glass-card sell-card" data-animation="fade-in" style="background-color: var(--bg-main); border: none; transition-delay: 0.1s;">
                        <img src="./images/Video-tutorial-bro.svg" class="sell-image" alt="Selling Video Tutorials Illustration">
                        <h3 class="card-title">Video Courses & Tutorials</h3>
                    </div>
                    <div class="glass-card sell-card" data-animation="fade-in" style="background-color: var(--bg-main); border: none; transition-delay: 0.2s;">
                        <img src="./images/Research-paper-bro.svg" class="sell-image" alt="Selling Ebooks and Papers Illustration">
                        <h3 class="card-title">E-books & Checklists</h3>
                    </div>
                </div>
            </div>
        </section>

        <section class="section-padding">
            <div class="container">
                <div data-animation="fade-in">
                    <h2 class="heading-lg">Popular This Week</h2>
                    <p class="sub-heading">See what's trending. Get instant access to top-rated materials from creators around the world.</p>
                </div>
                <div class="grid-container grid-3">
                     <% popularFiles.forEach((file, index) => { %>
                     <div class="glass-card product-card" data-animation="fade-in" style="transition-delay: <%= index * 100 %>ms;">
                         <% 
                         const img = file.previewUrl && file.previewUrl.trim() !== '' ? file.previewUrl : '/images/File_Demo.svg';
                         %>
                         <img class="product-thumbnail" src="<%= img %>" alt="<%= file.filename %> preview image" loading="lazy" onerror="this.src='/images/File_Demo.svg'">
                         <h4 class="product-title"><%= file.filename %></h4>
                         <div class="product-meta">
                             <img src="/images/logo.svg" class="creator-avatar" alt="<%=file.user%> Avatar" loading="lazy">
                             <span>by <%=file.user%></span>
                         </div>
                         <div class="product-footer">
                             <span style="color: var(--text-muted); font-size: 0.875rem;"><i class="fas fa-download me-1"></i> <%=file.downloadCount%></span>
                             <span class="product-price">₹<%=file.price%></span>
                         </div>
                     </div>
                     <% }); %>
                </div>
            </div>
        </section>

        <section class="section-padding" style="background-color: var(--bg-surface);">
            <div class="container" data-animation="fade-in">
                <div class="grid-container grid-2 learners-grid">
                    <div>
                        <h2 class="heading-lg" style="text-align: left;">For Every Kind of Learner</h2>
                        <p class="card-desc" style="margin: 16px 0 32px;">Access a global library of peer-reviewed knowledge to accelerate your learning and master new concepts faster.</p>
                        <ul class="feature-list">
                            <li class="feature-item"><i class="fas fa-check-circle feature-icon"></i> University & College Students</li>
                            <li class="feature-item"><i class="fas fa-check-circle feature-icon"></i> Professionals Seeking Certifications</li>
                            <li class="feature-item"><i class="fas fa-check-circle feature-icon"></i> Lifelong Learners & Hobbyists</li>
                        </ul>
                    </div>
                    <div>
                        <img src="./images/Learning-bro.svg" style="width: 100%; max-width: 400px; display: block; margin: 0 auto;" alt="Student reading online materials">
                    </div>
                </div>
            </div>
        </section>

        <section class="section-padding">
            <div class="container" data-animation="fade-in">
                <img src="./images/Pricing-plans-amico.svg" class="pricing-image" alt="Transparent Pricing Illustration">
                <h2 class="heading-lg">Simple, Transparent Pricing</h2>
                <p class="sub-heading">No monthly fees. No hidden costs. We only make money when you do.</p>
                <div class="pricing-bar">
                    <div class="bar-creator">You Keep 70%</div>
                    <div class="bar-platform">Platform Fee 30%</div>
                </div>
            </div>
        </section>

        <section class="section-padding">
            <div class="container" data-animation="fade-in">
                <h2 class="heading-lg">Frequently Asked Questions</h2>
                <div style="max-width: 760px; margin: 40px auto 0;">
                    <div class="faq-item" data-faq="item" data-animation="fade-in">
                        <div class="faq-question" data-faq="question">How do I get paid? 
                            <div class="faq-icon"><i class="fas fa-plus"></i></div>
                        </div>
                        <div class="faq-answer" data-faq="answer">
                            <p>Once your earnings reach the threshold amount of ₹1000, you can send a withdrawal request. After standard verification checks to ensure legitimacy, your total earnings will be directly credited to your linked UPI ID or bank account.</p>
                        </div>
                    </div>
                    <div class="faq-item" data-faq="item" data-animation="fade-in" style="transition-delay: 0.1s;">
                        <div class="faq-question" data-faq="question">What are the fees? 
                            <div class="faq-icon"><i class="fas fa-plus"></i></div>
                        </div>
                        <div class="faq-answer" data-faq="answer">
                            <p>Vidyari charges a simple, flat 30% fee on each sale. This covers all payment processing fees, secure file hosting, platform maintenance, and 24/7 customer support.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

</div>

<script>
    // Smooth Fade-in Intersection Observer
    const animatedElements = document.querySelectorAll('[data-animation="fade-in"]');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });
    
    animatedElements.forEach(el => { observer.observe(el); });

    // Smooth Accordion FAQ Logic
    const faqItems = document.querySelectorAll('[data-faq="item"]');
    faqItems.forEach(item => {
        const question = item.querySelector('[data-faq="question"]');
        const answer = item.querySelector('[data-faq="answer"]');
        const answerParagraph = answer.querySelector('p');
        
        question.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            
            // Close all others
            faqItems.forEach(otherItem => {
                otherItem.classList.remove('active');
                otherItem.querySelector('[data-faq="answer"]').style.maxHeight = null;
            });
            
            // Open clicked if it wasn't active
            if (!isActive) {
                item.classList.add('active');
                answer.style.maxHeight = answerParagraph.scrollHeight + 48 + "px"; 
            }
        });
    });
</script>

<%- include("../components/footer") %>
</body>
</html>